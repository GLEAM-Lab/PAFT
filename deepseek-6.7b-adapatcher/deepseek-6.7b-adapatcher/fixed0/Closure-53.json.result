  {
    "patch_code": "private void blacklist VarreferencesIn tree(Node node, Set<String> blacklist) {\n  Blacklist VarreferencesIn tree(node.getFirst child(), blacklist);\n  blacklist VarreferencesIn tree(node.getNext(), blacklist);\n}\n private void blacklist VarreferencesIn tree(Node node, Set<String> blacklist) {\n  if (node == null || blacklist. contains(node.getString())) { return; }\n  blacklist VarreferencesIn tree(node.getFirst child(), blacklist);\n  blacklist VarreferencesIn tree(node.getNext(), blacklist);\n}\n private void blacklist VarreferencesIn tree( Var v, Set<String> blacklist) {\n  blacklist VarreferencesIn tree(v.getAst(), blacklist);\n}\n private void blacklist VarreferencesIn tree( Var ref, Set<String> blacklist) {\n blacklist VarreferencesIn tree(ref.getAst(), blacklist);\n blacklist VarreferencesIn tree(ref.getparent(), blacklist);\n}",
