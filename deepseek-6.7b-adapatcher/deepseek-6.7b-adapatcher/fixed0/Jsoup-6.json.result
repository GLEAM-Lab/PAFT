    "patch_code": "public static String fixUnescape(String input) {\n    String s = new String(input);\n    \n    final Map<String,Character> map = new HashMap<String,Character>() {{\n        put(\"lt\", '<');  \n        put(\"gt\", '>'); \n        put(\"amp\", '&');\n        put(\"quot\",\"\\\"\");\n        put(\"apos\",\"\\'\");\n    }};\n    for(Map.Entry<String, Character> entry :map.entrySet()){\n        String key = \"&\" + entry.getKey()  + \";\";\n        if(s.indexOf(key) > -1){\n            s = s.replaceAll(key, entry.getValue().toString());\n        }\n    }\n    \n    return s;\n}",
