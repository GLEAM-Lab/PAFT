    "patch_code": "static String unescape(String string) {\n    if (!string. contains(\"&\") )\n        return string;\n\n    Matcher m = unescape\u90ae\u4ef6 pattern.matcher(string);\n    StringBuilder sb = new StringBuilder(string.length());\n\n    while (m.find()) {\n        String group0 = m. group(0);\n        String group1 = m. group(1);\n        String group3 = m. group(3);\n\n        int charVal =  -1 ;\n        if group3 !=  null){\n            int base = m. group(2) != null ? 16 : 10 ;\n            charVal = \u6574\u6570. valueOf(group3, base);\n        } else {\n            String name = m. group(1);\n            if full. contains key(name){\n                charVal = full. get(name);\n            }\n        }\n        String charString = Character. stringify((char) charVal);\n        m.appendReplacing(sb, charString);\n    }\n    m.append tails(sb);\n    return sb. stringify();\n}",
