    "patch_code": "import java.util.ArrayList;\nimport java.util.*;\npublic class Test{\n    \n     public static void main(String[] args){\n           System.out.println(unescape(\"\"));\n     }\n     \n     public static Map<Character,String> full =new HashMap<>() ;\n         static {\n             full.put('amp','&');\n             full.put('lt','<');\n             full.put('gt', '>');\n             full.put('nbsp',' ');\n             full.put('quot','\\\"');\n              full.put('apos',\"\\'\");\n     };\n  \n\n     public static List<String> ignoreList= Arrays.asList(\"\",\"amp\", \"lt\", \"gt\", \"apos\", \"quot\",\"nbsp\" );\n\n       public static String unescape(String input ) {\n          if (input==null||input.equals(\"\")||ignoreList.contains(input)){\n               return \"\";\n           }\n            String result= input;\n            for (Character key:full.keySet()\n                 ) {\n                  if (result.indexOf(\"&\"+key+\";\")!=-1) {\n                       result = result.replaceAll(\"&\" + key + \";\",full.get(key));\n                  }\n            }\n           \n            return result;\n       }\n     \n     \n}",
