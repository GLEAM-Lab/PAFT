    "patch_code": "public boolean anyOtherEndTag(Token t, HtmlTreeBuilder tb) throws IOException {\n    // Initialize variables.\n    int index = t.asEndTag().index;\n    CharSequence html = t.input();\n    int endIndex = html.length();\n    StringBuilder tagName = new StringBuilder();\n    \n    // Find the start of the tag.\n    while (true){\n        char c = 0;\n        try{ \n          c = html.charAt(--endIndex);\n        } catch (StringIndexOutOfBoundsException e) {\n        \tbreak;\n        }\n       if (c == '>') {\n           break;\n       }\n      tagName.append(Character.toString(c).toLowerCase());\n   }\n\n    ArrayList<Element> stack = tb.getStack();\n    for (int pos = stack.size()-1; pos >=0 ; pos--) {\n        Element node = stack.get(pos);\n        if (node.nodeName().equalsIgnoreCase(tagName.toString())) {\n            tb.generateImpliedEndTags(node.nodeName());\n            if (!node.nodeName().equals(tb.currentElement().nodeName()))\n            \ttb.error(index);\n            tb.popStackToClose(node.nodeName(), index);\n            break;\n        } else {\n            if (tb.isSpecial(node)){\n                tb.error(index);\n                continue;\n            }\n        }\n    }\n    return true;\n}",
