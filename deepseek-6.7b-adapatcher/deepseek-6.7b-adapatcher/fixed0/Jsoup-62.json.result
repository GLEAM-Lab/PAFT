    "patch_code": "protected boolean parseAttributes(ArrayList<Attribute> attrsList){\n\tif(_inputPtr >= _inputLength || !Character.isLetterOrDigit(_input[_inputPtr]) && _input[_inputPtr] != '-'){\n\t    return false;\n\t}\n\twhile(_inputPtr < _inputLength){\n\t\tchar ch = _input[_inputPtr];\n\t\tif(!Character.isAlphabetic(ch)){\n\t\t\tbreak;\n\t\t}\n\t\tStringBuffer buf = new StringBuffer();\n\t\t_inputPtr++;\n\t\tbuf.append((char)_tolower(ch)); // here we have made it case insensitive\n\t\twhile(_inputPtr < _inputLength){\n\t\t\tch = _input[_inputPtr];\n\t\t\tif(!Character.isAlphanumeric(ch)){\n\t\t\t\tbreak;\n\t\t\t}\n\t\t\tbuf.append((char)_tolower(ch)); // making it case insensitive\n\t\t\t_inputPtr++;\n\t\t}\n\t\tString attname = buf.toString();\n\t\tattrsList.add(new Attribute(attname, \"\"));\n\t}\n\treturn true;\n}",
