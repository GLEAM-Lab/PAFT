    "patch_code": "public static final int[] toJavaVersionIntArray(String str, int trimSize) {\n        if ((str == null) || (trimSize < 0)) {\n            throw new IllegalArgumentException(\"The argument \" + str + \" is not valid\");\n        } else if (str.length() <= trimSize) {\n            return new int[0];\n        } else {\n            int splitLen = 3;\n            int size = (str.length() - trimSize) / splitLen;\n            int idxStart = trimSize;\n            ArrayList alist = new ArrayList();\n            for (int ix = 0; ix < size; ++ix) {\n                int sublen = Math.min(splitLen + idxStart, str.length());\n                String subs = str.substring(idxStart, sublen);\n                idxStart += splitLen;\n                try {\n                    alist.add(Integer.valueOf(subs));\n                } catch (NumberFormatException ex) {\n                    throw new RuntimeException(ex.getMessage());\n                }\n            }\n            return listToArray((List) alist);\n        }\n    }\n\n    public static final float toVersionInt(int[] arrayVerNums) {\n        if (arrayVerNums.length == 0) {\n            throw new IllegalArgumentException(\"Argument can not be null\");\n        }\n        \n        int ver = 0;\n        float vf = 0.0F;\n        \n        int len = arrayVerNums.length;\n        int point = -1;\n        boolean hasPoint = false;\n        \n        for (int ix = 0; ix < len; ++ix) {\n            int num = arrayVerNums[ix];\n            if (num == 0 && !hasPoint){\n                continue;\n            }\n            \n            if (!hasPoint) {\n                point = ix;\n                hasPoint = true;\n            }\n            ver += num * (int)Math.pow(10.0D, len - ix - 1);\n            vf += (float)(num * Math.pow(10.0D, len - ix - 1));\n        }\n        \n        vf += (float)Math.pow(10.0D, point);\n        \n        return vf;\n    }\n\n    public static final float toVersionFloat(String sver) {\n        int[] vnms = toJavaVersionIntArray(sver, 0);\n        return toVersionInt(vnms);\n    }",
