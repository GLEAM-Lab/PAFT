    "patch_code": "static float toJavaVersionInt(String version) {\n    if (\"\".equals(version)) {\n        throw new IllegalArgumentException(\"Empty string not allowed\");\n    }\n    int idx = version.indexOf('+');\n    if (idx != -1) {\n        // \"a+b\" should become \"[a]\"\n        version = version.substring(0, idx);\n    }\n    final byte[] buf = version.getBytes();\n    final char[] tmp = {' ', ' ', ' ', ' ', ' ', ' '};\n    for (int i = 0; i < buf.length; i++) {\n        tmp[i] = (char) buf[i];\n    }\n    return Float.parseFloat(new String(tmp).trim());\n}",
