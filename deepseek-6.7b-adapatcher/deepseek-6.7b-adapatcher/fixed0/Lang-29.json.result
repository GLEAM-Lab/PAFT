    "patch_code": "static boolean isJDK7Or higher(String version) {\n    final int[] versionArray = toJDK versionIntArray(version);\n    return !((versionArray[0] == 1 && versionArray[1] == 7) || (versionArray[0] > 1));\n}\nstatic boolean isJDK6Or higher(String version) {\n    final int[] versionArray = toJDK versionIntArray(version);\n    return !((versionArray[0] == 1 && versionArray[1] == 6) || (versionArray[0] > 1));\n}\nstatic boolean isJDK5Or higher(String version) {\n    final int[] versionArray = toJDK versionIntArray(version);\n    return !((versionArray[0] == 1 && versionArray[1] == 5) || (versionArray[0] > 1));\n}\nstatic boolean isJDK4Or higher(String version) {\n    final int[] versionArray = toJDK versionIntArray(version);\n    return !((versionArray[0] == 1 && versionArray[1] == 4) || (versionArray[0] > 1));\n}\nstatic boolean isJDK3Or higher(String version) {\n    final int[] versionArray = toJDK versionIntArray(version);\n    return !((versionArray[0] == 1 && versionArray[1] == 3) || (versionArray[0] > 1));\n}",
