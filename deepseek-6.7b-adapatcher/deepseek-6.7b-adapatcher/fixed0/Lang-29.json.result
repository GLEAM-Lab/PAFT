    "patch_code": "float toJavaVersionInt(String version) {  \n  if (\"\".equalsIgnoreCase(version)) {      \n     throw new IllegalArgumentException(\"Empty string\");   \n  } else {        \n      final int dash = version.indexOf('-');        \n       version= version.replace('.', 'a').replaceAll(\"[^0-9]\", \".\").replace('a', '.');           \n       \n    try{  \n          Float v=Float.parseFloat(dash != -1 ? version.substring(0, dash) : version);            \n            return v;          \n        }catch(NumberFormatException e){                \n        throw new IllegalArgumentException(version + \" is not a valid Java release version number\",e);   \n     }\n    }\n}",
