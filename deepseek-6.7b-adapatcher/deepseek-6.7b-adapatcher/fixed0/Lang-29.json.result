    "patch_code": "static final int[] tojavaversionIntArray(String version) {\n    int[] result = new int[JAVA_versionIntArraySize];\n    if (!isEmpty(version)) {\n        String[] versionParts = version.split(\"[.]\");\n        for (int i = 0; i < JAVA_versionIntArraySize && i < versionParts.length; i++) {\n            result[i] = toInt(versionParts[i);\n        }\n    }\n    return result;\n}\nstatic final int to javaversionInt(String version) {\n    return to versionInt(tojavaversionIntArray(version));\n}\nstatic final int tojavaversionInt(String version) {\n    int[] versionIntArray = to javaversionIntArray(version);\n    int result = toInt(StringBuilder sb = new StringBuilder();\n    for (int i = 0; i < JAVA_versionIntArraySize; i++) {\n        sb.append(StringUtilities. zeroPad(versionIntArray[i], 2));\n    }\n    return toInt(sb.to string());\n}",
