  {
    "patch_code": "static float getJavaVersionAsFloat() {\n    try {\n        String version = getJavaVersion();\n        if ((version == null) || (\"\".equals(version))) {\n            throw new IllegalArgumentException(\"Can not determine java version\");\n        }\n        int dashIdx = version.indexOf('-');\n        if (dashIdx >= 0) {\n            version = version.substring(0, dashIdx);\n        }\n        if (!version.contains(\".\")) {\n            // Assume it's a major version number\n            return Integer.parseInt(version);\n        } else if (version.startsWith(\"1.\")) {\n            // Handle special case of Java 1.X versions\n            version = \"2\" + version.substring(2);\n        }\n        return toJavaVersionInt(version);\n    } catch (NumberFormatException ex) {\n        throw new AssertionFailedError(\"Unexpected value from java.specification.version property: '\" + System.getProperty(\"java.specification.version\") + \"'\", ex);\n    }\n}",
