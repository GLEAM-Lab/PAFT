    "patch_code": "static float toJavaVersionInt(String version) {\n    if (null == version || \"\".equals(version)) {\n        throw new IllegalArgumentException(\"version cannot be null or empty\");\n    }\n    String v = version.replaceAll(\"[^\\\\d.]\", \"\")\n            .substring(0, Math.min(JAVA_VERSION_FLOAT_MAX_LENGTH, version.length()));\n    int idx = v.indexOf('.');\n    \n    if (-1 != idx && v.charAt(idx + 1) >= '5') {\n        ++idx;\n    } else {\n        for (int i = 1; i < idx - 1; ++i) {\n            char c = v.charAt(i);\n            \n            if (!Character.isDigit(c) && !(c == '.') && !Character.isWhitespace(c)) {\n                v = v.substring(0, i).trim();\n                \n                break;\n            }\n        }\n    }\n\n    return Float.parseFloat(v);\n}",
