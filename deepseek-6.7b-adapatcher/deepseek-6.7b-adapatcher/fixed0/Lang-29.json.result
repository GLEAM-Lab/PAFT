  {
    "patch_code": "static float toJavaVersionInt(String version) {\n    if (version == null || version.length() < 3) {\n        return -1;\n    } else if (!version.startsWith(\"1.\")) {\n        return -1;\n    } else if (version.charAt(2) != '.') {\n        return -1;\n    }\n    \n    int major = Integer.parseInt(version.substring(2, 3));\n    int minor = 0;\n    \n    if (version.length() >= 5 && Character.isDigit(version.charAt(4))) {\n        minor = Integer.parseInt(version.substring(4, 5));\n    }\n    \n    return ((float)major * 1000 + minor * 10);\n}",
