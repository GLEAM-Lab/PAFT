[
  {
    "patch_code": "private void copyAttributes(org.jsoup.nodes.Node source, Element el) throws DOMException {\n    for (Attribute attribute : source.attributes()) {\n        // valid xml attribute names are: ^[a-zA-Z_:][-a-zA-Z0-9_:.]\n        if(!attribute.getKey().matches(\"[-a-zA-Z0-9_:\\\\.]+\")){\n            throw new DOMException((short)INVALID_CHARACTER_ERR,\"Invalid attribute name:\" + attribute.getKey());\n        }else{\n             el.setAttribute(attribute.getKey(), attribute.getValue());\n        }     \n        \n    }\n}",
