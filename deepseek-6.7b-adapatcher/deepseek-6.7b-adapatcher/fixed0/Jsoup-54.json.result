  {
    "patch_code": "private void copyAttributes(org.jsoup.nodes.Node source, Element el) throws DOMException{\n    try {\n        if(!source.hasAttrs()) return;\n        \n        Attributes attrs = source.attributes();\n        int nbAttributs = attrs.size();\n\n        for (int i = 0; i < nbAttributs; i++) {\n                Attr attr = attrs.get(i);\n                \n                String key = attr.getNodeName().replaceAll(\"[^\\\\p{IsAlphabetic}\\\\p{IsDigit}_:.].*\",\"\");\n                if (!key.isEmpty())\n                    el.setAttribute(key, attr.getNodeValue());\n            \n        }\n    }catch (RuntimeException t){\n    \tthrow new DOMException((short)DOMException.INVALID_CHARACTER_ERR,\"Invalid Character:\"+t.getMessage());\n    }\n   }",
    "patch_status": "UNCOMPILABLE",
