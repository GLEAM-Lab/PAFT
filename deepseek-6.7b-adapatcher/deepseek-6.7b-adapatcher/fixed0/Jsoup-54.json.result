    "patch_code": "import java.util.regex.*;\n\nprivate void copyAttributes(org.jsoup.nodes.Node source, Element el) throws DOMException{\n    Pattern attrNamePattern = \n       Pattern.compile(\"[^-a-zA-Z0-9_:.]|\\\\.$|^_[:]\");\n        \n    for (Attribute attribute : source.attributes()) {\n        Matcher matcher  =attrNamePattern.matcher(attribute.getKey());\n        if (!matcher.find()){  \n             String key = attribute.getKey();\n            el.setAttribute(key, attribute.getValue());\n        } else {throw new DOMException((short)DOMException.INVALID_CHARACTER_ERR, \"Invalid Attribute name:\"+ attribute.getKey());\n        }\n       \n         \n     \n    }\n}",
