    "patch_code": "public void ensureCapacity(int additionalNeededSize) {\n        int available = buffer.length - index;\n        if (available >= additionalNeededSize) {\n            return;\n        }\n        int needed = Math.max(_totalBytesInUse + 2 * additionalNeededSize, index);\n        byte[] newBuffer = new byte[needed];\n        System.arraycopy(buffer, 0, newBuffer, 0, index);\n        this.buffer = newBuffer;\n        this.availableChars = this.buffer.length - this.index;\n}",
