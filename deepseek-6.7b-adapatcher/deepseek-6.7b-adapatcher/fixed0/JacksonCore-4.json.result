  {
    "patch_code": "public char[] expandCurrentSegment() throws IOException\n{\n    final char[] curr = _currentSegment;\n    final int len = curr.length;\n    int newLen = 0;\n    \n    if (len == MAX_SEGMENT_LEN) {        \n        throw new IOException(\"Key too long\");         \n    } else if (len > MAX_SEGMENT_LEN) {\n        throw new IOException(\"Unable to handle keys this large.\");     \n    } else {\n        // let's grow by 50% by default\n        newLen = len + (len >> 1);  \n        if (newLen <= MAX_SEGMENT_LEN && newLen >= len) {\n            return (_currentSegment = Arrays.copyOf(curr, newLen));\n        } else if (newLen > MAX_SEGMENT_LEN || newLen < 0 ) {      \n            throw new IOException(\"Key size limit exceeded: \" + Integer.toString(len) );            \n        } else {\n            throw new IOException (\"Unknown error expanding buffer size\");              \n        } \n    }\n}",
