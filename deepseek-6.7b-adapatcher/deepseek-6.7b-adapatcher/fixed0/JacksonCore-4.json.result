    "patch_code": "public void ensureCapacity(int additionalBytesRequired) throws IOException {\n        if ((_endOffset - _startOffset) >= _segments[_currentSeg].length) {\n            if(_allowNonAscii){\n                checkAndIncreaseSize(_segments[_currentSeg], additionalBytesRequired);\n            } else {\n               throw new ArrayIndexOutOfBoundsException(\"Character too large!\");\n           }\n        }\n   }\n    \nprivate static void checkAndIncreaseSize(char[] cbuf, int minAdditional)\n    {\n        if (cbuf.length < minAdditional + MIN_BUFFER_SIZE) {\n            int newsize = Math.max((cbuf.length * 3)/2 + minAdditional, MIN_BUFFER_SIZE);\n            if (newsize > MAX_KEY_LENGTH) {\n                throw new ArrayIndexOutOfBoundsException(\"Key too large\");\n            }\n            char nbuf[] = new char[newsize];\n            for (int i = 0; i < cbuf.length; i++) {\n                nbuf[i] = cbuf[i];\n            }\n            cbuf = nbuf;\n        }\n    }",
