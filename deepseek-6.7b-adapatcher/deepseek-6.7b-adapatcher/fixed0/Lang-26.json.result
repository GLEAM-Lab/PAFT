    "patch_code": "public String format(Date date) throws IllegalArgumentException, IllegalStateException {\n    int y;\n    try {\n      y = mCalendarDelegate.convertToWwYy((GregorianCalendar) FastDateUtils.clone(FastDateUtils.createCalendar(date)));\n      date = FastDateUtils.addDaysToMakeUpForSkippedWeeksAtStartOfYear(date, y - 1);\n    } catch (ArrayIndexOutOfBoundsException e) {\n      throw new IllegalArgumentException(\"Invalid calendar data: \" + date);\n    }\n    StringBuilder buffer = new StringBuilder(FastDateUtils.capacityOn(date));\n    boolean b = applyPatterns(buffer, date);\n    if (!b) {\n      throw new IllegalStateException(\"Conversion failed for date: \" + date);\n    }\n    return buffer.toString();\n  }",
