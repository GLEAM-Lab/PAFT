    "patch_code": "private static int getMondayBasedWeekYear(final int fieldValue) {\n    final Date today = new Date();\n    final Calendar calendarForToday = Calendar.getInstance();\n    calendarForToday.setTime(today);\n\n    final int mondayBasedWeekYear;\n    if (fieldValue == 1) {\n        switch (calendarForToday.get(Calendar.DAY_OF_WEEK)) {\n            case Calendar.MONDAY:\n                mondayBasedWeekYear = fieldValue;\n                break;\n            case Calendar.TUESDAY:\n                mondayBasedWeekYear = fieldValue + 1;\n                break;\n            default:\n                throw new RuntimeException(\"The current time is not within Monday based week.\");\n        }\n    } else {\n        final int lastDayOfYear = calendarForToday.getActualMaximum(Calendar.DAY_OF_YEAR);\n        if ((lastDayOfYear - fieldValue) < 7) {\n            mondayBasedWeekYear = 1;\n        } else {\n            mondayBasedWeekYear = fieldValue / 7 + 1;\n        }\n    }\n    return mondayBasedWeekYear;\n}\n\n@Override\nprotected int parseImp(ParsePosition pos, final char[] input, final ParseContext ctx, boolean lenient) throws IllegalArgumentException {\n    try {\n        Calendar c = new GregorianCalendar();\n        if (!lenient && !pos.hasToken()) {\n            pos.tokenType = DATE_TOKEN_PARSED;\n        }\n        super.parseToken(input, pos, patternFlags & ~CAP_STRICT_FORMAT, null, ctx);\n        if (ctx == null || ctx.getTextWidth() <= 0) {\n            return super.parseImp(pos, input, patternFlags & ~CAP_STRICT_FORMAT, null, ctx);\n        }\n        pos.setIndex(pos.getErrorIndex());\n        if (patternFlags >= 0) {\n            if (lenient) {\n                try {\n                    return super.parseImp(pos, input, CAP_LENIENT | patternFlags, null, ctx);\n                } catch (RuntimeException exIgnored) {\n                    return pos.getIndex();\n                }\n            }\n            pos.setIndex(pos.getErrorIndex());\n        }\n        return pos.getIndex();\n    } finally {\n        patternMapLock.readLock().unlock();\n    }\n}\n\npublic Object clone() {\n    try {\n        FastDateFormat copy = (FastDateFormat)super.clone();\n        if (mTimeZone != TimeZone.getDefault()) {\n            copy.mTimeZone = (TimeZone) mTimeZone.clone();\n        }\n        return copy;\n    } catch (CloneNotSupportedException e) {\n        // should never happen since we implement Cloneable\n        throw new InternalError(e.toString());\n    }\n}\n\nprivate long computeDateTimeInstance(long l, Calendar ocal, byte flag) {\n    try {\n        SimpleDateFormat df = new SimpleDateFormat(\"w\");\n        int week = Integer.valueOf(df.format(l).trim()).intValue();\n        return week;\n    } catch (Exception e) {\n        throw new Error(e);\n    }\n}\n\nprivate boolean hasDigitBetweenTokens(final FormattingPattern tokens, final int start, final int end) {\n    if ((end <= start) || (start < 0) || (end >= tokens.length())) {\n        return false;\n    }\n    for (int i = start; i < end; ++i) {\n        if (Character.isDigit((char)tokens.charAt(i))) {\n            return true;\n        }\n    }\n    return false;\n}",
