    "patch_code": "import java.lang.Math.*;\npublic class Line {\nprivate static final double TOLERANCE = 1E-12;\n    \n    public static void main(String[] args) {\n        Line line = new Line(); \n\tline.setDirection(new Vector3D(-7456896,-4321150,98469984)); //input data here\n        \n\tVector3D v= line.getDirection().multiplyByScalar(1/(double)Math.sqrt(Math.pow(line.getDirection().getX(),2)+Math.pow(line.getDirection().getY(),2)+Math.pow(line.getDirection().getZ(),2)));  \n        System.out.println(v); //output result here\n\t}\n    private Vector3D zero = new Vector3D(0, 0, 0);\n    private Vector3D direction;\n\n    /**\n     * Constructs a degenerate line at the origin with all axes as directions.\n     */\n    public Line() {\n        this(new Vector3D(1, 1, 1), zero);\n    }\n\n    /**\n     * Constructs a line with a specified direction vector, the initial point of which is defined implicitly as the origin.\n     * \n     * @param dir the direction of the line.\n     */\n    public Line(Vector3D dir) {\n        this(dir, zero);\n    }\n\n    /**\n     * Constructs a line given its direction and initial point.\n     * \n     * @param dir the direction of the line.\n     * @param pointOnLine any point on the line.\n     */\n    public Line(Vector3D dir, Vector3D pointOnLine) {\n        if (Math.abs(dir.dotProduct(pointOnLine)) > TOLERANCE) {\n            throw new IllegalArgumentException(\"The provided point must lie on the line\");\n        }\n        direction = dir;\n    }\n    public Vector3D getDirection(){\n        return direction;\n    }\n    public void setDirection(Vector3D direction){\n        this.direction=direction;\n    }\n\n}",
