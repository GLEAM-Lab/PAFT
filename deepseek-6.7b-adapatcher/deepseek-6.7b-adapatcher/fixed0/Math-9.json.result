    "patch_code": "import org.apache.commons.math3.util.FastMath;\npublic class Main{ \n public static void main(String[] args){\n      System.out.println(new Vector3D(-2,-5,-9).length());\n }\n\n    \n   private static class Vector3D{\n        double x,y,z;\n        \n        public Vector3D(double x,double y,double z){\n            this.x=x;\n            this.y=y;\n            this.z=z;\n        }\n       public Vector3D subtract(Vector3D v) {\n           return new Vector3D(this.x - v.x, this.y - v.y, this.z - v.z);\n       }\n        \n         public Vector3D negate(){\n             return new Vector3D(-x,-y,-z);\n         }\n         \n         public double length(){\n             return FastMath.sqrt(x*x+y*y+z*z);\n         }\n    }\n     \n     private static class Line{\n         Vector3D start,end,dir;\n         \n         public Line(Vector3D a, Vector3D b){\n             this.start = a;\n             this.end = b;\n             dir = end.subtract(start);\n         }\n         \n         public Line revert(){\n             return new Line(end,start.subtract(end));\n         }\n     }\n }",
