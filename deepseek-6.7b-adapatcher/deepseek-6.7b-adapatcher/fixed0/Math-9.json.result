    "patch_code": "import org.apache.commons.math3.util.Precision;\nimport org.apache.commons.math3.geometry.Vector3D;\npublic class Line extends org.apache.commons.math3.geometry.euclidean.threed.Line{\n    public Line(Vector3D start, Vector3D direction) {\n        super(start, direction);\n    }\n\n    @Override\n    public Line revert() {\n        final double epsilon = 1E-5;\n        \n        boolean equalX = Precision.equals(getStart().getX(), 0, epsilon);\n        boolean equalY = Precision.equals(getStart().getY(), 0, epsilon);\n        boolean equalZ = Precision.equals(getStart().getZ(), 0, epsilon);\n        \n        if(!equalX || !equalY || !equalZ){\n            throw new IllegalArgumentException(\"Line cannot be reversed when its starting point isn't at the origin\");\n        }\n        \n        final Vector3D reversedDirection = new Vector3D(- getDirection().getX(), - getDirection().getY(), - getDirection().getZ());\n        final Line reverted = new Line(getStart(), reversedDirection);\n        return reverted;\n    }\n}",
