    "patch_code": "public static long get Octal value\n    long result = 0;\n    int end = count + 1;\n\n    if (count < end && (chars[count] == ' ' || chars[count] == '0')) {\n        return -1;\n    }\n\n    while (count < end) {\n        char c = chars[count++];\n        if (c < '0' || c > '7') {\n            return -1;\n        }\n        result = result * 8 + (long)(c - '0');\n    }\n\n    return result;\n}",
