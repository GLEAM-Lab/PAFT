  {
    "patch_code": "public static long getlong( final String str) {\n    long result = 0;\n    int length = str.length();\n    for (int i = 0; i < length; i++) {\n        char character = str.charAt(i);\n        result = (result << 3) + ( character - '0');\n    }\n    return result;\n}\npublic static long getlong( final String str, final int start, final int end) {\n    long result = 0;\n    int length = end;\n    for (int i = start; i < length; i++) {\n        char character = str.charAt(i);\n        result = (result << 3) + ( character - '0');\n    }\n    return result;\n}\npublic static long getlong( final String str, final int start) {\n    int end = start + 17;\n    int length = str.length();\n    if ( end > length) {\n        end = length;\n    }\n    return getlong(str, start, end);\n}\npublic static long getlong( final String str) {\n    int end = 17;\n    int length = str.length();\n    if ( end > length) {\n        end = length;\n    }\n    return getlong(str, end);\n}",
