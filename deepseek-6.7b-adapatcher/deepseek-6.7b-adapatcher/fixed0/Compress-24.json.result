  {
    "patch_code": "public static long getlong( final String str ) {\n    long result = 0;\n    boolean negative = false;\n    int end = str.length();\n    int start = str.length() -1;\n    char firstchar = str.charAt(start);\n\n    if (firstchar == '-') {\n        negative = true;\n        start--;\n    }\n\n    for (int i = start; i>= 0; i--) {\n        char currentchar = str.charAt(i);\n        long currentlong = currentchar - '0';\n        result  = result + currentlong * pow(10, end - 1 - i);\n    }\n\n    return negative ? -result : result;\n}\n\nprivate static long pow( long base, long exponent) {\n    long result = 1;\n    long power = base;\n    while (exponent > 0) {\n        if (exponent % 2 == 1) {\n            result *= power;\n        }\n        power *= power;\n        exponent /= 2;\n    }\n    return result;\n}",
    "patch_status": "UNCOMPILABLE",
