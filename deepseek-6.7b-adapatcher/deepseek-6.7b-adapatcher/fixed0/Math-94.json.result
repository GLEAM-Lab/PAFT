  {
    "patch_code": "public static int gcd(int u, int v) {\n    if (u == 0 || v == 0) {\n        return Math.max(Math.abs(u), Math.abs(v));\n    }\n    int k = 0;\n    while ((u | 0) % 2 == 0 && (v | 0) % 2 == 0 && k < 31) {\n        u >>= 1;\n        v >>= 1;\n        k++;\n    }\n    if (k == 31) {\n        throw new ArithmeticException();\n    }\n    while ((u & 1) == 0) {\n        u >>= 1;\n    }\n    if (v == 0) {\n        return u << 1;\n    }\n    do {\n        while ((v & 1) == 0) {\n            v >>= 1;\n        }\n        if (u > v) {\n            int temp = u;\n            u = v;\n            v = temp;\n        }\n        v = v - u;\n    } while (v != 0);\n    return u << k;\n}",
