    "patch_code": "public static int gcd(int u, int v) {\n    if (u == 0 || v == 0) {\n        return (u + v);\n    }\n    int k = 0;\n    while (((u & 1) == 0) && (v & 1) == 0 && k < 31) {\n        u /= 2;\n        v /= 2;\n        k++;\n    }\n    if (k == 31) {\n        throw new ArithmeticException(\"overflow: gcd is 2^31\");\n    }\n    int t = (u & 1) == 1 ? v : -u / 2;\n    while (t != 0) {\n        while ( (t & 1) == 0) {\n            t /= 2;\n        }\n        if (t > 0) {\n            u = -t;\n        } else {\n            v = t;\n            t = v/u;\n        }\n    }\n    return -u * (1 << k);\n}",
