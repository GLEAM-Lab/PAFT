  {
    "patch_code": "public static int gcd(int u, int v) {\n    if (u * v == 0) {\n        return (u == 0) ? v : u;\n    }\n    // keep u and v negative, as negative integers range down to\n    // -2^31, while positive numbers can only be as large as 2^31-1\n    // (i.e. we can's always negate a negative number without\n    //overflow)\n    if (u > 0) {\n        u = -u;\n    } // make u negative\n    if (v > 0) {\n        v = -v;\n    } // make v negative\n    // B1. [find power of 2]\n    int k = 0;\n    while (((u & 1) == 0) &&((v & 1) == 0)) {\n        u /= 2;\n        v /= 2;\n        k++;\n    }\n    if (u == 0 || v == 0) {\n        return u == v ? u * (1 << k) : (u == 0 ? v : u);\n    }\n    // B2. init: u and v are either all even or all\u5947\u6570.\n    int t = v - u;\n    while (t != 0) {\n        while (t % 2 == 0) {\n            t /= 2;\n        }\n        if (t > u) {\n            t = t - u;\n            u = v - t;\n        } else {\n            t = u - t;\n            u = v - u;\n            v = t;\n        }\n    }\n    return v * (1 << k);\n}",
