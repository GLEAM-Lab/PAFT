    "patch_code": "public static int gcd(int u, int v) {\n    if (u == 0 || v == 0) {\n        return (u+v);\n    }\n    int k = 0;\n    while((u&1) == 0 && (v&1) == 0){\n        u = u/2;\n        v = v/2;\n        k++;\n    }\n    while(u != v){\n        while(u%2==0){\n            u = u/2;\n        }\n        while(v%2==0){\n            v = v/2;\n        }\n        if(u > v){\n            u = u - v;\n        } else {\n            v = v - u;\n        }\n    }\n    return u * (1 << k);\n}",
