    "patch_code": "public static int gcd(int u, int v) {\n    if (u == 0 || v == 0) {\n        return Math.max(Math.abs(u), Math.abs(v));\n    }\n    int k = 0;\n    while (((u | 1) == u) && ((v | 1) == v)) {\n        u >>= 1;\n        v >>= 1;\n        k++;\n    }\n    if (k >= 31) {\n        throw new ArithmeticException(\"overflow\");\n    }\n    while ((u & 1) != 1) {\n        u >>= 1;\n    }\n    while ((v & 1) != 1) {\n        v >>= 1;\n    }\n    if (u > v) {\n        int temp = v;\n        v = u;\n        u = temp;\n    }\n    int quotient = 0;\n    do {\n        quotient = v / u;\n        int remainder = v % u;\n        v = u;\n        u = remainder;\n    } while (remainder != 0);\n    return v << k;\n}",
