    "patch_code": "public static int gcd(int u, int v) {\n    if (u * v == 0) {\n        return (Math.abs(u) + Math.abs(v)) / 2;\n    }\n    \n    if (u==0 || v ==0){\n         return Math.max(Math.abs(u), Math.abs(v));  \n    }\n      \n    long x = u, y = v;\n    long tmp;\n    \n    while(y>0){\n          tmp = y;\n          y = x % y;\n          x = tmp;\n    }\n     \n    return (int)x;\n}",
