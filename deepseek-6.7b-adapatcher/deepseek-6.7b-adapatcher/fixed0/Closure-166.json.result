    "patch_code": "private int matchRecordTypeConstraint(RhinoClassType prototype) throws ScriptException {\n  List<String> missingProperties = new ArrayList<>();\n  boolean allPresentAndMatching = true;\n\n  for (Map.Entry<PropertyKey, JSType> entry : prototype.getOwnPropertyTypes().entrySet()) {\n    PropertyKey key = entry.getKey();\n    if (!hasKey(key)) {\n      missingProperties.add(key.toString());\n    } else {\n      JSType value = getKey(key).getStaticValue();\n      if (value != null && !getPropertyValue(key).matchesPattern(value)) {\n        throw new RhinoException(\"actual parameter \" + currentFunctionParameterIndex\n                + \" of \" + currentFunctionName + \" does not match formal parameter\");\n      }\n    }\n  }\n  return (allPresentAndMatching ? MatchResult.PERFECT_MATCH : MatchResult.PARTIAL_MATCH);\n}",
