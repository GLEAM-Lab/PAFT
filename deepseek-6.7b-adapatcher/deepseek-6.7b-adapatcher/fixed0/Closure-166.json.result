    "patch_code": "private void matchRecordTypeConstraint(JSType constraint) {\n  ObjectType objectType = constraint.toObjectType();\n  for (int i = 0; i < objectType.getPropertiesSize(); i++) {\n      addProperty(objectType.getPropertyKeyAt(i), \n                  objectType.getPropertyConstraitAt(i));\n  }\n}",
