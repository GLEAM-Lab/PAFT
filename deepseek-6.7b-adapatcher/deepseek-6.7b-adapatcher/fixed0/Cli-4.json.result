    "patch_code": "private void checkRequiredOptions()\n    throws MissingOptionException\n{\n    // if there are required options that have not been\n    // processed\n    if (requiredOptions.size() > 0)\n    {\n        Iterator<CommandLine.Option> iter = requiredOptions.iterator();\n        StringBuffer buff = new StringBuffer();\n\n\n        // loop through the required options\n        while (iter.hasNext())\n        {\n            CommandLine.Option nextOption = iter.next();\n            \n            buff.append(nextOption.getOpt()).append(\", \");\n        }\n        \n        int lastCommaIndex = buff.lastIndexOf(\",\");\n        \n        if(lastCommaIndex != -1){\n            buff.replace(lastCommaIndex, buff.length(), \"\");\n        }\n        \n        throw new MissingOptionException(buff.toString());\n    }\n}",
