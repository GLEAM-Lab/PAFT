    "patch_code": "private void check requiredOptions()\n    throw Missing option exception;\n{\n    // if there are required options that have not been\n    // processed\n    if ( requiredOptions. size () > 0)\n    {\n        Iterator iter = requiredOptions. iterator();\n        StringBuilder buff = new StringBuilder();\n        StringBuilder sb = new StringBuilder();\n        int i = 0;\n\n        while (iter. has next())\n{\n            String str = iter. next();\n            i++;\n\n            if ( i == 1)\n{\n                sb.append(str);\n            } else\n{\n                sb.append(\"\\n\");\n                sb.append(str);\n                i = 0;\n            }\n\n        }\n\n        throw new Missing option exception(sb. string());\n    }\n}",
