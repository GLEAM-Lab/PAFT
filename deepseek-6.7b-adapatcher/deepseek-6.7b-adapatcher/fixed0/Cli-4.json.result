    "patch_code": "private void checkRequiredOptions()\n    throws MissingOptionException\n{\n    // if there are required options that have not been processed\n    if (!requiredOptions.isEmpty())\n    {\n        Set<String> requiredSet = new HashSet<>(requiredOptions);\n        Iterator<CommandLine.Option> argIter = argsList.iterator();\n\n        outerWhile:\n        while (argIter.hasNext())\n        {\n            CommandLine.Option arg = argIter.next();\n\n            if (!requiredSet.contains(arg.getValue())) continue;\n\n            ListIterator<CommandLine.Option> setIter = argsList.listIterator();\n            boolean foundInArgs = false;\n            while (setIter.hasNext())\n            {\n                CommandLine.Option currentArg = setIter.next();\n                if (currentArg.equals(arg))\n                {\n                    foundInArgs = true;\n                    break;\n                }\n            }\n\n            if (!foundInArgs)\n            {\n                requiredSet.remove(arg.getValue());\n                if (!commandLineHasShortPrefix && !isLongOption(arg.getValue()))\n                {\n                    argIter.remove();\n                    CommandLine.Option positionalArg = null;\n\n                    if (argsList.size() > index)\n                    {\n                        positionalArg = argsList.get(index);\n                    }\n\n                    if ((null == positionalArg || !isOption(positionalArg)))\n                    {\n                        continue outerWhile;\n                    }\n                }\n            }\n        }\n\n        if (!requiredSet.isEmpty())\n        {\n            StringBuilder sb = new StringBuilder();\n            for (String s : requiredSet)\n            {\n                if (sb.length() > 0)\n                {\n                    sb.append(\", \");\n                }\n\n                sb.append(s);\n            }\n\n            throw new MissingOptionException(sb.toString());\n        }\n    }\n}",
