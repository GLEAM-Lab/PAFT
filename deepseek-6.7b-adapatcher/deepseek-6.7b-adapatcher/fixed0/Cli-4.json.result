    "patch_code": "private List<String> parseSingleDashArgs(ListIterator<String> argsIter)\n{\n    List<String> optionNames = new ArrayList<>();\n    String arg;\n    boolean lastWasShortOptionName = false;\n\n    // Handle arguments containing '-', which were merged from multiple arguments.\n    outerWhile: while (argsIter.hasNext())\n    {\n        String rawArg = argsIter.next();\n        // Skip -- until we encounter space or end, because those must\n        // belong to the next command.\n        if (\"--\".equals(rawArg))\n        {\n            continue outerWhile;\n        }\n\n        if (rawArg.startsWith(\"--\"))\n        {\n            // Argument starting with --, e.g. \"--foo bar\", split into name \"--foo\" and value \"bar\".\n            arg = rawArg.substring(2);\n            lastWasShortOptionName = false;\n        }\n        else if (rawArg.startsWith(\"-\") && !lastWasShortOptionName)\n        {\n            // Argument starting with -, but none after us (e.g., \"-xyz\"), treat it as positional parameter.\n            // Only valid when -- is not encountered before, otherwise treated as invalid.\n            argsIter.previous();\n            break;\n        }\n        else if (!rawArg.startsWith(\"-\"))\n        {\n            // No leading -, belongs to previous options.\n            argsIter.previous();\n            break;\n        }\n        else // Treat rawArg as name of any single char option (-h, -r etc.)\n        {\n            // Argument starting with -, consider its components as separate options. E.g., \"-abc\".\n            for (int i = 1; i < rawArg.length(); i++)\n            {\n                optionNames.add(\"-\" + rawArg.charAt(i));\n            }\n            lastWasShortOptionName = true;\n            continue outerWhile;\n        }\n\n        int idx = arg.indexOf('=');\n        String name, value = null;\n        if (idx >= 0)\n        {\n            name  = arg.substring(0, idx).trim();\n            value = arg.substring(idx+1).trim();\n        }\n        else\n        {\n            name = arg;\n        }\n        optionNames.addAll(possibleValuesForOptionNames(name));\n    }\n    return optionNames;\n}",
