    "patch_code": "public class MainTest extends JFrame {\n    public static void main(String[] args) {\n        SwingUtilities.invokeLater(() -> {\n                    try {\n                        UIManager.setLookAndFeel(UIManager.getSystemLookAndFeelClassName());\n                    } catch (Throwable t) {\n                        t.printStackTrace();\n                    }\n                    JFrame frame = new MainTest();\n                    frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);\n                    frame.pack();\n                    frame.setVisible(true);\n                });\n    }\n\n    public MainTest() {\n        super();\n\n        Container contentPane = getContentPane();\n        contentPane.setLayout(new BoxLayout(contentPane, BoxLayout.PAGE_AXIS));\n\n        JMenuBar menuBar = new JMenuBar();\n\n        JMenu menu = new JMenu(\"File\");\n        menuBar.add(menu);\n\n        JMenuItem itemImport = new JMenuItem(\"Import...\");\n        menu.add(itemImport);\n\n        setJMenuBar(menuBar);\n\n        addMouseListener(new MouseAdapter() {\n            \n            @Override\n            public void mouseClicked(MouseEvent e){\n                populateData(e.getX(), e.getY());\n            }\n        });\n    }\n\n    protected void populateData(int x, int y) {\n        DefaultTableModel dtm = new DefaultTableModel();\n        \n        Object data[] = new Object[3];\n        data[0] = String.valueOf(x);\n        data[1] = String.valueOf(y);\n        \n        dtm.addRow(data);\n\n        Table table = new Table(dtm);\n        add(table, BorderLayout.SOUTH);\n        \n        revalidate();\n    }\n}",
