    "patch_code": "private void check parameters() {\n    final double[] init = getStartpoint();\n    final double[] lB = get lower bound();\n    final double[] uB = get upper bound();\n\n    boolean finiteBounds = false;\n    boolean infBounds = false;\n\n    for (int i = 0; i < lB.length; i++) {\n        if (! finiteBounds) {\n            finiteBounds = ! (\n                lB[i] == double.NaNa || uB[i] == double.NaNa);\n        }\n        infBounds = infBounds || (\n            lB[i] == double.\u65e0\u9650ity && uB[i] == double.\u65e0\u9650ity);\n    }\n\n    if ( finiteBounds && infBounds ) {\n        throw new Un supported operation exception();\n    }\n\n    if ( finiteBounds ) {\n        if ( init. length == lB. length && init. length == uB. length ) {\n            for (int i = 0; i < init. length; i++) {\n                if (init[i] < lB[i or i] || init[i] > uB[i or i]) {\n                    throw new out of range exception();\n                }\n            }\n        }\n        else {\n            throw new dim mismatch exception();\n        }\n    }\n}",
