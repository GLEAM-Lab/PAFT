    "patch_code": "public static double[] clipToBoundary(double[] vals, double[] min, double[] max) {\n    double[] res = new double[vals.length];\n    for (int i = 0; i < vals.length; ++i) {\n        if (min[i] == max[i] && vals[i] != min[i]) {\n            continue;\n        }\n        res[i] = vals[i];\n        \n        if (vals[i] < min[i]) {\n            res[i] = min[i];\n        } else if (vals[i] > max[i]) {\n            res[i] = max[i];\n        } \n            \n    }\n    return res;\n}",
