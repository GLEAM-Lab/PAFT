    "patch_code": "public class Normalizer implements TraversalCallback{\n  public boolean shouldTraverse(NodeTraversal t, Node n){\n    return true;\n  }\n  public void doTraversal(NodeTraversal t, Node n){\n     if(n instanceof FunctionCall){\n       Expression functionNameExpression=((FunctionCall)n).getMethodExpr();\n       if(!(functionNameExpression instanceof Variable)){\n         throw new AssertionError(\"Not implemented\");\n       }else{\n         String variableName=((Variable)functionNameExpression).getName();\n         if(variableName.equals(\"arguments\")){\n           List<String> localsToRemove=new ArrayList<>();\n           for(Node child : t.children(n)){\n             if(child instanceof VariableDeclarationStatement){\n               Local variableDeclarationLocal=((VariableDeclarationStatement)child).getVariable().name;\n                              \n                              \n                            \n                  \n                 \n               \n                           \n                   \n                       \n                         \n                             \n                                        \n                                                      \n                                     \n                                                                         \n                                  \n                               \n                \n                          \n                    \n                          \n                              \n                        \n                   \n                                 \n                     \n                           \n                    \n                                         \n                                    \n                                          \n                                             \n                                       \n                                   \n\n                                         \n                                       \n                                           \n                                      \n                                    \n                                     \n                                     \n                               \n                                         \n                                            \n                                                  \n                                               \n       \n                              \n                  \n              \n\n        \n              \n  t.replace(n,EmptyStatement.INSTANCE);\n}\n         }\n       \n     }\n    }\n  }\n  @Override\n  public void afterTraversal(NodeTraversal t, Node n){}\n  private static final org.apache.commons.logging.Log log =\n  org.apache.commons.logging.LogFactory.getLog(Normalizer.class);\n  protected Compiler compiler;\n  protected AbstractAlgorithm pass;\n  protected AlgorithmSettings settings;\n  public Normalizer(Compiler compiler,AbstractAlgorithm pass, AlgorithmSettings settings){\n    super();\n    this.compiler=compiler;\n    this.pass=pass;\n    this.settings=settings;\n  }\n}",
