    "patch_code": "static TypeAdapter<?> getTypeAdapter(ConstructorConstructor constructorConstructor, Gson gson,\n    TypeToken<?> fieldType, JsonAdapter annotation) throws Exception {\n  Class<?> value = annotation.value();\n  TypeAdapter<?> typeAdapter;\n  if (TypeAdapter.class.isAssignableFrom(value)) {\n    Class<TypeAdapter<?>> typeAdapterClass = (Class<TypeAdapter<?>>) value;\n    typeAdapter = constructorConstructor.get(TypeToken.get(typeAdapterClass)).newInstance();\n  } else if (TypeAdapterFactory.class.isAssignableFrom(value)) {\n    Class<TypeAdapterFactory> typeAdapterFactory = (Class<TypeAdapterFactory>) value;\n    Object obj=constructorConstructor.get(TypeToken.get(typeAdapterFactory)).newInstance();\n      \n      // Ensure that object is not null before calling methods on it.\n    if (obj == null){\n          throw new NullPointerException(\"The instance from class \" + typeAdapterFactory.getName() + \n             \" constructed via ConstructorCould Be NULL\");\n     }else{\n         typeAdapter=((TypeAdapterFactory)obj).create(gson, fieldType);\n    }\n    \n    \n  } else {\n    throw new IllegalArgumentException(\n        \"@JsonAdapter value must be TypeAdapter or TypeAdapterFactory reference.\");\n  }\n  \n    typeAdapter = typeAdapter.nullSafe();\n  return typeAdapter;\n}",
