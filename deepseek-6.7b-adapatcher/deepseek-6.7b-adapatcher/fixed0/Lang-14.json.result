    "patch_code": "import org.apache.commons.lang3.reflect.MethodUtils;\npublic static boolean equals(final CharSequence cs1, final CharSequence cs2){    \n    try{\n        return MethodUtils.invokeExactMethod(cs1, \"equals\", cs2).equals(true);\n    }catch(Exception e){\n        return false;\n    }\n}",
