    "patch_code": "public static boolean equals(final CharSequence cs1, final CharSequence cs2) {\n    if (cs1 instanceof Name && cs2 instanceof String) {\n        return ((Name) cs1).contentEquals((String) cs2);\n    } else if (cs2 instanceof Name && cs1 instanceof String) {\n        return ((Name) cs2).contentEquals((String) cs1);\n    }\n    return org.apache.commons.lang3.StringUtils.equals(cs1.toString(), cs2.toString());\n}",
