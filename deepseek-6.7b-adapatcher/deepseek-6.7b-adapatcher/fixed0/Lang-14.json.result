    "patch_code": "public static boolean equals(CharSequence cs1, CharSequence cs2) {\n    if (cs1 instanceof Name && cs2 instanceof Name) { // If both are names\n        return ((Name) cs1).contentEquals((Name) cs2);\n    } else if (cs1 instanceof String && cs2 instanceof String) { // If both are strings\n        return ((String) cs1).contentEquals((String) cs2);\n    } else if (cs1 != null && cs2 != null) { // Neither are special cases\n        int length = cs1.length();\n        if (length == cs2.length()) {\n            for (int i = 0; i < length; i++) {\n                if (!(cs1.charAt(i) == cs2.charAt(i))) {\n                    return false;\n                }\n            }\n            return true;\n        }\n    }\n    return cs1 == cs2;\n}",
