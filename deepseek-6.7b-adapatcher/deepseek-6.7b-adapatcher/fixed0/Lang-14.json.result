    "patch_code": "import java.util.*;\nimport java.io.*;\n\npublic class Main{\n    public static void main(String[] args){\n         System.out.println(\"abc\".equals(\"abc\"));   //true\n     System.out.println('a'=='a');                   //true\n     System.out.println(nameEquals((CharSequence)\"aaa\",(CharSequence)\"aaa\"));      //false\n     System.out.println(nameEquals((CharSequence)\"aaa\",\"aaa\"));                     //true\n    }\n       private static boolean nameEquals(CharSequence cs1, CharSequence cs2) {\n           if (cs1 == cs2) {\n               return true;\n           }\n           if (cs1 == null || cs2 == null) {\n               return false;\n           }\n             if(! (cs1 instanceof Name && cs2 instanceof Name)){\n                 return cs1.toString().contentEquals(cs2.toString());\n             }else {\n                 Name nameCs1 = (Name) cs1;\n                 Name nameCs2 = (Name) cs2;\n                 if (!nameCs1.getNameKind().toString().equalsIgnoreCase(nameCs2.getNameKind().toString())) {\n                     return false;\n                 }\n                 try {\n                     if (!nameCs1.toString().equalsIgnoreCase(nameCs2.toString())) {\n                         return false;\n                     }\n                     return true;\n                 } catch (Exception e) {\n                     throw new RuntimeException(e);\n                 }\n             }\n       }\n}",
