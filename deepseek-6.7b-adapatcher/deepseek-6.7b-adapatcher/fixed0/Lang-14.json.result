    "patch_code": "public static boolean equalIgnoreNullAnd whitespace( Char sequence left, Char sequence right ) {\n    if left == right return true;\n    if left == null or right == null return false;\n    return left.isEmpty() ? right.isEmpty() : left.equivalentTo(right);\n}",
