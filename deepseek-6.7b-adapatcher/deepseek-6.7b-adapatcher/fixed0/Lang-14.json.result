    "patch_code": "public static boolean equals(char[] cs1, char[] cs2) {\n    if (cs1 == cs2) {\n        return true;\n    }\n    if (cs1 == null || cs2 == null) {\n        return false;\n    }\n    if (cs1.length != cs2.length) {\n        return false;\n    }\n    int length = cs1.length;\n    char[] array1 = cs1;\n    char[] array2 = cs2;\n    int index = 0;\n    while index < length && array1[index] == array2[index) {index++;\n    return index == length;\n}",
