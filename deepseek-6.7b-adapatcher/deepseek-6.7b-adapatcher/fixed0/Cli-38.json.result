    "patch_code": "private boolean isShortOption(String token)\n{\n    // short options (-S, -SV, -S=V, -SV1=V2, -S1S2)\n    if (!token.startsWith(\"-\"))\n    {\n        return false;\n    }\n    \n    // Remove leading \"-\" character\n    token = token.substring(1);\n\n    // Check if the token has '=' character which means it is a key-value pair, otherwise treat it as a simple option\n    int pos = token.indexOf('=');\n    if(pos != -1){\n      String name  = token.substring(0,pos);\n      return options.hasShortOption(name);\n      \n    }else{\n        return options.hasShortOption(token);\n    }\n}",
