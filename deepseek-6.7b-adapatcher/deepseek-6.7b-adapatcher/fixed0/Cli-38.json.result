    "patch_code": "protected boolean handleShortOption(String arg0, List<String> arg1) throws ParseException {\n\t//short options (-S, -SV, -S=V, -SV1=V2, -S1S2)\n\tif(!arg0.startsWith(\"-\") || arg0.length()==1){\n\t\treturn false;\n\t}\n\t//remove leading '-' and '=Value'\n\tint index = arg0.indexOf('=');\n\tString name = arg0.substring(1,index != -1 ? index : arg0.length());\n\n\tif(!options.hasShortOption(name)){\n\t\tthrow new UnrecognizedOptionException(name,\"The input string was \\'\" + arg0 + \"\\'\");\n\t}else{\n\t\t++position;\n\t\tif(index!=-1 && position < arg1.size() && arg1.get(position)[0] != '-'){\n            setOptionArgument(new CommandLine(), name, arg1.get(position));\n\t\t\tposition++;\n        } else if(args[position][0] == '-'){\n             setOptionArgument(new CommandLine(), name, true);\n        }else{\n        \tsetOptionArgument(currentLine, name, true);\n        }\n\t}\n\treturn true;\n}",
