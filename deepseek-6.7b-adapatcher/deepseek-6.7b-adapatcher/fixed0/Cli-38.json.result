    "patch_code": "private boolean isShortOption(String token)\n{\n    // short options (-S, -SV, -S=V, -SV1=V2, -S1S2)\n    if (!token.startsWith(\"-\") || token.length() == 1)\n    {\n        return false;\n    }\n    \n    // Check whether it is actually a separate option (e.g., -last), which cannot directly be parsed because there is no corresponding matching Option object\n    if (options != null && options.getOptions().stream().anyMatch(o -> o.getName().equalsIgnoreCase(token))) {\n    \treturn true;\n\t}\n\n    // remove leading \"-\" and \"=value\"\n    int pos = token.indexOf(\"=\");\n    String optName = pos == -1 ? token.substring(1) : token.substring(1, pos);\n    return options.hasShortOption(optName);\n    // check for several concatenated short options\n}",
