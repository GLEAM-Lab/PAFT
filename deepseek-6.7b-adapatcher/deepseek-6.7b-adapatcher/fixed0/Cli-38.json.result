    "patch_code": "protected List<String> splitQuotedArguments(ListIterator<String> iter) throws ParseException {\n        ArrayList<String> args = new ArrayList<>();\n        \n        while (iter.hasNext()) {\n            String arg = null;\n            \n            try {\n                arg = ArgumentParser.unquote(iter.next());\n            } catch (ArgumentParser.UnbalancedQuoteException ex) {\n                throw new UnmatchedArgumentException(\"Unmatched quote\");\n            }\n            \n            if (!arg.isEmpty()) {\n                Collections.addAll(args, arg.split(Pattern.quote(\"\\\\\"), -1));\n            }\n        }\n        \n        return args;\n    }\n    \nprotected static class ArgumentParser {\n        private final CommandLine cli;\n        private final Pattern pattern;\n        private Matcher matcher;\n\n        public ArgumentParser(CommandLine cli) {\n            this.cli = cli;\n            this.pattern = Pattern.compile(SystemProperties.ARGUMENT_SPLITTER);\n        }\n\n        protected void processArgument(ArrayList<Object> current, String rawValue) throws ParseException {\n            Object value = convertToValue(rawValue);\n            \n            if (current != null && current.size() > 0 && current.get(current.size() - 1) instanceof Option) {\n                Object previous = current.remove(current.size() - 1);\n                \n                if (previous instanceof Option) {\n                    cli.setOptionValue((Option) previous, value);\n                } else if (previous instanceof String) {\n                    cli.setOptionValue((String) previous, value);\n                }\n            }\n        }\n\n        public void parseArgument(ListIterator<String> iterator) throws ParseException {\n            ArrayList<Object> stack = new ArrayList<>();\n            \n            while (iterator.hasNext()) {\n                String token = unquote(iterator.next());\n                \n                if (token.equals(\"--\")) {\n                    break;\n                } else if (token.equals(\"-\")) {\n                    continue;\n                }\n                \n                if (matchesOptionsStart(token)) {\n                    processArgument(stack, token);\n                    \n                    continue;\n                }\n                \n                if (cli.allowsAbbreviatedOptions() && matchesLongestMatchingOptionEnd(token)) {\n                    processArgument(stack, token);\n                    \n                    continue;\n                }\n                \n                if (cli.containsOption('\\'' + token + '\\'')) {\n                    processArgument(stack, token);\n                    \n                    continue;\n                }\n                \n                if ((matcher = PATTERN.matcher(token)).find()) {\n                    int end = matcher.end();\n                    String prefix = token.substring(0, end);\n                    String suffix = token.substring(end);\n\n                    if (prefix.isEmpty() && suffix.startsWith(\"/=\") ) {\n                        processArgument(stack, token);\n                        \n                        continue;\n                    }\n\n                    if (cli.allowsLeadingDashes()) {\n                        throw new IllegalArgumentException(\"An option cannot start with '-': '\" + prefix  + \"'\");\n                    }\n                    \n                    throw new ParseException(\"Unknown option: '\" + prefix + \"'\");\n                }\n                \n                processArgument(stack, token);\n            }\n            \n            while (!stack.isEmpty()) {\n                processArgument(null, stack.remove(stack.size()-1));\n            }\n        }\n    }",
