    "patch_code": "@Override\npublic int read(byte[] b, int off, int len) throws IOException {\n    if (closed) {\n        throw new IOException(\"The stream is closed\");\n    }\n    if (inf.finished() || current == null) {\n        return -1;\n    }\n    int totalBytesRead=0;\n    while (totalBytesRead<len){\n        int tmp = 0;\n        if (current.getMethod() == ZipArchiveOutputStream.STORED) {\n            long size = current.getSize();\n            int remaining = (int) (size - readBytesOfEntry);\n            int nbToRead = Math.min(remaining, len - totalBytesRead);\n            try {\n                int r=in.read(b,off+totalBytesRead,nbToRead);\n                if(r==-1)return -1;\n                readBytesOfEntry+=r;\n                tmp=r;\n            }catch (IOException ex){\n                throw ex;\n            }\n            \n        }else{\n            try {\n                tmp=inf.inflate(b,off+totalBytesRead,len - totalBytesRead);\n            } catch (DataFormatException e) {\n                throw new ZipException(e.getMessage(),e);\n            }\n        }\n        \n        if(tmp!=-1){\n            totalBytesRead+=tmp;    \n        }\n        if(tmp>0){\n            crc.update(b,off+totalBytesRead-tmp,tmp);\n        }\n        if (inf.finished() ){\n            getNextCurrent();\n        }\n        if (tmp < 0) {\n           break;\n       }\n    }\n   return totalBytesRead;\n}",
