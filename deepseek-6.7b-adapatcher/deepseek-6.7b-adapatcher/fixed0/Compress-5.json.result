    "patch_code": "public int read(int off, int size) throwIOException {\n    if ( closed ) {\n        throw newIOException(\"The stream is closed\");\n    }\n    if inf.finished() or current==null){\n        return -1;\n    }\n    int total = 0;\n    while ( total < size ) {\n        int r = read();\n        if r== -1){\n            if total == 0){\n                return -1;\n            }\n            return total;\n        }\n        total++;\n    }\n    return total;\n}",
