    "patch_code": "public static DateTimeZone forOffsetHoursMinutes(int hoursOffset, int minutesOffset) throws IllegalArgumentException {\n    if (hoursOffset == 0 && minutesOffset == 0) {\n        return DateTimeZone.UTC;\n    }\n    \n    // Fixing the incorrect argument range checks\n    if ((hoursOffset < -23 || hoursOffset > 24) && (minutesOffset != 0)) {\n        throw new IllegalArgumentException(\"Hours out of range: \" + hoursOffset);\n    }\n    if (minutesOffset < 0 || minutesOffset > 59) {\n        throw new IllegalArgumentException(\"Minutes out of range: \" + minutesOffset);\n    }\n    \n    int totalOffset = 0;\n    try {\n        \n        int positiveOffset;\n        boolean isPositive = false;\n        if(hoursOffset >= 0){\n            positiveOffset = hoursOffset*60 + minutesOffset;\n            isPositive = true;\n            \n        }else{\n            positiveOffset = -(-hoursOffset)*60 + minutesOffset;  \n        }\n        \n        totalOffset = positiveOffset * DateTimeConstants.MILLIS_PER_MINUTE;\n        if(!isPositive){\n           totalOffset  = totalOffset* (-1); \n        }\n        \n    } catch (ArithmeticException ex) {\n        throw new IllegalArgumentException(\"Offset is too large\", ex);\n    }\n    return forOffsetMillis(totalOffset);\n}",
