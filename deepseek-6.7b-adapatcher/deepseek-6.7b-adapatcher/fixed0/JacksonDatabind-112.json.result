    "patch_code": "public class MyCustomCollection extends AbstractList<String> implements Serializable {\n    private static final long serialVersionUID = 1L;\n    \n    List<String> internalList;\n    \n    public MyCustomCollection() {\n        this.internalList = new ArrayList<>();\n    }\n\n    @JsonCreator\n    public MyCustomCollection(List<String> list) {\n        if (list == null) {\n            throw new IllegalArgumentException(\"null\");\n        }\n        \n        this.internalList = Collections.unmodifiableList(new ArrayList<>(list));\n    }\n\n    ...\n}",
