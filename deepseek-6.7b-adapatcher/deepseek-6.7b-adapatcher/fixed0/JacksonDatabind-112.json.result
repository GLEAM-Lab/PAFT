    "patch_code": "private static class DelegatingMapDeserializer extends StdKeyValueDeserializer implements ResolvableDeserializer {\n\n\tprotected static final long serialVersionUID = 1L;\n\n\t/** Default key deserializer to use when not configured differently */\n\tprivate static final KeyDeserializer DEFAULT_KEY_DESERIALIZER;\n\tstatic {\n\t    /* [bug] missing code -- replace below line:\n\t        DEFAULT_KEY_DESERIALIZER = new StringKeyDeserializer();\n\t      With these lines: */\n\t    try {\n          DEFAULT_KEY_DESERIALIZER = (KeyDeserializer) Class.forName(\"com.fasterxml.jackson.databind.deser.std.StringKeyDeserializer\").newInstance();\n     \t } catch (InstantiationException e) {\n             throw new RuntimeException(e);\n         } catch (IllegalAccessException e) {\n             throw new RuntimeException(e);\n         } catch (ClassNotFoundException e) {\n             throw new RuntimeException(e);\n    \t\t}\n\t}\n\n\t/*\n\t * / ***********************************************************************\n\t * Base method implementations\n\t * ************************************************************************\n\t */\n\t\n\tpublic Map<?, ?> convert(JsonNode rootNode) throws IOException {\n\t\t\tif (rootNode == null || rootNode instanceof NullNode) {\n\t\t\t\treturn _emptyMap;\n\t\t\t}\n\t\t\t// If single valued - wrap into array to process as usual\n\t\t\tif (rootNode instanceof TextNode) {\n\t\t\t\t\treturn Collections.singletonMap((String)DEFAULT_KEY_DESERIALIZER.deserializeKey(null, ((TextNode) rootNode).textValue()), _emptyArray);\n\t\t\t}\n\t\t\tassert (rootNode instanceof ObjectNode);\n\t\t\tIterator<? extends JsonNode> elements = rootNode.elements();\n\t\t\tint i = 0;\n\t\t\tint size = rootNode.size();\n\t\t\tMap<Object, Object> result = new HashMap<>(size << 1);\n\t\t\twhile (elements.hasNext()) {\n\t\t\t\ti++;\n\t\t\t\tfinal Object v = elements.next();\n\t\t\t\tString key = (String)_keyDeserializer.deserializeKey(_keyClass, v);\n\t\t\t\tObject value = _valueDeserializer.deserialize(v);\n\t\t\t\tif (!result.containsKey(key)) {\n\t\t\t\t\tresult.put(key, value);\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn result;\n\t\t}\n\t\t\n\t\t/*\n\t\t* / ******************************************************************************\n\t\t* Construction\n\t\t* ******************************************************************************\n\t\t*/\n\n\t\tpublic DelegatingMapDeserializer(JavaType keyType, JavaType valueType) {\n\t\t\tsuper(keyType, valueType);\n\t\t}\n\n\t}",
