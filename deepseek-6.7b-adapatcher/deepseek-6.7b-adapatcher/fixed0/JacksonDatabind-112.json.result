  {
    "patch_code": "public class StringCustomCollection implements List<String> {\n    \n    private ImmutableList<String> list;\n    \n    public static class CustomSerializer extends StdSerializer<ImmutableList<String>> {\n        \n        protected CustomSerializer() {\n            super(ImmutableList.class);\n        }\n        \n        @Override\n        public void serialize(\n                ImmutableList<String> value, JsonGenerator gen, SerializerProvider provider) \n                throws IOException, JsonProcessingException {\n            \n            if (!value.isEmpty()) {\n                gen.writeStartArray();\n                \n                for (String string : value) {\n                    gen.writeString(string);\n                }\n                \n                gen.writeEndArray();\n            }\n        }\n    }\n    \n    @JsonDeserialize(using = StringCollectionDeserializer.class)\n    public void setData(@JsonProperty(\"data\") List<String> data) {\n        this.list = ImmutableList.copyOf(data);\n    }\n}",
