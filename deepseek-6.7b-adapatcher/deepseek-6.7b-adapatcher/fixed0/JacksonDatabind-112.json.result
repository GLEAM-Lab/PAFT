    "patch_code": "public class CustomStringCollectionDeserializer extends StdScalarDeserializer<ImmutableCustomStringCollectionImpl> implements ContextualDeserializer {\n\n    private static final long serialVersionUID = 1L;\n    \n    private final TypeDeserializer elementTypeDeser;\n\n    public ImmutableListCollector collector;\n\n    protected CustomStringCollectionDeserializer(StdDeserializer<?> src) {\n        super((Class<?>) src.handledType());\n        this.elementTypeDeser = src.getDeserializer(null, null);\n    }\n    \n    @Override\n    public ImmutableCustomStringCollectionImpl deserialize(JsonParser jsonParser, DeserializationContext deserializationContext) throws IOException {\n        \n        List<String> collected = collector.finish();\n        return new ImmutableCustomStringCollectionImpl(collected);\n    }\n\n    /*@SuppressWarnings(\"unchecked\")\n    public <T> T deserialize(JsonParser jp, DeserializationContext ctxt)\n            throws IOException, JsonProcessingException {\n        ObjectCodec oc = jp.getCodec();\n        assertNotNull();\n        assertTrue(jp instanceof ContainerNode);\n        ContainerNode container = (ContainerNode) jp;\n        Iterator<Map.Entry<String,JsonNode>> it = container.fields();\n        while (it.hasNext()) {\n            Map.Entry<String, JsonNode> entry = it.next();\n            JsonNode value = entry.getValue();\n            \n            Importer importer = imports.putIfAbsent(value, new Importer());\n            if (importer==null){ // never before seen\n                try {\n                    Field f = _class.getDeclaredField(entry.getKey());\n                    handleNonstandardImport(oc, value, f, imports);\n                    continue;\n                } catch (NoSuchFieldException e) {}\n            }\n        }\n    }*/\n\n    @Override\n    public JsonDeserializer<?> createContextual(final DeserializationContext ctxt,\n            final BeanProperty property) throws JsonMappingException {\n        final Class<?> rawCls = (property != null && property.getType() != null ? property.getType().getRawClass() : null);\n        final String collectionName = (rawCls == null || EnumSet.class == rawCls ? \"_enum\" : ctxt.getConfig().introspectClassAnnotations(rawCls).getNameForDeserialization());\n        final SimpleModule module = (SimpleModule)_cfg.getAnnotationIntrospector().findOuterModule(this);\n        final String collectionId;\n        if (module != null) {\n            collectionId = ((ModuleSerializerId) module.serializerByType(_type)).id + \"#collection\";\n        } else {\n            collectionId = ctxt.getConfig().getSerializationConfig().getAnnotationIntrospector().findSerializer(this._type).getId() + \"#collection\";\n        }\n        final Module moduleReferringToThis;\n        synchronized (_modulesReferringToMe) {\n            moduleReferringToThis = _modulesReferringToMe.get(_type);\n        }\n        if (moduleReferringToThis == null) {\n            throw new IllegalArgumentException(\"Type id \" + collectionId + \" has already been used\");\n        }\n        ((ModuleReferringToItself) moduleReferringToThis).setReferenceToThis(this);\n        final JsonDeserializer<?> self = this;\n        return new JsonDeserializer<Object>(){\n\n            @Override\n            public Object deserialize(JsonParser p, DeserializationContext ctxt)\n                    throws IOException, JsonProcessingException {\n                \n                return self.deserialize(p, ctxt);\n            }\n        };\n    }\n}",
