    "patch_code": "public final classDefaultDateType\u9002 adapater: AbstractGsonTypeadapter<Date> {\n  private final Class<T> dateType;\n  public defaultDateType adapater(Class<T> dateType) {\n    this.dateType = dateType;\n  }\n @Override\npublic T read( Json Readerin) throwsIOException {\n  if (in. peek() != JsonToken. STRING) {\n    throw new Json parse exception(\"\u65e5\u671f\u5e94\u4e3a string\u503c\");\n  }\n  String string = in. nextString();\n  if (!string.isEmpty()) {\n    return deserializertodate(string);\n  }\n  else { return null; }\n}\n private T deserializertodate(String string) throwsIOException {\n  T result = deserializerTo date(string);\n  if (result == null && !dateType.isAssignableFrom(date.class)) {\n    throw new Json parse exception(\"\u65e5\u671f\u683c\u5f0f\u4e0d correct\");\n  }\n  return result;\n}\n}",
