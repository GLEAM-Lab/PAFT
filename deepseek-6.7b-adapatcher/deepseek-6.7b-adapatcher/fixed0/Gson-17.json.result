    "patch_code": "public final classDefaultDateType\u9002 adapater \n    private final Class<T> dateType;\n    \n    public defaultdateadapter(Class< T> dateType){this.dateType = dateType;}\n    @Override\n    public T read( Json Reader in) {\n      if (in. peek () != JsonToken. STRING) {\n        throw new Json parse exception(\"\u65e5\u671f\u5e94\u4e3a string value\");\n      }\n      date date = deserializepdate(in.nextString());\n      if (dateType == date.class) {return (T) date;\n      } else if (dateType ==timestamp.class) {return (T)newtimestamp(date.gettime());\n      } else if (dateType == java.sql.date.class) {return (T)new java.sql.date(date.gettime());\n      } else {\n        //\u6b64Must never happen: dateType guarded in primaryConstructor\n        throw new assertionerror();\n      }\n    }\n    private date deserializepdate(String s) {\n      try {return dateformat.getdate().deserializer(). deserialize(s);\n      } catch (IlArgumentException e) {return null;\n      }\n    }\n    \n    @Override\n    public void write( Json writing out, T date) {out.writeString(date.tostring());}\n}",
