    "patch_code": "import com.google.gson.*;\nimport java.lang.reflect.Type;\nimport java.util.Date;\n\npublic class NullSafeDateTypeAdapter implements JsonSerializer<Date>, JsonDeserializer<Date>{\n  private final Type dateType;\n  \n  public NullSafeDateTypeAdapter(Type dateType){\n      this.dateType = dateType;\n  }\n  \n  @Override\n  public synchronized JsonElement serialize(Date src, Type typeOfSrc, JsonSerializationContext context) {\n        return new JsonPrimitive(context.serialize(src));\n  }\n      \n    \n  @Override\n  public synchronized Date deserialize(JsonElement json, Type typeOfT, JsonDeserializationContext context) throws JsonParseException {\n          return new Date(json.getAsLong());\n      }\n}",
