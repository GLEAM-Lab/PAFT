    "patch_code": "public int read(byte[] buf, int offset, int numToRead) throws IOException {\n    if (entryOffset >= entrySize) {\n        return -1;\n    }\n    \n    if (!isInitialized) {\n        initialize();\n        isInitialized = true;\n    }\n    \n    if (headerParsed && currHeader.isDirectory()) {\n        headerParsed = false;\n        return read(buf, offset, numToRead);\n    }\n    \n    if (headerParsed && !currHeader.isDirectory()) {\n        numToRead = Math.min(numToRead, (int)(entrySize - entryOffset));\n    } else if (!headerParsed) {\n        numToRead = Math.min(numToRead, getRecordSize());\n    }\n    \n    if (numToRead <= 0) {\n        return 0;\n    }\n    \n    int bytesRead = 0;\n    try {\n        bytesRead = is.read(buf, offset, numToRead);\n    } catch (IOException e) {\n        // Handle IOExceptions with missing files and such better here than in org.apache.commons.compress.archivers.tar.TarArchiveEntry.getRealContent().handleIOE(e);\n        if (bytesRead < 0 && ((IOException)e).getMessage().contains(\"Received disconnect from\")) {\n            return -1;\n        }\n        \n        throw e;\n    }\n    \n    if (bytesRead >= 0) {\n        entryOffset += bytesRead;\n    }\n    \n    return bytesRead;\n}",
