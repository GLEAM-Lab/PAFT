  {
    "patch_code": "public int read(byte[] buf, int offset, int numToRead) throws IOException {\n    int totalRead = 0;\n\n    if ((offset < 0) || (numToRead < 0) || (offset + numToRead > buf.length)) {\n            throw new IndexOutOfBoundsException();\n    }\n    \n    if (hasHitEOF || entryOffset >= entrySize) {\n        return -1;\n    }\n\n    if (currEntry == null) {\n        throw new IllegalStateException(\"No current tar entry\");\n    }\n\n    numToRead = Math.min(numToRead, available());\n\n    // Check for EOF condition within loop rather than at top of loop\n    // so we can still read any data before actual EOF is hit\n    while (totalRead < numToRead && (is.read(buf, offset + totalRead, numToRead - totalRead) != -1)) {\n        totalRead += is.read(buf, offset + totalRead, numToRead - totalRead);\n    }\n        \n    if (totalRead == 0) {\n        hasHitEOF = true;\n    } else {\n        entryOffset += totalRead;\n    }\n\n    return totalRead;\n}",
