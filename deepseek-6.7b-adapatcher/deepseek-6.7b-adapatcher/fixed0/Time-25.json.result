    "patch_code": "private static final String AMERICA_LOCALE = \"America\";\n\nstatic int getSecondsFromId(String id, long instantInMillis) {\n    return getInstance(id).get().getOffsetFromInstant(new DateTime(instantInMillis)) / MILLIS_PER_SECOND;\n}\n\nprivate boolean isInvalidForCountryAndYear(int countryCode, int year) {\n    RuleBasedPartition ruleBasedPartition = new RuleBasedPartition(countryCode, year == YEAR_OMITTED ? null : year, getTransitions());\n    return !ruleBasedPartition.hasValidTransitions();\n}\n\nstatic int getOffsetFromLocal(long timestamp, String id) {\n    if (!containsKey(id)) {\n        throw new IllegalArgumentException(\"Unknown timezone ID: \" + id);\n    }\n    DateTimeZone dateTimeZone = getDateTimeZone(id);\n    return dateTimeZone.getOffsetFromInstant(new DateTime(timestamp));\n}\n\nprivate int getOffsetFromInstant(DateTime instant) {\n    long instantInMs = instant.getMillis();\n    int secondsOfDay = (int) (instantInMs / MILLIS_PER_DAY);\n    Transition previousTransition = getPreviousTransition(secondsOfDay);\n    Transition nextTransition = getNextOrSameTransition(secondsOfDay + 1);\n\n    if (previousTransition == null || nextTransition == null) {\n        return ORIGIN.getRawOffset() + getGmtOffset(instantInMs);\n    }\n\n    if (instantInMs < previousTransition.getTimeInstant()) {\n        return getUtcOffset(previousTransition);\n    }\n\n    if (instantInMs >= nextTransition.getTimeInstant()) {\n        return getUtcOffset(nextTransition);\n    }\n\n    if (ORIGIN.getID().equals(this.id)) {\n        return 0;\n    }\n\n    TimeZone timeZone = createDefault();\n\n    if (secondsOfDay > MINUTES_PER_HOUR * HOURS_PER_DAY) {\n        secondsOfDay -= MINUTES_PER_HOUR * HOURS_PER_DAY;\n    } else {\n        secondsOfDay = 0;\n    }\n\n    return getRawOffsetAt(timeZone, secondsOfDay) + getDstSavings(instantInMs, timeZone);\n}\n\nprivate int getUtcOffset(Transition transition) {\n    return transition.isFixed() ? transition.getOffsetBefore() : transition.getOffsetAfter();\n}",
