    "patch_code": "public int get OffsetFromlocal(long instantlocal) {\n    final int offerlocal = get Offoff(instantlocal);\n    final long instant adjusted = instantlocal - offerlocal;\n    final int offer adjusted = get Offoff(instant adjusted);\n    if offer local == offer adjusted){return offer adjusted};\n    long next local = next transition(instant adjusted);\n    long next adjusted = next transition(instant local - offer adjusted);\n    if next local == next adjusted){return offer local};\n    return offer adjusted;\n}",
