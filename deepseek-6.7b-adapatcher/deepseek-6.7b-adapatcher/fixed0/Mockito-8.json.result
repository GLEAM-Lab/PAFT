    "patch_code": "protected List<TypeVariable> getAllUniqueTypeVariablesThatAppearIn(Type type) {\n        if (type == null) {\n            return emptyList();\n        }\n        Set<String> seen = new HashSet<String>();\n        LinkedList<TypeVariable> result = new LinkedList<>();\n        if (type instanceof Class) {\n            for (Field f : ((Class<?>) type).getDeclaredFields()) {\n                addUnseenTypeVarsFrom(f.getGenericType(), seen, result);\n            }\n        } else if (type instanceof ParameterizedType) {\n            addUnseenTypeVarsFrom(((ParameterizedType) type).getRawType(), seen, result);\n        } else if (type instanceof GenericArrayType) {\n            addUnseenTypeVarsFrom(((GenericArrayType) type).getGenericComponentType(), seen, result);\n        } else if (type instanceof TypeVariable) {\n            addIfNotSeenYet(seen, result, (TypeVariable) type);\n        } else if (type instanceof WildcardType) {\n            addUnseenTypeVarsFromBoundsOf((WildcardType) type, seen, result);\n        } else {\n            throw new UnsupportedOperationException(type.getClass().getName());\n        }\n        return result;\n    }\n\nprivate void addUnseenTypeVarsFrom(Type from, Set<String> seen, List<TypeVariable> into) {\n    for (TypeVariable t : getAllUniqueTypeVariablesThatAppearIn(from)) {\n        addIfNotSeenYet(seen, into, t);\n    }\n}\n\nprivate void addUnseenTypeVarsFromBoundsOf(WildcardType wildcard, Set<String> seen, List<TypeVariable> into) {\n    for (Type t : wildcard.getLowerBounds()) {\n        addUnseenTypeVarsFrom(t, seen, into);\n    }\n    for (Type t : wildcard.getUpperBounds()) {\n        addUnseenTypeVarsFrom(t, seen, into);\n    }\n}",
