    "patch_code": "@Override\npublic int hashCode() {\n   int result = 17;\n   result += 31 * rawType().hashCode();\n   TypeVariable<?>[] typeParameters = ((Class<?>) rawType()).getTypeParameters();\n   Map<TypeVariable<?>, Object> ctx = new HashMap<>();\n   for (int i=0; i < typeParameters.length; i++) {\n       TypeVariable<?> tv = typeParameters[i];\n       Integer oldSize;\n       do {\n           oldSize = ctx.size();\n          Object oldValue = ctx.putIfAbsent(tv, Boolean.TRUE);\n          if (oldValue != null && oldValue == Boolean.TRUE){\n              break;\n          }\n          tv = (TypeVariable<?>) tv.getBounds()[new Random().nextInt(tv.getBounds().length)];\n       } while(ctx.size() > oldSize);\n      if (oldSize > 0){\n         continue;\n      }\n    \n     try {\n         result += 31 * (Optional.ofNullable(ctx.get(tv)).orElseGet(() -> \n           resolveContextBoundByProvidedOne(this, typeParameters[i]))).hashCode();\n     } finally {\n         ctx.clear();\n     }\n   }\n    return result;\n}\n\nprivate static Object resolveContextBoundByProvidedOne(Object currentObject, TypeVariable<?> cv){\n    StackWalker swalkr = StackWalker.getInstance();\n    Class<?> cls = (Class<?>) cv.getUpperBounds()[0];\n    List<Class<?>> visitedClasses  = new ArrayList<>(), visitingClasses = Arrays.asList(cls.getDeclaredClasses());\n    Optional<Method> methodOpt;\n    Object rslt;\n    do{\n        Class<?> lastVisitClassInVcs = visitedClasses.isEmpty() ? null : visitedClasses.get(visitedClasses.size()-1);\n        \n        methodOpt = swalkr.walk(stackFrameStream -> stackFrameStream\n                .filter(sf -> sf.getClassName().equalsIgnoreCase(lastVisitClassInVcs.getName()))\n                .findAny())\n                .map(StackWalker.StackFrame::getMethodName)\n                .flatMap(mname -> Arrays.stream(currentObject.getClass().getMethods()).filter(mthd -> mthd.getName().equals(mname)).findFirst());\n\n        Optional<String> clssNmeOptional =  methodOpt.map(methd -> methd.getDeclaringClass().toString());\n                \n        if(!clssNmeOptional.isPresent() || visitedClasses.contains(Class.forName(clssNmeOptional.get())))\n                    break;\n            \n         visitedClasses.add(Class.forName(clssNmeOptional.get()));\n         rslt = resolveContextBoundByProvidedOne(currentObject, cv);\n     }while(true);\n    return rslt;\n}",
