    "patch_code": "protected void registers type variables on(Type classType) {\n    if (!(classType instanceof ParameterizedType)) {\n        return;\n    }\n    ParameterizedType parameterizedType = ( parameterizedType);\n    Type variable[] type parameters =(( classType.getRawType() .class)) getType parameters();\n    type[] actual types = parameterized type.getActual types();\n    for (int i = 0; i < actual types. length; i++) {\n        type variable type parameter = type parameters[i];\n        type actual types = actual types[i];\n        if ( actual types instance of wild card type) {\n            contextual actual type parameters. put(type variable type parameter,Bounds of(( wild card type actual types)));\n        } else {\n            contextual actual type parameters. put(type variable type parameter, actual types);\n        }\n    }\n}",
