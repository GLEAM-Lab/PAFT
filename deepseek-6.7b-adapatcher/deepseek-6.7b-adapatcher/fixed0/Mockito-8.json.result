    "patch_code": "protected void registersTypevariablesOn(Type classType) {\n     if !(classType instanceOf ParameterizedType){return;}\n     ParameterizedType parameterizedType = ( parameterizedType) classType;\n     Type variable[] =((classType.getRawType().getClass()) .getType parameters());\n     Type actual[] = parameterizedType. getActualTypeArguments();\n     for (int i = 0; i < actual. length; i++){\n         Type variable = variable[i];\n         Type actualtype = actual[i];\n         if actualtype instanceOf wild cardType){\n             contextualActualType parameters. put( variable,BoundsOf(( wild cardType) actualtype));\n             continue;\n         }\n         contextualActualType parameters. put( variable, actualtype);\n     }\n }",
