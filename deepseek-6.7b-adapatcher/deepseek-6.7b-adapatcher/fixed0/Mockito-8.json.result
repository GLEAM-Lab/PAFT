    "patch_code": "protected void registerTypeVariablesOn(Type classType) {\n        if (!(classType instanceof ParameterizedType)) {\n            return;\n        }\n        ParameterizedType parameterizedType = (ParameterizedType) classType;\n        TypeVariable[] typeParameters = ((Class<?>) parameterizedType.getRawType()).getTypeParameters();\n        Type[] actualTypeArguments = parameterizedType.getActualTypeArguments();\n        for (int i = 0; i < actualTypeArguments.length; i++) {\n            TypeVariable typeParameter = typeParameters[i];\n            Type actualTypeArgument = actualTypeArguments[i];\n            \n            List<String> seen = new ArrayList<>();\n            Context ctx = new Context(){};\n            \n            if (seen.contains(ctx.name(typeParameter))) {\n                continue;\n            }\n            seen.add(ctx.name(typeParameter));\n                \n            if (actualTypeArgument instanceof WildcardType) {\n                contextualActualTypeParameters.put(typeParameter, boundsOf((WildcardType) actualTypeArgument, seen, ctx));\n            } else {\n                contextualActualTypeParameters.put(typeParameter, actualTypeArgument);\n            }\n            // logger.log(\"For '\" + parameterizedType + \"' found type variable : { '\" + typeParameter + \"(\" + System.identityHashCode(typeParameter) + \")\" + \"' : '\" + actualTypeArgument + \"(\" + System.identityHashCode(typeParameter) + \")\" + \"' }\");\n        }\n    }\n    \n    private Collection<? super Type> boundsOf(WildcardType wildCardType, List<String> seen, Context ctx) {\n        if (wildCardType == null){\n            return Collections.emptyList();\n        }\n        \n        Type[] types = wildCardType.getUpperBounds();\n        if (types.length == 0){\n            return Collections.emptyList();\n        }\n        List<Type> result = new LinkedList<>();\n        for (Type t : types){\n            String name = ctx.name(t);\n            if (seen.contains(name)){\n                continue;\n            }\n            seen.add(name);\n            if (t instanceof Class || t instanceof ParameterizedType) {\n                result.addAll(boundsOf((WildcardType) ((Class<?>) t).getGenericSuperclass(), seen, ctx));\n            } else if (t instanceof TypeVariable) {\n                result.addAll(boundsOf((WildcardType)((TypeVariable<?>) t).getBounds(), seen, ctx));\n            } else if (t instanceof WildcardType){\n                result.addAll(boundsOf((WildcardType) t, seen, ctx));\n            }else{\n                throw new RuntimeException(\"Unsupported upper bound: \"+t);\n            }\n        }\n        return result;\n    }",
