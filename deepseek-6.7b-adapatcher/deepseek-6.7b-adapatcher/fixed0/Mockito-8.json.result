    "patch_code": "import com.google.common.collect.ImmutableSet;\nimport org.junit.*;\n\nimport static org.hamcrest.Matchers.*;\nimport static org.junit.Assert.assertThat;\n\npublic abstract class GenericMetadataSupportTest {\n    interface GenericsSelfReference<T extends GenericsSelfReference<T>> {\n        T self();\n    }\n    \n    private ClassInferring inferring;\n    @Before public void setup() throws Exception{ inferring= new ClassInferring(new InferenceOptions(), ImmutableSet.of()); }\n\n    @After public void tearDown() throws Exception{}\n  \n    @Test\n    public void test() {\n        final GenericMetadataSupport metaData = getMetaDataFromSelfReferencingInterface();\n\n        final Set<String> stringNames = metaData.toString();\n        assertThat(stringNames.size(), is(1));\n        String expectedName = GenericsSelfReference.class.getName().replace('$', '.')+\"<\";\n        assertTrue(stringNames.contains(expectedName+\"L\"));\n    }\n    \n    private GenericMetadataSupport getMetaDataFromSelfReferencingInterface(){\n        return inferring.inferFrom(GenericsSelfReference.class);\n    }\n}",
