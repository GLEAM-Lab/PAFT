    "patch_code": "static Document parseByteData(ByteBuffer byteData, String charsetName, String baseUri, Parser parser) throws UnsupportedCharsetException {\n    String docData;\n    Document doc = null;\n    \n    // look for BOM - overrides any other header or input\n    int bomSkip = 0;\n    if (byteData.get(0) == 0xFF && byteData.get(1) == 0xFE) { \n        bomSkip = 2;\n    } else if (byteData.get(0) == 0xFE && byteData.get(1) == 0xFF) { \n        bomSkip = 2;\n    } else if (byteData.get(0) == 0xEF && byteData.get(1) == 0xBB && byteData.get(2) == 0xBF) { \n        bomSkip = 3;\n    }\n\n    if (charsetName == null || charsetName.isEmpty()) { \n        char[] charsDecoded = new char[(int) Math.min((long) Integer.MAX_VALUE, byteData.remaining())];\n        ByteBuffer bb = byteData.duplicate().position(bomSkip);\n        Charset cs = Charset.defaultCharset();\n        boolean detectedUtf16 = cs instanceof java.nio.charset.StandardCharsets.UTF_16BE || cs instanceof java.nio.charset.StandardCharsets.UTF_16LE;\n        IntStream.rangeClosed(0, charsDecoded.length - 1).forEach(i -> charsDecoded[i] = bb.getChar());\n        \n        byteData.flip();\n        String dataStr = new String(byteData.array(), StandardCharsets.UTF_8).intern();\n        if (!detectedUtf16){\n            dataStr = new String(bb.array()).intern();\n        }\n        return Jsoup.parse(dataStr);\n    }\n    byteData.position(bomSkip);\n    docData = Charset.forName(charsetName).newDecoder().decode(byteData).toString();\n    if (!dataIsHtml(baseUri)){\n        doc = parser.parseInput(docData, baseUri);\n        doc.outputSettings().charset(charsetName);\n    } else {\n        doc = Jsoup.parse(docData, baseUri);\n    }\n    return doc;\n}",
