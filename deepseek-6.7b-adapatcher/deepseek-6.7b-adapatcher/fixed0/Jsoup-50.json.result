    "patch_code": "import java.nio.ByteBuffer;\nimport java.util.HashSet;\nimport java.util.Set;\nimport javax.annotation.Nonnull;\nimport org.apache.commons.lang3.Validate;\nimport org.jsoup.nodes.Document;\n\npublic class DataUtil {\n  private static final String DEFAULT_CHARSET = \"UTF-8\";\n  \n  @Nonnull\n  public static Document parseByteData(@Nonnull ByteBuffer byteData, @Nonnull String charsetName, @Nonnull String baseUri, @Nonnull Parser parser) throws UnsupportedOperationException {\n    String docData;\n    Document doc = null;\n    \n    if (charsetName == null || charsetName.isEmpty()) {\n      throw new IllegalArgumentException(\"charset name cannot be empty.\");\n    }\n    \n    Validate.notNull(parser, \"Parser must not be null\");\n    \n    boolean bomFound = false;\n    \n    int length = Math.min(byteData.remaining(), 2);\n    short value = 0;\n    while (length-- > 0) {\n      value <<= 8;\n      value |= byteData.get() & 0xFF;\n    }\n    \n    byteData.mark();\n    \n    switch ((int)value) {\n      case 0xFEFF:\n        charsetName = \"UTF-16BE\";\n        break;\n      case 0xFFFE:\n        charsetName = \"UTF-16LE\";\n        break;\n      default:\n        byteData.reset();\n        break;\n    }\n    \n    docData = Charset.forName(charsetName).newDecoder().decode(byteData).toString();\n    \n    if (!DEFAULT_CHARSET.equalsIgnoreCase(charsetName)) {\n      doc = parser.parseInput(docData, baseUri);\n    } else {\n      doc = parser.parse(docData);\n    }\n    \n    doc.outputSettings().encoding(charsetName);\n    \n    return doc;\n  }\n}",
