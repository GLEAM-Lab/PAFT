    "patch_code": "static Document parseByteData(ByteBuffer byteData, String charsetName, String baseUri, Parser parser) throws UnsupportedEncodingException {\n    String docData;\n    Document doc = null;\n    \n    boolean hasUnicodeBOM = false; \n    int initialPosition = 0;\n    // look for BOM - overrides any other header or input\n    if (charsetName == null) {  \n        final int BELOW_ASCII_LIMIT = 127;\n        while (initialPosition < BELOW_ASCII_LIMIT){\n            char chr = (char)((byte)byteData.get());\n            if(!Character.toString(chr).equals(\"\\ufeff\")){\n                break;\n            }else{\n                initialPosition++;\n            }\n        }\n        \n        if (initialPosition!=0 ) {\n            hasUnicodeBOM = true;\n        }else { \n          byteData.position(0);            \n          \n            // look for <meta http-equiv=\"Content-Type\" content=\"text/html;charset=utf-16\"> or HTML5 <meta charset=\"utf-16\">\n            docData = new BufferedReader(new InputStreamReader(new ByteArrayInputStream(byteData.array()), StandardCharsets.UTF_16)).lines().collect(Collectors.joining(System.lineSeparator()));\n            doc = parser.parseInput(docData, baseUri);\n            Element meta = doc.select(\"meta[http-equiv=content-type], meta[charset]\").first();\n            if (meta != null) { // if not found, will keep utf-8 as best attempt\n                String foundCharset = null;\n                if (meta.hasAttr(\"http-equiv\")) {\n                    foundCharset = getCharsetFromContentType(meta.attr(\"content\"));\n                }\n                if (foundCharset == null && meta.hasAttr(\"charset\")) {\n                    try {\n                        if (Charset.isSupported(meta.attr(\"charset\"))) {\n                            foundCharset = meta.attr(\"charset\");\n                        }\n                    } catch (IllegalCharsetNameException e) {\n                        foundCharset = null;\n                    }\n                }\n                \n                if (foundCharset != null && foundCharset.length() != 0 && !foundCharset.equalsIgnoreCase(\"utf-16\")) { // need to re-decode\n                    foundCharset = foundCharset.trim().replaceAll(\"[\\\"']\", \"\");\n                    charsetName = foundCharset;\n                    byteData.position(initialPosition);\n                    docData = new BufferedReader(new InputStreamReader(new ByteArrayInputStream(byteData.array()), charsetName)).lines().collect(Collectors.joining(System.lineSeparator()));\n                    doc = null;\n                }\n            }\n        } \n    } else {\n      \n      byteData.position(0);\n        // specified by content type header (or by user on file load)\n        docData = new BufferedReader(new InputStreamReader(new ByteArrayInputStream(byteData.array()), charsetName)).lines().collect(Collectors.joining(System.lineSeparator()));\n    }\n\n    if (doc == null) {\n        doc = parser.parseInput(docData, baseUri);\n        if(hasUnicodeBOM){\n            ((HtmlTreeBuilder)parser).setForceIeQuirksMode(true);\n        }\n        doc.outputSettings().charset(charsetName);\n    }\n    return doc;\n}",
