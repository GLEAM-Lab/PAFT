    "patch_code": "static Document parseByteData(ByteBuffer byteData, String charsetName, String baseUri, Parser parser) throws IOException {\n    final ByteOrder BO = ByteOrder.BIG_ENDIAN; \n    int i = 0xfffe; \n\n    List<String> stringList = new ArrayList<>(); \n\n    while(i!=0){ \n        stringList.add(Integer.toHexString(i)); \n        byteData.position(byteData.position()+2);\n        \n    }\n    \n    \n    if (!stringList.isEmpty()) {\n        if (charsetName == null) { \n            \n            if ((stringList.get(0).equalsIgnoreCase(\"fe\") && stringList.get(1).equalsIgnoreCase(\"ff\"))||((stringList.get(0).equalsIgnoreCase(\"ff\")&&stringList.get(1).equalsIgnoreCase(\"fe\")))){\n                charsetName = \"UTF-16BE\";\n                \n            }else if(stringList.get(0).equalsIgnoreCase(\"ff\")&&stringList.get(1).equalsIgnoreCase(\"fe\")){\n                charsetName = \"UTF-16LE\";\n            }\n            \n         \n            \n            \n        } \n        \n      \n        \n    }\n\n  \n     \n\n    InputStream bis = new ByteArrayInputStream(new ByteBuffer[]{byteData}.array());\n    BufferedReader br = new BufferedReader(new InputStreamReader(bis, Charset.forName(charsetName)));\n\n    String line;\n    StringBuilder sb = new StringBuilder();\n\n    while ((line = br.readLine()) != null) {\n        sb.append(line);\n        sb.append(\"\\n\");\n    }\n\n    br.close();\n\n    return Jsoup.parse(sb.toString(), baseUri);\n\n}",
