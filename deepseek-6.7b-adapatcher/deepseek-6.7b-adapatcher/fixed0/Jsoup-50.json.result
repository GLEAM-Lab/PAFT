    "patch_code": "import java.nio.*;  \n\npublic class MainClass \n{  \n    public static void main(String[] args) throws Exception  \n    {  \n        byte b1 = 0xFF;  \n        byte b2 = 0xFE;  \n        \n        ByteBuffer byteBuf = ByteBuffer.allocate(2);  \n        byteBuf.put(b1);  \n        byteBuf.put(b2);  \n    \tbyteBuf.flip();  \n      \n    \tif (byteBuf.get(0) == 0xFF && byteBuf.get(1) == 0xFE){  \n           System.out.println (\"It's a little endian UTF16 BOM.\");  \n     \t}else if(byteBuf.get(0)==0xEF&&byteBuf.get(1)==0XBB&&byteBuf.get(2)==0XBF){  \n\t\t\tSystem.out.println(\"It's a UTF8 BOM\");  \n\t\t}  \n    }  \n}",
