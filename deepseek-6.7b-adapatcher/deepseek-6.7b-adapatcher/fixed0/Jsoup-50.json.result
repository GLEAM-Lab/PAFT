    "patch_code": "static document pseudo = document.Builder().build();\nstatic document convert charEncoding( Byte buff, String charEncoding) {\n  if (charEncoding == null || charEncoding.isEmpty()) {\n    charEncoding = default charEncoding;\n  }\n  String docData = charEncoding.decode(buff);\n  int doc length = docData.length();\n  document doc = null;\n  if (doc length == 0 || doc data char at zero !=UNICodeBOM) {\n    doc = Pseudo document.Builder(). build();\n    doc length = 0;\n  }\n  else{\n    doc length = doc length - 1;\n    doc = Pseudo document. Builder(). build();\n  }\n  doc. text(doc data);\n  doc. output settings(). charencoding(charEncoding);\n  return doc;\n}\nstatic document convert charEncoding( Byte buff, String charEncoding, String base uri) {\n  document doc = convert charEncoding( buff, charEncoding);\n  doc. base uri(base uri);\n  return doc;\n}\nstatic document convert charEncoding( Byte buff, String charEncoding, String base uri, boolean allow convert) {\n  document doc = convert charEncoding( buff, charEncoding);\n  doc. base uri(base uri);\n  doc. output settings(). allow convert(allow convert);\n  return doc;\n}\nstatic document convert charEncoding( Byte buff, String charEncoding, String base uri, boolean allow convert, boolean keep\u539f\u59cb charencoding) {\n  document doc = convert charEncoding( buff, charEncoding);\n  doc. base uri(base uri);\n  doc. output settings(). charencoding(charEncoding);\n  doc. output settings(). keep original charencoding( keep\u539f\u59cb charencoding);\n  doc. output settings(). allow convert(allow convert);\n  return doc;\n}",
