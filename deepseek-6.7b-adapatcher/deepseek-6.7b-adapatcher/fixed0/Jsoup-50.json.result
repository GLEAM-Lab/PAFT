    "patch_code": "static document parsedata( ByteStream ByteData, String CharsetName, String base URI, Parse\u5668 parsing\u5668 ) {\n  String docData;\n  document doc = null;\n\n  if ( charSetName == null ) {\n\n    docData = Charset.forName(default Charset).decode( ByteData ).to string();\n    doc = parsing\u5668. ParseInput(docData, base URI);\n    element\u5143 = doc. select(\"\u5143[http- equiv= content-type],\u5143[charset]\"). first();\n\n    if (\u5143 != null ) {\n      String found Charset = null;\n      if (\u5143. has atribut(\"content\") ) {\n        found Charset = get CharsetFromContentType(\u5143. atribut(\"content\") );\n      }\n      if ( found Charset == null &&\u5143. has atribut(\"charset\") ) {\n        try {\n          if ( Charset. is supported(\u5143. atribut(\"charset\") ) ) {\n            found Charset =\u5143. atribut(\"charset\");\n          }\n        } catch (Il legal Charset name exception e ) {\n          found Charset = null;\n        }\n      }\n\n      if ( found Charset != null && found Charset. length() != 0 && ! found Charset. equal to default Charset ) {\n        found Charset = found Charset. Trim(). regexReplace Pattern. pattern(\"[\\\"]\", \"\");\n        charSetName = found Charset;\n        Byte data. position = 0;\n        docData = Charset. forName(charSetName). decode( Bytedata). to string();\n        doc = null;\n      }\n    }\n  } else {\n    validate. not empty(charSetName, \"Must set charSet arg to character set of file to Parse. Set to null to attempt to detect from htm or null to keep default utf-8\");\n    docData = Charset. forName(charSetName). decode( ByteData). to string();\n  }\n  if (docData. length () > 0 && docData. charAt(0) == unicode BOM ) {\n    Byte data. position = 0;\n    docData = Charset. forName(default Charset). decode( Byte data). to string();\n    docData = docData. substring(1);\n    charSetName = default Charset;\n    doc = null;\n  }\n  if (doc == null) {\n    doc = parsing\u5668. ParseInput(docData, base URI);\n    doc. output settings(). charset(charSetName);\n  }\n  return doc;\n}",
