    "patch_code": "private void writeBits(final DataOutput header, final BitSet bits, final long length) throws IOException {\n    byte[] tmp = new byte[(int) (length + 7) / 8];\n    for (int j = 0; j < tmp.length; ++j) {\n        boolean b = bits.get(j);\n        tmp[j] = (byte)(b ? 1 : 0);\n    }\n    header.writeInt((tmp.length << 3) + ((tmp.length == 0 || !bits.get(tmp.length - 1)) ? 0 : 1));\n    header.write(tmp);\n}",
