    "patch_code": "public static void main(String[] args) throws IOException{  \n\t  \n\ttry {    \n\t\tnew Main().run();\n\t} catch (IOException e) {\n\t\te.printStackTrace();\n\t}\n\n}\nclass OutputStream extends java.io.OutputStream {\n\tprivate byte buffer[];\n\tpublic int offset;\n\tprivate java.io.DataOutputStream stream;\n\tint totalCount=0;\n\t{\n\t\t\n\t\tbuffer = new byte[65536];\n\t}\n\n\tOutputStream(java.io.DataOutputStream s){\n\t\tstream = s;\n\t\t//System.out.println(\"OutputStream initialized\");\n\t}\n\t\n\t/*\n\t * Overriding write method to add our custom logic for controlling how many bytes get written into the output stream\n\t */\n\t@Override\n\tpublic synchronized void write(byte b[]) throws IOException {\n\t    //Adding null check to ensure we do not go out of bounds in array\n\t\tif(offset+b.length<65536){\n\t        System.arraycopy(b, 0, buffer, offset, b.length);\n\t        offset += b.length;\n\t        \n\t\t}else throw new IndexOutOfBoundsException();\n\t}\n\n\tpublic synchronized void write() throws IOException{\n\t\t//We have to tell the input file that there are no more files left\n\t\tWriteFinishedHeader();\n\t\tfor (int pos = 0; pos < offset; ) {\n\t\t\tint len = Math.min(65536, offset - pos);\n\t\t\t\n\t\t\tlong startPos = totalCount + SEEK_BEFORE_FINALIZE_SIZE;\n\t\t\tEncryptAndHash(buffer, pos, len);\n\t\t\tlen = WriteBlockHeader(startPos, len);\n\t\t\ttotalCount += len + 2;//+2 because of two Byte after each block header\n\t\t\tstream.writeBytes(Utils.toStringNoCheck(buffer, pos, len));\n\t\t\tpos += len;\n\t\t}\n\t\tUpdateCRCs();\n\t\tstream.close();\n\t\t\n\t}\n\t/**\n\t * Implement your Logic here for writing the finished Header after closing all the Files inside the Archive.\n\t * @throws IOException\n\t */\n\tvoid WriteFinishedHeader() throws IOException{\n\t\t//Place holder so that program would compile successfully\n\t\treturn ;\n\t}\n\t/**\n\t * Use the Encryption Algorith to encrypt the data blocks \n\t * @param buf\n\t * @param pos\n\t * @param len\n\t */\n\tvoid EncryptAndHash(byte []buf, int pos , int len) {\n\t\t//placeholder\n\t\treturn ;\n\t}\n\t/**\n\t * This Method should contain the logic needed to control the size of the Block Headers in the archive\n\t * @return Size of Block headers used in the archive format\n\t */\n\tint WriteBlockHeader(long positionInCompressed, int len) {\n\t\t\n\t\treturn len;\n\t}\n\t\n\tvoid UpdateCRCs() {\n\t\t//Placeholder\n\t\treturn;\n\t}\n\t \nvoid run() throws IOException{\n    long startFullSize = archiveStartPosition;\n    OutputStream os = new OutputStream(dataOutput);\n    os.WriteFinishedHeader();//This needs to be implemented.\n     while (currentEntry != null){\n    \t //Logic to read from current Entry goes Here\n     \n       int realSize = calculateRealSize();\n       int compressedSize = compressAndWriteToBuffer();\n       \n       long curFullSize = startFullSize + calculateCurrentHeaderSize(realSize,compressedSize);\n       long startOffset = curFullSize;\n       os.WriteFileHeader(curFullSize, startOffset, realSize, compressedSize);\n       os.write((int)((startOffset >> 32)));\n       os.write((int)(startOffset & 0xFFFFFFFFL));\n       os.write((int)(realSize >> 24));\n       os.write((int)(realSize & 0XFFFFFF));\n       \n    \t skipRestForEmptyFiles();\n    \t archiveStartPosition = startOffset;\n    \tcurrentEntry = nextEntry();\n\t } \n\tos.write();\n}\n}",
