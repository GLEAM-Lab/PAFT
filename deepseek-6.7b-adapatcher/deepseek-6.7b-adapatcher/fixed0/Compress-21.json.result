    "patch_code": "public class SevenZOutputFile extends SevenZArchiveOutputStream implements ArchiveStreamFactory {\n   ...\n   private static final int MAX_FILE_SIZE = 0xFFFFFFF; // Maximum size value in HEAD block, according to documentation\n   @Override\n   protected void processNewEntry() throws IOException {\n      FileSystemLike fs = context.getFileSystem();\n      ArchiveEntry currentEntry = getCurrentEntry();\n      long remainingBytesToProcess = Math.min(MAX_FILE_SIZE, fs.length(currentEntry));\n      int processedChunkSizeInBlock = (int)Math.min(remainingBytesToProcess, 0xFFFFFFL);\n\n      if (!currentEntry.isDirectory()) {\n         long posInCompressedData = out.size();\n         super.processNewEntry();\n         \n         while (true) {\n            byte[] buffer = new byte[BUFFER];\n            int bytesRead = fs.read(buffer, 0, BUFFER);\n            remainingBytesToProcess -= bytesRead;\n            if (bytesRead == 0 || remainingBytesToProcess <= 0) break;\n            \n            try {\n               putNextBlock(buffer, processedChunkSizeInBlock);\n               \n               processedChunkSizeInBlock = 0;\n            } catch (IOException ex) {\n               throw ex;\n            }\n         }\n\n         processNewEmptyEntry();\n         return;\n      } else if (currentEntry.getName().endsWith(\"/\")) {\n         String name = currentEntry.getName().substring(0, currentEntry.getName().length()-1);\n         \n         out.writeByte((byte)0x40);\n         writeString(name+'/');\n         writeInt(-1, 5);\n         \n         processNewEmptyEntry();\n         return;\n      }\n\n      super.processNewEntry();\n      if(!out.hasClosed()) {\n         out.flush();\n      }\n      \n      context.close();\n      out.writeByte((byte)0x00);\n      writeString(currentEntry.getName());\n      long packedSize = posInCompressedData;\n      long uncompressedSize = currentEntry.getSize();\n      \n      boolean hasCrc32 = false;\n      if(features.contains(\"CRC32\")) {\n         hasCrc32 = true;\n      }\n\n      writeInt((int)(packedSize), 0);\n      writeUInt((long)(uncompressedSize), 0);\n      writeUInt(currentEntry.getPackedSize(), 0);\n      if(hasCrc32) {\n         writeInt((int)(posInCompressedData & 0xFF), 0);\n      }\n      \n      writeShort(info.blockIndices.peek()&65535, 0);\n      info.blockIndices.push(info.blockIndices.peek() + 1);\n      \n      processNewEmptyEntry();\n   }\n}",
