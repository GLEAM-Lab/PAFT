    "patch_code": "private void writeBits(final DataOutput header, final BitSet bits, final long length) throws IOException {\n    byte cachenew = 0;\n    int shiftr = Integer.numberOfLeadingZeros(Long.toBinaryString(length)) ^ 63;\n    while(--shiftr>=0){\n         boolean bitvalue=(((long)(Integer.MAX_VALUE+Integer.MIN_VALUE)/2 +length>>shiftr & 1)==1)? true:false;\n      //  System.out.println(\"bit\"+bitvalue);\n       cachenew|=((byte) (bitvalue?1L<<(6-(byte)shiftr%7):0));\n       if(shiftr %7 ==0&& shiftr!=0||true){header.writeByte(cachenew);cachenew=0;}\n     }\n   header.writeByte(cachenew);\n   }",
