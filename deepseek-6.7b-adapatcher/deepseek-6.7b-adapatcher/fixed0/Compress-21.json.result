    "patch_code": "private void writeBits(final DataOutput header, final BitSet bits, final long posInStream, final int length) throws IOException {\n    long position = header.getFilePointer();\n    while (posInStream > position + length * 7) {\n        // Find the next byte boundary in input stream\n        header.skipBytes((int) ((posInStream - position + 6) / 7));\n        position += header.readByte() << 5;\n    }\n    position += 0xFFFFF & posInStream;\n    \n    ByteArrayOutputStream baos = new ByteArrayOutputStream();\n    OutputBitStream obs = new OutputBitStream(baos);\n    obs.writeData(bits);\n    byte[] bs = baos.toByteArray();\n    for (byte data : bs) {\n        header.writeByte(data);\n    }\n}",
