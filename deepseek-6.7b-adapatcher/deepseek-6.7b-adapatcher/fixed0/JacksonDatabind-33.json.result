  {
    "patch_code": "public PropertyName findNameForSerialization(Annotated a)\n{\n    String name = null;\n\n    JsonGetter jg = _findAnnotation(a, JsonGetter.class);\n    if (jg != null) {\n        name = jg.value();\n    } else {\n        JsonProperty pann = _findAnnotation(a, JsonProperty.class);\n        if (pann != null && !\"\".equals(pann.value())) {\n            name = pann.value();\n        } else if (!Modifier.isPrivate(_findMember(a).getModifiers()) &&\n                ((_hasAnnotation(a, JsonIgnore.class) && !pann.ignore()) ||\n                        _hasAnnotation(a, JsonAnySetter.class) ||\n                        _hasAnnotation(a, JsonManagedReference.class))) {\n            name = _propertyNamingStrategy.propertyToSnakeCase(a.getName());\n        } else if (_hasAnnotation(a, JsonBackReference.class)) {\n            return null;\n        } else if (_hasAnnotation(a, JsonUnwrapped.class)) {\n            return null;\n        } else if (_hasAnnotation(a, JsonAutoDetect.class)) {\n            final boolean hasCreatorOrFactory = _hasAnnotationWithParameterlessCtor(a);\n            if ((hasCreatorOrFactory && !((JsonAutoDetect.Value) _findAnnotation(a, JsonAutoDetect.class)).isCreator())\n                    || !hasCreatorOrFactory && !((JsonAutoDetect.Value) _findAnnotation(a, JsonAutoDetect.class)).isAlways()) {\n                return null;\n            }\n        } else {\n            return null;\n        }\n    }\n    return PropertyName.construct(name);\n}",
