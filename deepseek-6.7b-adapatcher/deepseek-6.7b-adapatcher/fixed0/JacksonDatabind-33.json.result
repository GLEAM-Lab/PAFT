  {
    "patch_code": "public PropertyName findNameForSerialization(Annotated a)\n{\n    String name = null;\n\n    JsonGetter jg = _findAnnotation(a, JsonGetter.class);\n    if (jg != null) {\n        name = jg.value();\n    } else {\n        JsonProperty pann = _findAnnotation(a, JsonProperty.class);\n        if (pann != null && !pann.value().equalsIgnoreCase(\"\")) {\n            name = pann.value();\n        } else if (!(_hasAnnotation(a, JsonInclude.class) || _hasAnnotation(a, JsonAnySetter.class))) {\n                try {\n                    Field f = ((AnnotatedField) a).getDeclaringClass().getDeclaredField(((AnnotatedField) a).getName());\n                    if (null == f) {\n                        throw new IllegalArgumentException(\"No such field: \" + a.getDeclaringType().getCanonicalName()+ '.' + a.getLocalName());\n                    }\n                    JsonUnwrapped uw = f.getAnnotation(JsonUnwrapped.class);\n                    if (null != uw) {\n                        try {\n                            Class<?> type = f.getType();\n                            for (Method m : type.getMethods()) {\n                                if (!Modifier.isPublic(m.getModifiers())) {\n                                    continue;\n                                }\n                                if (\"equals\".equals(m.getName()) || \"hashCode\".equals(m.getName())) {\n                                    continue;\n                                }\n                                \n                                name = Character.toLowerCase(type.getSimpleName().charAt(0)) + \n                                        type.getSimpleName().substring(1) + '.' + m.getName();\n                                break;\n                            }\n                            \n                        } catch (Exception e3) {\n                            throw new RuntimeException(e3);\n                        }\n                        \n                    }\n                } catch (Exception e2) {\n                    throw new RuntimeException(e2);\n                }\n        }\n    }\n    \n    return PropertyName.construct(name);\n}",
