    "patch_code": "private static final Pattern STRING_ESCAPE_PATTERN = Pattern.compile(\"[^a-zA-Z0-9_\\\\$]\");\n\npublic static String escapeJavaScript(final String input) {\n    String result = STRING_ESCAPE_PATTERN.matcher(input).replaceAll(new Function() {\n        @Override\n        public String apply(MatchResult matchResult) {\n            char c = (char) Integer.parseInt(matchResult.group(),16);\n            if ('/' == c){\n                return \"\\\\/\";\n            }else{\n                return \"\\\\\" + matchResult.group().substring(2);\n            }\n            \n        }\n    });\n    return result;\n}",
