    "patch_code": "private static voidescape javascript style string(StringBuilder sb, String str, booleanescape singlequoted) {\n    int sz = str.length();\n    for (int i = 0; i < sz; i++) {\n        char ch = str.charAt(i);\n        switch (ch) {\ncase '':\n    sb.append('\\\\' + ch + '\\\\');\n    break;\ncase '':\n    sb.append('\\\\' + ch + '\\\\');\n    break;\ncase '':\n    sb.append('\\\\' + ch + '\\\\');\n    break;\ncase '':\n    sb.append('\\\\' + ch + '\\\\');\n    break;\ndefault:\n    sb.append(ch);\n    break;\n        }\n    }\n}",
