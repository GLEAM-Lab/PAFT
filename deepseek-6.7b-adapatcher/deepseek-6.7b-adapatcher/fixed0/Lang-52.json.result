    "patch_code": "private static void escapeJavaStyleString(Writer out, String str, boolean escapeSingleQuote) throws IOException {\n     if (out == null) {\n         throw new IllegalArgumentException(\"The Writer must not be null\");\n     }\n     if (str == null) {\n         return;\n     }\n     int sz;\n     sz = str.length();\n     for (int i = 0; i < sz; i++) {\n         char ch = str.charAt(i);\n\n         // handle unicode\n         if (ch > 0xfff) {\n             out.write(\"\\\\u\" + hex(ch));\n         } else if (ch > 0xff) {\n             out.write(\"\\\\u0\" + hex(ch));\n         } else if (ch > 0x7f) {\n             out.write(\"\\\\u00\" + hex(ch));\n         } else if (ch < 32) {\n             switch (ch) {\n                 case '\\b':\n                     out.write('\\\\');\n                     out.write('b');\n                     break;\n                 case '\\n':\n                     out.write('\\\\');\n                     out.write('n');\n                     break;\n                 case '\\t':\n                     out.write('\\\\');\n                     out.write('t');\n                     break;\n                 case '\\f':\n                     out.write('\\\\');\n                     out.write('f');\n                     break;\n                 case '\\r':\n                     out.write('\\\\');\n                     out.write('r');\n                     break;\n                 default :\n                     if (ch > 0xf) {\n                         out.write(\"\\\\u00\" + hex(ch));\n                     } else {\n                         out.write(\"\\\\u000\" + hex(ch));\n                     }\n                     break;\n             }\n         } else {\n             switch (ch) {\n                 case '\\'':\n                     if (escapeSingleQuote) {\n                       out.write('\\\\');\n                       out.write('\\\\');\n                       out.write('5');\n                       out.write('C');\n                     } else {\n                          out.write('\\'');\n                     }\n                     break;\n                 case '\"':\n                     out.write('\\\\');\n                     out.write('\"');\n                     break;\n                 case '\\\\':\n                     out.write('\\\\');\n                     out.write('\\\\');\n                     break;\n                 default :\n                     out.write(ch);\n                     break;\n             }\n         }\n     }\n }",
