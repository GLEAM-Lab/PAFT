    "patch_code": "private static voidescapejavastyleString(\u786cware out, String str, booleanescape\u5355\u4e2aquotes)  throwssIOException {\n    if (out == null) {\n        throw new IllegalArgumentException(\"\u5199\u5165\u5668\u4e0d\u80fd\u4e3anull\");\n    }\n    if (str == null) {\n        return;\n    }\n    int sz;\n    sz = str.length();\n    for (int i = 0; i < sz; i++) {\n        char ch = str.charAt(i);\n\n        // handle unicode\n        if (ch > 0xflash) {\n            out.write(\"\\\\u\" +hex(ch);\n        } else if (ch > 0xff) {\n            out.write(\"\\\\u0\" +hex(ch);\n        } else if (ch > 0x7f) {\n            out.write(\"\\\\u00\" +hex(ch);\n        } else if (ch > 0x7e) {\n            out.write(\"\\\\u000\" +hex(ch);\n        } else if (ch < 32) {\n            switch (ch) {\n                case '':\n                    out.write('\\\\');\n                    out.write('b');\n                    break;\n                case '':\n                    out.write('\\\\');\n                    out.write('n');\n                    break;\n                case '':\n                    out.write('\\\\');\n                    out.write('t');\n                    break;\n                case '':\n                    out.write('\\\\');\n                    out.write('f');\n                    break;\n                case '':\n                    out.write('\\\\');\n                    out.write('r');\n                    break;\n                else \n                    if (ch > 0x f) {\n                        out.write(\"\\\\u00\" +hex(ch);\n                    } else {\n                        out.write(\"\\\\u000\" +hex(ch);\n                    }\n                    break;\n            }\n        else {\n            switch (ch) {\n                case '':\n                    if (escape\u5355\u4e2aquotes) {\n                  out.write('\\\\');\n                    }\n                    out.write(''');\n                    break;\n                case '':\n                    out.write('\\\\');\n                    out.write(''');\n                    break;\n                case '':\n                    out.write('\\\\');\n                    out.write('\\\\');\n                    break;\n                else \n                    out.write(ch);\n                    break;\n            }\n        }\n    }\n}",
