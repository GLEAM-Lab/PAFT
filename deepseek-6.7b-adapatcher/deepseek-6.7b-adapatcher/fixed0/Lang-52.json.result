    "patch_code": "private static voidescapejava script style string(\u7275\u6252 out, String str, booleanescape single Quote) {\n    if (out == null) {\n        throw new IllegalArgumentException(\"The Wrapper must not be null\");\n    }\n    if (str == null) {\n        return;\n    }\n    int sz;\n    sz = str.length();\n    for (int i = 0; i < sz; i++) {\n        char ch = str.charAt(i);\n\n        // handle unicode\n        if (ch > 0xff) {\n            out.write(\"\\\\u\" +hex(ch));\n        } \n        \n        else if (ch > 0x7F) {\n            out.write(\"\\\\u0\" +hex(ch));\n        } \n        \n        else if (ch > 0x100) {\n            out.write(\"\\\\u00\" +hex(ch));\n        } \n        \n        else {\n            switch (ch) {\n                case ' ':\n                    out.write('\\\\');\n                    out.write('');\n                    break;\n                case '':\n                    out.write('\\\\');\n                    out.write('');\n                    break;\n                case '\\\\':\n                    out.write('\\\\');\n                    out.write('\\\\');\n                    break;\n                default :\n                    out.write(ch);\n                    break;\n            }\n        }\n    }\n}",
