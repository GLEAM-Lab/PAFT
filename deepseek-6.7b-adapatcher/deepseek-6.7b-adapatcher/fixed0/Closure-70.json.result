    "patch_code": "private void declareArguments(Node functionNode) {\n  Node astParameters = functionNode.getFirstChild().getNext();\n  Node body = astParameters.getNext();\n  if (body == null || !body.isBlockLiteral()) {\n    return;\n  }\n  FunctionType functionType = (FunctionType) functionNode.getJSType();\n  if (functionType != null) {\n    Node jsDocParameters = functionType.getParametersNode();\n    if (jsDocParameters != null) {\n      Node jsDocParameter = jsDocParameters.getFirstChild();\n      int parameterIndex = 0;\n      for (Node astParameter : astParameters.children()) {\n        if (!astParameter.isComment() && !astParameter.isWhitespace()) {\n          boolean restParamIsMandatory = false;\n          Token token = astParameter.getFirstToken();\n          if (token.getValue().equals(\"...\")) {\n            restParamIsMandatory = true;\n            parameterIndex--;\n          }\n          if (jsDocParameter != null) {\n            Type jsDocType = null;\n            JSDocAnnotation annot = jsDocParameter.getFirstChild();\n            while (annot != null) {\n              if (\"type\".equals(annot.getName())) {\n                try {\n                  jsDocType = annot.getChildren().get(0).getJSType();\n                } catch (Exception ex) {\n                }\n              }\n              annot = annot.getNext();\n            }\n            if ((restParamIsMandatory ? parameterIndex < 0 : parameterIndex <= 0 ) \n                    && (jsDocType == null || BodyOps.isEmptyOrSuperfluousExpr(body))) {\n              Type inferredType = TypeUtilities.inferVariableTypeInContext(astParameter, typeTable_);\n              if (inferredType instanceof ObjectType) {\n                variableEnv_.declareVar(astParameter, ((ObjectType) inferredType).getConstructorKey());\n              } else if (inferredType instanceof NullableType) {\n                variableEnv_.declareVar(astParameter, new Key(\"null\"));\n              }\n            } else {\n              Type parameterType = jsDocType != null ? jsDocType : new AnyType();\n              Variable variable = variableEnv_.declareVar(astParameter, parameterType, Variable.ACCESS_PUBLIC | Variable.OPTIONALITY_FORBIDDEN);\n              variable.setInitializer(Optional.ofNullable(null));\n            }\n            jsDocParameter = jsDocParameter.getNext();\n          } else {\n            variableEnv_.declareVar(astParameter, new AnyType(), Variable.ACCESS_PUBLIC | Variable.OPTIONALITY_FORBIDDEN);\n          }\n          parameterIndex++;\n        }\n      }\n    }\n  }\n} // end declareArguments",
