    "patch_code": "private void declareArguments(Node functionNode) {\n  Node astParameters = functionNode.getFirstChild().getNext();\n  Node body = astParameters.getNext();\n  boolean hasArgs = false;\n  boolean hasRestArg = false;\n  \n  FunctionType functionType = (FunctionType) functionNode.getJSType();\n  if (functionType != null) {\n    Node jsDocParameters = functionType.getParametersNode();\n    if (jsDocParameters != null && jsDocParameters instanceof JSArrayLiteral) {\n      Node jsDocParameter = ((JSArrayLiteral)jsDocParameters).firstChild;\n      while (jsDocParameter != null) {\n        String strParamName = \"\";\n        if (jsDocParameter instanceof ObjectLiteral) {\n          Hashtable<String,Object> paramObj = \n            (Hashtable<String,Object>)((ObjectLiteral)jsDocParameter).getValue();\n          strParamName = (String)paramObj.get(\"name\");\n        } else if (jsDocParameter instanceof JSBinaryExpression) {\n          JSDebug.getInstance().warning(\"@param should be an object, not \" +\n                                        jsDocParameter.getClass());\n        } else {\n          continue;\n        }\n        \n        AstVisitor visitor = new AstVisitor(){};\n        visitor.visitNode(body);\n        hasArgs = true;\n          \n        if (\"...\" == strParamName) {\n          hasRestArg = true;\n          break;\n        }\n        jsDocParameter = jsDocParameter.next;\n      }\n      \n      if (!hasArgs) return;\n      if (hasRestArg) {\n        for (Node astParameter : astParameters.children()) {\n          defineSlot(astParameter, functionNode, null, false);\n        }\n        return;\n      }\n      \n      int argIdx = 0;\n      for (Node astParameter : astParameters.children()) {\n        String argName = astParameter.getName();\n        if (argName == null || argName.length() <= 0) {\n          defineSlot(astParameter, functionNode, null, false);\n        } else if (strParamName.equalsIgnoreCase(argName)) {\n          defineSlot(astParameter, functionNode, \n                     functionType.parameterList[argIdx], false);\n        }\n        argIdx++;\n      }\n      return;\n    }\n  }\n  for (Node astParameter : astParameters.children()) {\n    defineSlot(astParameter, functionNode, null, false);\n  }\n} // end declareArguments",
