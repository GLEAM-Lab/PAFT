    "patch_code": "public static long safeMultiply(long val1, int scalar) {\n    if (scalar == 0 || val1 == 0) {\n         return 0;\n     }\n     boolean sameSign = (val1 > 0 && scalar > 0)|| (val1 < 0 && scalar < 0); \n     if ((sameSign && val1 <= Long.MAX_VALUE/Math.abs(scalar)) || \n          (!sameSign && Math.abs(val1) >=Long.MAX_VALUE/Math.abs(scalar))) {\n         return val1*scalar;\n     } else {\n        throw new ArithmeticException(\"Multiplication overflow\");\n     }\n}",
