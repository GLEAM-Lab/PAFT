    "patch_code": "public static long safemultiply(long val1, int val2) {\n    switch (val2) {\ncase -1:\n    return -val1;\ncase 0:\n    return 0L;\ncase 1:\n    return val1;\n    }\n    long total = val1 * val2;\n    if (val2 > 0 && val1 > total) {\n        throw new ArithmeticException(\" multiplication\u6ea2\u51fa: \" + val1 + \" * \" + val2);\n    }\n    if (val2 < -1 && val1 < total) {\n        throw new ArithmeticException(\" multiplication\u6ea2\u51fa: \" + val1 + \" * \" + val2);\n    }\n    return total;\n}",
