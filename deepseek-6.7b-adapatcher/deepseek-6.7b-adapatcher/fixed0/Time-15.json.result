    "patch_code": "import java.math.BigInteger;\npublic class FieldUtils {\n    public static long safeMultiply(long lngVal, int intScalar) throws Exception {    \t\n\t\tif ((intScalar == 0) || (lngVal == 0)) {\n\t\t\treturn 0;\n\t   \t}\n\n\t\tif (intScalar < 0) {\n\t\t\tlngVal = ~lngVal + 1; // Two's complement\n\t        if (((lngVal & BigInteger.valueOf(-Long.MIN_VALUE).longValue()) ^ BigInteger.valueOf(-Long.MAX_VALUE).longValue() ) <= 0) {\n\t\t\t   throw new Exception (\"Overflow\");\n\t\t\t}\n\t\t} else if (intScalar > 0) {\n\t\t\t// no operation needed as it's correct formula already provided\n\t\t} else {\n\t\t\tthrow new Exception (\"Division By Zero\");\n\t\t}\n\t\treturn lngVal * intScalar;\n    }\n}",
