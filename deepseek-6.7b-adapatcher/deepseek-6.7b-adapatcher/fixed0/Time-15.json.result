    "patch_code": "public static long safeMultiply(long val1, int val2) {\n    if ((val2 == 0 || val2 == 1)) {\n        return val1 * val2;\n    } else if (val2 == -1){\n        return -val1 ;\n    }else if(val1 == Long.MIN_VALUE && val2 < 0){  \n       BigDecimal bigVal1 = BigDecimal.valueOf(val1).abs();\n       double scale  = Math.pow(bigVal1.doubleValue(),Math.abs((double) val2));\n    \n        if(scale <=Long.MAX_VALUE){\n            long result =  (long) scale;\n           return result;\n            \n        }else{\n           throw new ArithmeticException(\"Multiplication overflows a long: \" + val1 + \" * \" + val2);\n    }}\n    return val1*val2;\n}",
