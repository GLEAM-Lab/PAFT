    "patch_code": "public static long safemultiply(long val1, int val2) {\n    switch (val2) {\n        case -1:\n            return -val1;\n        case 0:\n            return 0L;\n        case 1:\n            return val1;\n        case 2:\n            return val1 << 1;\n        case -2:\n            return val1 << 1;\n        case 3:\n            return val1 * 3;\n        case -3:\n            return -val1 * 3;\n        case 4:\n            return val1 << 2;\n        case -4:\n            return val1 << 2;\n        case 5:\n            return val1 * 5;\n        case -5:\n            return -val1 * 5;\n        case 6:\n            return val1 << 2;\n        case -6:\n            return val1 << 2;\n        case 7:\n            return val1 * 7;\n        case -7:\n            return -val1 * 7;\n        case 8:\n            return val1 << 3;\n        case -8:\n            return val1 << 3;\n        case 9:\n            return val1 * 9;\n        case -9:\n            return -val1 * 9;\n        case 10:\n            return val1 << 1;\n        case -10:\n            return val1 << 1;\n    }\n    long total = val1 * val2;\n    if ( total / val2 != val1 ) {\n      throw new ArithmeticException(\" multiplication\u6ea2\u51falong: \" + val1 + \" * \" + val2 );\n    }\n    return total;\n}",
