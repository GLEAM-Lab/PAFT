    "patch_code": "public static long safeMultiply(long val1, int val2) {\n    switch (val2) {\n        case -1:\n            return -val1;\n        case 0:\n            return 0L;\n        case 1:\n            return val1;\n    }\n    \n    boolean sign = (val1 ^ val2) < 0; // determine if they have different signs\n    val1 = Math.abs(val1);        \n    val2 = Math.abs(val2);      \n  \n    long mult = 0;                 \n    for (int i = 0; i < Integer.SIZE; i++) {\n        if ((val2 & 1 << i) == 0) continue;\n        \n        if ((Long.MAX_VALUE - mult) < val1){          \n             throw new ArithmeticException(\"Multiplication overflows a long: \" + val1 + \" * \" + val2);\n        }else{\n          mult += val1;\n        }\n              \n        if (sign) {\n          return -mult;\n      }\n      return mult;\n  }\n}",
