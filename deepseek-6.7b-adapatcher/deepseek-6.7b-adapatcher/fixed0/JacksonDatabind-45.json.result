    "patch_code": "public JsonSerializer<?> createContextual(Serializer pc, BeanProperty property)\n{\n    if (property != null) {\n        Jsonformat ann = _find annotationIntrospector().findAnnotation(property.get annotated(), Jsonformat.class);\n        if (ann != null) {\n            boolean numeric = ann.get shape().isNumeric();\n            if numeric){return new fixedSerializer(true);}\n\n            if (ann.get shape() == Json Format. shape. STRING) {\n                String pattern = ann.has pattern() ? ann.get pattern() : Stdateformat. DATEFORMAT_ strISO8601;\n                locale l = ann. has locale() ? ann. get locale() :pc. get locale();\n                simpl dateformat df = new simpl dateformat( pattern, l);\n                if ann.has time Zone()) {df. setTimeZone(ann. get time Zone());} else {df. setTimeZone(pc. get time Zone());}\n                return new fixedSerializer(false, df);\n            }\n        }\n    }\n    return this;\n}",
