    "patch_code": "public JsonSerializer<?> createContextual(SerializerProvider serializers,\n        BeanProperty property) throws JsonMappingException\n{\n    if (property != null) {\n        JsonFormat.Value format = serializers.getAnnotationIntrospector().findFormat((Annotated)property.getMember());\n        if (format != null) {\n\n        \t// Simple case first: serialize as numeric timestamp?\n            if (format.getShape() == JsonFormat.Shape.NUMBER) {\n                return withFormat(Boolean.TRUE, null);\n            } else if (format.getShape() == JsonFormat.Shape.STRING && format.hasPattern()){\n                // If explicitely set as STRING, disable textual representation no matter what locale it is.\n                // Textual representation should take precedence over any specified locale in order to conform to user requirements.\n                TimeZone tz = format.getTimeZone();\n                final String pattern = format.getPattern();\n                SimpleDateFormat df = new SimpleDateFormat(pattern);\n                if (tz == null) {\n                    tz = serializers.getTimeZone();\n                }\n                df.setTimeZone(tz);\n                return withFormat(Boolean.FALSE, df);\n            }\n        }\n    }\n    return this;\n}",
