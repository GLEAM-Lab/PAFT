    "patch_code": "public class Solution {\n    public static void main(String[] args) throws IOException {\n        \n\n        File file = new File(\"data.txt\");\n        BufferedReader br = new BufferedReader(new FileReader(file));\n        String st;\n        List<Integer> numbers = new ArrayList<>();\n        while ((st = br.readLine()) != null){\n            numbers.add(Integer.parseInt(st));\n        }\n        Collections.sort(numbers);\n\n        BigDecimal sumBigDecimal = new BigDecimal(\"0\");\n        double sumDouble = 0;\n        long start = System.currentTimeMillis();\n        for(int i : numbers){\n            sumDouble += i;\n        }\n        System.out.println(\"\u0421\u0442\u0430\u0440\u0442 double \u0441\u0443\u043c\u043c\u0430 \u0432\u0441\u0435\u0445 \u0447\u0438\u0441\u0435\u043b: \" + sumDouble + \". \u0412\u0440\u0435\u043c\u044f \u0440\u0430\u0441\u0447\u0435\u0442\u0430: \" + (System.currentTimeMillis() - start) / 1000D + \" \u0441\u0435\u043a\u0443\u043d\u0434\");\n\n        start = System.currentTimeMillis();\n        for(int i : numbers){\n            sumBigDecimal = sumBigDecimal.add(BigDecimal.valueOf(i));\n        }\n        System.out.println(\"\u0421\u0442\u0430\u0440\u0442 BigDecimal \u0441\u0443\u043c\u043c\u0430 \u0432\u0441\u0435\u0445 \u0447\u0438\u0441\u0435\u043b: \" + sumBigDecimal + \". \u0412\u0440\u0435\u043c\u044f \u0440\u0430\u0441\u0447\u0435\u0442\u0430: \" + (System.currentTimeMillis() - start) / 1000D + \" \u0441\u0435\u043a\u0443\u043d\u0434\");\n    }\n}",
