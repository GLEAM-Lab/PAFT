    "patch_code": "public OpenMapRealMatrix(long rowDimension, long columnDimension) throws IllegalArgumentException {\n        super(rowDimension < 1 ? 0 : (int)rowDimension, columnDimension < 1 ? 0 : (int)columnDimension);\n\n        ArgumentChecks.checkInRange(rowDimension >= 0, \"Number of rows must be nonnegative\");\n        ArgumentChecks.checkInRange(columnDimension >= 0, \"Number of columns must be nonnegative\");\n        \n        this.rows = (int)rowDimension;\n        this.columns = (int)columnDimension;\n        this.entries = new OpenIntToDoubleHashMap((double)0x7fffffff + 1); //0.0);\n}",
