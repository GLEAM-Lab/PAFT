    "patch_code": "import org.apache.commons.collections4.map.OpenIntToDoubleHashMap;\n\npublic class RepairedOpenMapRealMatrix extends RealMatrix implements Serializable {\n   private static final long serialVersionUID = 736892547182818230L;\n   protected OpenIntToDoubleHashMap entries;\n\n   public RepairedOpenMapRealMatrix(int rowDimension, int columnDimension){\n       super(rowDimension,columnDimension);\n        try{\n            this.entries=new OpenIntToDoubleHashMap((int) Math.ceil(Math.sqrt(rowDimension*columnDimension)), 0.0d);\n        } catch (OutOfMemoryError e){\n            throw new IllegalArgumentException(\"Number of cells (\" + rowDimension * columnDimension + \n                                               \") exceeds maximum number of cells for a \" + OpenMapRealMatrix.class.getSimpleName() + \n                                               \". Workaround: avoid creating matrices with more cells than can fit into memory.\",e);\n        }\n    \n   }\n}",
