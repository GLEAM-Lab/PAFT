    "patch_code": "protected boolean equal(EvalContext context, Expression left, Expression right) {\n    Object l = left.compute(context);\n    Object r = right.compute(context);\n\n    System.err.println(\"COMPARING: \" +\n        (l == null ? \"null\" : l.getClass().getName()) + \" \" +\n        (r == null ? \"null\" : r.getClass().getName()));\n\n    if (l instanceof InitialContext || l instanceof SelfContext) {\n        l = ((EvalContext) l).getSingleNodePointer();\n    }\n\n    if (r instanceof InitialContext || r instanceof SelfContext) {\n        r = ((EvalContext) r).getSingleNodePointer();\n    }\n\n    if (l instanceof Collection) {\n        l = ((Collection) l).toArray();\n    }\n\n    if (r instanceof Collection) {\n        r = ((Collection) r).toArray();\n    }\n\n    if ((l instanceof Object[]) && !(r instanceof Object[])) {\n        return contains((Object[]) l, r);\n    }\n    if (!(l instanceof Object[]) && (r instanceof Object[])) {\n        return contains((Object[]) r, l);\n    }\n    if (l instanceof Object[] && r instanceof Object[]) {\n        return findMatch((Object[]) l, (Object[]) r);\n    }\n    return equal(l, r);\n}\n\nprivate static boolean contains(Object[] array, Object target) {\n    for (int i = 0; i < array.length; i++) {\n        if (array[i].equals(target)) {\n            return true;\n        }\n    }\n    return false;\n}\n\nprivate static boolean findMatch(Object[] array1, Object[] array2) {\n    for (int i = 0; i < array1.length; i++) {\n        int foundIndex = -1;\n        for (int j = 0; j < array2.length; j++) {\n            if (array1[i] instanceof EvalContext && array2[j] instanceof EvalContext) {\n                EvalContext evalLeft = (EvalContext) array1[i];\n                EvalContext evalRight = (EvalContext) array2[j];\n                if (evalLeft.isEqualTo(evalRight)){\n                    foundIndex = j;\n                    break;\n                }\n            } else {\n                if (array1[i].equals(array2[j])) {\n                    foundIndex = j;\n                    break;\n                }\n            }\n        }\n        if (foundIndex == -1){\n            return false;\n        }\n    }\n    return true;\n}",
