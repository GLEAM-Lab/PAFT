    "patch_code": "import java.util.*;\npublic class Main{\n    public static void main(String args[]){\n        String [] d= {\"a\",\"b\"};\n        \n        CoreOperationCompare copc  = new CoreOperationCompare();\n        System.out.println(copc.equal(d,\"a\"));//expecting true\n        System.out.println(copc.equal(d,\"b\"));//expecting true\n    \n    }\n}\nclass CoreOperationCompare{\n    protected boolean equal(Object obj1, String value2) {\n        Object obj2;\n        if(obj1==null){\n            return false;\n        }else{\n            if(obj1 instanceof Object []){\n                Object[] oArr = (Object [])obj1;\n                  for(int i = 0 ;i<oArr.length;i++){\n                       if(!oArr[i].equalsIgnoreCase(value2)){\n                            return false;\n                        }  \n                    }\n                  \n             }else{\n                 return false;\n             }\n        }      \n        \n        \n       \n        return true;\n    }\n}",
