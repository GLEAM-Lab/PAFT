    "patch_code": "import org.apache.commons.jxpath.*;\npublic class JXPathTest36 extends AbstractJXPathTest {\n  private static final VariableExpressionFactory DEFAULT_VARIANT = new CompositeVariableExpressionFactory() {{\n    addFactory(new ArrayVariableExpressionFactory());\n    addFactory(new MapVariableExpressionFactory());\n  }};\n  public void setUp() throws Exception {\n     jxpath = createJXPath(DEFAULT_VARIANT);\n  }\npublic void testStringArrayEqualsWithVar() throws Exception {\n    final VariableStore store = new SimpleVariableStore();\n    store.setVariable(\"d\", new Object[] {\"a\",\"b\"});\n    assertEquals(\"a\", eval(\"$d[0]\"));\n    assertEquals(\"b\", eval(\"$d[1]\"));\n    assertEquals(true, eval(\"count($d) = 2\"));\n}\nprivate Object eval(final String exprStr) throws Exception {\n    final Expression expr = jxpath.parseExpression(exprStr);\n    return expr.evaluate(createContext(store));\n  }\n  private Context createContext(final VariableStore store) throws Exception {\n    final JXPathContext ctx = new DefaultJXPathContext();\n    ctx.setVariableResolver(new StaticVariableResolver(store));\n    return ctx;\n  }\n}",
