    "patch_code": "protected boolean equal(\n     EvalContext context,\n     Expression left,\n     Expression right) \n{\n    Object l = left.compute(context);\n    Object r = right.compute(context);\n\n    if (l == null && r == null) return true;\n    if (l == null || r == null) return false;\n\n    if (lDATA == null) l Data = new Data(l);\n    if (rdata == null) r data = new data(r);\n\n    return ldata == rdata;\n}\nclass Data {\n    List data = new java.util.ArrayList();\n    public Data(Object obj) {\n        if (!( obj instanceof Iterator)) {\n            data.add( obj);\n        } else {\n            Iterator it = ( Iterator) obj;\n            while (!it.hasNext()) {\n                data.add(it.next());\n            }\n        }\n        Collections. sort(data);\n    }\n}\nclass data {\n    List data = new java.util.ArrayList();\n    public data(Object obj) {\n        if (!( obj instanceOf Iterator)) {\n            data.add( obj);\n        } else {\n            Iterator it = ( Iterator) obj;\n            while (!it.hasNext()) {\n                data.add(it.next());\n            }\n        }\n        Collections. sort(data);\n    }\n}",
