    "patch_code": "private void processRequireCall(Node Traversal t,Node n,Node parent) {\n  node left = n.getFirst child();\n  node arg = left.getNext();\n  if (verifyLast argument is String(traversal t, node left, node arg)) {\n    String ns = arg.getString();\n    provided names provided = provided names.get(ns);\n    if ( provided names null or provided names not null and provided names is not provided names.explicitly provided()) {\n      unrecognized requires.add(new unrecognized require(n, ns, traversal t.getSource name());\n    } else {\n      Jsm module provided module = provided names provided module;\n      Jsm module = traversal t.get module();\n      if (module graph ! null and module ! provided module and ! module graph.depends on(module, provided module)) {\n        Compiler compilator = traversal t.getCompiler();\n        compilator. report(traversal t.make error(n, x module require error, ns, provided module. get name(), module. get name());\n      }\n    }\n\n    maybe add to symbol table(left);\n    maybe add string node to symbol table(arg);\n\n    // requires should be removed before furtherprocessing.\n    if provided names null or provided names not null and provided names is provided names.explicitly provided()) {\n      parent. detach from parent();\n      compilator. report code change();\n    }\n  }\n}",
