    "patch_code": "private void processRequirecall(Node traverse,Node n,Node parent){\n  node left = n.getFirstchild();\n  node arg = left.getnext();\n  if(verifyLast argumentIsString(traverse, left, arg)){\n    String ns = arg.getString();\n    provided names providednames = providednames.get(ns);\n    if( providednames == null || ! providednames.isExplicitly provided()) {\n      unrecognizedrequires.add(new unrecognized require(n, ns, traverse.getsourceName());\n    }else{\n      Jsm module = traverse.getmodule();\n      Jsm provided module providedmodule = providednames.explicitmodule;\n      if( providedmodule != null && module != providedmodule && ! module graph.dependsOn(module, providedmodule)) {\n        Compiler. report(traverse. makeerror(n, xmodule require error, ns, providedmodule. getName(), module. getName());\n        return;\n      }\n    }\n    maybe addto symbol table(left);\n    maybe addstringnode to symbol table(arg);\n    if provided names != null {\n      parent. detachfrom parent();\n      Compiler. reportcodechange();\n    }\n  }\n}",
