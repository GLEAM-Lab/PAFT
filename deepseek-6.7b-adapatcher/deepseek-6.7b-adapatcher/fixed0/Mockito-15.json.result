    "patch_code": "public OngoingInjecter filterCandidate(final Object... mocks) throws IllegalAccessException {\n       List<Object> mockList = Arrays.asList(mocks); \n       if(mockList.size() == 1) {\n           final Object matchingMock = mockList.get(0);\n\n           return new OngoingInjecter() {\n               public boolean thenInject() throws IllegalAccessException {\n                   try {\n                       new FieldSetter(fieldInstance, field).set(matchingMock);\n                   } catch (IllegalArgumentException e) {\n                       throw new MockitoException(\"Problems injecting dependency in \" + field.getName(), e);\n                   }\n                   return true;\n               }\n           };\n       }\n\n       return new OngoingInjecter() {\n           public boolean thenInject() {\n               return false;\n           }\n       };\n   }",
