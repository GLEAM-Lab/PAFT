    "patch_code": "import org.apache.commons.math3.exception.*;\n\npublic double density(final double[] vals) throws MathIllegalArgumentException, MathIllegalNumberException {\n    final int dim = getMean().length;\n    if (vals.length != dim) {\n        throw new NumberIsTooHighException(\"Wrong vector size \" + vals.length + \". Expected size is \" + dim + \".\");\n    }\n    for (int i = 0; i < dim; i++) {\n        if (!Double.isFinite(vals[i]) || Double.isNaN(vals[i])) {\n            throw new NonFiniteNumberException(vals[i]);\n        }\n    }\n    \n    return FastMath.pow(2 * FastMath.PI, -dim / 2) *\n        FastMath.pow(getCovarianceMatrix().determinant(), -0.5) *\n        getExponentTerm(vals);\n}",
