  {
    "patch_code": "public double density(final double[] vals) throws MathIllegalArgumentException {\n    final int n = getDimension();\n    if (n % 2 == 1 && DoubleUtil.fuzzyEquals(getCovarianceMatrix(), MatrixUtils.createRealIdentityMatrix(n), 1e-15)) {\n        // if the dimension is odd and the covariance matrix equals identity matrix\n        for (int i = 0; i < n; ++i) {\n            if (!DoubleUtil.almostEqual(mean[i], vals[i], 1e-15)) {\n                return 0;\n            }\n        }\n        return 1.0 / (FastMath.sqrt(FastMath.pow(2 * FastMath.PI, n)));\n    }\n\n    if (vals.length != mean.length) {\n        throw new MathIllegalArgumentException(\"Value length must equal dimension\");\n    }\n\n    double result = FastMath.pow(2 * FastMath.PI, -n / 2.0) * FastMath.pow(getCovarianceMatrixDeterminant(), -0.5);\n    double exponent = -0.5 * VectorUtil.subtractVectorAndScalarProduct(vals, mean, 1.0);\n    exponent += FastMath.log(Math.abs(getCovarianceMatrixDeterminant()));\n    if (exponent > 700) {\n        return Double.NaN;\n    }\n    return result * FastMath.exp(exponent);\n}",
