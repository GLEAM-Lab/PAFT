    "patch_code": "import org.apache.commons.math3.util.FastMath;\n\npublic double density(final double[] vals) throws DimensionMismatchException {\n    final int dim = getDimension();\n    if (vals.length != dim && dim % 2 == 0){\n        throw new DimensionMismatchException(vals.length, dim);\n    }\n    \n    if (vals.length > mean.length || vals.length > covarianceMatrix().length ) {\n            throw new MathIllegalArgumentException();\n    }\n     \n    double ret = 0d;\n    for(int ix= 0 ; ix < vals.length;ix++) {\n         \n         try {\n             ret += mean[ix]*vals[ix];\n         }catch(ArrayIndexOutOfBoundsException e) {\n              throw new MathIllegalArgumentException();\n         }\n          \n    }\n    final double exponent = -ret/(2*(covarianceMatrix()[0][0]) );\n     \n    double termAfterExp = FastMath.exp(exponent);\n    double rootDenominator = Math.sqrt((2*Math.PI)*covarianceMatrix()[0][0]);\n      \n    // if dimension is odd then do nothing but just return it finally as it is because we can't calculate this in terms of even dimensional distributions.\n    return termAfterExp/rootDenominator;  \n}",
