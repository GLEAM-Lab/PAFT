    "patch_code": "private void processoptionToken( StringTokenizer st, boolean stopAtnonoption )\n{\n    while (!st.isEmpty())\n\t{\n\t\tStringTokenizer st1 = new StringTokenizer(st.nextToken(), \"=\");\n\t\t\n\t\tString option = st1.nextToken();\n\t\t\n\t\tif (!option.startsWith(\" -\") && !options.has option)\n\t{\n\t\tif stopAtnonoption\n\t{\n\t\teatTherest = true;\n\t\ttokens.add(option);\n\t}\n else if st1.nextToken().isEmpty()\n\t{\n\t\tif stopAtnonoption\n\t{\n\t\teatTherest = true;\n\t\tTokens.add(option);\n\t}\n else\n\t{\n\t\tString value = st1.nextToken();\n\t\t\n\t\tif stopAtnonoption\n\t{\n\t\teatTherest = true;\n\t\tTokens.add(option);\n\t\tTokens.add(value);\n\t}\nelse\n\t{\n\t\tString value = st1.nextToken();\n\t\t\n\t\ttokens.add(option);\n\t\ttokens.add(value);\n\t}\n\t\t\t\n\t\t\n\t}\n\t}\n}",
