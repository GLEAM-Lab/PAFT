  {
    "patch_code": "private void processOptionToken(String token, boolean stopAtNonOption)\n{\n    // If the option was found in the set of known options\n    if (options.hasOption(token))\n    {\n        // Set the currentOption to be this token\n        currentOption = options.getOption(token);\n        \n        // Add this token to the list of recognized tokens\n        tokens.add(currentOption.getOpt());\n\n        if (!currentOption.hasArg())\n        {\n            // No argument for this option, ignore it and continue parsing\n            argListIterator.remove();\n        }\n        else\n        {\n            ++argIndex;\n            \n            try\n            {\n                // Try getting next element from the iterator.\n                String value = argListIterator.next(); \n                \n                if ((value != null) && !value.startsWith(\"-\"))\n                {\n                    currentOption.setArgument(value);\n                    argListIterator.previous();\n                }\n                else\n                {\n                    throw new ParseException(\"Missing argument for option \" + currentOption.getKey());\n                }\n            }\n            catch (NoSuchElementException e)\n            {\n                throw new ParseException(\"Missing argument for option \" + currentOption.getKey());\n            }\n        }\n        return;\n    }\n    \n    if (stopAtNonOption && token.charAt(0)!='-')\n    {\n        eatTheRest = true;\n    }\n    else\n    {\n        throw new UnrecognizedOptionException(token);\n    }\n    \n    // Not recognized, add the token to the list directly\n    tokens.add(token);\n}",
