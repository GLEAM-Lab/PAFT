  {
    "patch_code": "import java.util.*;\nimport org.apache.commons.cli.*;\n\npublic class MyCommandLineParser extends DefaultParser {\n  public static final int INDEX_OF_UNRECOGNIZED_TOKEN = 2;\n  \n  private ArrayList<Object> unknownTokens = new ArrayList<>();\n\n  @Override\n  protected Options getOptions() throws ParseException {\n      return super.getOptions();\n  }\n\n  @Override\n  public CommandLine parse(final String[] args) throws ParseException {\n      try {\n          CommandLine cmd = super.parse(args);\n          \n          for (int i=0 ; i < args.length ; i++) {\n              Object o = args[i];\n              \n              if (!(o instanceof String)) continue;\n              String s = (String) o;\n              \n              // If it starts with \"-\" AND NOT one of the already processed options AND has no associated value AND not \"--\".\n              if (s.startsWith(\"-\") && !cmd.hasOption(s.substring(1).trim()) && s.indexOf(' ') == -1 && !s.equals(\"--\")){\n                  this.unknownTokens.add(INDEX_OF_UNRECOGNIZED_TOKEN,args[i]);\n                  break;\n              }\n          }\n          \n          return cmd;\n      } catch (ParseException pe) {\n          throw pe;\n      }\n  }\n  \n  public List<Object> getUnknownTokens() {\n      return Collections.unmodifiableList(this.unknownTokens);\n  }\n}",
