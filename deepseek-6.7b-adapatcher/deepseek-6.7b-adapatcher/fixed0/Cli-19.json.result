  {
    "patch_code": "private void processOptionToken(String token, boolean stopAtNonOption)\n{\n    if (token.startsWith(\"-\")) \n    {\n        // Ignore unrecognized long options, which start with \"-\" but do not exist in options definition\n        if (!options.hasLongOpt(token.substring(1)))\n        {\n            throw new UnrecognizedOptionException(token);\n        }\n        \n        String optName=null;\n        // When user provides \"-longOption arg\", it should be splitted into two tokens \"-longOption\" & \"arg\".\n        for(Iterator iterator=options.iterator();iterator.hasNext();){\n            CommandLineOption cliopt=(CommandLineOption)iterator.next();\n            List<String> names=cliopt.getNames();\n            \n            for(int i=0;names!= null && i < names.size() ;i++){\n                if(!names.get(i).equalsIgnoreCase(token)){\n                    continue;\n                }    \n                \n                // If no argument expected for this option then add it to tokens list and return from here\n                if((currentOption==null || !currentOption.isArgsAllowed())&&currentArg==null){\n                     currentOption = cliopt;\n                     tokens.add(token);\n                     \n                    \n                     return;\n                }\n                 \n                 optName=names.get(i);\n            }\n            \n        }\n         \n      if(currentOption ==null )\n       {\n           currentOption =new DefaultCommadlineOptionDecorator(new org.apache.commons.cli.Option(optName,null));\n           \n       }\n        tokens.add(token);  \n    }\n    \n    else\n    {\n        if (!stopAtNonOption)\n        {\n            if (currentOption == null)\n            {\n                throw new ParseException(\"Missing option\");\n            }\n            currentOption.setArgument(token);\n        }\n        else\n        {\n            tokens.add(token);\n        }\n    }\n}",
