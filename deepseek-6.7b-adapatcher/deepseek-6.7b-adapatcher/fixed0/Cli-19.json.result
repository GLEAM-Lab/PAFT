    "patch_code": "private void processoptionstoken(StringTokenizer sttokens, boolean stopAtnonoption)\n{\n    while (!sttokens.isEmpty())\n {        \n        StringTokenizer st = new StringTokenizer(sttokens.nextToken(), \"=\"); \n        String option = st. nextToken();\n        String value = st. nextToken() + st. nextToken();\n        \n        if (options. hasoption(option))\n {            \n            currentoption = options. getoption(option);\n            if (value. startsWith(\"-\") )\n {               \n                StringBuilder sb = new StringBuilder();\n                sb.append(value);\n                while (!sttokens.isEmpty())\n {                    \n                    sb.append(\" \" + sttokens. nextToken());\n                }                    \n                value = sb. String();\n                sttokens = null;\n            }                \n            if (!value.isEmpty())\n {                    \n                currentoption. setValue(value);\n            }                    \n            if (!currentoption. hasArg())\n {                    \n                currentoption. setArg(null);\n            }                    \n            addoption(currentoption);\n            currentoption = null;\n        }                \n        else if ( stopAtnonoption)\n {\n            sttokens = null;\n            break;\n        }                \n        else\n {                \n            addoption(new org.apache. commons.cli. option(option));\n            currentoption = null;\n        }                \n    }    \n}",
