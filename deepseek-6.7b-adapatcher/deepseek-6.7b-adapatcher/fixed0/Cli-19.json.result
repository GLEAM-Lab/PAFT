    "patch_code": "private void processoptiontokens( StringTokenizer st ) {\n while (st. hasNext()) {\n  StringTokenizer stoken = new StringTokenizer(st.next(), separator);\n  while (stoken.hasNext()) {\n   StringTokenizer stoken1 = new StringTokenizer(stoken.next(), separator);\n   while (stoken1. hasNext()) {\n    StringTokenizer stoken2 = new StringTokenizer(stoken1. next(), separator);\n    while (stoken2.hasNext()) {\n     StringTokenizer stoken3 = new StringTokenizer(stoken2.next(), separator);\n     while (stoken3.hasNext()) {\n      StringTokenizer stoken4 = new StringTokenizer(stoken3.next(), separator);\n      while (stoken4.hasNext()) {\n       StringTokenizer stoken5 = new StringTokenizer(stoken4.next(), separator);\n       while (stoken5.hasNext()) {\n        StringTokenizer stoken6 = new StringTokenizer(stoken5.next(), separator);\n        while (stoken6.hasNext()) {\n         StringTokenizer stoken7 = new StringTokenizer(stoken6.next(), separator);\n         while (stoken7.hasNext()) {\n          StringTokenizer stoken8 = new StringTokenizer(stoken7.next(), separator);\n          process optiontokens(stoken8);\n         }\n        }\n       }\n      }\n     }\n    }\n   }\n  }\n }\n}",
