    "patch_code": "private void processOptionToken(String token, boolean stopAtNonOption)\n{\n    int indexOf = token.indexOf(\"-\");\n    \n    if(indexOf == 0){ \n        if (!options.hasOption(token.substring(1))) \n        {\n            if (stopAtNonOption && !currentOptsStack.isEmpty()) \n            {\n                nextArg();\n            } \n            else \n            {\n                super.unrecognizedOption(token, options);\n            }\n        } \n        else \n        {\n            processLongOptionToken(token, stopAtNonOption);\n        }\n    } \n    else \n    {\n        if (super.processOptionToken(token, stopAtNonOption)) \n        {\n            return;\n        } \n        \n        if (!currentOptsStack.isEmpty() || !stopAtNonOption) \n        {\n            nextArg();\n        }\n    }\n}",
