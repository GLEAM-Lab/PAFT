    "patch_code": "private void processOptionToken(String token, boolean stopAtNonOption)\n{\n    if (token.charAt(0)!='-')\n    {\n        \n        return ;\n    }\n    \n    if (!stopAtNonOption && token.length() == 2 && \"-\".equalsIgnoreCase(token)) \n    {\n       skipToEndOfOptions();\n       return;\n    }\n    if (options.hasLongOpt(token.substring(1))) \n    {\n        String optName=options.getLongOpt(token.substring(1));\n      //  System.out.println(\"optName:\"+optName);\n       currentOption = options.getOption(optName);\n     \n        tokens.add(currentOption==null ? token : currentOption.getOpt());\n        return ;\n    } \n    else if (options.hasShortOpt(token.substring(1))) \n    {\n       String[] tokenss=  options.getOptionStrings(token.substring(1));\n        for (int i = 0; i <tokenss.length ; i++) \n        {\n            tokens.add(tokenss[i]);\n        }\n        return ;\n       \n        \n    }\n    else \n    {\n        if (stopAtNonOption) \n        {\n           tokens.add(token);\n            \n            \n        } \n        else \n        {\n          eatTheRest = true;\n        }\n    }\n}",
