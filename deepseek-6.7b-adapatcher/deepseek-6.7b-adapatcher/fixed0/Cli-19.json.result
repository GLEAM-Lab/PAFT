  {
    "patch_code": "private void processOptionToken(String token, boolean stopAtNonOption)\n{\n     if (!token.startsWith(\"-\")) \n     {\n         if (!tokens.isEmpty() && !tokens.contains(\"--\") ) \n         {\n             String lastArgumentOrOpt=(String)tokens.get(tokens.size()-1);\n             \n                 if ((lastArgumentOrOpt!=null)&&(!lastArgumentOrOpt.equalsIgnoreCase(\"--\")) \n                     && (!lastArgumentOrOpt.startsWith(\"-\"))  \n                      && (Character.isLetter((lastArgumentOrOpt.charAt(0))) || (lastArgumentOrOpt.indexOf('-')>0) )){\n                      \n                     // The previous argument was an option but it didn't have an argument itself so\n                     // this one gets its value from next string in array.\n                     currentOption.setArgValue(token);\n                     return;\n                    }\n            }\n         \n     }else\n     \n     if (options.hasOption(token))\n     {\n         currentOption = options.getOption(token);\n         tokens.add(token);\n     }\n     else if (stopAtNonOption)\n     {\n         eatTheRest = true;\n         tokens.add(token);\n     }\n     else \n         throw new UnrecognizedOptionException(token);\n}",
