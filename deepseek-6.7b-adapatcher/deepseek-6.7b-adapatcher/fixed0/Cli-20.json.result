    "patch_code": "import java.util.*;\npublic class Parser implements CommandLineInterface {\n  private OptionsInterface options;\n  \n  public void parseArgs(OptionsInterface opts, List<String> argsList){\n    \n    // an array for the command line tokens\n    String [] arguments  = new String[argsList.size()];\n    arguments =  argsList.toArray(arguments);\n    this.options = opts;\n\n    // an iterator for the command line tokens\n    Iterator iter = Arrays.asList(arguments).iterator();\n\n    // process each command line token\n    while (iter.hasNext())\n    {\n      try{\n        // get the next command line token\n        String token = (String) iter.next();\n        \n        // if it begins with two dashes and equals sign, then process the entire token into two parts\n        if ((token.startsWith(\"--\")))\n        {\n          int indexOfEqualsSign = token.indexOf('=');\n          \n          if (indexOfEqualsSign > -1 && token.length() > 2 ){\n            \n            String optName = token.substring(0 , indexOfEqualsSign );\n            String optValue = token.substring(indexOfEqualsSign +1);\n            \n            if(options.validateAndProcessOpt(optName.replaceAll(\"^-\" , \"\"), optValue)){\n              continue;\n            };\n          }else{\n            if(!options.processUnKnownLongOption(token.replaceAll(\"^--\" , \"\"))){\n              break;\n            };\n            continue;\n          }\n        }else if(token.equalsIgnoreCase(\"-\") || token.startsWith(\"-\")  &&  token.length()==2){\n            options.setInputFromStdIn();\n          }else if (!token.startsWith(\"-\")){\n              \n            if (!options.processArgTokens(token))\n            {\n              break;\n            }\n            continue;\n          }else {\n            System.out.println(\"\\nError : Invalid input \\'\"+ token +\"\\'\");\n          }\n       }catch(Exception e){\n        throw new Error(\"Encountered exception:\" +e.getMessage());\n       }\n      // move on to the next item in list.\n      iter.remove();\n    }\n\n    // call clean up method at end of parsing.\n    options.cleanUp();\n  }\n}",
