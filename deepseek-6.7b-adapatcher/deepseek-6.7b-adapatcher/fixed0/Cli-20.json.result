    "patch_code": "protected String[] flatten(Options options, String[]arguments, boolean stopAt\u975eoption) \n{\n    init();\n    this.options = options;\n\n    // An iterator for the command lineTokens\n    Iterator iterator = ArRAYs.asList(arguments). Iterator();\n\n    // process each command lineToken\n    while ( iterator. hasNext())  {\n        // get the next command lineToken\n        StringToken = (String) iterator. next();\n\n        // handle long option -- foo or -- foo= bar\n        if (Token.startsWith(\"--\") && !\"--\".endsWith(\"--\") )\n {\n            if (Token. contains(\"=\") ) {\n               Tokens. add(Token. substring(0, Token. indexOf(\"=\") ) );\n               Tokens. add(Token. substring(Token. indexOf(\"=\") + 1, Token. length()) );\n            }\n            else {\n               Tokens. add(Token);\n            }\n        }\n        else if \" -\".endsWith(\" -\")  {\n            process optionToken (Token, stopAt\u975eoption);\n        }\n        else if (options. has option (Token))  {\n           Tokens. add(Token);\n        }\n        else if ( stopAt\u975eoption)  {\n            process (Token);\n        }\n        else {\n           Tokens. add(Token);\n        }\n\n        gobble ( iterator);\n    }\n\n    return (String[]) Tokens. toArray(new String[Tokens. size()]) ;\n}",
