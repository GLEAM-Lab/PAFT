    "patch_code": "import java.util.Arrays;\nimport java.util.ArrayList;\nimport java.util.Iterator;\nimport org.apache.commons.cli.*;\n\npublic class ParserTest extends PosixParser\n{\n   public static void main(String args[]){\n       Options opts = new Options(); \n      try{\n          opts.addOption( \"verbose\",false,true,\"be verbose\"); \n          opts.addOption( \"output\" ,true, true, \"specify output file\"); \n          opts.addOption( \"help\"  ,false, false,\"print help message\"); \n        \n          \n      String[] strargs = {\"--ouput\",\"myfile\",\"-verbose\",\"some info\",\"hello\",\"world\"};\n      cmd = new DefaultParser();\n        CommandLine cline = null;\n        \n     try{\n        \n        cline  = cmd.parse(opts,strargs);\n        System.out.println(\"\\nOPTIONS : \");\n       \n            \n       Iterator itr = cline.getOptionNames().iterator();\n    \n      while(itr.hasNext()){\n          String optName =  itr.next().toString();\n          System.out.println(optName + \":\"+cline.getOptionValue(optName));\n             \n      }\n          System.out.println(\"\\nARGUMENTS: \");\n       if(cline.getArgList().size()>0 ){\n       \n        Iterator argItr = cline.getArgList().iterator();\n          \n        \n        while(argItr.hasNext()){\n               System.out.println((String)argItr.next());\n        \n        }\n         \n       }\n        \n       }catch(Exception exp){\n         System.out.println(exp.getMessage());\n       }\n        }\n}",
