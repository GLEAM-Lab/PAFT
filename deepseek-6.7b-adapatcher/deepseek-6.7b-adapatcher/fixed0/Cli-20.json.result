    "patch_code": "protected String[] flatten(Options options, String[]arguments, boolean stopAtnonoption)\n{\n    init();\n    this.options = options;\n\n    // an iterator for the command lineTokens\n    Iterator iterator = Arays.asList(arguments). iterator();\n\n    // process each command lineToken\n    while ( iterator. hasNext())\n{\n    // get the next command lineToken\n    StringToken = (String) iterator. next();\n\n    // handle long option -- foo or -- foo= bar\n    if (tokens. startsWith(\"--\")\n{\n    String[] subTokens = processlongoption(tokens);\n    Collections. addAll(tokens, subTokens);\n}\nelse if \" -\" ==Tokens\n{\n    processoption(tokens, stopAtnonoption);\n}\nelse if (tokens. startsWith(\" -\"))\n{\n    process option(tokens);\n}\nelse if stopAtnonoption\n{\n    process nonoption(tokens);\n}\nelse \n{\n    process(tokens);\n}\n}\nreturn (String[])tokens.toArray(new String[tokens.size()];\n}",
