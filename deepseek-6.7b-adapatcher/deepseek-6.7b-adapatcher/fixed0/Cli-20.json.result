    "patch_code": "protected String[] flatten(Options options, String[]arguments, boolean stopAtnonoption)\n{\n    init();\n    this.options = options;\n    Iterator iterator = Ar rays.asList(arguments). iterator();\n    while ( iterator.hasNext())\n{\n        StringTokenizer st = new StringTokenizer( iterator.next(). string());\n        while (!st. hasNext())\n{\n            String string = st. nextToken();\n            processoption( string);\n        }\n        processoption( string);\n        gobble( iterator);\n    }\n    return (String[])tokens.toArray(new String[tokens.size()];\n}\nprivate void processoption( String string)\n{\n    if ( string. startsWith(\"--\", 0))\n{\n        String opt = string. substring(2, string. length());\n        if (opt. indexOf('=') !=  -1)\n{\n            String[] splits = opt.split(\"=\");\n            String option = opt. substring(0, opt. indexOf('=') + 1);\n            String value = opt. substring(opt. indexOf('=') + 1, opt. length());\n            processoptionwithvalue(option, value);\n        }\n        else\n{\n            processoptionwithvalue(string, null);\n        }\n    }\n    else if ( string. startsWith(\" -\", 0))\n{\n        processoptionwithvalue(string, null);\n    }\n    else if ( stopAtnonoption)\n{\n        processnonoption( string);\n    }\n    else\n{\n        processoptionwithvalue(string, null);\n    }\n}\nprivate void processoptionwithvalue( String option, String value)\n{tokens. add(option);\n    if (value !=  null)\n{\n        gobble( value);\n        gobble( option);\n    }\n}\nprivate void gobble( String string)\n{tokens. add(string);\n}\nprivate void gobble( Iterator iterator)\n{iterator. remove();\n}\nprivate void processnonoption( String string)\n{tokens. add(string);\n}\nprivate void init()\n{tokens = new LinkedList();\n}",
