    "patch_code": "import java.util.*;\npublic class Main {\n  public static void main(String[] args){\n      List<String> list = new ArrayList<>(Arrays.asList(\"--zop\",\"-abfoo\"));\n      \n      List<String> result = process(list);\n        \n      System.out.println(result);\n  }\n  \n  private static List<String> process(List<String> dataList){\n     List<String> retList = new ArrayList<>();\n       \n    for(int i = 0 ;i <dataList.size();i++){\n         \n         String item = dataList.get(i);\n          \n         if(item.startsWith(\"--\") && !retList.contains(item)){\n             \n             int indexOfEqual = item.indexOf('=');\n                 \n             if(indexOfEqual != -1){\n                 retList.addAll(Arrays.asList(item.substring(0,indexOfEqual),item.substring(indexOfEqual+1)));\n                 \n                 continue;\n             }else{\n                 retList.add(item);\n             }\n         }else if(!retList.contains(item)&& item.startsWith(\"-\")){\n             if(item.length()==2){\n                 retList.add(item);\n             }else{\n                 char[] cahrItem = item.toCharArray();\n                     \n                 for(char c :cahrItem){\n                     retList.add(String.valueOf(c));\n                 }\n             }\n         }else{\n             retList.add(item);\n         }\n     }\n    return retList;\n  }\n  \n}",
