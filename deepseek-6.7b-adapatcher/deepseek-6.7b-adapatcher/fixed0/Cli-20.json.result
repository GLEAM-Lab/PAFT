    "patch_code": "protected String[] flatten(Options options, String[] arguments, boolean stopAtNonOption)\n{\n    init();\n    this.options = options;\n\n    // an iterator for the command line tokens\n    Iterator<String> iter = Arrays.asList(arguments).iterator();\n\n    // process each command line token\n    while (iter.hasNext())\n    {\n        // get the next command line token\n        String token = iter.next();\n\n        // handle long option --foo or --foo=bar\n        if (token.startsWith(\"--\"))\n        {\n            if (token.contains(\"=\") && token.indexOf('=') != 2 )\n            {\n                tokens.add(token.substring(0, token.indexOf('=')));\n                tokens.add(token.substring(token.indexOf('=') + 1));\n            }\n            else if (!options.hasLongOpt(token.substring(2))) \n            {\n                tokens.add(token);\n                 gobble(iter);\n                continue;\n            \n            }\n            else\n            {\n                tokens.add(token);\n            }\n        }\n\n        // single hyphen\n        else if (\"-\".equals(token))\n        {\n            tokens.add(token);\n        }\n        else if (token.startsWith(\"-\"))\n        {\n            if (token.length() > 2) \n            {\n                List<String> subTokens = new ArrayList<>();\n                for (int i = 1 ; i < token.length() ; i ++)\n                    subTokens.add(Character.toString(token.charAt(i)));\n               for (String subToken : subTokens){\n                   if (options.hasOption(subToken)){\n                        tokens.add(\"-\" + subToken);\n                   }else if (stopAtNonOption){\n                       iter = Arrays.asList(new String[]{token}).iterator();\n                       break;\n                   }else{\n                       tokens.add(token);\n                   }\n                    \n                }\n                 \n                  gobble(iter);\n                continue;\n            }\n          \n         \n            \n        }\n        else if (stopAtNonOption)\n        {\n            tokens.add(token);\n           gobble(iter);\n            continue;\n        }\n        else\n        {\n            tokens.add(token);\n        }\n         gobble(iter);\n    }\n\n    return (String[]) tokens.toArray(new String[tokens.size()]);\n}\nprivate void gobble(Iterator iter){\n    if(iter.hasNext()){\n       iter.next();\n    }\n}",
