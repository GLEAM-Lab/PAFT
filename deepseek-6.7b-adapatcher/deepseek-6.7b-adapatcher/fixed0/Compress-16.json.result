    "patch_code": "import java.io.*;\npublic class Main{\n  public static void main(String []args){\n     File f=new File(\"/path/to/file\");\n     byte[] s=new byte[(int)f.length()];\n     try{\n       FileInputStream fis=new FileInputStream(f);\n       fis.read(s);\n       fis.close();\n     }catch(FileNotFoundException fnfe){\n       System.out.println(\"FILE NOT FOUND\");\n     }catch(IOException ioe){\n       System.out.println(\"ERROR READING THE FILE\");\n     }finally{\n       \n         for(int x=0;x<s.length;x++){\n           boolean flag=true;\n           for(int y=0;y<Main.hexesToBytes().length;y++){\n             if(s[x]==Main.hexesToBytes()[y])flag=false;break;\n           }\n           if(!flag){\n              System.out.print((char)s[x]);\n           }else{\n             break;\n           }\n         }\n         \n       \n     \n       \n     }\n  \n  }\n public static byte[] hexesToBytes(){\n  String hexDigits = \"0123456789abcdef\";\n  byte[] bytes = new byte[hexDigits.length()];\n  for (int i = 0; i < hexDigits.length(); i++) {\n    bytes[i] = (byte)Character.digit(hexDigits.charAt(i), 16);\n  }\n   return bytes;\n  \n }\n  \n  \n  \n  \n}",
