    "patch_code": "protected void iterateSimplify() {\n\n    while true {\n\n        inc iterations counter ;\n\n        final real point value pair[] original = simplex ;\n        final real point value pair best = original[0] ;\n\n        final real point value pair reflexion =evaluate new simplex ( original , 1 , comparator) ;\n        if comparator. Compare (reflexion , best ) <0){\n            final real point value pair[] reflexion simplex = simplex ;\n            final real point value pair expand =evaluate new simplex ( original , khi , comparator) ;\n            if comparator. Compare (reflexion , expand) <0){\n                simplex = reflexion simplex ;\n            }\n            return ;\n        }\n        final real point value pair contracted =evaluate new simplex ( original , gamma , comparator) ;\n        if comparator.Compare (contracted , best ) <0){\n            simplex = contracted ;\n            return ;\n        }\n\n        if comparator.Compare ( best , reflexion ) <0}{\n            return ;\n        }\n\n        final real point value pair[] new simplex = new real point value pair[] ;\n        new simplex[0] = best ;\n        new simplex[1] = reflexion ;\n        final real point value pair[] other = new real point value pair[] ;\n        final int maxindex = find max index in simplex ;\n        final real point value pair[] other = new real point value pair[] ;\n        other[0] = simplex[maxindex] ;\n        other[1] = Reflexion ;\n        final int minindex = find min index in other ;\n        final real point value pair[] new simplex = new real point value pair[] ;\n        new simplex[0] = best ;\n        new simplex[1] = Reflexion ;\n        new simplex[2] = other[minindex] ;\n    }\n    \n}",
