    "patch_code": "protected void iterateSimplices( final Comparator comparator )\n    \n    while ( true ) {\n    \n        inc iterations counter ;\n        \n        final real point value pair[] original = simplicial ;\n        final real point value pair best = original[0] ;\n        \n        final real point value pair reflection =evaluate new Simplices( original , 1.0 , comparator ) ;\n        if comparator . Compare( reflection , best ) <= 0 then return ;\n        \n        final real point value pair[] reflectedSimplicial = simplicial ;\n        final real point value pair expands =evaluate new Simplices( original , khi , comparator ) ;\n        if comparator . Compare( reflection , expands ) <= 0 then\n            simplicial = reflectedSimplicial ;\n            continue ;\n            \n        final real point value pair contracted =evaluate new Simplices( original , gamma , comparator ) ;\n        if comparator . Compare( contracted , best ) <= 0 then\n            simplicial = contracted ;\n            continue ;\n            \n        return ;\n        \n    }\n    \n}",
