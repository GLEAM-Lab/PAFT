    "patch_code": "private void normalise(Element element) {\n    List<Node> toMove = new ArrayList<Node>();\n    for (int i = 0; i < element.childNodesSize(); i++) {\n        Node node = element.childNode(i);\n        if (node instanceof TextNode) {\n            TextNode tn = (TextNode) node;\n            if (!tn.isBlank())\n                toMove.add(tn);\n        } else {\n            normalise((Element) node); \n        }\n    }\n\n    for (Node node: toMove) {\n        int index = element.indexOfChild(node);\n        element.removeChild(node);\n        element.insertChild(index, new TextNode(\" \", \"\"));\n        element.insertChild(index + 1, node);\n    }\n}",
