    "patch_code": "private void normalise(Element element) {\n    List<Node> toRemove = new ArrayList<>();\n    StringBuilder stringBuffer = null;\n    \n    for (int i = 0; i < element.childNodesSize(); i++){\n        \n        Node childNode = element.childNode(i);\n        // Remove blank lines \n        if (childNode instanceof TextNode && ((TextNode) childNode).getWholeText() == null || ((TextNode) childNode).getWholeText().trim().isEmpty() ){\n            toRemove.add(childNode);\n        }else if(stringBuffer != null && childNode instanceof TextNode) {\n            \n            String sTmp1 = ((TextNode) childNode).wholeText();\n            \n            stringBuffer.append(((TextNode) childNode).wholeText());\n            ((TextNode) childNode).setWholeText(null);\n            \n            toRemove.add(childNode);\n            \n            continue;\n        }\n        else if(childNode instanceof Element){\n            \n            stringBuffer = new StringBuilder();\n            normalise((Element) childNode);\n            \n        }\n     \n    }\n    \n    \n    for(Node n :toRemove){\n        element.removeChild(n);\n    }\n   if(element instanceof Document.OutputSettings) {\n           \n       return ;\n   } \n    \n   String txtVal = element.wholeText();\n   if(!(txtVal==null||txtVal.trim().length()==0)) {\n          \n       appendRecursive(body(), new TextNode(txtVal));\n      \n   }\n\n\n}\n\n private static final class TextNode extends LeafNode implements InheritanceBoundaryMarker, Browsable {\n       \n       \n          private transient Attributes attributes = new Attributes();\n       \n       \n          public TextNode(String name) {\n              super(name);\n          }\n\n          public TextNode(String wholeText, String baseUri) {\n              super(baseUri);\n              this.wholeTextr = Utils.escapeHtml(wholeText);\n          }\n\n        \n          @Override\n        \n        public TextNode clone() {\n              TextNode node = new TextNode(getName());\n              node.attributes.cloneMe(attributes);\n              return node;\n          }\n\n         \n        \n        public boolean isBlank() {\n              return wholeText == null || wholeText.trim().equals(\"\");\n          }\n      \n    }",
