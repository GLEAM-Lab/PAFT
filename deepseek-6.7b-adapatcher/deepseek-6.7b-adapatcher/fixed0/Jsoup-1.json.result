    "patch_code": "import org.jsoup.*;\nimport org.jsoup.nodes.*;\nimport org.jsoup.parser.*;\nimport java.util.*;\n\npublic class Main{\n\npublic static String htmlToText(String input){\n    StringBuilder result= new StringBuilder(); \n\n    Queue<Token> tokenize = Tokenizer.tokenize(input);\n    \n    while(!tokenize.isEmpty()){\n        \n        Token temp= tokenize.poll();\n        \n        if(temp==null || !result.toString().equals(\"\") ){\n            \n           if(temp.type() == Token.TokenType.TAG_START){\n               result.insert(0,\" \");\n           }else if(temp.type() == Token.TokenType.TEXT){\n               result.insert(0,temp.getWholeAttribute());  \n            }else if(temp.type() == Token.TokenType.COMMENT){\n                 continue ;\n            }else if(temp.normalisedText().startsWith(\"script\")||temp.normalisedText().startsWith(\"style\")){\n                  continue ;\n            } else if(temp.normalisedText().contains(\"/body\")&& temp.normalisedText().contains(\"/html\")){\n                 break ;\n            } \n            \n          }\n     \n    \n        }\n       return result.toString().trim();\n    }\n}\npublic static void main(String[] args){\n\n        System.out.print(\"\\\"\"+htmlToText(\"foo <b>bar</b> baz\") +\"\\\"\");\n}\n}",
