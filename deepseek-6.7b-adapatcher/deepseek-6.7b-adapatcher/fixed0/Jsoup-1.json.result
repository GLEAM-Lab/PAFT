    "patch_code": "// src/main/java/org/jsoup/nodes/Document.java\nprivate String getText() {\n     StringBuilder buffer = new StringBuilder();\n    traverseTextNodes(0, buffer);\n    return buffer.toString();\n}\n\npublic void setData(int startPos, int endPos, String data) {\n    throw new UnsupportedOperationException();\n}\n\npublic Element appendData(int insertAt, String data) {\n    throw new UnsupportedOperationException();\n}\n\nprotected void output(Appendable accum) throws IOException {\n    throw new UnsupportedOperationException();\n}\n\n/**\n * Traverses all the child nodes of an element in order, appending textual data as it comes across it. \n */\nprivate boolean traverseTextNodes(int depth, Appendable accum) throws IOException {\n  \n     // Check each direct children until leaf node found or cycle detected\n    if ((depth & Node.WHITESPACE_NODE_MASK) != Node.ELEMENT_NODE) {\n        if (depth == Node.TEXT_NODE) {\n            String text = this.wholeText();\n         accum.append(text);\n        } else { // WS_CDATA_SECTION_NODE etc.,\n          accum.append(' ');\n        }\n     \n       // Return false because we've reached a terminal condition\n        return false;\n    }\n    Element el = (Element)this;\n   // Else recurse through all children\n    for (Node c : el.childNodes()) {\n      // Continue until a terminal condition encountered (leaf node or cycle detected)\n       if (c.traverseTextNodes(el.hasKey(c.attrKey()), accum)) {\n          continue;\n       } else if(!c.hasKey(c.attrKey())){\n           accum.append(\"\\n\");\n       }\n    }\n    return true;\n}",
