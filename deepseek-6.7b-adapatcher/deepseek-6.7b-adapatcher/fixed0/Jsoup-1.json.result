    "patch_code": "private void normalise(Element element) {\n    List<Node> to move = newArrayList();\n    List<Node> text node = newArrayList();\n    List<Node> other node = newArrayList();\n    for (Node node: element. childNode) {\n        if (node instanceOf textnode) {\n            text node. add((text node);\n        } else if (node instanceOf element) {\n            normalise((element node);\n        } else {\n            other node. add((node);\n        }\n    }\n    for (node in other node) {\n        element. removechild(node);\n    }\n    for (node in text node) {\n        element. removechild(node);\n    }\n    for (node in text node) {\n        element.appendchild(new textnode(\"\", node. text());\n    }\n}",
