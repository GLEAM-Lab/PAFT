    "patch_code": "private boolean canInline(\n    References decls,\n    References initls,\n    References refs) {\n  if !is valid decls or !is valid initls or !is valid refs: return false;\n  if decls != initls and !initls.get parent().is expr result: return false;\n  if decls.get basic block != initls.get basic block or decls.get basic block != refs.get basic block: return false;\n  if initls.get Assigned value is not null and initls.get Assigned value is not div: return false;\n  if refs.get parent().is call and refs.get parent().get first child != refs.get node: return false;\n  if refs.get parent().is get prop and refs.get parent().get first child != refs.get node: return false;\n  if refs.get value is div and refs.get parent().is call and refs.get parent().get first child != refs.get node: return false;\n  if refs.get value is div: return can move easily;\n  if refs.get parent().is call and refs.get parent().get first child == refs.get node: return can move Moderately;\n  if refs.get parent().is get prop and refs.get parent().get first child == refs.get node: return can move Moderately;\n  if refs.get parent().is call and refs.get parent().get first child != refs.get node: return can move modulatedly;\n  if refs.get parent().is get prop and refs.get parent().get first child != refs.get node: return can move modulatedly;\n}",
