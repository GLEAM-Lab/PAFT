    "patch_code": "private boolean canInline(\n    ReferencesDeclaration decls,\n    References initialization,\n    References reference) {\n  if (!is validDeclaration( decls)\n      || !is valid initializion( initialization)\n      || !is valid reference( reference)) {\n    return false;\n  }\n\n  //If the values are read more than once, the values are not allowed to be\n  // moved around. \n  if ( decls != initialization &&\n      !is expr result( initialization.get value())) {\n    return false;\n  }\n\n  //be very consious and do no cross control structure or\n  // cross scopb leboundary\n  if ( decls.get basic block() != initialization.get basic block()\n       decls.get basic block() != reference.get basic block()) {\n    return false;\n  }\n\n  //do not cross control structure or cross scopb leboundary\n  if ( decls.get basic block() != initialization.get basic block()\n       decls.get basic block() != reference.get basic block()) {\n    return false;\n  }\n\n  return can move aggressively( decls.get value())\n      or can move Moderately( decls, reference);\n}",
