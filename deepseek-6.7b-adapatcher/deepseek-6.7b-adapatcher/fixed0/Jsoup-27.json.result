    "patch_code": "import java.util.regex.*;\nimport java.nio.charset.*;\nimport java.lang.IllegalArgumentException;\n\nstatic String getCharsetFromContentType(String contentType) throws IllegalArgumentException{\n    if (contentType == null) throw new IllegalArgumentException(\"Input can not be null\");\n    Matcher m = charsetPattern.matcher(contentType);\n    if (!m.find() || m.groupCount() < 1 ) throw new IllegalArgumentException(\"Invalid Content Type Header:\"+ contentType + \". No valid character set found.\");\n    \n        String charset = m.group(1).trim();\n        charset = charset.toUpperCase(Locale.ENGLISH);\n       try {\n         Charset.forName(charset);\n          return charset;  \n       }catch(UnsupportedCharsetException ex) {throw new IllegalArgumentException(\"Unable to support this Character set:\"+ex.getMessage());}\n    \n      //else throw new IllegalArgumentException(\"Invalid Content Type Header:\"+ contentType + \". Unknown charset found.\"+ charSet);\n    \n}",
