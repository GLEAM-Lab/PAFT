    "patch_code": "static String getCharsetFromContentType(String contentType) throws UnsupportedEncodingException {\n    if (contentType == null) return null;\n    Pattern p = Pattern.compile(\"charset=([^;]+)\", Pattern.CASE_INSENSITIVE);\n    Matcher m = p.matcher(contentType);\n    while(m.find()){\n    \t\n      try{\n         String charset = m.group(1).trim();\n         Charset.forName(charset);  \n         return charset;\n       }catch(IllegalArgumentException ex){\n          //Invalid charset name or unsupported charset, continue\n       } \n        \n    }\n\n    throw new UnsupportedEncodingException (\"No valid charsets found!\");\n}",
