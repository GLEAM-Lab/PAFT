  {
    "patch_code": "public static String getCharsetFromContentType(String contentType) {\n    if (contentType == null || contentType.equals(\"\")) {\n        return null;\n    }\n    \n    String lowercaseContentType = contentType.toLowerCase(Locale.ENGLISH); // convert to lowercase\n    \n    int startIndex = lowercaseContentType.indexOf(\"charset=\") + \"charset=\".length();\n    \n    // no charset parameter found\n    if(startIndex == 0){\n         return null;\n     }\n     \n    int endIndex = lowercaseContentType.length();\n      \n    for(int i = startIndex ;i<endIndex;i++){\n        char currentCharacter = contentType.charAt(i);\n        // end of the charset name\n        if(currentCharacter==';'||currentCharacter== ' '||currentCharacter=='(' ){\n            endIndex=i;\n             break;\n          }  \n    }\n    if(endIndex==startIndex){\n        return null;\n    }\n    String charsetName = contentType.substring(startIndex, endIndex).trim().replaceAll(\"\\\\s\", \"\");\n    \n    charsetName = charsetName.toUpperCase(Locale.ENGLISH);\n    \n    boolean isSupported=Charset.isSupported(charsetName);\n    if (!isSupported){\n         return null;\n    }\n\n    return charsetName;\n}",
