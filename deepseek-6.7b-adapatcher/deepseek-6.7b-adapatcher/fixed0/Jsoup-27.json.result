  {
    "patch_code": "import java.util.regex.*;\npublic class Main {\n   static Pattern charsetPattern;\n    static {\n       // \u4fee\u6b63\n      charsetPattern = Pattern.compile(\"charset\\\\s*=\\\\s*([a-zA-Z0-9\\\\-\\\\_\\\\,]+)\",Pattern.CASE_INSENSITIVE );\n  }\n  static String getCharsetFromContentType(String contentType) throws UnsupportedCharsetException {\n    if (contentType == null) return null;\n    Matcher m = charsetPattern.matcher(contentType);\n    if (!m.find()) {\n         throw new UnsupportedCharsetException(\"Can't find any charset declaration inside Content-Type Header\");\n     }\n    \n    String charset = m.group(1).trim();\n    charset = charset.replaceAll(\"\\\\s\",\"\").toLowerCase(Locale.ENGLISH);\n    boolean isSupported = false;\n    for(String s : java.nio.charset.Charset.availableCharsets().keySet() ){\n            if(charshet.equalsIgnoreCase(s)){\n                isSupported = true;\n                break;\n           }\n    }\n    if(!isSupported){\n         throw new UnsupportedCharsetException (\"No JDK support for \" + charset +\" char encoding \");\n    }else{\n         return charset;\n    }\n}\n public static void main(String[] args) {\n try{\n  System.out.println(getCharsetFromContentType(\"Content-type: text/html; charset=UFT8\"));\n }catch (UnsupportedCharsetException e){\n  System.err.println(\"Error Message:\"+e.getMessage());\n }\n}\n}",
