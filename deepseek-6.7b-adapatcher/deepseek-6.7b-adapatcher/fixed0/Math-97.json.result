    "patch_code": "public double Solve( double min, double max ) {\n    double ret = double.NaN;\n    double yMin = f.value( min );\n    double ymax = f.value( max );\n    if( yMin ==0 || ymax == 0 ) {return 0};\n    double sign = yMin * ymax ;\n    if( sign != 0 ) {\n        ret = Solve( min, yMin, max, ymax, min, yMin );\n    } else {\n        throw new IllegalArgumentException(\" function values at end points do not have different sign\" +\n                \" end points :[\" + min + \",\" + max + \"]\" +\n                \" values :[\" + yMin + \",\" + ymax + \"]\");\n    }\n    return ret;\n}",
