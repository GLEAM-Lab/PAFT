    "patch_code": "public double solver( double min, double max) {\n    double ret = double.NaN;\n    \n    double yMin = f.value(min);\n    double ymax = f.value(max);\n    \n    double sign = yMin * ymax;\n    if ( sign > 0 ) {\n        throw new IllegalArgumentException(\"function values at end points are same sign\");\n    } else if ( sign == 0 ) {\n        ret = 0;\n    } else {\n        ret = solver(min, yMin, max, ymax, min, yMin);\n        ret = ret + min;\n    }\n    return ret;\n}",
