    "patch_code": "import java.util.*;\nclass Solution {\n    static class TernaryTreeNode {\n        int data;\n        TernaryTreeNode left, mid, right;\n        boolean flag=true;\n    }\n    public void insert(TernaryTreeNode node,int data){\n        if(node.data<data){\n            if(node.right==null){\n                node.right=new TernaryTreeNode();\n                node.right.data=data;\n            }else{\n                insert(node.right,data);\n            }\n        }else if(node.data>data){\n            if(node.left==null){\n                node.left=new TernaryTreeNode();\n                node.left.data=data;\n            }else{\n                insert(node.left,data);\n            }\n        }else{\n            if(node.mid!=null){\n                insert(node.mid,data);\n            }else{\n                node.mid=new TernaryTreeNode();\n                node.mid.data=data;\n            }\n        }\n    }\n    \n\n    public List<Integer> findAll(TernaryTreeNode tree) {\n        ArrayList<Integer> list = new ArrayList<>();\n        Queue<TernaryTreeNode> queue = new LinkedList<>();\n        if (tree != null) {\n            queue.add(tree);\n        }\n        while (!queue.isEmpty()) {\n            TernaryTreeNode temp = queue.poll();\n            if(!temp.flag){\n                continue;\n            }\n            \n            if(tree.left!=null||tree.right!=null||tree.mid!=null){\n                if(tree.left!=null){\n                    queue.offer(tree.left);\n                    \n                }if(tree.right!=null){\n                    queue.offer(tree.right);\n                    \n                }if(tree.mid!=null){\n                    queue.offer(tree.mid);\n                }\n                \n            }\n            list.add(temp.data);\n        }\n        return list;\n    }\n\n    public static void main(String[] args) {\n       Scanner in=new Scanner(System.in);\n        TernaryTreeNode ttn=new TernaryTreeNode();\n        \n        String str=\"\";\n        try{\n            \n              for (;;) {\n                  if(!((str=in.nextLine()).equals(\"\"))){\n                      ttn.insert(ttn, Integer.parseInt(str));\n                  }\n               }\n           }catch (InputMismatchException e) {}\n        \n       \n        System.out.println(findAll(ttn));\n        \n    }\n}",
