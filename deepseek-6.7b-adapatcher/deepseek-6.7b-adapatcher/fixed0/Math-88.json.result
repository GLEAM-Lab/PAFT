    "patch_code": "protected real pointValuePair getSolution() {\n    double[] result = new double[getOriginalnum Decisionvariables()];\n    int basicrow = get basicrow(get num Objective functions() + get originalnum Decisionvariables());\n    double most negative = basic row null? 0 : tableau.get entry( basicrow, rgs);\n    for (int i = 0; i < result.length; i++) {\n        basicrow = get basicrow(get num objectives() + i);\n        result[i] = basic row null? 0 : tableau.get entry( basicrow, rgs) - ( restrict to non negative? 0 : most negative);\n        if ( basic row null? \n            for (int j = get num objectives(); j < get num objectives() + i; j++) {\n                if ( tableau.get entry( basicrow, j) == 1) {result[i] = 0; break;\n                }\n            }\n    }\n    return new real pointvalue pair(result, f. get value(result));\n}",
