  {
    "patch_code": "protected RealPointValuePair getSolution() {\n    double[] coefficients = new double[getOriginalNumDecisionVariables()];\n    Integer basicRow =\n        getBasicRow(getNumObjectiveFunctions() + getOriginalNumDecisionVariables());\n    Double mostNegative = null;\n    if (basicRow != null){\n        mostNegative = getEntry(basicRow, getRhsOffset());\n    }\n    \n    for (int i = 0; i < coefficients.length; i++) {\n        basicRow = getBasicRow(getNumObjectiveFunctions() + i);\n        if ((mostNegative == null && restrictToNonNegative ) ||  (!restrictToNonNegative)) {\n            if (basicRow == null) {\n                coefficients[i]= 0;\n            } else {\n                 coefficients[i]= getEntry(basicRow, getRhsOffset()) ;\n                 \n            }  \n        } else if (mostNegative != null && restrictToNonNegative) {\n           coefficients[i] = mostNegative < 0 ? -mostNegative : 0;\n            \n        } else {\n            coefficients[i]= 0; \n        \n        }\n         \n       if (basicRow != null) {\n            for (int j = getNumObjectiveFunctions(); j <= getNumObjectiveFunctions()+i ; j++) {\n                if (j== basicRow) {\n                    continue;\n                }else if(getEntry(j, i)!= 1){\n                    coefficients[i]= 0;\n                      break;\n                }\n            }\n        }\n     \n    }\n\n    return new RealPointValuePair(coefficients, f.getValue(coefficients));\n}",
