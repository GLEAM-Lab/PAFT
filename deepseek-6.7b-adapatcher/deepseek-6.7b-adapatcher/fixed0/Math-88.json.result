  {
    "patch_code": "protected RealPointValuePair getSolution() {\n    double[] coefficients = new double[getOriginalNumDecisionVariables()];\n    int numObjVars = getNumObjectiveFunctions();\n    Integer basicRow ;\n    boolean hasChanged;\n    \n    do{\n        hasChanged=false;\n        for (int i = 0; i < coefficients.length; i++) {\n            \n            basicRow = getBasicRow(numObjVars + i);\n            \n            if (basicRow == null) continue;  \n          \n            double temp = Math.max(-getEntry(basicRow, getRhsOffset()), 0 );\n        \n            if (!Arrays.equals(coefficients,new double[numObjVars])){\n                for (int k = 0; k< coefficients.length;k++){\n                    if (temp==coefficients[k])\n                        coefficients[k]=0;\n                }\n                \n            }else{ Arrays.fill(coefficients, Double.NEGATIVE_INFINITY);}\n             \n              \n      \n            coefficients[i] += (-getEntry(basicRow, getRhsOffset())+ restrictToNonNegative ? 0 : temp);\n        \n            \n            for (int j = numObjVars; j < numObjVars + i; j++) {\n         \n                if (Math.abs(tableau.getEntry(basicRow, j)) > 1e-5) {\n                 \n                     coefficients[i] = 0;\n                     \n                    break;\n                }\n            }\n           \n        }\n    }while(hasChanged);\n   \n    return new RealPointValuePair(coefficients, f.getValue(coefficients));\n}",
