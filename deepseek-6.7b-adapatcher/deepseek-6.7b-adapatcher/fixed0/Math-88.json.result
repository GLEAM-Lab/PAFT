  {
    "patch_code": "protected RealPointValuePair getSolution() {\n    double[] coefficients = new double[getOriginalNumDecisionVariables()];\n    List<Integer> basicRows = getBasicRows();\n    int rhsOffset = getRhsOffset();\n    for (int variableIndex = 0; variableIndex < getOriginalNumDecisionVariables(); variableIndex ++) {\n        boolean findOneInRow = false;\n        double sum = 0;\n        for (int rowIndex = 0; rowIndex <= getRowSize() - 2; rowIndex ++) {\n             if (!findOneInRow && basicRows.contains(rowIndex)) {\n                 sum += getEntry(rowIndex, rhsOffset);\n                 break;\n             } else if (getEntry(rowIndex, variableIndex + getNumObjectiveFunctions()) > 0) {\n                 sum += getEntry(rowIndex, rhsOffset);\n                 findOneInRow = true;\n             }\n         }\n         if (!findOneInRow) {\n             coefficients[variableIndex] = 0;\n         } else {\n             coefficients[variableIndex] = -sum;\n         }\n     }\n     double[] finalCoefficients = Arrays.copyOfRange(coefficients, 0, getNumObjectiveFunctions() + getOriginalNumDecisionVariables());\n     return new RealPointValuePair(finalCoefficients, f.getValue(coefficients));\n}",
