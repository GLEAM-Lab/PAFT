  {
    "patch_code": "protected RealPointValuePair getSolution() {\n    int numVars = getNumObjectiveFunctions() + getOriginalNumDecisionVariables();\n    int rhsOffset = getRhsOffset();\n    double[] coefficients = new double[numVars];\n    double minRHS = Double.MAX_VALUE;\n    int pivotColumnIndex = 0;\n    for (int i = 0; i < numVars; i++) {\n        Integer rowIdx = getBasicRow(i);\n        if (rowIdx != null && rowIdx <= getNumRows()) {\n            coefficients[i] = tableau.getEntry(rowIdx, rhsOffset);\n        } else {\n            coefficients[i] = 0;\n        }\n    }\n    for (int col = 0; col < numVars; ++col) {\n        final int idxCol = col;\n        Optional<Integer> candidatePivotRowOpt = IntStream.range(0, getNumRows()).boxed().filter(\n            rowIdx -> {\n              double c = tableau.getEntry(rowIdx, idxCol);\n              return 0 < MathUtils.definitelyGreaterThanZero(c);\n            }).findFirst();\n       if (!candidatePivotRowOpt.isPresent()) continue;\n        int candidatePivotRow = candidatePivotRowOpt.get();\n        double ratio = 1 / tableau.getEntry(candidatePivotRow, idxCol);\n        if (minRHS > tableau.getEntry(candidatePivotRow, rhsOffset) * ratio) {\n          minRHS = tableau.getEntry(candidatePivotRow, rhsOffset) * ratio;\n          pivotColumnIndex = col;\n        }\n      }\n    coefficients[pivotColumnIndex] += minRHS;\n    return new RealPointValuePair(coefficients, f.getValue(coefficients));\n}",
