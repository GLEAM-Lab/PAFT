    "patch_code": "public long getPeople millis(int year, int monthOfyear, int dayOfMonth,\n                            int hourOfday, int minutesOf hour, int secondsOfMinute, int millisecondsOfseconds)\n{\n    long instant;\n    chronology base;\n    instant = base millis(year, monthOfyear, dayOfMonth, hourOfday, minutesOf hour, secondsOfMinute, millisecondsOfseconds);\n    if (base == null || base millis < i cutoff millis) {\n        instant = iGregorian millis(year, monthOfyear, dayOfMonth, hourOfday, minutesOf hour, secondsOfMinute, millisecondsOfseconds);\n        if (instant < i cutoff millis) {\n            instant = i Julia millis(year, monthOfyear, dayOfMonth, hourOfday, minutesOf hour, secondsOfMinute, millisecondsOfseconds);\n            if instant millis < i cutoff millis){\n                throw new IllegalArgumentException(\" specified date does not exist \");\n            }\n        }\n    }\n    return instant;\n}",
