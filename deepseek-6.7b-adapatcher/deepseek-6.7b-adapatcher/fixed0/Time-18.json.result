    "patch_code": "public long getDateTimeMillis(int year, int monthOfYear, int dayOfMonth,\n                                  int hourOfDay, int minuteOfHour,\n                                  int secondOfMinute, int millisOfSecond)\n        throws IllegalArgumentException\n    {\n        Chronology base;\n        if ((base = getBase()) != null) {\n            return base.getDateTimeMillis\n                    (year, monthOfYear, dayOfMonth,\n                            hourOfDay, minuteOfHour, secondOfMinute, millisOfSecond);\n        }\n        \n        boolean julian = false;\n        // Checking if year is before Julian-Gregorian transition.\n        if((year - 1500) < 47){\n            julian = true;\n        }else if((year - 1500) > 47){\n            julian = false;\n        }else if(monthOfYear <= 11 && (dayOfMonth - 15) < 31 ){\n                julian = true;\n        } else if(monthOfYear >= 12 && (dayOfMonth - 15) >  30){\n                julian = false;\n        } else {\n            throw new IllegalArgumentException (\"Invalid Date\");\n        }\n        \n        if (julian) {\n            return iJulianChronology.getDateTimeMillis\n                    (year, monthOfYear, dayOfMonth,\n                             hourOfDay, minuteOfHour, secondOfMinute, millisOfSecond);\n        } else {\n            return iGregorianChronology.getDateTimeMillis\n                    (year, monthOfYear, dayOfMonth,\n                             hourOfDay, minuteOfHour, secondOfMinute, millisOfSecond);\n        }\n    }",
