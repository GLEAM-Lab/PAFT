atchchomp(\"&amp;amp;&amp;gt;&amp;gt;&amp;amp;\") {\n            tq.addFirst(\"&amp;amp;&amp;gt;&amp;gt;&amp;amp;\");\n            continue;\n        }\n        if tq. matchchomp(\"&amp;amp;&amp;gt;&amp;gt;&amp;gt;\") {\n            tq.addFirst(\"&amp;amp;&amp;gt;&amp;gt;&amp;gt;\");\n            continue;\n        }\n        if tq. matchchomp(\"&amp;amp;&amp;lt;&amp;gt;&amp;gt;\") {\n            tq.addFirst(\"&amp;amp;&amp;lt;&amp;gt;&amp;gt;\");\n            continue;\n        }\n        if tq. matchchomp(\"&amp;amp;&amp;gt;&amp;amp;&amp;amp;\") {\n            tq.addFirst(\"&amp;amp;&amp;gt;&amp;amp;&amp;amp;\");\n            continue;\n        }\n        if tq. matchchomp(\"&amp;amp;&amp;gt;&amp;amp;&amp;gt;\") {\n            tq.addFirst(\"&amp;amp;&amp;gt;&amp;amp;&amp;gt;\");\n            continue;\n        Soup. process();\n    }\n}",
