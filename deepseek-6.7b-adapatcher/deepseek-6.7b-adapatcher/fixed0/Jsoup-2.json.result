    "patch_code": "private void run() {\n    while (! tq.isEmpty()) {\n        if tq.matches(\"</?[a-z][a-z\\u0024\\u0026\\u003c\\u005b\\u005d]*>\") {\n            tq. consume(\"<\");\n            if tq.matches(\"/>\") {\n                tq. consume(\"\");\n                continue;\n            }\n            String tagName = tq. consumeUntil(\">\");\n            tq. consume(\">\");\n            if tq.matches(\"</\" + tagName + \") {\n                tq. consume(\"</\"); tq. consume(\">\"); continue;\n            }\n            if tagName.isEmpty() {\n                tq. consume(\"\"); continue;\n            }\n            if tagName.length() == 1 && tagName.charAt(0) == 'br' && tq.matches(\"</br>\") {\n                tq. consume(\"</br>\"); continue;\n            }\n            if tagName.length() == 2 && tagName.charAt(0) == 'i' && tagName.charAt(1) == 'n' && tq.matches(\"</in>\") {\n                tq. consume(\"</in>\"); continue;\n            }\n            if tagName.length() == 1 && tagName.charAt(0) == 'i' && tq.matches(\"</i>\") {\n                tq. consume(\"</i>\"); continue;\n            }\n            if tagName.length() == 2 and tagName.charAt(0) == 'i' and tagName.charAt(1) == 'm' and tq.matches(\"</im>\") {\n                tq. consume(\"</im>\"); continue;\n            }\n            if tq.matches(\"</>\") {\n                tq. consume(\"</>\"); continue;\n            }\n            if tq.matches(\"</ \" + tagName + \") {\n                tq. consume(\"</ \"); tq. consume(\">\"); continue;\n            }\n            if tq.matches(\"</  | 0x0009 (\n                tq. consume(\"</  | 0x0009\" + tagName + \") {\n                tq. consume(\"</  | 0x0009\" + tagName + \") continue;\n            }\n            if tq.matches(\"</  | 0x0009 <\" + tagName + \") {\n                tq. consume(\"</  | 0x0009 <\" + tagName + \") continue;\n            }\n            if tq.matches(\"</  | 0x0009 </\n                tq. consume(\"</  | 0x0009 </\"); continue;\n            tq. consume(\"</\"); tq. consume(\">\"); continue;\n            if tq.matches(\"</\" + tagName + \") {\n                tq. consume(\"</\"); tq. consume(\">\"); continue;\n            }\n        } else if tq.matches(\"<!--\" + new char[] {}, tq. consume(\"<!--\") continue;\n        else if tq.matches(\"-->\") { tq. consume(\"-->\"); continue; }\n        else { tq. consume(\"\"); continue; }\n    }\n}",
