    "patch_code": "else { // Chunk of input that looks like normal text / shouldn't go into script\n                int nextOpeningBracket = buffer.indexOf('<');\n                int nextClosingBracket = Math.max(buffer.lastIndexOf(\"</\"), buffer.lastIndexOf(\"<\\\\\"));\n                if (nextOpeningBracket == -1 && nextClosingBracket == -1) {\n                    break;\n                } else if ((nextOpeningBracket > -1 && nextOpeningBracket <= pos + 3) || \n                           (nextClosingBracket > -1 && nextClosingBracket <= pos + 4)) {  \n                    continue;\n                } else if (pos > nextOpeningBracket) { \n                    queueInputToBeProcessedLater();\n                    currentTokenEnd = nextOpeningBracket;\n                    continue PARSE_TAGS;\n                }\n                Token token = peekLastQueuedTokenIfPossible();\n                if (token != null && token instanceof EndTagToken && token.toString().equalsIgnoreCase(\"script\")) {\n                    Token poppedToken = tokenQueue.remove(tokenQueue.size() - 1);\n                    queuedTokensAreDirty = true;\n                    currentTokenEnd++;\n                    queueNextAvailableToken();\n                    continue PARSE_TAGS;\n                }\n            }",
