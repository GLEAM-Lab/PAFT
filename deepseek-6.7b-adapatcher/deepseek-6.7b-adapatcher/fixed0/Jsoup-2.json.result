    "patch_code": "public class Html {\n     public static String fixScriptError(String htmlCode) {\n         int i = 0;\n         char[] c = htmlCode.toCharArray();\n         \n          for (; i < c.length - 1; i++) {\n              if ((c[i] == 's') && (c[i + 1] == 'c')) {\n                  c[i+2] = 'r';\n                  c[i+3] = 'i';\n                  c[i+4] = 'p';\n                  c[i+5] = 't';\n                  \n              } else if((c[i] == 's') && (c[i + 1] == 'y')){\n                 c[i+2] = 'n';\n                  c[i+3] = 'a';\n                  c[i+4] = 'm';\n                 \n               } else if ((c[i] == 'b') && (c[i + 1] == 'o')) {\n                  c[i+2] = 'd';\n                     \n               }\n           }\n           return new String(c).replace(\" />\",\"></\").replace(\"/body>\",\"</body>\").replace(\"</body>\",\"</html>\");\n       }\n}",
