  {
    "patch_code": "public T[] sample(int sampleSize) throws NotStrictlyPositiveException {\n    if (sampleSize <= 0) {\n        throw new NotStrictlyPositiveException(LocalizedFormats.NUMBER_OF_SAMPLES,\n                sampleSize);\n    }\n\n    List<T> tempSingletonCache = Lists.newArrayList();\n    \n    Class<? extends T> cacheType = null;\n    for (final Triplet<String, String, Object> triplet : distribution) {\n      try {\n        final double value = ((Number) triplet.getValue()).doubleValue();\n        if (value > 0) {\n          int times = (int) Math.floor(value * sampleSize); \n          \n          // get the class of objects in singletons and store it into cacheType variable\n          if (cacheType == null){\n            cacheType = (Class<? extends T>) triplet.getFirst().getClass();\n          }\n          \n          // fill up temporary singleton cache with objects according to their frequency\n          IntStream.rangeClosed(0, times).forEach(idx -> {\n            tempSingletonCache.add((T)triplet.getFirst());\n          });\n        }\n        \n      } catch (final ArithmeticException e) {\n        // Value too large, downscale\n        long tmpVal = Math.round(value * sampleSize);\n        IntStream.rangeClosed(0, (int)tmpVal).forEach(idx -> {\n          tempSingletonCache.add((T)triplet.getFirst());\n        });\n      }\n      \n    }\n  \n    final RandomDataGenerator randGen = new RandomDataGenerator();\n    while (tempSingletonCache.size() < sampleSize) {\n      tempSingletonCache.add(randGen.nextUniform(0, 1) < 0.5 ?\n              randomSingleton() : singleton());\n    }\n    \n    Collections.shuffle(tempSingletonCache, random);\n    \n    @SuppressWarnings(\"unchecked\")\n    final T[] out = (T[]) java.lang.reflect.Array.newInstance(cacheType , sampleSize);\n    \n    // fill up output array from temporary singleton cache\n    IntStream.range(0, sampleSize).forEach(idx -> {\n      out[idx] = tempSingletonCache.get(idx);\n    });\n\n    return out;\n\n}",
