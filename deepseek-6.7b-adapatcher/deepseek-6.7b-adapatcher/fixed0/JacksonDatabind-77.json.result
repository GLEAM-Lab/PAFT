    "patch_code": "@Override\npublic JsonDeserializer<Object> createBeanDeserializer(DeserializationContext ctxt,\n        JavaType type, BeanDescription beanDesc)\nthrows JsonMappingException\n{\n    final DeserializationConfig config = ctxt.getConfig();\n    Class<?> rawCls = type.getRawClass();\n\n     /* If rawCls was erased prior to this method being called (as would happen in serialization), there's nothing we can do about it.\n      * It's best we simply return NULL since we couldn't determine real class of object to deserialize\n      */\n    if(rawCls == null){\n        throw new IllegalArgumentException(\"Can not handle abstract class without any information\");\n     }\n\n   // Your logic here ...\n}",
