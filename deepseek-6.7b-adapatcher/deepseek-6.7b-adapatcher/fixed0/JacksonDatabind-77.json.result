    "patch_code": "package com.fasterxml.jackson.databind.deser;\n\nimport java.io.IOException;\n\nimport org.springframework.security.access.method.P;\n\nimport com.fasterxml.jackson.annotation.JacksonAnnotation;\nimport com.fasterxml.jackson.core.JsonParser;\nimport com.fasterxml.jackson.databind.*;\nimport com.fasterxml.jackson.databind.cfg.DeserializerConfig;\nimport com.sun.org.apache.xalan.internal.utils.XSLStylesheetImpl;\n\npublic class CustomBeanDeserializer extends StdDeserializer<Object> {\n    \n   private static final long serialVersionUID = 1L;\n     \n     protected Class<?> _class;\n\n   public CustomBeanDeserializer(JavaType type){\n       this((Class<?>)type.getRawClass());\n   }\n\n   /**\n    * Constructor for use when deserializing object properties of specified class\n    */\n   public CustomBeanDeserializer(Class<?> cls) {\n       super(cls);\n       _class = cls;\n   }\n\n\n   \n}",
