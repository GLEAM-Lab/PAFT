    "patch_code": "import com.fasterxml.jackson.core.JsonParser;\nimport com.fasterxml.jackson.databind.*;\nimport java.io.IOException;\n\npublic class CustomDeserializer extends JsonDeserializer<Object> {\n    \nprivate final String propertyName;\n    \n    public CustomDeserializer(String name){\n       this.propertyName = name;\n   }\n\n    @Override\n    public Object deserialize(JsonParser jsonparser, DeserializationContext context)\n      throws IOException, JsonProcessingException {\n        \n      ObjectCodec oc = jsonparser.getCodec();\n      JsonNode node = oc.readTree(jsonparser);\n      \n      try {\n          if (node == null || node.toString().trim().isEmpty()) {\n              return null;\n          }\n          \n          Class<? extends Enum> enumClass = \n             (Class<Enum>) ((ParameterizedType) getClass().getGenericSuperclass()).getActualTypeArguments()[0];\n          \n          return Enum.valueOf(enumClass, node.asText());\n      } catch (Exception e) {\n          throw new RuntimeException(e);\n      }\n  }\n}",
    "patch_status": "UNCOMPILABLE",
