    "patch_code": "import java.util.*;\npublic class Main {\n    public static void main(String[] args){\n        MySet ms1=new MySet();\n        ms1.add(\"A\");\n        MySet ms2=ms1.myClone();\n        System.out.println(ms2);\n        ms1.add(\"B\");\n        System.out.println(ms1);\n        System.out.println(ms2);\n        \n    }\n    \n}\nclass MySet extends HashSet{\n    public MySet myClone(){\n        MySet temp=new MySet();\n        Iterator it=this.iterator();\n        while(it.hasNext()){\n            temp.add(it.next());\n        }\n        return temp;\n    }\n}",
