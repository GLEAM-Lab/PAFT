    "patch_code": "import org.jsoup.nodes.*;\n\nimport java.util.*;\n\npublic class Main{\n\n  public static void main(String[] args){\n      \n      Document doc1 = Jsoup.parse(\"<html><body><div id=\\\"testId\\\">Test Content <span>Span content</span><br><i>Italic text</i><a href=\\\"https://www.google.com\\\">Google Link</a><img src=\\\"https://www.google.com\\\"/></div><div id=\\\"testDivClone\\\"><h3>Test h3</h3><b>Bold text</b><hr/><button type=\\\"submit\\\">Submit</button></div><input name=\\\"testInputNameClone\\\" value=\\\"Test Input Value Clone\\\"/><textarea name=\\\"testTextAreaNameClone\\\">Test Text Area Value Clone</textarea><select name=\\\"testSelectNameClone\\\"><option>Option one Test</option><option>Option two Test</option></select><label for=\\\"testLabelForClone\\\">Test Label for attribute</label><fieldset><legend>FieldSet Test Legend</legend><form action=\\\"#\\\" target=\\\"_blank\\\"> <label>Test Form label <input type=\\\"radio\\\" name=\\\"testRadioNameClone\\\"></label></form><script src=\\\"https://www.googletest.com\\\"></script><noscript>No script support test</noscript><style>div { color : blue }</style></fieldset><table border=\\\"10\\\" cellpadding=\\\"20\\\" cellspacing=\\\"5\\\"><thead><tr><th>TH Head 1</th><th>TH Head 2</th><th>TH Head 3</th></tr></thead><tbody><tr><td colspan=\\\"2\\\" rowspan=\\\"3\\\">Cell Content Col span 2, Row span 3</td></tr><tr><td align=\\\"center\\\" valign=\\\"top\\\">Td Cell Content</td></tr><tfoot><tr><td>TF td cell Content Footer One</td><td>TF td cell Content Footer Two</td></tr></tfoot></table></body></html>\");\n        Element body = doc1.body();\n          Element divClone =  ((Element) body.getElementById(\"testId\")).clone();\n          \n         System.out.println(((Element) body.getElementById(\"testId\")).classNames());\n           \n           System.out.println(divClone.classNames());\n            \n        }\n    \n    \n    static class Element extends Node{\n        private ArrayList<Node> classNames = new ArrayList<>();\n        \n        @Override\n        public Element clone(){\n          try{\n              Element c = (Element)super.clone();\n              \n              if(c.getClass().equals(this.getClass())){\n                  c.classNames = (ArrayList<Node>) this.classNames.clone();  \n              }else{\n                  c.classNames = new ArrayList<>();\n              }\n              \n              return c;\n          }catch (CloneNotSupportedException e){\n              throw new AssertionError();\n          }\n        }\n    }\n}",
