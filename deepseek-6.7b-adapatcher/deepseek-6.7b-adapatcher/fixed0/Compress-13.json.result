  {
    "patch_code": "public class ApacheCompressWorkaround implements PreArchiveInputStreamFactory {\n\n    public static final String DEFAULT_ENCODING = \"ISO-8859-1\";\n    private boolean forceDisableUnicodeFlag; // workaround until Commons Compress gets fixed\n    \n    @Override\n    public InputStream createArchiveInputStream(final ArchiveStreamFactory factory,\n                                               final InputStream archiveStream) throws IOException {\n        if (!forceDisableUnicodeFlag && ((WinZipDecryptingFileSystemLocator)factory.getLocator()).requiresUnicodeConversion()) {\n            return new UnicodeForcedWinZipInputStream(archiveStream);\n        } else {\n            return factory.createArchiveInputStream(archiveStream);\n        }\n    }\n    \n    /**\n     * An implementation of {@link WinZipEncodingStrategy}, ensuring we always process the archive as LATIN-1 regardless of the UNICODE flag being present or absent in the central directory.\n     */\n    protected static final class ForceLatin1Strategy extends AbstractUnicodeStrategy {\n        \n        public ForceLatin1Strategy() {\n            super(\"CP437\");  \n        }\n        \n        @Override\n        public boolean shouldConvert(String entryName) {\n            return !entryName.equalsIgnoreCase(\"\");\n        }\n\n    }\n    \n    /**\n     * A wrapper around a normal ZipArchiveInputStream that forces its content to be interpreted in Latin-1 even if the UNICODE conversion flag was enabled in the Central Directory header.\n     */\n    protected static final class UnicodeForcedWinZipInputStream extends FilterInputStream {\n        \n        public UnicodeForcedWinZipInputStream(InputStream delegate) {\n            super(delegate);\n        }\n        \n        @Override\n        public int read() throws IOException {\n            return getIn().read(); // this stream just passes through any bytes it reads from the underlying stream\n        }\n\n        @Override\n        public int read(byte[] b) throws IOException {\n            return getIn().read(b); // ditto\n        }\n        \n        @Override\n        public int read(byte[] b, int off, int len) throws IOException {\n            return getIn().read(b, off, len); // ditto\n        }\n    }\n}",
