    "patch_code": "protected void setName(String name) {\n     if (!isDirectory()) {\n          int index = name.lastIndexOf('/');\n          String subdirPath = null;\n          if (index != -1 && index != name.length() - 1) {\n               subdirPath = name.substring(0, index);\n          }\n          if (subdirPath != null) {\n               // The entry is inside another directory, let's check it out\n              try {\n                   Path path = FileSystems.defaultProvider().getPath(subdirPath);\n                    Files.createDirectories(path);\n                } catch (IOException ex) {\n                     LOGGER.warn(\"Error while trying to create \" + subdirPath, ex);\n                 }\n            }\n        }\n      this.name = name;\n   }",
