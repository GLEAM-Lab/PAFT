    "patch_code": "/**\n * Sets the name of this entry. This method should NOT be used directly because it may lead to invalid zip files if one tries to use backslash characters ('\\') even though they represent the path separator character '/'. Instead, please use {@link org.apache.commons.compress.archivers.zip.ZipArchiveEntry#setName(java.io.File)} or {@link org.apache.commons.compress.archivers.zip.ZipArchiveEntry#setName(java.lang.String)}.\n * @param name The new name for this entry. Must not be null.\n */\nprotected void setName(String name) {\n    int i = 0;\n    while ((i < name.length()) && (name.charAt(i) != '\\\\')){\n        i++;\n     }\n    if(i == name.length()){\n        throw new IllegalArgumentException(\"Please don't use backslash(\\\\) as your filename\");\n    }else{\n       String beforeStr = name.substring(0,i);\n       String afterStr  = name.substring(i+1);\n       this.name = beforeStr + \"/\" +afterStr;\n    }\n}",
    "patch_status": "TRIGGER_ERROR",
