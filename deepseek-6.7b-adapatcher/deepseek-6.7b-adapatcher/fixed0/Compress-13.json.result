    "patch_code": "private String sanitize(String s) {\n    return s.replace('\\\\', '/');\n}\n\npublic ZipArchiveInputStream(InputStream in) throws IOException {\n        super(new org.tukaani.zip.ZipFile(in), null);\n    }\n    \npublic ArchiveEntry getNextEntry() throws IOException {\n        if (!is || isClosed) {\n            throw new IllegalStateException(\"Attempted to read from closed stream\");\n        }\n        \n        final org.tukaani.zip.ZipEntry entry = zis.getNextEntry();\n        if (entry == null) {\n            close();\n            return null;\n        }\n        \n        return new ZipArchiveEntry(this, sanitize(entry.getName()), entry.getCompressedSize(), entry.getSize());\n    }\n\n    private static class org_tukaani_zip_ZipFile extends ZipFile implements Closeable {\n        org_tukaani_zip_ZipFile(final InputStream in) throws IOException {\n            super(in);\n        }\n\n        @Override\n        public void close() throws IOException {\n            tryClose();\n        }\n    }",
