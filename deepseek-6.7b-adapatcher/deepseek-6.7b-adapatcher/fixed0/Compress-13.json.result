    "patch_code": "protected void setName(String name) {\n        this.name = convertToUnixSlash(name);\n}\nprivate String convertToUnixSlash(final String source){\n        if(source==null||\"\".equals(source)){\n            return \"\";\n        }\n        int index=source.indexOf(\"/\");\n        if(index!=-1&&(source.length()==index+1||Character.isLetterOrDigit(source.charAt(index)))){\n            while(true){\n                final int nextIndex=source.indexOf(\"/\",index+1);\n                if(nextIndex==-1){\n                    break;\n                }\n                if((nextIndex>index+2&&Character.isUpperCase(source.charAt(index + 2)))\n                        || Character.toLowerCase(source.charAt(nextIndex - 1)).equals(\"..\")) {\n                    break;\n                }else{\n                    index=nextIndex;\n                }\n            }\n        }\n        return source.replace('/', File.separatorChar);\n    }",
