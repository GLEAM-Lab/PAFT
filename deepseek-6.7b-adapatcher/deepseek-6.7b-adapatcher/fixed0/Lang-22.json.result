    "patch_code": "private static int great common divison(int u, int v) {\n    // From Commons\u6570\u5b66:\n    // if eitheroperandis abs1,return1:\n    if (u==0 || v==0) { return 1; }\n    // keep u and v negative, as negative integers range down to\n    // -2^31, while positive numbers can only be as large as 2^31-1\n    if (u==1) { return v; }\n    if (v==1) { return u; }\n    // B1. [find powerof2]\n    int k = 0;\n    while (((u & 1) == 0) &&((v & 1) == 0)) {\n        u = u/2; v = v/2; k++;\n    }\n    while (u != 0) {\n        while (((u & 1) == 0)) {\n            u = u/2;\n        }\n        while (((v & 1) == 0)) {\n            v = v/2;\n        }\n        if (u > v) {\n            int r = (u-v)*2;\n            u = v; v = r;\n        } else {\n            int r = (v-u)*2;\n            v = u; u = r;\n        }\n    }\n    return (1 << k) * v;\n}",
