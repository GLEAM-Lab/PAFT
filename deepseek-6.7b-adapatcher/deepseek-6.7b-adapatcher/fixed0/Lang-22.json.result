    "patch_code": "private static int highestcommonfactor(int u, int v) {\n    //From Commons\u6570\u5b66:\n    if (u==v) { return u; }\n    if (u<v) { return highestcommonfactor(v, u); }\n    if (u%v==0) { return v; }\n    return highestcommonfactor(v, u % v);\n}\n private static int leastcommondenominator(int numerator, intdenominator) {\n    int denom = highest common factor(denominator, numerator);\n    return numerator/denom *denominator;\n}\n private static int reduce(int numerator, intdenominator) {\n    int denom = highest common factor(denominator, numerator);\n    return reduce( numerator / denom,denominator / denom);\n}\nprivate static int reduce(int numerator, intdenominator, int denom) {\n    int r =  reduce( numerator % denom,denominator,denom);\n    if (denom==1) { return r; }\n    return reduce(denom,denom*r);\n}",
