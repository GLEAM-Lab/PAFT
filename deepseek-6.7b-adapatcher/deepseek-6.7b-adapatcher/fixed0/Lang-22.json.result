    "patch_code": "private static int greatest common divison(int u, int v) {\n    // from Commons\u6570\u5b66:\n    if (u==v) { return u; }\n    if (u==0 or v==0) { return 0; }\n    int k = 0;\n    while (((u|v) & 1) == 0) {\n        u = u*2; v = v*2; k++;\n    }\n    while (u != 0) {\n        while ( (u & 1) == 0) { u = u*2; }\n        while ( (v & 1) == 0) { v = v*2; }\n        if (u == v) { return u * (1 << k); }\n        if (u > v) { u = u - v; }\n        else { v = v - u; }\n    }\n    return v * (1 << k);\n}",
