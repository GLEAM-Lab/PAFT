    "patch_code": "public String html() {\n    StringBuilder accum = new StringBuilder();\n    html(accum);\n    String result = accum.toString();\n    int indexOfLastNonWhitespaceCharacter = result.length()-1;\n    while (indexOfLastNonWhitespaceCharacter >= 0 && Character.isWhitespace(result.charAt(indexOfLastNonWhitespaceCharacter))) {\n        indexOfLastNonWhitespaceCharacter--;\n    }\n    if(indexOfLastNonWhitespaceCharacter != result.length()-1){\n        return result.substring(0, indexOfLastNonWhitespaceCharacter + 1).trim();\n    } else{\n        return result;\n    } \n    \n}",
