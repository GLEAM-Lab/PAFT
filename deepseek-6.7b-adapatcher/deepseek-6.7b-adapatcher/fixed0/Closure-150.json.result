  {
    "patch_code": "@Override public void visit(NodeTraversal t, Node n, Node parent) {\n  if (n == scope.getRootNode()) return;\n  \n  attachLiteralTypes(n);\n  \n  switch (n.getType()) {\n    case Token.LP:\n      if (parent.getType() == Token.FUNCTION) {\n        handleFunctionInputs(parent);\n      } else {\n        t.traverseDown(); // skip parsing this block for now\n      }\n      break;\n    case Token.THIS:\n      if (!context.isInNonStrictMode()) {\n        report(\"'this' must be called in a method.\", parent);\n      }\n      break;\n    case Token.FUNCTION:\n      if (parent.getType() != Token.NAME || context.isInArrowKeywordContext()) {\n        return;\n      }\n      defineDeclaredFunction(n, parent);\n      break;\n    case Token.CATCH:\n      defineCatch(n, parent);\n      break;\n    case Token.VAR:\n      defineVar(n, parent);\n      break;\n    default:\n      if (n instanceof NameExpression && ((NameExpression) n).refersToVariable() && context.shouldGenerateExistenceChecks()) {\n        String name = ((NameExpression) n).getName();\n        \n        if (!scope.hasBinding(name)) {\n          reportWarning(\"Uninitialized variable: \\\"\" + name + \"\\\", did you forget to initialise it?\");\n        }\n      }\n      break;\n  }\n}",
