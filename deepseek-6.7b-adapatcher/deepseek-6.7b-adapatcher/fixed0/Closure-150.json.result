    "patch_code": "@Override public void visit(Node traversee,Node parent){\n  if (traversee==null || !traversee.hasnode()) return;\n\n  if (traversee.getType() == Token.FUNction){\n    define declares function(traversee);\n    return;\n  }\n\n  if (traversee.getType() == Token. LP){\n    define declares function(parent);\n    return;\n  }\n\n  if (traversee.getType() == Token.PARAM){\n    define declares function(parent);\n  }\n}",
