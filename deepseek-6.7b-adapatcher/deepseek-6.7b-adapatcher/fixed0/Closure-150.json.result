    "patch_code": "public class TypedScopeCreator extends ScopeCreator {\nprivate static final boolean DEBUG = false;\n\nprivate String functionName_;\nprotected boolean hasReturnStatement_ = true;\n\nstatic class VisitorAdapter implements ScopeVisitor<Object> {\n  private final HashMap<AstNode, List<String>> varInfoListCache = new HashMap<>();\n  \n  @Nullable @Override\n  protected Object defaultAction(AstNode node, ScopedDescriber scope, int depth) {\n    if (!scope.isClosure() && DEBUG && depth == 0) {\n      System.out.println(\"default action\");\n    }\n    List<String> infoList = getOrCreateVariableInfoList(node, varInfoListCache, scope, depth);\n    \n    if (infoList != null) {\n      for (String name : infoList) {\n        AstNode varExpr = new NameImpl(name, node.getLineNumber(), false);\n        AstPath path = AstPathUtil.createSimplePath(node);\n        scope.addScopedChild(path, varExpr);\n      }\n    }\n    return super.defaultAction(node, scope, depth);\n  }\n}\n\nprivate VisitorAdapter visitorAdapter = new VisitorAdapter();\n\n@Override\npublic FunctionScope createScopeForFunctionDeclaration(FunctionNode function, VarArgsAnalyzer analyzer) {\n  if (!shouldGenerate(function)) return new PassThroughFunctionScope(function);\n  \n  ScopedDescriber describer = new ScopedDescriber(function, this, /* closure */ false);\n  FunctionScope created = new TypedScope(describer, false);\n  visitedFunctions_.put(created, function);\n  analysisResults_.add(new AnalysisResult(AnalysisResult.ResultKind.SCOPE, function));\n  \n  functionName_ = function.getName().getValue();\n  \n  FunctionScope enclosingMethod = analyzedEnclosingMethods_.get(created);\n  if (enclosingMethod == null || !analyzedInlineConstructions_.containsKey(created)) {\n    hasReturnStatement_ = analyzeHasReturnStatements(function);\n  } else {\n    hasReturnStatement_ = false; // No return statements in method bodies.\n  }\n  \n  Utilities.traverseWithLimit(visitorAdapter, function, describer, Integer.MAX_VALUE - 1);\n  return created;\n}\n\n@Override public void postProcess(Compiler compiler) {\n  typedFunctionCallHandler_ = new TypedFunctionCallHandler(compiler.analysis());\n}\n\nprivate boolean shouldGenerate(FunctionNode function) {\n  return ((TypeScriptCompilerOptions)compiler.options()).typeInferenceEnabled();\n}\n}",
