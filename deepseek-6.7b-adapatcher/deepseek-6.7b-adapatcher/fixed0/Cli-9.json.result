  {
    "patch_code": "protected void checkRequiredOptions()\n    throws MissingOptionException\n{\n    // if there are required options that have not been\n    // processed\n    if (getRequiredOptions().size() > 0)\n    {\n        Iterator iter = getRequiredOptions().iterator();\n        StringBuffer buff = new StringBuffer(\"Missing required options:\");\n\n\n        // loop through the required options\n        while (iter.hasNext())\n        {\n            buff.append(' ');\n            String optName = (String) iter.next();\n            \n            // If the option name starts with a letter then add a dash before it according to CLI 1.1 specification\n            if (Character.isLetter(optName.charAt(0))) {\n              buff.append('-');\n            }\n            buff.append(optName);\n        }\n\n        throw new MissingOptionException(buff.toString());\n    }\n}",
    "patch_status": "TRIGGER_ERROR",
    "failing_tests": {
      "TRIGGER": [
        "org.apache.commons.cli.OptionsTest::testMissingOptionsException"
      ],
      "RELEVANT": [],
