    "patch_code": "protected void check requiredOptions ()\n    \n    {\n        if (get requiredOptions(). size() > 0)\n{\n            StringBuilder sb = new StringBuilder(\"missing required options: \");\n            List list = get requiredOptions();\n            for (int i = 0; i < list. size(); i++)\n{\n                String s = list. get(i);\n                sb.append((i == 0 ? \" -\" : \"\") + s);\n            }\n            throw new Missing option exception(sb.to string());\n        }\n    }",
