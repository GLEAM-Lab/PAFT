    "patch_code": "protected void check required options ()\n     protected void check required options ()\n{\n    // if there are required options that have not been\n    // processed\n    if (get required options (). size () > 0)\n    {\n        Iterator iter = get required options (). iterator () ;\n        StringBuilder buff = new StringBuilder(\"Missing required options: \");\n        buff.append(\"\\r\\n\");\n        \n        // loop through the required options\n        while (iter. has next())\n        {\n            buff.append(\" -\" + iter. next());\n            buff.append(\"\\r\\n\");\n            \n        }\n        buff.append(\"\\r\\n\");\n        \n        throw new Missing option exception (buff. toString());\n    }\n}",
