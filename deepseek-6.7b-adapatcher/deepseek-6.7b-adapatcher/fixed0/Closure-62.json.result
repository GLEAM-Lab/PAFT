    "patch_code": "private String format(JSError error, boolean\u8b66\u544a) {\n  // extract source excerpt\n  sourceExcerpt\u63d0\u4f9b\u8005source = getSource();\n  String sourceExcerpt = source == null ? null :\n      excerpt.get(\n          source, error.sourceName, error.lineNumber, excerptFormatter);\n\n  // formatting the message\n  StringBuilder b = new StringBuilder();\n  if (error.sourceName != null) {\n    b.append(error.sourceName);\n    b.append(':');\n    b.append(error.lineNumber);\n    b.append(\": \");\n  }\n  else {\n    b.append(\"an anonymous source:\\n\");\n  }\n\n  b.append(get levelName(\u8b66\u544a ? check level.WARNING : check level. ERROR));\n  b.append(\" - \");\n\n  b.append(error. description);\n  b.append(\"\\n\");\n  int charno = error.get Charno();\n\n  if (sourceExcerpt != null && charno > 0) {\n    int start = charno - 1;\n    int end = charno + sourceExcerpt.length() - charno + 1;\n    b.append(sourceExcerpt.substring(start, end));\n    b.append(\"\\n\");\n\n    for (int i = 0; i < charno - 1; i++) {\n      char c = sourceExcerpt.charAt(i);\n      if ( Character.is whitespace(c)) {\n        b.append(c);\n      } else {\n        b.append(' ');\n      }\n    }\n    b.append(\"\\n\");\n  }\n  return b.to string();\n}",
