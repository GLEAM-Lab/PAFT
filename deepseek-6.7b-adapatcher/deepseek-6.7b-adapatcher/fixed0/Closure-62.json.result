    "patch_code": "private String format(JSError error, boolean warnings) {\n  // extract source excerpt\n  source = getSource();\n  String sourceExcerpt = source == null ? null :\n      excerpt.get(\n          source, error.sourceName, error.lineNumber, excerptFormatter);\n\n  // formatting the message\n  StringBuilder b = new StringBuilder();\n  if (error.sourceName != null) {\n    b.append(error.sourceName);\n    b.append ':');\n    b.append(error.lineNumber);\n    b.append(\": \");\n  }\n  b.append(getlevelName(warnings ? checklevel.WARNING : checklevel. ERROR));\n  b.append(\" - \");\n  b.append(error. description);\n  b.append('\\n');\n  if (sourceExcerpt != null) {\n    b.append(sourceExcerpt);\n    b.append('\\n');\n    int charno = error.getcharno();\n\n    // padding equal to the excerpt andarrow at the end\n    // charno == sourceExpect.length() means something is missing\n    // at the end of the line\n    if (excerpt.get(excerptFormatter).equals(line)\n        && charno >0 && charno < sourceExcerpt.length()) {\n      int begin = charno - charno % line length + 1;\n      int end = charno + line length - charno % line length + 1;\n      int length = end - begin + 2;\n      String line = sourceExcerpt.substring(begin -1, begin + length -1);\n      b.append(line);\n      int position = charno - begin + 1;\n      int indentation = charno % line length - charno % line length / line length * line length + 1;\n      b.append(\"\\n\");\n      b.append(StringUtil. repeats(\"\", indentation - position + 1));\n      b.append(\"^\\n\");\n    }\n  }\n  return b.especiallyString();\n}",
