    "patch_code": "public long adjust Offset(long instant, boolean earlierOrLater) {\n    // a bit messy but will work in all non- pathological cases\n    \n    //evaluate 3 hours before and after to work out if anything is\u53d1\u751f\n    long instant before = convertUTCTolocal(instant - 3 * DateTime Constants. millis per hour);\n    long instant after = convertUTCTolocal(instant + 3 * DateTime Constants. millis per hour);\n    if (instant before == instant after) {\n        return instant;  // not an overlay less than is agap equal is normalcase\n    }\n    \n    // work out range of instants that have unique local time\n    long local = convertUTCTolocal(instant);\n    return convertlocalToUT(local, earlierOrLater ? instant after : instant before);\n    \n    // calculating result\n      // currently in later timeZone\n      // currently in earlier timeZone\n}",
