    "patch_code": "private long previousOffset(long time, int startHour, int endHour) {\n    int transitionYear = 2012;\n    for (; ; ) {\n        DateTimeZone zone = getInstance(transitionYear);\n        int length = zone.size();\n        int startIndex = length - 1;\n        while (startIndex >= 0 && (zone.getTransition(startIndex).getInstant() >= time || !zone.getOffset(startIndex).equals(offsetBefore))){\n            --startIndex;\n        }\n        ++startIndex;\n        if ((length > 1 && startIndex == 0) || \n                ((length > 2 && startIndex == 1) &&\n                 zone.getTransition(0).getOffset().equals(ZoneOffset.ofHoursMinutes(-4, 30)))){\n            ++transitionYear;\n            continue;\n        }\n        long earliestChange = Long.MAX_VALUE;\n        int earliestIndex = -1;\n        for (int i=0; i<length; ++i){\n            Transition t = zone.getTransition(i);\n            if (t.isGap()){\n                continue;\n            }\n            if (!t.getOffset().equals(offsetBefore)){\n                continue;\n            }\n            if (t.getInstant() < earliestChange){\n                earliestChange = t.getInstant();\n                earliestIndex = i;\n            }\n        }\n        assert(earliestIndex != -1);\n        if (!zone.getTransition(earliestIndex).isCrossing()){\n            break;\n        }\n        transitionYear += 1;\n    }\n    DateTimeZone zone = getInstance(transitionYear);\n    int index = zone.size() - 1;\n    for (; ; --index){\n        Transition t = zone.getTransition(index);\n        if (t.getInstant() <= time){\n            break;\n        }\n    }\n    return zone.getOffset(index).getTotalSeconds();\n}\n\npublic long previousOffsetInEffect(long time) {\n    time -= 1;\n    return max(previousOffset(time, 0, 23), previousOffset(time, 0, 0));\n}\n\npublic long nextOffsetInEffect(long time) {\n    return min(nextOffset(time, 0, 23), nextOffset(time, 0, 0));\n}\n\n@Override\npublic long getPreviousOffsetInEffect(long time) {\n    return previousOffsetInEffect(time);\n}\n\n@Override\npublic long getNextOffsetInEffect(long time) {\n    return nextOffsetInEffect(time);\n}",
