    "patch_code": "public long adjustOffset(long instant, boolean earlierOrLater) {\n    // a bit messy, but will work in all non-pathological cases\n    \n    // evaluate 3 hours before and after to work out if anything is happening\n    long instantBefore = convertUTCToLocal(instant - 3 * DateTimeConstants.MILLIS_PER_HOUR);\n    long instantAfter = convertUTCToLocal(instant + 3 * DateTimeConstants.MILLIS_PER_HOUR);\n    if (instantBefore != instantAfter) {\n        return instant;  // not an overlap (less than is a gap, equal is normal case)\n    }\n    \n    // work out range of instants that have duplicate local times\n    long startOfDay = LocalDateTimes.fromMillis(instantBefore).toLocalDate().toStandardDate().getMillis();\n    long endOfNextDay = startOfDay + TimeUtils.DAYS_TO_MILLIS[1];\n    long localEnd = convertUTCToLocal(endOfNextDay - 1);\n    \n    if (!earlierOrLater && instant >= localEnd){\n        // if requested time is already in the later offset, there's nothing else to do\n        return instant;  \n    }else if(earlierOrLater && instant < localEnd){\n         // if the requested time is within the earlier offset, there's nothing else to do\n         return instant;\n    }\n\n    long local = convertUTCToLocal(instant);\n    if(!earlierOrLater){\n        // in late offset mode, everything above localEnd is outside the current date range.  So, shift forward one day to get the \"next\" valid UTC instant\n       return instant + (endOfNextDay - local);\n    }else{\n          // in early offset mode, everything below localEnd is inside the current date range.  Shift backward one day to get the \"previous\" valid UTC instant.\n          \n         return instant - (local - startOfDay);\n    }\n      // currently in later offset\n      // currently in earlier offset\n}",
