    "patch_code": "public static long adjustOffset(long instant, int baseIndex, long[] baseValues, boolean earlierOrLater) {\n\n    /* A simple algorithm for calculating time zones' rules. This method was redefined in order to adapt \n       the bug occurring in the \"withLaterOffsetAtOverlap\" method due to an error in obtaining the overlapping\n       instant from the previous rule set */\n\n    // a bit messy, but will work in all non-pathological cases\n  \n    // evaluate 3 hours before and after to work out if anything is happening\n    long instantBefore = baseValues[baseIndex] - 3 * DateTimeConstants.MILLIS_PER_HOUR + baseValues[0];\n    long instantAfter = baseValues[baseIndex] + 3 * DateTimeConstants.MILLIS_PER_HOUR + baseValues[0];\n    if (instantBefore == instantAfter) {\n        return instant;  // not an overlap (less than is a gap, equal is normal case)\n    }\n    \n    // work out range of instants that have duplicate local times\n    long local = baseValues[baseIndex] + instant - baseValues[0];\n    if(earlierOrLater){\n        // currently in later offset\n        return baseValues[baseIndex]+local - DateTimeConstants.MILLIS_PER_DAY;\n        \n    }else{\n        // currently in earlier offset\n        return baseValues[baseIndex]+local ;\n    }\n}",
