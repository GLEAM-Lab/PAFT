    "patch_code": "/**\n * Returns a copy of this date-time with the offset adjusted for an overlap with another date-time.\n * When {@code earlierOffset == 0}, behaves identically to {@link #withEarlierOffsetAtOverlap}.\n * @param comparisonDateTime  the datetime to compare against\n * @return the adjusted date-time\n */\npublic org.joda.time.DateTime withLaterOffsetAtOverlap(org.joda.time.DateTime comparisonDateTime) {\n    int differenceInMinutes = getOffsetFromUtc(comparisonDateTime.getMillis()) / 60000;\n    if (differenceInMinutes != 0 && differenceInMinutes % 2 == 1) {\n        return plusMinutes(-differenceInMinutes);\n    } else {\n        return plusMinutes(1);\n    }\n}",
