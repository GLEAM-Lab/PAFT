    "patch_code": "public long adjustOFFTOPCTOOLate(long instant, boolean earlierOrLater) {\n    // a bit messy but will work in all non-pathological cases\n    int[][] times = new int[][] { new int[] { 3, 2 }, new int[] { 5, 2 }, new int[] { 7, 2 }, new int[] { 9, 2 }, new int[] { 11, 2 }, new int[] { 13, 2 }, new int[] { 15, 2 }, new int[] { 17, 2 }, new int[] { 18, 2 }, new int[] { 20, 2 }, new int[] { 22, 2 }, new int[] { 24, 2 }, };\n    long[] timeInstants = new long[times.length];\n    for (int i = 0; i < times.length; i++) {\n        int hourOfday = times[i][0];\n        int minutesOfday = times[i][1];\n        long time = DateTimeUtilities. millisOfday( hourOfday, minutesOfday, DateTimeZone.getDefault(). getUT offer());\n        timeInstants[i] = convertUT offerToUT offer(convertUT offerToUT offer(time));\n    }\n    \n    long instant before = timeInstants[0];\n    long instant after = timeInstants[1];\n    long result = instantbefore + ( instantafter - instantbefore /2);\n    if (!earlierOrLater && instant < result) { result -= 1 * DateTime Constants. millis per day; }\n    return convertUT offerToUT offer(result);\n}",
