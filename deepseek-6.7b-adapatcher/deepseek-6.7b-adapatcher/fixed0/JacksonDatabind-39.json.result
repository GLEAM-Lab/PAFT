    "patch_code": "public class NullifyingDeserializer extends StdScalarDeserializer<Object> {\n     private static final long serialVersionUID = 1L;\n     \n     protected NullifyingDeserializer(Class<Object> type) {\n         super(type);\n     }\n     \n    @Override\n    public Object deserialize(JsonParser p, DeserializationContext ctxt) throws IOException\n    {\n        JsonToken t = p.getCurrentToken();\n        switch (t) {\n           case START_OBJECT : {\n             p.nextToken();\n             break;\n          }\n          default : {\n               ctxt.handleUnexpectedToken(handledType(), p.getCurrentToken(),\n                     \"Invalid token in unwrapping value of Object\");\n               return null;\n         }  \n       } \n       try {\n         p.setCodec(ctxt.findRootValueSeparatorSerializer(p, handledType()));\n         return _parseAndClose(p, ctxt, null, null);\n       } finally {\n         p.setCodec(null);\n      }\n    }\n}",
