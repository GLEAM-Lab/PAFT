    "patch_code": "package com.fasterxml.jackson.databind.deser.std;\n\nimport java.io.IOException;\n\nimport com.fasterxml.jackson.core.*;\nimport com.fasterxml.jackson.databind.DeserializationContext;\n\npublic class NullifyingDeserializer extends StdScalarDeserializer<Object>\n{\n    private static final long serialVersionUID = 1L;\n    \n    protected NullifyingDeserializer() {\n        super(Object.class);\n    }\n\n    @Override\n    public Object deserialize(JsonParser p, DeserializationContext ctxt) throws IOException\n    {\n        if (!p.hasCurrentToken()) {\n            return null;\n        }\n        switch (p.getCurrentToken()) {\n        case VALUE_STRING:\n        case VALUE_NUMBER_INT:\n        case VALUE_NUMBER_FLOAT:\n        case VALUE_TRUE:\n        case VALUE_FALSE:\n        case VALUE_NULL:\n            break;\n        default:\n        \tif(!p.isExpectedStartArrayToken()) {\n        \t\tp.nextToken();\n        \t}\n            while ((p.getCurrentToken() == JsonToken.START_OBJECT || p.getCurrentToken()==JsonToken.FIELD_NAME|| p.getCurrentToken()==JsonToken.VALUE_EMBEDDED_OBJECT)) {\n            \tif(p.getCurrentToken() == JsonToken.START_OBJECT){\n                    try {\n                        p.nextToken();\n                    } catch (JsonParseException e) {\n                    \treturn null;\n                    }\n                }else {\n                \tp.nextField();\n                }  \n               if(p.getCurrentToken()==JsonToken.END_OBJECT) {\n                   p.nextToken();\n                  break;\n              }\n           }\n        }\n        return null;\n    }\n}",
