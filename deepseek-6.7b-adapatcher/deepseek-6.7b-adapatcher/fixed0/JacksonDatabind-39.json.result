    "patch_code": "public class NullifyingDeserializer extends StdScalarDeserializer<Object> {\n    private static final long serialVersionUID = 1L;\n\n    protected NullifyingDeserializer() {\n        super(null);\n    }\n\n    /*\n     /***********************************************\n     ***********************************************/\n\n    @Override\n    public Object deserialize(JsonParser p, DeserializationContext ctxt) throws IOException {\n        // Note: we are using raw exception handling here due to limitation in prior JDK versions\n        try {\n            /* Special case for 'null': handle separately since normal entry does\n             *  not make sense.\n             */\n            if (p.getCurrentToken() == JsonToken.VALUE_STRING) {\n                String value = _parser.getText();\n                if (\"null\".equalsIgnoreCase(value)) {\n                    return null;\n                }\n            }\n            /* If token represents start of object or array, go deeper:\n             * either get new content from stream, or just create new parser that points at same content\n             */\n            boolean handled = false;\n            if (_processContents != Processing.CONTENTS && p.hasCurrentToken()) {\n                switch (p.currentToken()) {\n                    case START_ARRAY:\n                        p = p.getCodec().createAndProcessObject(p);\n                        break;\n                    case START_OBJECT:\n                        p = p.getCodec().createAndProcessObject(p);\n                        break;\n                }\n                handled = true;\n            }\n            /* Regular objects and arrays just skip children.\n             */\n            if (!handled && p.isExpectedStartArrayToken() || p.isExpectedStartObjectToken()) {\n                while (true) {\n                    if (!p.nextValue(null)) {\n                        throw ctxt.wrongTokenException(p, JsonToken.END_ARRAY,\n                                \"No space available in output buffer when attempting to write field data.\");\n                    }\n                    if ((p.getCurrentToken() == JsonToken.END_ARRAY) || (p.getCurrentToken() == JsonToken.END_OBJECT)) {\n                        break;\n                    }\n                }\n                handled = true;\n            }\n            if (handled) {\n                return null;\n            }\n        } catch (Exception e) {\n            throw ctxt.wrap(e);\n        }\n        throw ctxt.mappingException(p.getCurrentName());\n    }\n}",
