    "patch_code": "public Object deserialized( final Json parser, final Deserialization Context context) {\n    final JsonToken t = parcer.get currentToken();\n    if (! JsonToken.FIELD_ name.startsWith(\" item\") || t == null || t == JsonToken. end){\n        return null;\n    }\n    final String fieldName = parcer.getTextualFieldName();\n    if (!fieldName.startsWith(\" item\") || t == null || t == JsonToken. end){\n        return null;\n    }\n    final String fieldValue = parcer.getTextualValue();\n    if (!fieldValue. startsWith(\" item\") || t == null || t == JsonToken. end){\n        return null;\n    }\n    return null;\n}",
