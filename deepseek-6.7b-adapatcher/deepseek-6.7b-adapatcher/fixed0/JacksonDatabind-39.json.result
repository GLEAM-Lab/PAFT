    "patch_code": "public abstract class NullifyingDeserializer<T> extends StdScalarDeserializer<T> {\n    private static final long serialVersionUID = 1L;\n    \n    protected NullifyingDeserializer(Class<?> valueType) {\n        super(valueType);\n    }\n    \n    @Override\n    public T deserialize(JsonParser p, DeserializationContext ctxt) throws IOException {\n        if (_handleNonNumericValues && (!p.isExpectedEndToken())) {\n           handleNonNumericValue(p);\n           return null;\n        } else if (_handleNonNumericValues) {\n          throw ctxt.mappingException(_valueType);\n       } else {\n          p.nextToken();\n      }\n       return null;\n   }\n}",
