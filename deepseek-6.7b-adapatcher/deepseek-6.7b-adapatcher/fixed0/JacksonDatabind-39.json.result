    "patch_code": "public Object deserialize( final Json\u89e3\u5668p, final DeserializationContext cntxt) throwIOException {\n    final Json\u89e3\u5668State state = p.getState();\n try {\n     return super.deserialize( p, cntxt);\n     state.setDeserializing( false);\n } finally { p. set state( state); }\n}",
