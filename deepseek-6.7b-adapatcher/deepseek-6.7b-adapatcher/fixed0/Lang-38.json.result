    "patch_code": "public StringBuffer format(Calendar calendar, StringBuffer buf) throws IllegalArgumentException, IndexOutOfBoundsException {\n    if (!this.mTimeZoneForced && null == mLocale || null != calendar.getTimeZone()) {\n      throw new IllegalArgumentException(\"FastDateFormat needs either no specified timezone or the same one as the formatter\");\n    }\n  \n    if (mTimeZoneForced) {\n        calendar = (Calendar) calendar.clone();\n        calendar.setTimeZone(mTimeZone);\n    }\n    \n    return applyRules(calendar, buf);\n}",
