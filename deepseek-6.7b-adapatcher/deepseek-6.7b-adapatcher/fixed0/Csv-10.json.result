    "patch_code": "public class HeaderFixCSVPrinter extends CSVPrinter{\n\n  private boolean didPrintHeader = false;\n  \n\tpublic HeaderFixCSVPrinter(Appendable out, CSVFormat format) throws IOException {\n\t\tsuper(out, format);\n\t}\n  \n\t@Override\n\tpublic void printRecord(List<String> values) throws IOException {\n        ensureOpen();\n\t\t\n\t    if (!didPrintHeader && getCurrentLine() == 0L) {\n\t        for (Iterator<String> iterator = getHeaderIterators().iterator(); iterator.hasNext();){\n                String s = iterator.next();\n    \t\t\tif (s == null || s.isEmpty()) {\n    \t\t\t\ts = \"\";\n    \t\t\t} else {\n    \t\t\t\twrite(format.getStringDelimiter());\n    \t\t\t}\n    \t\t\twrite(s);\n            }\n      \t\tdidPrintHeader = true;\n        }\n        \n\t\tsuper.printRecord(values);\n\t}\n\n\t@Override\n\tpublic void flush(){\n\t\ttry{\n\t\t\tsuper.flush();\n\t\t}catch(IOException e){\n\t\t\tthrow new RuntimeException(e);\n\t\t}\n\t}\n\n\t@Override\n\tpublic void close() throws IOException{\n\t\ttry{\n\t\t\tsuper.close();\n\t\t}finally{\n\t\t\tout = null;\n\t\t}\n\t}\n\n\tprivate Iterable<String> getHeaderIterators(){\n\t\treturn () -> new Iterator<String>(){\n\t\t\tint index = 0;\n      List<String> headers = HeaderFixCSVPrinter.this.format.getHeaders();\n      \n\t\t\t@Override public boolean hasNext(){ return index < headers.size(); }\n\t\t\t@Override public String next(){ return headers.get(index++); }\n\t\t};\n\t}\n}",
