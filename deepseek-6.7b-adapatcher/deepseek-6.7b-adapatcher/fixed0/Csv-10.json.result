    "patch_code": "// In the repair version (src/main/java/org/apache/commons/csv/CSVPrinter.java), we create a new class that extends the original class, adding a new feature\npublic abstract class NewCSVPrinter extends CSVPrinter {\n    \n    private String[] headers;\n\n    public NewCSVPrinter(Appendable out, CSVFormat format) throws IOException {\n        super(out, format);\n    }\n\n    @Override\n    public void flush() throws IOException {\n        getOut().flush();\n    }\n\n    /**\n     * Sets the record number for printing methods. The default is 0 - no special prefixes or postfixes\n     */\n    protected int recordNumber = 0;\n\n    public void setRecordNumber(int recordNumber) {\n        this.recordNumber = recordNumber;\n    }\n\n    public int getRecordNumber() {\n        return recordNumber;\n    }\n\n    public boolean hasHeaders(){\n        return headers != null && headers.length > 0;\n    }\n    \n    public CSVPrinter withHeader(String... headers){\n        this.headers = headers;\n        return this;\n    }\n    \n    @Override\n    public void close() throws IOException {\n        try {\n            flush();\n        } finally {\n            getOut().close();\n        }\n    }\n    \n    @Override\n    protected void beforePrintingStarts() throws IOException{\n      if (!hasHeaders())\n          return;\n        \n       for (String h : headers){\n           getOut().append(h).append(System.lineSeparator());\n       }\n       headers = null;\n    }\n\n}",
