    "patch_code": "public class RepairCSVPrinter {\n     private boolean headerPrinted = false;\n    \n        public void print(String[] headers, Object... args) throws IOException{\n            if(!headerPrinted){\n                for(int i=0;i<headers.length;i++){\n                    String s = headers[i];\n                    write(s);\n                \n                    if(i < headers.length - 1){\n                        write(format.getColumnDelimiter());\n                    }else{\n                        newLine();\n                    }\n            \n                }\n                headerPrinted = true;\n            } else {\n                println(args);\n            }\n         }\n      }",
