    "patch_code": "package org.joda.time.format;\nimport java.util.*;\npublic class DateTimeParserBucket extends BucketBase implements Cloneable, Comparable<Bucket> {\n    public long computeMillis(boolean resetFields, String text) throws IllegalArgumentException {\n        List list = new ArrayList();\n        String s = (new StringBuilder()).append((char)'x').append((char)'x').append((char)'x').append((char)'x').toString();\n        ((List)list).add(DateTimeFieldType.year());\n        ((List)list).add(DateTimeFieldType.weekOfWeekBasedYear());\n        ((List)list).add(DateTimeFieldType.dayOfWeek());\n        Iterator iter = ((List)list).iterator();\n        while (iter.hasNext()) {\n            Object object = iter.next();\n            System.out.print(((DateTimeFieldType)object).getName() + \" \");\n        }\n        \n        return super.computeMillis(resetFields, text);\n    }\n}",
