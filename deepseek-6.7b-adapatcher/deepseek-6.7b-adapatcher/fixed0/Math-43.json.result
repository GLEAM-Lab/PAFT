    "patch_code": "public void setVarianceImpl(final org.apache.commons.math.stat.descriptive.rank.Variance variance){\n            this.variance=null;\n            if((variance!=null)!=true){\n                return;\n            }\n            final boolean p0=((boolean)(variance)).isPopulation();\n            this.varianceImpl=new org.apache.commons.math.stat.descriptive.rank.Variance(){\n\n\n                public double getResult(){\n                    if(!p0&&n==0){\n                        return Double.NaN;\n                    }else{\n                        return super.getResult();\n                    }\n                }\n            };\n            reset();\n        }",
