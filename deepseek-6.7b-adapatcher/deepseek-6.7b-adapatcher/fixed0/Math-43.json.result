    "patch_code": "@Override\npublic void addValue(double value) {\n    sum += value;\n    sumsq += value * value;\n    if (min == null || Double.compare(value, min) < 0) {\n        min = value;\n    }\n    if (max == null || Double.compare(value, max) > 0) {\n        max = value;\n    }\n    logSum += Math.log(value);\n    secondMoment += value*value;\n    n++;\n}",
