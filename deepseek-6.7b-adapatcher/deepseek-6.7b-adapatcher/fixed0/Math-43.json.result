  {
    "patch_code": "public class MySummaryStatistics extends SummaryStatistics {\n\n    private boolean populationVariance = true;\n  \n    public MySummaryStatistics(){\n      super();\n      \n     /* this.sumImpl = new Sum();\n      this.sumsqImpl = new Sum();\n      this.minImpl = new Min();\n      this.maxImpl = new Max();\n      this.sumLogImpl = new Sum();*/\n      \n    }\n    \n    @Override\n    public void addValue(double value) {\n      sumImpl.increment(value);\n      sumsqImpl.increment(value * value);\n      minImpl.increment(value);\n      maxImpl.increment(value);\n      sumLogImpl.increment(FastMath.log(value));\n        \n      secondMoment.increment(value);\n      \n      // If mean, variance or geomean have been overridden,\n      // need to increment these\n      if (!(meanImpl instanceof Mean)) {\n          meanImpl.increment(value);\n      }\n      \n      if(!(varianceImpl instanceof Variance)){\n        ((Variance)varianceImpl).setPopulation(populationVariance);\n        varianceImpl.increment(value);\n          \n      } else{\n            varianceImpl.increment(value);\n      }\n      \n        \n      if (!(geoMeanImpl instanceof GeometricMean)) {\n          geoMeanImpl.increment(value);\n      }\n    }\n    \n    /**\n     * Sets whether to use population variance or sample variance as the default in future calculations.\n     * By default, uses population variance.\n     */\n    public void setVarianceAsPopulation(boolean populationVariance) {\n        this.populationVariance= populationVariance;\n        \n        if(!(varianceImpl instanceof Variance)){\n             throw new UnsupportedOperationException(\"Cannot change variantion type after initialisation\");\n        }\n        \n        ((Variance)varianceImpl).setPopulation(populationVariance);\n    }\n    \n\n  \n}",
