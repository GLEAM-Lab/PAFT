    "patch_code": "public class SummaryStatistics extends AbstractAggregation implements Serializable {\nprivate long n = 0;\n@Override\npublic double getStandardDeviation() {\nif (n == 0 || Double.isNaN(sumSq()) ) return Double.NaN;\nreturn Math.sqrt(getVariance());\n}\n\n@Override\npublic double getGeometricMean() {\nif (n == 0) return Double.NaN;\nreturn Math.exp(getSumLog() / n);\n}\n//...other codes...\nprotected double getSumLog(){\ndouble result=0.0D;\nif (hasCountOfValuesIncludedInTheMean()){\nresult=sumLogImpl.evaluate()-(min()*MathUtils.LN2)*countOfValues();\n}else{\nresult=sumLogImpl.evaluate();\n}\nreturn result;\n}\n}",
