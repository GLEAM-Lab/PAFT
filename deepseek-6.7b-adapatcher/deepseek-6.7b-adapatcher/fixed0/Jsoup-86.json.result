    "patch_code": "public XmlDeclaration asXmlDeclaration() {\n    String data = getData();\n    try{\n      if(!data.isEmpty()){\n          int begin = 0;\n        \n     while ((begin = data.indexOf('<', begin)) != -1) {\n            int end = data.indexOf('>', begin + 1);\n            if (end == -1) {\n                break;\n            }\n        \n       String tagString = data.substring(begin+1,end );\n        \n             if (!XmlHelper.isXmlDeclare(tagString)){\n                    break ;\n             }\n            attributes = Attributes.build(ElementTag.XmlDeclare , tagString ) ;\n                 \n           setData(\"!\"+data.charAt(begin+2));\n                  \n                \n               break ;  \n            }\n         begin = end +1  ; \n           \n     }}catch(IndexOutOfBoundsException e ){\n          System.out.println(e.toString());\n      }\n    Document doc = Jsoup.parse(\"<\" + getData() + \">\", baseUri(), Parser.xmlParser());\n    XmlDeclaration decl = null;\n    if (doc.childNodeSize() > 0) {\n        Element el = doc.child(0);\n        decl = new XmlDeclaration(NodeUtils.parser(doc).settings().normalizeTag(el.tagName()), true);\n        decl.attributes().addAll(el.attributes());\n    }\n    return decl;\n}",
