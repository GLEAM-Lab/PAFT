    "patch_code": "public XmlDeclaration asXmlDeclaration() {\n    String data = getData();\n    String outerData = \"<root>\"+data.substring(1, data.length()-1)+\"</root>\";\n    System.out.println(outerData);\n    Document doc = Jsoup.parse(outerData, \"\", Parser.xmlParser());\n    Node node= doc.childNode(0);\n    \n   while(!node.isDocument()){\n      System.out.println(node instanceof org.jsoup.nodes.Element );\n       System.out.println(((org.jsoup.nodes.Element)node).tagName());\n       \n       if(((org.jsoup.nodes.Element)node).hasText())System.out.println(((org.jsoup.nodes.Element)node).text());\n       if(((org.jsoup.nodes.Element)node).hasAttr(\"src\"))System.out.println(((org.jsoup.nodes.Element)node).attr(\"src\").trim());\n       \n       for(Attribute attr : ((org.jsoup.nodes.Element)node).attributes()){\n         \n         System.out.println(attr.getKey()+\":\"+attr.getValue());\n        }\n       System.out.println(\"\\n\\n\");\n       \n       node=node.nextSibling();\n   }\n   \n   \n  \n    \n   \n   \n    \n   \n   \n    \n   \n    \n   \n    XmlDeclaration decl = null;\n    if (!doc.childNodes().isEmpty()) {\n        Element el = doc.child(0);\n        decl = new XmlDeclaration(NodeUtils.parser(doc).settings().normalizeTag(el.tagName()), data.startsWith(\"!\"));\n        decl.attributes().addAll(el.attributes());\n    }\n    return decl;\n}",
