    "patch_code": "public void writeEmbeddedObject(byte[] v) throws IOException {\n     if (v == null) {\n         writeNull();\n     } else {\n        if (!_cfg.isEnabled(Feature.WRITE_ENUMS_USING_INDEX)) {\n             // we use type ids for enumerations; but they need to correspond across\n             // writers, so it's best to fail if there're no such ids available\n             throw new IllegalArgumentException(\"No EnumTypeInfo available\");\n         }\n         _serializerProvider().defaultSerializeValue(v,this);\n     }\n }",
