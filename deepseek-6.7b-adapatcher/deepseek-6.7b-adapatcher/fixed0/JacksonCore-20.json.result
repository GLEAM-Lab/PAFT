    "patch_code": "public void writeEmbeddedObject(Object object) throw JsonGenerationException {\n    if (object == null) {\n        writeNull(); return;\n    }\n    try {\n        writeRaw(object); return;\n    } catch (IOException e) {\n        throw new JsonGenerationException(\"failed to writeembeddedObject: \" + object + \" due to %s\", e);\n    }\n}",
