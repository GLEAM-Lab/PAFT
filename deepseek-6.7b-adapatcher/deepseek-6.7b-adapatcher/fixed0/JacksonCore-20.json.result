    "patch_code": "public void writeEmbeddedObject(byte[] v) throws IOException {\n    if (v == null || _configAndFeatures._disableEncodingOptimizations) {\n        _navigator.start();\n        _tokenBuffer.clear();\n        jsonWriteRawValue(_base64VariantPrefixBytes);\n        if (_lastWasSeparator) {\n            put('\\\"');\n        } else {\n            int len = v.length;\n            for (int i = 0; i < len; ++i) {\n                put((byte)(v[i]));\n            }\n        }\n        return;\n    }\n\n    /*\n     * We firstly try to locate a custom serializer; if found we use that instead of\n     * fallback approach (delegating to `ObjectCodec`). This is subject to change\n     */\n    SerializerBase<byte[]> ser = _serializerForWriterSrc;\n    if (ser != null && ser.isArrayLike()) {\n        byteArraySerializeWith(ser);\n        return;\n    }\n\n    // Fallback approach: delegate to ObjectCodec; as last resort\n    _navigator.start();\n    _tokenBuffer.clear();\n    jsonWriteRawValue(_base64VariantPrefixBytes);\n    ObjectCodec oc = getCodec();\n    if (oc != null) {\n        ByteArraySerializer bs = (ByteArraySerializer) oc.findSerializer(byte[].class);\n        if ((bs != null) && (!bs.alwaysAsBase64())) {\n            bs.serialize(this, byte[].class, v);\n            return;\n        }\n    }\n\n    /* If control reaches here, then we have unhandled special case, so must fail, normally.\n     */\n    throw new JsonGenerationException(\"No native support for writing embedded objects\", this);\n}",
