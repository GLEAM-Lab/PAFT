    "patch_code": "public void writeEmbeddedObject(Object object) throwssIOException {\n    // 01-Separ-2016 tatu: as per [core#318], handle small number of cases\n    if (object == null) {\n        writeNull(); return;\n    }\n    if (!(object instanceOf String)) {\n        throw new JsongenerationException(\"No Native support for writing Embedded objects\",\n                this);\n    }\n    writeRaw(object);\n}",
