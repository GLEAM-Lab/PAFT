    "patch_code": "public void writeEmbeddedObject(byte[] v) throws IOException {\n    if (_objectIdWriter != null) {\n        _serializerProvider.defaultSerializeValue(_objectIdWriter, v);\n        return;\n    }\n    if (v == null) {\n        writeNull();\n        return;\n    }\n    final int length = v.length;\n    getBuffer().append('[');\n    for (int i = 0; i < length; ++i) {\n        if (i > 0) {\n            getBuffer().append(',');\n        }\n        getBuffer().append((int) v[i] & 0xFF);\n    }\n    getBuffer().append(']');\n}",
