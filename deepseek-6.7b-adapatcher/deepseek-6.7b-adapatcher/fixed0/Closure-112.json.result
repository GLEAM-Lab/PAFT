  {
    "patch_code": "private void inferTemplatedTypesForCall(\n    Node n, CallExpression cex, Context cx) {\n  if (!cex.hasQP()) {\n    return;\n  }\n  Node callee = cex.getCallee();\n  if (callee instanceof PropertyGetter) {\n    return;\n  } else if (!isObjectCallExpressionOrMethodOf(cx, callee)) {\n    return;\n  }\n\n  FunctionExpression fexp = getFunctionExpressionFor(cx, callee);\n  if (fexp == null || !fexp.hasSlot(0)) {\n    return;\n  }\n\n  // We know that this expression corresponds to some known builtin or constructor\n  int namePos = cex.getName().pos;\n  PropertyGetter propGetter = NameDictionary.getPropGetterForBuiltInOrConstructor(namePos);\n  if (propGetter == null) {\n    return;\n  }\n\n  PropertyDefinition pd = propGetter.staticElement;\n  if (pd == null || pd.isDynamic()) {\n    return;\n  }\n  \n  FunctionType fnType = pd.type.asFunction();\n  if (fnType == null) {\n    return;\n  }\n  final ImmutableList<TemplateType> keys = fnType.getTemplateTypeMap()\n      .getTemplateKeys();\n  if (keys.isEmpty()) {\n    return;\n  }\n\n  Map<TemplateType, JSType> inferredArgs = Utils.mapWith(\n      keys, new com.google.common.base.Function<TemplateType, JSType>() {\n        public JSType apply(TemplateType tmplType) {\n          JSType jsType = TypeInference.guessTypeForTemplateType(\n              cex, tmplType);\n          return jsType == Types.UNKNOWN ? tmplType : jsType;\n        }\n      });\n\n\n  if (!replaceOrRecheckAllArgsOf(cex, inferredArgs)) {\n    return;\n  }\n\n  n.setKind(Node.CALL_EXPR);\n}",
