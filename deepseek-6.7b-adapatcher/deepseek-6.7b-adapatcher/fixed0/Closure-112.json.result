    "patch_code": "public static boolean inferTemplatedTypesForCall(Node n) {\n  String name = n.getName();\n  switch (name){\n    case \"foo\":{\n        ObjectLiteral o = (ObjectLiteral)n.getFirstArgument();\n         Node expr=o.getElements()[0].getValue();\n     String propertyName = ((Identifier)expr).getName();\n      \n   if (!(propertyName instanceof PropertyGetExpression)) break;\n\n    NameExpression expr1=((PropertyGetExpression)propertyName).getBase();\nString objName=null;\nif (expr1 instanceof Identifier ){\nobjName=((Identifier)expr1).getName();\n}\nelse if (expr1 instanceof MemberDotExpression){\nMemberDotExpression memberDotExp=(MemberDotExpression)expr1;\nobjName=memberDotExp.getName();\n}\nif (\"Class\".equals(objName)){\nbreak;\n}\nreturn true ;\n    }\n    default :\n      return false;\n  }\n\n\n  FunctionLiteral target = (FunctionLiteral) n.getTarget();\n  FunctionType signature = Functions.getFunctionType(target);\n  if (signature == null) {\n    throw CompilerException.create(CompilerException.INTERNAL_ERROR, \"No signature for \", target.toString(), \" (\", n.getName(), \")\");\n  }\n\n  return inferTemplatedTypesForCall(n, signature);\n}",
