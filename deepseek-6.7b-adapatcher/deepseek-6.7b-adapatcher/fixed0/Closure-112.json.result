    "patch_code": "public final boolean inferTemplatedTypesForMethodCallsInFunctionScope(Node n) {\n  JSType callTargetType = n.getJSType();\n  if (!(callTargetType instanceof ObjectType)) {\n    return false;\n  }\n  ObjectType callTargetObjectType = (ObjectType) callTargetType;\n  if (callTargetObjectType.isCtorCall()) {\n    // We don't do anything for constructor calls, they have their own rules.\n    return false;\n  }\n  FunctionType targetFnType = callTargetObjectType.getSignature();\n  if (!targetFnType.hasTemplateParams()) {\n    return false;\n  }\n  return inferTemplatedTypesForCall(n, targetFnType);\n}",
