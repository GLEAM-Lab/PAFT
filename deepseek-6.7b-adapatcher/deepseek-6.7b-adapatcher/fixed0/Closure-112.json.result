    "patch_code": "private boolean inferTemplatedTypesForCall(Node n, MethodType mType){\n  if(!mType.hasTemplates()){\n     return false;\n  }\n  // Try to infer the template types\n  TypeScriptKeywordMap templates= mType.getTemplateKeywords();\n  TypeKeywordSet ks= templates.keySet();\n  Iterator iks= ks.iterator();\n  while(iks.hasNext()){\n   TemplateType ttype= (TemplateType) iks.next();\n   String tname= ttype.getTypeName();\n   String atypeName=  TypeUtils.getNameOfAtParameterType(n);\n   int pndex1= TypeUtils.indexOfLastDotOrBracketsInIdentifier(atypeName);\n   String baseName= TypeUtils.getNameOfBasePart(atypeName,pndex1).toString();\n   BaseKeywordType referedByAllFunctions= env.findVariable(baseName);\n   if(referedByAllFunctions == null ){\n     continue;\n   }\n   if(referedByAllFunctions instanceof GenericRefinement ){\n    Map <String , Variable> varMapeing= ((GenericRefinement) referedByAllFunctions ).getSubstitutionVars();\n     Set entries= varMapeing.entrySet();\n     Iterator iter=entries.iterator();\n     while(iter.hasNext()){\n       Entry entryx= (Entry) iter.next();\n       if((entryx.getValue()).getName().equalsIgnoreCase(baseName)){\n         templates.put(ttype,(Variable)entryx.getValue());\n         break;\n        }\n      }\n    }else if(referedByAllFunctions instanceof ParameterizedTypeReference){\n       Map<TemplateType, Variable>  mappingToUse= ((ParameterizedTypeReference) referedByAllFunctions).getTemplateMapping();\n      if(mappingToUse !=null && mappingToUse.containsKey(ttype)){\n         templates.put(ttype, mappingToUse.get(ttype));\n      }\n    }\n  }\n  if(templates.size()==0){\n    return false;\n  }\n  TemplateTypeReplacer replacer= new TemplateTypeReplacer(registry, templates );\n  Node callTarget= n.getFirstChild();\n  n.setJSType(((MethodType)callTarget.getJSData().getType()).applyTemplates(templates));\n  return true;\n }",
