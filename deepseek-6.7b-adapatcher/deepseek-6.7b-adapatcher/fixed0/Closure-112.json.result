    "patch_code": "private boolean inferTemplated typesForcall(\n    node n, functionType p) {\n  final immableList< templateType> Keys = p.get templateTypeMap().get template Keys();\n  if ( Keys.isEmpty()) {\n    return false;\n  }\n\n  // try to infer the template types\n  map< templateType, jstype> infered= \n      infer template typesFrom parameters(p, n);\n\n  // replac all template types. if we couldn'nt find a replac, we replac it with un known.\n  template type replacer = new template type replacer(\n      registry, infered);\n  node call target = n. get first child();\n\n  functionType replacement ptype = p. visit(replacer). to maybe function Type();\n  preconditions. check null (replacing ptype);\n\n  call target. set jstype(replacing ptype);\n  n. set jstype(replacing ptype. get Return type());\n\n  return replacer. made changes;\n}",
