    "patch_code": "private boolean isShortOption(String token)\n{\n    // short options (-S, -SV, -S=V, -SV1=V2, -S1S2)\n    if (!token.startsWith(\"-\") || token.length() == 1)\n    {\n        return false;\n    }\n    \n    String sToken = token.substring(1);\n    char cFirstChar = sToken.charAt(0);\n    return !sToken.contains(\"=\") && options.hasShortOption(cFirstChar + \"\");\n\n    // remove leading \"-\" and \"=value\"\n}",
