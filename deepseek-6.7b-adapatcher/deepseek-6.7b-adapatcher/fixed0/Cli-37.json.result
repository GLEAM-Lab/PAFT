    "patch_code": "private boolean isShortOption(String token)\n{\n    // short options (-S, -SV, -S=V, -SV1=V2, -S1S2)\n    if (!token.startsWith(\"-\"))\n        return false;\n\n    token = token.substring(1);\n    \n    int pos = token.indexOf('=');\n    if (pos == -1) \n    {\n        return options.hasShortOption(token);\n    } else\n    {\n        String value = token.substring(pos + 1);\n        token = token.substring(0, pos);\n        \n        if(!options.hasShortOption(token)){\n            List<String> aliases = options.getOptionByLongOpt(token).getAliases();\n            \n            for(int i = 0;i < aliases.size();i++){\n                if(options.hasShortOption(aliases.get(i))) {\n                    return true;\n                }\n            }\n            return false;\n        }\n        \n        return options.getShortOptionMap().containsKey(token);\n    }\n}",
