    "patch_code": "public <T> MappingIterator<T> readValues(byte[] src, int offset, int length)\n        throws IOException, JsonProcessingException {\n    byte[] copy = Arrays.copyOfRange(src, offset, length + offset); // Create a subrange of the input bytes that we want to read.\n    \n    if (_dataFormatReaders != null) {\n        return _detectBindAndReadValues(_dataFormatReaders.findFormat(copy, 0, copy.length), false);\n    }\n    return _bindAndReadValues(_considerFilter(_parserFactory.createParser(new String(copy)), \n            true));\n}",
