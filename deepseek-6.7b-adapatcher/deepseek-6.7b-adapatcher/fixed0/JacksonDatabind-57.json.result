    "patch_code": "public <T> MappingIterator<T> readValues(byte[] src, int offset, int length)\n    throws IOException, JsonProcessingException\n{\n    DataFormatReaders dataFormatReaders = _dataFormatReaders;\n    if (dataFormatReaders == null) {\n         /* 1 */\n        throw new UnsupportedOperationException(\"No built-in format readers available\");\n    }\n    \n    JsonParser parser;\n    try {\n        parser = dataFormatReaders.findFormat(src, offset, length).createParser(src, offset, length);\n    } catch (DataFormatReadException e) {\n        /* 2 */\n        throw new UnrecognizedFormatException(e, \"Unable to unwrap value as one of supported formats\");\n    }\n    boolean filtered = _considerFilter(parser, true);\n    // [..]\n    return _bindAndReadValues(parser, filtered);\n}",
