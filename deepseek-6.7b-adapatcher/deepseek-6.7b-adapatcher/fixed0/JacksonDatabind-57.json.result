    "patch_code": "public <T> MappingIterator<T> readValues(byte[] src, int offset, int length)\n        throws IOException, JsonProcessingException {\n        \n        if (_dataFormatReaders == null) {\n                throw new UnsupportedOperationException(\"Null DataFormatReaders not supported\");\n        }\n        \n        // Find right data format reader\n        final InputStreamPart streamPart = new InputStreamPart(new ByteArrayInputStream(src), offset, length);\n        DataFormatDetector.Result result = _dataFormatReaders.findByMimeType(null).detect(streamPart);\n    \n        if (result == null) {\n            throw new UnrecognizedPropertyException(\"No data format reader for byte array content\");\n        }\n  \n    /* \n    * Use correct sequence of values from 'src' - ignore any arguments `offset` & `length`;\n    * instead just call `values()` method from `JsonToken.START_ARRAY` till `END_ARRAY` */\n    \n    TokenBuffer tb = result._tokenBuffer;\n\n        List<T> elements = new ArrayList<>();\n        while (tb.nextToken() != null && tb.currentToken() != JsonToken.END_ARRAY) {\n            \n      /*  if we got START_OBJECT or similar, then process accordingly as per normal pathway... */\n            elements.add((T)_deserializeFromArray(tb, result));\n        }\n        \n        return new ArrayBackedMappingIterator<T>(elements.toArray(), result._typeDeserializer);\n}",
