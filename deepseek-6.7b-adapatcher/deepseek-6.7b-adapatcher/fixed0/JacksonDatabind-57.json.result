  {
    "patch_code": "public <T> List<T> readValues(byte[] bytes, Class<T> valueType){\n    try {\n        ByteArrayInputStream bis = new ByteArrayInputStream(bytes);\n        InputStreamReader reader = new InputStreamReader(bis,\"UTF-8\");\n        ObjectMapper mapper = new ObjectMapper();\n        CollectionType collectionType = mapper.getTypeFactory().constructCollectionType(List.class,valueType);\n        List<T> list = mapper.readValue(reader,collectionType);\n        bis.close();\n        reader.close();\n        \n        return list;\n    } catch (IOException e) {\n        throw new RuntimeException(\"Could not parse JSON \" + bytes ,e);\n    }\n}",
