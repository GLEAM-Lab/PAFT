    "patch_code": "public <T> MappingIterator<T> readValues(byte[] src, int offset, int length)\n     throws IOException, JsonProcessingException {\n    \n    // create copy of data in order to not mess with original values outside this method\n    byte[] realData = new byte[length];\n    System.arraycopy(src, offset, realData, 0, length);\n  \n    if (_dataFormatReaders != null) {\n         return _detectBindAndReadValues(_dataFormatReaders.findFormat(realData, 0, realData.length), false);\n    }\n    return _bindAndReadValues(_considerFilter(_parserFactory.createParser(realData), \n             true));\n}",
