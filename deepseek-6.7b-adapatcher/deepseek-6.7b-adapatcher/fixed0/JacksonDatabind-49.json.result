    "patch_code": "// Repaired Code: \npublic Object generateId(Object forPojo) {\n    synchronized (_sync) {\n        _assignedIds.add(forPojo);\n        \n        if (!_objectToId.containsKey(forPojo)) {\n            _objectToId.put(forPojo, nextId());\n            \n            int lastDot = getClass().getName().lastIndexOf('.');\n            String keySuffix = (lastDot < 0 ? getClass().getName() : getClass().getName().substring(lastDot + 1));\n\n            Map<String, Object> data = new HashMap<String.java.util.LinkedHashMap<String,Object>>();\n            data.put(\"@class\", keySuffix + '#' + _objectToId.get(forPojo));\n            try {\n                ByteArrayOutputStream baos = new java.io.ByteArrayOutputStream();\n                getMapper().writerFor(Map.class).writeValue(baos, data);\n                \n                byte [] bytes = baos.toByteArray();\n                MessageDigest md = MessageDigest.getInstance(\"MD5\");\n                byte[] hashBytes = md.digest(bytes);\n                long id = ((hashBytes[3]<<24) & 0xFF000000) |((hashBytes[2]<<16)&0xFF0000) |((hashBytes[1]<<8)&0xFF00) |(hashBytes[0]);\n                return Long.valueOf(id);\n            } catch (Exception e) {\n                throw new RuntimeException(\"Unexpected problem while trying to generate id: \"+e.getMessage(), e);\n            }\n        } else {\n            return _objectToId.get(forPojo);\n        }\n    }\n}",
