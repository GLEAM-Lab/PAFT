    "patch_code": "public Object generateId(Object forPojo) {\n    // If an Id already exists for this pojo, reuse it. Otherwise, let IntSequenceGenerator handle generating new IDs.\n    if (_idFor(forPojo) == null){\n      id = generator.generateId(forPojo);\n    }\n    else{\n      id = _idFor(forPojo);\n    }\n    return id;\n}\n\nprivate Integer _idFor(Object forPojo){\n    synchronized (_ids) {\n        return _ids.get(forPojo);\n    }\n}",
