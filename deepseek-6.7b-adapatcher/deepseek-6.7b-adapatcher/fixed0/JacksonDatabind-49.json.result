    "patch_code": "private int _nextId = 0;\n    \n// replace old generateId()\npublic int generateId(Object forPojo) {\n    /* 3-Aug-2019, tatu: Changed original implementation to ensure we do NOT write ids multiple times */\n    Integer i = _pojoToId.get(forPojo);\n    if (i == null) {\n        synchronized (this) {\n            i = _pojoToId.get(forPojo);\n            if (i == null) {\n                _pojoToId.put(forPojo, _nextId);\n                return _nextId++;\n            }\n        }\n    }\n    return i;\n}",
