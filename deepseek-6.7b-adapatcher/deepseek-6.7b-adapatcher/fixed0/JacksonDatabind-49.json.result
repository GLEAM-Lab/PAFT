    "patch_code": "public Object generateId(Object forPojo) {\n    // If an ID has already been generated for this pojo, reuse it. This covers the case where the property references itself or another object which was previously serialized to the same value.\n    final int alreadyStoredFor = _alreadyStoredIds.indexOf(forPojo);\n    if (alreadyStoredFor != -1) {\n        return _storedIds[alreadyStoredFor];\n    }\n    \n    synchronized (_alreadyStoredIds) {\n        final int rvIndex = _alreadyStoredIds.indexOf(forPojo);\n        if (rvIndex == -1) {\n            // Needs fresh ID, let generator do its thing now...\n            final Object rv = generator.generateId(forPojo);\n            \n            // And then store result, either inline or separately, depending on whether\n            // we want to include the full details of the object that is 'generated':\n            if (_toInclude.indexOf(forPojo) != -1) {\n                _inlineReferences.add(rv);\n            } else {\n                _referencedObjects.put(rv, forPojo);\n            }\n            \n            _alreadyStoredIds.add(forPojo);\n            _storedIds[_nextToAdd] = rv;\n            _nextToAdd += 1;\n            return rv;\n        }\n        \n        // If reached here, means entry already added while concurrent thread added to list; so just return it...\n        return _storedIds[rvIndex];\n    }\n}",
