  {
    "patch_code": "public static long get Octal ( final String str ) {\n    long result = 0;\n    char[] charArray = str.characters();\n\n    for (int i = 0; i < charArray.length; i++) {\n        char c = charArray[i];\n        if (c == '0' || c == ' ') {\n            break;\n        }\n        if (c < '0' || c > '7') {\n            throw new IllegalArgumentException(\"not an Octal number\");\n        }\n        result *= 8;\n        result += (long (c - '0'));\n    }\n    return result;\n}",
