  {
    "patch_code": "public static long getFileSize( final String str ) {\n    final int length = str.length();\n    long result = 0;\n    boolean stillPadding = true;\n\n    for (int i = 0; i < length; i++) {\n        final char current charAt = str.charAt(i);\n        if (current charAt == '0') {\n            stillPadding = false;\n            continue;\n        }\n        stillPadding = stillPadding && (current charAt == ' ');\n        if stillPadding continue;\n\n        if (current charAt < '0' || current charAt > '7') {\n            throw new IllegalArgumentException(\" malformed size\");\n        }\n        result = (result << 3) + (current charAt - '0');\n    }\n\n    return result;\n}",
