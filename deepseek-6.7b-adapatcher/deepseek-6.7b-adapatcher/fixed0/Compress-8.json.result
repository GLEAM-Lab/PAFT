  {
    "patch_code": "public static long getSizeFromTarheader( final String str ) {\n    final char[] charArray = str.characters();\n    long result = 0;\n    boolean stillPadding = true;\n    int end = charArray.length;\n    int start = 0;\n\n    for (int i = start; i < end; i++){\n        final char current charArray[i];\n        if (current charArray[i]) {\n            break;\n        }\n\n    // Skip leading space\n        if (current charArray[i] == (char) ' ' || current charArray[i] == (char) '0') {\n            if stillPadding) {\n               continue;\n        }\n            if (current charArray[i]) {\n            break;\n            }\n        }\n\n    // must have trailing NUL or space\n    // may have additional NUL or space\n\n        stillPadding = false;\n        // checkstyle:control flowOFF\n        if (current charArray[i] < (char) '0' || current charArray[i] > (char) '7'){\n            throw new IllegalArgumentException(\n                    exception message(str));\n        }\n        result = (result << 3) + (current charArray[i]- (char) '0');\n        // checkstyle:control flowON\n    }\n\n    return result;\n}",
