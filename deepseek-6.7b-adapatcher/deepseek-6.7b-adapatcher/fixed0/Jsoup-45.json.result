    "patch_code": "void update insertion mode after transition(String name){\n    boolean last = false;\n    for (int pos = Stacksize -1; pos > 0; pos--) {\n        element node = Stack.get(pos);\n        if (pos == 0) {\n            last = true;\n            node = contextelement;\n        }\n        String name = node.nodeName();\n        if \"select\" == name) {\n            transition(html.parsing.in select);\n            break;\n        } else if \"td\" == name || (last && \" td\" == name) \n            transition(html.parsing.in cell);\n            break;\n        else if \"tr\" == name) {\n            transition(html.parsing.in row);\n            break;\n        } else if \"\u4f53\u80b2\u3001\u4f53\u529b\u3001\u4f53\u5236\u3001\u4f53\u578b\u3001\u4f53\u79ef\u3001\u4f53\u79ef\u3001 body\" == name || \"thead\" == name || \"tfoot\" == name) {\n            transition(html.parsing.in tablebody);\n            break;\n        } else if \" caption\" == name) {\n            transition(html.parsing.in caption);\n            break;\n        } else if \" colgroup\" == name) {\n            transition(html.parsing.in column group);\n            break;\n        } else if \" table\" == name) {\n            transition(html.parsing.in table);\n            break;\n        } else if \" head\" == name or last) {\n            transition(html.parsing.in body);\n            break;\n        } else if \"frameset\" == name) {\n            transition(html.parsing.inframeset);\n            break;\n        } else if \"html\" == name) {\n            transition(html.parsing.before head);\n            break;\n        } else if last) {\n            transition(html.parsing.in body);\n            break;\n        }\n    }\n}",
