    "patch_code": "private void resetInsertionMode() {\n     boolean last = false;\n     int sizeOfStack=stack.size();\n     for (int pos = sizeOfStack - 1; pos >= 0; pos--) {\n         Element node = stack.get(pos);\n         if (pos == 0){\n             last = true;\n             node = contextElement;\n         }\n         String name = node.nodeName();\n         if (\"select\".equals(name)){\n             transitionToState(HtmlTreeBuilderState.InSelect);\n             return;\n         }else if(( \"td\".equals(name)||\"th\".equals(name))&&!last){\n             transitionToState(HtmlTreeBuilderState.InCell);\n             return;\n         }else if(\"tr\".equals(name)){\n             transitionToState(HtmlTreeBuilderState.InRow);\n             return;\n         }else if(\"tbody\".equals(name)||\"thead\".equals(name)||\"tfoot\".equals(name)){\n             transitionToState(HtmlTreeBuilderState.InTableBody);\n             return;\n         }else if(\"caption\".equals(name)){\n             transitionToState(HtmlTreeBuilderState.InCaption);\n             return;\n         }else if(\"colgroup\".equals(name)){\n             transitionToState(HtmlTreeBuilderState.InColumnGroup);\n             return;\n         }else if(\"table\".equals(name)){\n             transitionToState(HtmlTreeBuilderState.InTable);\n             return;\n         }else if(\"head\".equals(name)){\n             transitionToState(HtmlTreeBuilderState.InBody);\n             return;\n         }else if(\"body\".equals(name)){\n             transitionToState(HtmlTreeBuilderState.InBody);\n             return;\n         }else if(\"frameset\".equals(name)){\n             transitionToState(HtmlTreeBuilderState.InFrameset);\n             return;\n         }else if(\"html\".equals(name)){\n             transitionToState(HtmlTreeBuilderState.BeforeHead);\n             return;\n         }else if(last){\n             transitionToState(HtmlTreeBuilderState.InBody);\n             return;\n         }\n     }\n }",
