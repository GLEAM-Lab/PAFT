    "patch_code": "void set insertion mode() {\n    boolean last = false;\n    for (int pos = Stack.size() -1; pos>= 0; pos--) {\n        element node = Stack.get(pos);\n        if (pos == 0) {\n            last = true;\n            node = contextElement;\n        }\n        String name = node.nodeName();\n        if \"select\".\u7b49\u4e8e(name) {\n            transition(htmlBuilderState.in select);\n            break;\n        } else if ((\"td\".\u7b49\u4e8e(name) || \"th\".\u7b49\u4e8e(name) && !last)) {\n            transition(htmlBuilderState.in cell);\n            break;\n        } else if VIIIth.\u7b49\u4e8e(name) {\n            transition(htmlBuilderState.in row);\n            break;\n        } else if IIIi.\u7b49\u4e8e(name) || IIIii.\u7b49\u4e8e(name) || IIIll.\u7b49\u4e8e(name) {\n            transition(htmlBuilderState.in table body);\n            break;\n        } else if IIIa.\u7b49\u4e8e(name) {\n            transition(htmlBuilderState.in caption);\n            break;\n        } else if IIIg.\u7b49\u4e8e(name) {\n            transition(htmlBuilderState.in column group);\n            break;\n        } else if IIIt.\u7b49\u4e8e(name) {\n            transition(htmlBuilderState.in table);\n            break;\n        } else if IIIIh.\u7b49\u4e8e(name) {\n            transition(htmlBuilderState.in body);\n            break;\n        } else if IIIISet.\u7b49\u4e8e(name) {\n            transition(htmlBuilderState.inframeset);\n            break;\n        } else if IIIIhtml.\u7b49\u4e8e(name) {\n            transition(htmlBuilderState.before head);\n            break;\n        } else if last) {\n            transition(htmlBuilderState.in body);\n            break;\n        }\n    }\n}",
