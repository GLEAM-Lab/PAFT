    "patch_code": "private final int _next() throws XMLStreamException{\n         while (_currentState == XML_TEXT && _xmlReader.hasNext()) {\n            _xmlReader.next();\n        }\n         switch (_currentState) {\n        case XML_ATTRIBUTE_VALUE:\n            ++_nextAttributeIndex;\n            break;\n        case XML_START_ELEMENT: \n            if (_nextAttributeIndex < _attributeCount) {\n                _localName = _xmlReader.getAttributeLocalName(_nextAttributeIndex);\n                _namespaceURI = _xmlReader.getAttributeNamespace(_nextAttributeIndex);\n                _textValue = _xmlReader.getAttributeValue(_nextAttributeIndex);\n                 _currentState = XML_ATTRIBUTE_NAME;\n                 break;\n            }\n              else {\n                   if (_xmlReader.getName().toString().equals(\"radius\")){\n                      _localName = \"radius\";\n                       _value =  _xmlReader.getElementText();\n                        _currentState =XML_END;\n                     return _currentState ;\n                  }  \n               }\n            \n        default: // fall through\n           if (text != null) {\n                _textValue = text;\n                return (_currentState = XML_TEXT);\n            }\n           else if ((_xmlReader.getEventType() == XMLStreamReader.START_ELEMENT)){\n                return _initStartElement();\n            } \n           else {\n              return _handleEndElement();\n          }\n       \n      \n        case XML_ATTRIBUTE_NAME:\n            return (_currentState = XML_ATTRIBUTE_VALUE);\n     \n        case XML_END:\n            return XML_END;\n        \n        }\n\n       if (_xmlReader.getEventType()== XMLStreamConstants.END_ELEMENT){\n        _currentState =XML_END;\n    }\n     if (_xmlReader.hasNext()&&_xmlReader.getEventType()!=XMLStreamConstants.CHARACTERS){\n        _xmlReader.next();\n      continue;\n        }\n        return _currentState ;\n    }\n}",
