    "patch_code": "private final int _next() throws XMLStreamException\n    {\n        while (true) {\n            switch (_currentState) {\n                case XML_ATTRIBUTE_VALUE:\n                    ++_nextAttributeIndex;\n                    break;\n                case XML_START_ELEMENT: \n                    if (_nextAttributeIndex >= _attributeCount){\n                        _localName = _xmlReader.getLocalName();\n                        _namespaceURI = _xmlReader.getNamespaceURI();\n                        String text = _collectUntilTag();\n                        if (!hasMoreChildrenInSameLevel()) {\n                            _textValue = text;  \n                            return XML_TEXT;\n                        }\n                        \n                        else{\n                            _elementStack.push(_newElementInfo());\n                            return XML_START_ELEMENT;\n                        }\n                    }\n                    break;\n                    \n                case XML_ATTRIBUTE_NAME:\n                    return (_currentState = XML_ATTRIBUTE_VALUE);\n                \n                case XML_TEXT: \n                   if (!hasMoreChildrenInSameLevel() && _xmlReader.getEventType() != XMLStreamConstants.START_ELEMENT ){\n                       return XML_END;\n                    }\n                    \n                    else if(!hasMoreChildrenInSameLevel()&&_xmlReader.getEventType()==XMLStreamConstants.START_ELEMENT){\n                       _elementStack.peek()._totalElements++;\n                    }\n                    break;\n                case XML_END:\n                    return XML_END;\n            }\n        \n        \n        \n            switch (_skipUntilTag()) {\n                case XMLStreamConstants.CHARACTERS:\n                    continue;\n                case XMLStreamConstants.END_DOCUMENT:\n                    return (_currentState = XML_END);\n                case XMLStreamConstants.END_ELEMENT:\n                    return _handleEndElement();\n            }\n        \n            _currentState = XML_START_ELEMENT;\n            break;\n        }\n    }\n    \n    boolean hasMoreChildrenInSameLevel(){\n        for(int i = 0;i<_elementStack.size();i++){\n            ElementInfo e  = _elementStack.get(_elementStack.size()-1-i);\n            if((e.index+1)<e.count){\n                return true;\n            }\n        }\n        return false;\n    }",
