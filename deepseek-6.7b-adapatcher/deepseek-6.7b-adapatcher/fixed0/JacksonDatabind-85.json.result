    "patch_code": "public class CustomDateTimeSerializer extends DateTimeSerializerBase<Date>{\n    \n    private static final long serialVersionUID = 1L;\n\n    protected Format _format;\n    \n    public CustomDateTimeSerializer(){\n        super(Date.class,new StdDateFormat());\n        \n    }\n    \n    @Override\n    public JsonSerializer<?> createContextual(SerializerProvider prov, BeanProperty property){\n        if (prov.getConfig() != null && prov.getConfig().hasDesiredFormatForContentType(this)){\n            DateFormat df = prov.getConfig().getDesiredFormatForContentType(_contentType,\n                    Date.class).toDateFormat();\n            \n            if (!(df instanceof StdDateFormat))\n                throw new IllegalArgumentException(\"Unsupported format \" + df.getClass().getName());\n            \n            _format = (Format)df;\n        }else{\n            _format = new SimpleDateFormat(DateFormatUtils.ISO_DATETIME_TIME_ZONE_FORMAT.toString());\n        }\n        \n        try{\n            _format.setTimeZone(prov.getTimeZone());\n        }catch(IllegalArgumentException ex){\n            System.err.println(ex.getMessage());\n        }\n        \n        return this;\n    }\n    \n    @Override\n    public void serialize(Date value, JsonGenerator gen, SerializerProvider provider) throws IOException{\n        synchronized (_format){\n            gen.writeString(_format.format(value));\n        }\n    }\n    \n    public class StdDateFormat extends DateTimeFormatter{\n        \n        /**\n         * \n         */\n        private static final long serialVersionUID = 1L;\n\n        public static final String DATE_FORMAT_STR_CUSTOM=\"yyyy-MM-dd HH:mm:ss\";\n        \n        private transient DateFormat _formatter;\n        \n        public StdDateFormat(){\n            this._formatter = new SimpleDateFormat(DATE_FORMAT_STR_CUSTOM);\n        }\n        \n        @Override\n        public String getPattern(){\n            return this._formatter.toPattern();\n        }\n        \n        @Override\n        public boolean isLenient(){\n            return false;\n        }\n        \n        @Override\n        public DateFormat setLenient(boolean lenienct){\n            this._formatter.setLenient(lenienct);\n            return this;\n        }\n        \n        @Override\n        public Object parseObject(String source)throws ParseException{\n            return _formatter.parse(source);\n        }\n        \n        @Override\n        public StringBuffer format(Date date , StringBuffer toAppendTo,FieldPosition fieldPosition)throws IllegalArgumentException{\n            return _formatter.format(date,toAppendTo,fieldPosition);\n        }\n        \n        @Override\n        public Date parse(String source) throws ParseException{\n            return (Date)_formatter.parse(source);\n        }\n        \n        @Override\n        public DateTimeFormatter withLocale(Locale locale){\n            ((SimpleDateFormat)this._formatter).applyLocalizedPattern(locale);\n            return this;\n        }\n        \n        @Override\n        public DateTimeFormatter withZone(ZoneId zone){\n            _formatter.setTimeZone(DateUtils.convertZoneIdToTimeZone(zone));\n            return this;\n        }\n    }\n    \n    \n}",
