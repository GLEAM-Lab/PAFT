    "patch_code": "public class CustomDateTimeSerializer extends DateTimeSerializerBase<Date> {\n\n  private static final long serialVersionUID = 1L;\n\n  protected SimpleDateFormat _dateFormat;\n\n  public CustomDateTimeSerializer(){\n      super(Date.class, null, null);\n  }\n\n  @Override\n  public JsonSerializer<?> createContextual(SerializerProvider prov, BeanProperty property)\n          throws JsonMappingException {\n      \n      if (property != null) {\n          JsonFormatAnnotation formatAnno = property.getAnnotation(JsonFormatAnnotation.class);\n          \n          if (formatAnno != null && formatAnno.timezone() != null && formatAnno.timezone() != \"\") {\n              setTimeZone(formatAnno.timezone());\n          }\n          if (formatAnno != null && formatAnno.locale() != null && formatAnno.locale() != \"\") {\n              setLocale(formatAnno.locale());\n          }\n          if (formatAnno != null && formatAnno.shape() != JsonFormat.Shape.ANY && formatAnno.shape() != JsonFormat.Shape.DEFAULT) {\n              _shape = formatAnno.shape();\n          }\n          if (formatAnno != null && formatAnno.pattern() != null && formatAnno.pattern() != \"\") {\n              _dateFormat = new SimpleDateFormat(formatAnno.pattern());\n              \n              if (_locale != null) {\n                  _dateFormat.setLocale(_locale);\n              }\n              if (_timeZone != null) {\n                  _dateFormat.setTimeZone(_timeZone);\n              }\n          } else {\n              _dateFormat = StdDateFormat.instance;\n          }\n      }\n      return this;\n  }\n  \n}",
