    "patch_code": "public class CustomDateTimeSerializer extends DateTimeSerializerBase<Date> {\n    \n    private static final long serialVersionUID = 1L;\n\n    public CustomDateTimeSerializer() {\n        super(Date.class, JsonFormat.Feature.ACCEPT_CASE_INSENSITIVE_PROPERTIES);\n    }\n\n    @Override\n    public JsonSerializer<?> createContextual(SerializerProvider serializers, BeanProperty property) throws JsonMappingException {\n        \n        // Call parent method to get base Date Serializer object with correct format\n        DateTimeSerializerBase<?> parent = (DateTimeSerializerBase<?>) super.createContextual(serializers, property);\n            \n        // Replace format from original DateSerializer\n        DateFormat df = parent._dateFormat;\n        if (!(df instanceof SimpleDateFormat)){\n            throw new IllegalArgumentException(\"CustomDateTimeSerializer requires SimpleDateFormat\");\n        }\n        SimpleDateFormat simpleDf = (SimpleDateFormat) df;\n        \n        JsonFormat.Value format = findFormatOverrides(serializers, property, handledType());\n        \n        if (format != null && format.hasPattern()){\n            simpleDf.applyPattern(format.getPattern());\n        }else{\n            simpleDf.applyPattern(simpleDf.toPattern());\n        }\n        \n        return this;\n    }\n    \n}",
    "patch_status": "UNCOMPILABLE",
