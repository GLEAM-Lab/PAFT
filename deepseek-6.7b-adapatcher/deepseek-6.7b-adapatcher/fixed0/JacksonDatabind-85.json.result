    "patch_code": "public abstract class DateTimeSerializerBase extends StdScalarSerializer<Date> implements ContextualSerializer {\n    private static final long serialVersionUID = 324597902659598268L;\n    \n    protected SimpleDateFormat _dateFormat;\n    protected boolean _timestampedAsNumberOfMillisecondsSinceEpoch;\n    \n    protected DateTimeSerializerBase(Class<Date> type) {\n        super(type);\n    }\n\n    @Override\n    public JsonSerializer<?> createContextual(SerializerProvider prov, BeanProperty property) throws JsonMappingException {\n        if (_dateFormat != null) {\n            return this;\n        }\n        \n        if (property == null) {\n            return this;\n        }\n        \n        DateFormat df = getFormat(prov, property);\n        \n        if (!(df instanceof SimpleDateFormat)) {\n            throw new IllegalArgumentException(\"Require SimpleDateFormat to obtain format definition\");\n        }\n        \n        final SimpleDateFormat simpleDf = (SimpleDateFormat) df;\n        final SimpleDateFormat myCopy = (SimpleDateFormat) simpleDf.clone();\n        myCopy.setLenient(_lenient);\n\n        return withFormat((myCopy == simpleDf), myCopy);\n    }\n    \n    protected Object _transform(Long value, SerializerProvider provider) throws IOException, JsonProcessingException {\n        /* note: unlike all other classes in this hierarchy, this one\n         * does not call method \"handleUnknown\" since we don't know what\n         * to do when an unknown (null) value is encountered. Instead,\n         * it simply returns the special value returned by #getTimestampAsFullDate;\n         */\n        if (_timestampedAsNumberOfMillisecondsSinceEpoch) {\n            return value.longValue();\n        }\n\n        synchronized (_dateFormat) {\n            try {\n                return _dateFormat.format(new Date(value));\n            } catch (RuntimeException ex) {\n                throw ex;\n            } catch (Exception ex) {\n                throw new RuntimeException(ex);\n            }\n        }\n    }\n\n    /**\n     * Since SimpleDateFormat instances used in different threads could potentially have\n     * different formats (even with the same pattern) we will ignore the current thread's locale while\n     * comparing patterns to avoid unnecessary object creations. This means, for example,\n     * two different SerializeProvider with Pattern \"yyyy-MM-dd\" should use equal instances\n     */\n    private int hashCodeForCompareToSameClass() {\n        if (_dateFormat == null) {\n            return 0;\n        }\n        String patterndHash = _dateFormat.toPattern().replaceAll(\"\\\\w*\", \"\");\n        return patterndHash.hashCode();\n    }\n}",
