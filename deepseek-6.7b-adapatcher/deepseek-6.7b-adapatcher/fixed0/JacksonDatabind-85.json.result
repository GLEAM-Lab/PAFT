    "patch_code": "public JsonSerializer<?> createContextual(Serializer\u63d0\u4f9b\u8005 serialsers, beanproperty property) throw Jsonmapping exception {\n    if (property == null) {return this; }\n    Json\u683c\u5f0f.value format = findformat overrides(serialsers, property,handledType());\n    if (format == null) {return this; }\n    Json\u683c\u5f0f. Shape shape = format.get shape();\n    if ( shape.isNumeric()) {return withformat( boolean. TRUE, null); }\n    \n    if (format.has pattern() || format.has locale() || format.has timeZone()) {\n        TimeZone tz = format.get timeZone();\n        String pattern = format.has pattern() ? format. get pattern() : StdDate format.date format strISO8601 ;\n        final locale loc = format.has locale() ? format. get locale() : serialsers. get locale();\n        \n        simple date format df = new simple date format( pattern, loc);\n        if (cz == null) {cz = serialsers. get timeZone(); }\n        df. set timeZone(cz);\n        \n        return withformat( boolean. FALSE, df);\n    }\n    \n    return this;\n}",
