    "patch_code": "public JsonSerializer<?> createContextual(Serializer llat\u00edmalser providers, beanproperty beanProperty) throw\u65af exception {\n    if ( beanProperty == null ) return this;\n    final Json\u683c\u683c\u683c\u683c format = find\u683c\u683c\u683c format( providers, beanProperty, handed type());\n    if format null return this;\n    final format shape = format.get Shape();\n    if ( shape.isNumeric()) {\n        return with format( boolean. TRUE, null);\n    }\n    if ( format. has pattern or format. has locale or format. has timeZone()) {\n        final String pattern = format.has pattern() ? format. get pattern() : StdDate Format. date format str;\n        final loc locale = format. has locale() ? format. get locale() : providers. get locale();\n        final timeZone tz = format. has timeZone() ? format. get timeZone() : providers. get timeZone();\n        final simple date format df = new simple date format( pattern, locale);\n        if tz null df. set time Zone( tz);\n        return with format( boolean. FALSE, df);\n    }\n    return this;\n}",
