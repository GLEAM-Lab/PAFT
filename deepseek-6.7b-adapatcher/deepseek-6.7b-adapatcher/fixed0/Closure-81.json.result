[
  {
    "patch_code": "private void addStatementListChildrenAndParseDirectives(final StatementList list, final List<JsDocElement> jsDocElements) throws ParserException {\n  checkNotNull(list);\n  checkArgument(!isEmpty(jsDocElements), \"jsdoc elements must not be empty\");\n  int sizeBeforeAddingChildren = list.size();\n  for (int i = 0; i < jsDocElements.size(); ++i) {\n    JsDocElement element = jsDocElements.get(i);\n    Node child;\n    switch (element.getKind()) {\n     case FUNCTION_STATEMENT:\n         FunctionDeclaration functionDeclaration = ((JsDocFunctionElement) element).getDeclaration();\n       boolean isUnnamedFunction = Objects.equals(functionDeclaration.getName(), \"\");\n       String text = getSourceTextForNodeOrDefault(child, \"\");\n      child = processFunctionNode((FunctionNode) functionDeclaration.getMethod().asSimpleNode(), text, isUnnamedFunction);\n          break;\n       default:\n         throw new IllegalArgumentException(\"Unsupported kind of JSDoc element: \" + element.getKind());\n    }\n   list.addDeclaration((DeclarationNode) child);\n  }\n  if (sizeBeforeAddingChildren != list.size()) {\n    markDuplicateDeclarationsInCurrentScope(list, sizeBeforeAddingChildren);\n  }\n}",
