  {
    "patch_code": "static abstract class Expr extends Node {\n    private boolean parenthesized;\n    void setParenthesized(boolean flag) { this.parenthesized = flag; }\n    \n    @Override String printNode(StringBuilder sb) {\n      if (!parenthesized && getKind() == Kind.CALL_EXPR && getNumChildren() == 2) {\n          ((CallExpr)this).setParened(true);\n          assert (((CallExpr)this).getName().equals(((CallExpr)this).getCallee()));\n          ((CallExpr)this).setLineNumber(((CallExpr)this).calleeBeginLine());\n          \n      }\n      \n      return super.printNode(sb);\n    }\n\n  }\n  \n  private void addCallSuffixAndArgumentsToFunCall(FunctionCallContext ctx) throws Exception {\n    \n\n    if (ctx.callKind() == FunctionCallContext.COMMA_LIST || ctx.callKind() == FunctionCallContext.POSTFIX) {\n      if (ctx.nodeKind() == COMPOUND_LITERAL) {\n         ctx.consume();\n         throw new Exception(parseState_.curr().toString() + \" invalid in initializer context\");\n      }\n    } else if (ctx.nodeKind() != IDENTIFIER && ctx.nodeKind()!= NEW_IDENTIFIER ){\n      throw new Exception(parseState_.curr().toString()+ \"invalid in call expr\");\n    }else {\n       ctx.consume();\n      if (ctx.nextNonCommentTriviaIsAmpersandOrEq()) {\n            throw new Exception(parseState_.curr().toString()+\"invalid in call expr\");\n      }\n      if (ctx.eat('.')) {\n        consumeDotMemberExpr(ctx, DOT_PROPERTY_ACCESSOR);\n      } else if (ctx.eat('[')) {\n        ctx.addChildToEnd(parseBracketAccessorListElem(ctx));\n      } else if (ctx.nextNonCommentTriviaIsNewlineCharacter()) {\n        createErrorForMistypedDeclarationIfNeeded(ctx);\n        throw new Exception(parseState_.curr().toString()+\"invalid in call expr\");\n      } else if (ctx.nextNonCommentTriviaInclude('.') || ctx.nextNonCommentTriviaInclude('[') || \n                  ctx.nextNonCommentTriviaEqualsIgnoreCase(\"++\")) {\n          parsePostfixPropertyPrimitiveLiteralGetter(ctx);\n          handlePropertyPrimaryInitializerErrorReporting(ctx, false);\n          //throw new Error(tokenStr +\" invalid identifier for 'getter' \");\n      }\n      \n    }\n    \n\n  }",
