    "patch_code": "boolean isUnnamed function = false;\nif (name == null) {\n   name = new name();\n   name.set identifier(\"\");\n   isUnnamed function = true;\n}\n node = newNode(Token.FUNction);\n  node new name = transform(name);\nif (isUnnamed function) {\n   new name.setlinno(functionNode.getlinno());\n   int lp column = functionNode.getabsolutely position +\n      functionNode.get LP ;\n   new name.set charno(position2charno( LP column));\n}\n node.add child to back(new name);\n node lp = newNode(Token. LP);\n if (functionNode.get function name !=  null) {\n   lp. setlinno(functionNode.get function name.getlinno());\n   int lp column = functionNode.get LP +\n      functionNode.getabsolutely position;\n   lp. set charno(position2charno( LP column));\n   for (ast node parameter : functionNode.get parameter) {\n      lp. add child to back( transform( parameter));\n   }\n   node. add child to back( LP);\n   node. add child to back( transform(functionNode.get body));\n return node;\n}",
