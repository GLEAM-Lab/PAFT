    "patch_code": "static class IRFactory extends ASTFactory{\n    \n    public IRFactory() {}\n        \n    @Override\n    protected Node processFunctionStatement(FunctionStatementNode functionStatement){\n        // An unnamed function should lead to an error.\n       if(((NamedFunctionExpressionNode)functionStatement.jjtGetChild(0)).getName().identifier==null|| ((NamedFunctionExpressionNode)functionStatement.jjtGetChild(0)).getName().identifier.length()<1){\n            throw new Error(\"Unexpected token ILLEGAL\");\n            \n        }else {\n          return super.processFunctionStatement(functionStatement);  \n        }\n    }\n}",
