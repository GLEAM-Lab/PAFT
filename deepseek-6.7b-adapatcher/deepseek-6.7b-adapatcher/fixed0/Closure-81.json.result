    "patch_code": "public Node processFunctionNode(FunctionNode functionNode) throws ParseException{\n  List<String> commentsBetweenTokens = new ArrayList<>();\n  TokenStream tokenStream = getTokenizer().getAllTokens();\n  while (!tokenStream.eof()) {\n    tokenStream.next();\n    boolean isLineTerminatorOrEndOfFileBeforeComment = false;\n    final boolean lastWasLineTerminatorInInput = tokenStream.lastWasLineTerminatorInInput();\n    if (!isSkippedToken && isBeforeFirstComment) {\n      // Add the start position after skipping any preceding whitespaces or tokens.\n      addSourceInfoForCommentElementStartIfNecessary();\n      isBeforeFirstComment = false;\n      int commentElementStartOffset = tokenStream.getCurrentOffset();\n      StringBuilder text = new StringBuilder();\n      do {\n        if (lineBreakFoundWhileScanningCommentsAndPossibleTrailingWhitespace(commentsBetweenTokens)) break;\n        handleEscapedCharactersWhenScanningComments(text);\n        \n       char nextCharacter = tokenStream.currentAsCharacter();\n      if (nextCharacter == '/') {\n        throw new ParseError(\"Unexpected token / \");\n      }\n      \n      }\n    }\n\n  Function function = buildFunctionFromNodes(nodeList);\n  \n  Node node = new Node();\n  node.setType(FunctionType.NODE_TYPE_FUNCTION);\n  node.setData((Object) function);\n  \n  updateSourceInfoAtEndOfFunctionStatement(tokenStream, sourceCodePropertyMap, offsetOfNextTokenAfterCodeEval, node);\n  \n  return node;\n  }\n}",
