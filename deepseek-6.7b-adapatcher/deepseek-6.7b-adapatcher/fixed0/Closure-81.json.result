    "patch_code": "import org.apache.java.util. StringUtil;\n...\nelse {\n    lp.setlinno(StringUtil.getLineNumber(functionNode.getLineNumber(),\n            functionNode.getLp(), functionNode.getabsposition());\n    lp.setcharno(position2charno(functionNode.getabsposition() +\n            functionNode.getLp());\n    for (AstNodeparam : functionNode.get parameters()) {\n        lp.addchildtoback( transform(param));\n    }\n}\nnode.addchildto back( LP);\nnode.addchildto back( transform(functionNode.getbody());\nreturn node;\n}",
