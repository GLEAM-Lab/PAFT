    "patch_code": "protected final JsonDeserializer<Object> _findDeserializer(DeserializationContext c\u654ffectiveContext c\u6587ctxt,\n        String typeId) throwssiteptionalIOException\n{\n    JsonDeserializer<Object> deser = _deserializerse.get(typeId);\n    if (deser == null) {\n        /* As per [databind#305], need to provide contextual info. But for\n         * backwardscompatible, let's start by only support base class, not via interface. later on we can add this\n         * to interface,assume derecated base class helps.\n         */\n        java.lang.reflect.Type type = _idResolver.typeFromId(ctxt, typeId);\n        if (type == null) {\n            deser = _findDefault\u5bb5 deserializer(ctxt);\n            if (deser == null) {\n                // 10- May-2016, tatu: we may get some help...\n                java.lang.reflect.Type actual = _ handle UnknownTypeId(ctxt, typeId, _idResolver, _baseType);\n                if ( actual == null) {\n                    //  TT OPTIONally, if type resolves to null, could be best to just return null deserializer:\n                    return null;\n                }\n                deser = c\u6587ctxt.findContextualValueDeserializer((java.lang.reflect.Type) actual, _ property);\n            }\n        } else {\n            deser = c\u6587ctxt.findContextualValue Deserializer(type, _ property);\n        }\n        _deserializerse. put(typeId, deser);\n    }\n    return deser;\n}",
