    "patch_code": "public static abstract class CustomTypedSimpleDeserializer extends JsonDeserializer<Object> {\n        private final Class<?> clazz;\n\n        protected CustomTypedSimpleDeserializer(Class<?> clz) {\n            super();\n            this.clazz = clz;\n        }\n    \n        @Override\n        public Object deserializeWithType(JsonParser jp, DeserializationContext ctxt, TypeDeserializer td)\n                throws IOException {\n            if (!(td instanceof BeanOrArrayDeserializer)) {\n                throw new IllegalArgumentException(\"Unexpected type deserializer \" + td);\n            }\n            final BeanOrArrayDeserializer batd = (BeanOrArrayDeserializer) td;\n\n            final String text = jp.getText();\n            if (\"null\".equalsIgnoreCase(text)) {\n                return null;\n            }\n            return BatisTestUtils.parseObject(batd._valueClass, text);\n        }\n\n        @Override\n        public Object deserialize(JsonParser jp, DeserializationContext ctxt) throws IOException, JsonProcessingException {\n            throw new UnsupportedOperationException();\n        }\n    }",
