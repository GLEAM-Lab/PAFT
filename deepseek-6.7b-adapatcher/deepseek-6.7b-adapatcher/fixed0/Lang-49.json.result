    "patch_code": "public Fraction reduce() throws IllegalArgumentException{\n    // TODO : What do we want our program to do when denomiator == 0?\n    if (denominator==0){ \n        throw new IllegalArgumentException(\"Denominator should not be zero\");\n     }\n    int gcd = greatestCommonDivisor(Math.abs(numerator), Math.abs(denominator));\n    boolean negateFlag=false;\n    if ((numerator<0 && denominator>0)||(numerator>0&&denominator<0)){\n        negateFlag=true;\n    }\n        \n    numerator=Math.abs(numerator)/gcd;\n    denominator=Math.abs(denominator)/gcd;\n     \n    if (negateFlag==true){\n        numerator=-numerator;\n        denominator=Math.abs(denominator);\n    }  \n          \n          return new Fraction(this.numerator, this.denominator);\n}",
