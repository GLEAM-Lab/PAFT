    "patch_code": "public Fraction reduce() {\n    int gcd = greatestCommonDivisor(Math.abs(numerator), denominator);\n    if (gcd == 1 && Math.abs(numerator) != 0 ) {\n        return new Fraction(numerator,denominator);\n    } else if (Math.abs(numerator) == 0){ \n        return new Fraction();\n    } else {\n        return new Fraction(numerator / gcd, denominator / gcd).reduce();\n    }\n}",
