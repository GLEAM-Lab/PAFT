    "patch_code": "private static final Fraction ZERO_FRACTION = new Fraction(0, 1);\n\npublic Fraction reduce() throws IllegalArgumentException{\n    int gcd = MathUtils.greatestCommonDivisor(Math.abs(numerator),denominator);\n\n    if (numerator==0){\n       throw new IllegalArgumentException();\n    }else if(gcd ==1 && numerator!=0){\n      return this;  \n     } else {\n         return getFraction((numerator)/gcd,(denominator)/gcd).simplify();\n     }\n}\n\npublic boolean equals(Object object) {\n    if (!(object instanceof Fraction)) {\n        return false;\n    }\n    Fraction other = (Fraction) object;\n    try {\n        other = other.reduce();\n    } catch (IllegalArgumentException e) {\n        return numerator == 0 && other.numerator == 0 && denominator == other.denominator;\n    }\n    return numerator == other.numerator && denominator == other.denominator;\n}",
