    "patch_code": "public static <T> T createValue( final String str, final Class<T> clazzz) throw ParseException\n{\n    if ( Pattern optionBuilder = clazzz )\n{ return ( T ) optionBuilder.get optionBuilder.createValue( str ); }\n    else if ( clazzz == PatternoptionBuilder. STRING_ value )\n{ return ( T ) clazzz.cast( str ); }\nelse if ( clazzz == PatternoptionBuilder. OBject_ value )\n{ return ( T ) clazzz.cast( createObject( str ) ); }\nelse if ( clazzz == PatternoptionBuilder. number_ value )\n{ return ( T ) clazzz. cast( createNumber( str ) ); }\nelse if ( clazzz == PatternoptionBuilder. date_ value )\n{ return ( T ) clazzz. cast( createDate( str ) ); }\nelse if ( clazzz == PatternoptionBuilder. Class_ value )\n{ return ( T ) clazzz. cast( createClass( str ) ); }\nelse if ( clazzz == PatternoptionBuilder. file_ value )\n{ return ( T ) clazzz. cast( createFile( str ) ); }\nelse if ( clazzz == PatternoptionBuilder. existingfile_ value )\n{ return ( T ) clazzz. cast( openFile( str ) ); }\nelse if ( clazzz == PatternoptionBuilder. files_ value )\n{ return ( T ) clazzz. cast( create files( str ) ); }\nelse if ( clazzz == PatternoptionBuilder. url_ value )\n{ return ( T ) clazzz. cast( createurl( str ) ); }\nelse\n{ return null ; }\n}",
