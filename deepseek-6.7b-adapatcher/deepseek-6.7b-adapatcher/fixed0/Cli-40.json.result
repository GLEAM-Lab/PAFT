    "patch_code": "import java.text.ParseException;\nimport org.apache.commons.cli.*;\n\npublic abstract class AbstractTypeHandler implements TypeHandler<Object> {\n    \n    public static Object createValue(final String s, final Class<?> c) throws ParseException {\n        \n        if (!c.equals(String.class)) \n            throw new ParseException(\"Unsupported class \" + c, -1);\n            \n        if (isBooleanPrimitive(c)){\n            return Boolean.parseBoolean(s);\n        }else if (isBytePrimitive(c)) {\n            return Byte.parseByte(s);\n        }else if (isShortPrimitive(c)) {\n            return Short.parseShort(s);\n        }else if (isIntegerPrimitive(c)) {\n            return Integer.parseInt(s);\n        }else if (isLongPrimitive(c)) {\n            return Long.parseLong(s);\n        }else if (isCharacter(c)) {\n            if (s.length() != 1)\n                throw new IllegalArgumentException();\n            return Character.valueOf(s.charAt(0));\n        }else if (isFloatPrimitive(c)) {\n            return Float.parseFloat(s);\n        }else if (isDoublePrimitive(c)) {\n            return Double.parseDouble(s);\n        }else {\n            throw new ParseException (\"Invalid class\"+c ,-1);\n        }\n        \n    }\n    \n   private static boolean isBooleanPrimitive(Class<?> c){\n       return c==boolean.class;\n   } \n   \n   private static boolean isBytePrimitive(Class<?> c){\n       return c==byte.class;\n   }\n   \n   private static boolean isShortPrimitive(Class<?> c){\n       return c==short.class;\n   }\n   \n   private static boolean isIntegerPrimitive(Class<?> c){\n       return c==int.class;\n   }\n   \n   private static boolean isLongPrimitive(Class<?> c){\n       return c==long.class;\n   }\n   \n   private static boolean isCharacter(Class<?> c){\n       return c==char.class;\n   }\n   \n   private static boolean isFloatPrimitive(Class<?> c){\n       return c==float.class;\n   }\n   \n   private static boolean isDoublePrimitive(Class<?> c){\n       return c==double.class;\n   }\n}",
