  {
    "patch_code": "import java.text.*;\nimport org.apache.commons.cli.*;\n\npublic static <T> T createValue(final String str, final Class<T> clazz) throws ParseException\n{\n    \n        // String\n       if(clazz == PatternOptionBuilder.STRING_VALUE){\n           try {\n               return (T) str;\n           } catch(Exception e){\n                throw new ParseException(\"Error parsing string:\" + str);\n            }\n         } \n        // Objects \n       else if(clazz == PatternOptionBuilder.OBJECT_VALUE){\n           try {\n               return (T) createObject(str);\n           }catch(Exception e){\n                throw new ParseException(\"Error creating object from string:\" + str);\n            }\n         \n     \n        }  \n        // Numbers\n       else if(clazz == PatternOptionBuilder.NUMBER_VALUE){\n           try {\n               return (T) createNumber(str);\n           } catch(Exception e){\n                throw new ParseException(\"Error creating number from string:\" + str);\n            }\n            \n        } \n        // Dates \n        else if(clazz == PatternOptionBuilder.DATE_VALUE){\n           try {\n              return (T) createDate(str);\n            }catch(Exception e){\n                 throw new ParseException(\"Error creating date from string:\" + str);\n             }\n\n        } \n        // Classes \n        else if(clazz == PatternOptionBuilder.CLASS_VALUE){\n            try {\n              return (T) createClass(str);\n            }catch(Exception e){\n                throw new ParseException(\"Error creating class from string:\" + str);\n             }\n\n        } \n        // Files \n        else if(clazz == PatternOptionBuilder.FILE_VALUE){\n            try {\n              return (T) createFile(str);\n            }catch(Exception e){\n                 throw new ParseException(\"Error creating file from string:\" + str);\n             }\n\n        } \n        // Existing Files \n        else if(clazz == PatternOptionBuilder.EXISTING_FILE_VALUE){\n            try {\n              return (T) openFile(str);\n            }catch(Exception e){\n                 throw new ParseException(\"Error opening existing file from string:\" + str);\n             }\n\n        } \n        // File List\n        else if(clazz == PatternOptionBuilder.FILES_VALUE){\n            try {\n              return (T) createFiles(str);\n            }catch(Exception e){\n                 throw new ParseException(\"Error creating files list from string:\" + str);\n             }\n\n        } \n        // URLs \n        else if(clazz == PatternOptionBuilder.URL_VALUE){\n            try {\n              return (T) createURL(str);\n            }catch(Exception e){\n                 throw new ParseException(\"Error creating url from string:\" + str);\n             }\n      \n        }else{\n            throw new IllegalArgumentException (\"Unhandled data type:\"+ clazz);\n        }\n    \n}",
