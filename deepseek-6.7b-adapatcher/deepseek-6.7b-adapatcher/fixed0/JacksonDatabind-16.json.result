    "patch_code": "protected final void addOrMergeFrom(AnnotationMap source) {\n    for (Entry<Class<? extends Annotation>, Annotation> entry : source._annotations.entrySet()) {\n        Class<? extends Annotation> clazz = entry.getKey();\n        Annotation ann = entry.getValue();\n        if (!_annotations.containsKey(clazz)) {\n            _annotations.put(clazz, ann);\n        } else {\n            // since we do not support merging of multi valued properties at present\n            // simply override current definition instead of attempting to merge or ignore\n            _annotations.replace(clazz, ann);\n        }\n    }\n}",
