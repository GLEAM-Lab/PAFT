    "patch_code": "protected final boolean _add(Annotation ann) {\n        if (ann instanceof JacksonAnnotationsInside){\n            // Add all contained annotations as well\n            for (Annotation a : ((JacksonAnnotationsInside) ann).value()) {\n                if (!_add(a)) {\n                    return false;\n                }\n            }\n        } else if (_annotations == null) {\n            _annotations = new HashMap<Class<? extends Annotation>,Annotation>();\n        }\n        Annotation previous = _annotations.put(ann.annotationType(), ann);\n        return (previous != null) && previous.equals(ann);\n    }",
