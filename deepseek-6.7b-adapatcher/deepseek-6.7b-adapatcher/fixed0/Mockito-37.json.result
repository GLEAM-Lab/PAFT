    "patch_code": "private final Object mock;\n    \n    public AnswersValidator(Object mock) {\n        this.mock = mock;\n    }\n\n    @Override\n    public void validate(Answer<?> answer, Invocation invocation) {\n        if (answer == null) {\n            throw new NullPointerException(\"Stubbing must have an answer\");\n        }\n        if (answer instanceof ThrowsException) {\n            validateException((ThrowsException) answer, invocation);\n        } else if (answer instanceof Returns) {\n            validateReturnValue((Returns) answer, invocation);\n        } else if (answer instanceof DoesNothing) {\n            validateDoNothing((DoesNothing) answer, invocation);\n        } else {\n            throw new IllegalArgumentException(\"Invalid stubbing type: \" + answer);\n        }\n        \n    }",
