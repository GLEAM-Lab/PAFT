    "patch_code": "import org.mockito.invocation.Invocation;\nimport org.mockito.stubbing.OngoingStubbing;\n\npublic class AnswersValidator extends OngoingStubbing {\n     public AnswersValidator(Invocation invocation) {\n        super(null, null); // we don't care about these parameters here as they are never used\n        this.validate(invocation);\n      }\n      \n      private boolean hasValidParamsForStaticMethod(){\n          return methodUnderTest != null && \"static\".equalsIgnoreCase(methodUnderTest.getDeclaringClass().getName());\n      }\n      \n    public void validate(final Invocation invocation) {\n        String simpleName = getTestedType() == Void.TYPE ? void.class.getSimpleName(): getTestedType().getSimpleName();\n        Object valueToSetFromMock = getValue(invocation);\n        String valueAsString = valueToSetFromMock == null ? \"null\" : valueToSetFromMock.toString();\n        if(!hasValidParamsForStaticMethod()){\n            throw new IllegalArgumentException(\"No parameters for static methods. Found:\" + simpleName);\n        } else if (!methodMatchesSignature(simpleName)) {\n                throw new IllegalArgumentException(\"Mismatched types in stubbing: expected \" + getTestedType());\n            }else if (!isParameterCountEqualOrSmaller()) {\n                  throw new IllegalArgumentException(\"Mismatched argument counts. Found at least one argument that doesn't match any method declared on the mock object.\");\n              }else if (!argumentsMatch()) {\n                      throw new IllegalArgumentException(\"Argument matching failed\");\n           }\n            \n        if (answer instanceof ThrowsException) {\n            validateException((ThrowsException) answer, invocation);\n        }\n        \n        if (answer instanceof Returns) {\n            validateReturnValue((Returns) answer, invocation);\n        }\n        \n        if (answer instanceof DoesNothing) {\n            validateDoNothing((DoesNothing) answer, invocation);\n        }\n        \n    }\n}",
