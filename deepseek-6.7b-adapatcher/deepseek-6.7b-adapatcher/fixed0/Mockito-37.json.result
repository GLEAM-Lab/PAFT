    "patch_code": "public void validate(Answer<?> answer, Invocation invocation) {\n       Object mock = invocation.getMock();\n       AnswerWrapper wrapper;\n        try{\n             wrapper = (AnswerWrapper) mock;\n        }catch(ClassCastException e){\n           throw new AssertionError(\"Mock was not created using the Answer syntax\");\n      }\n      Class<?>[] parameterTypes=invocation.getMethod().getParameterTypes();\n     //If there's more than one param,it means it's a method or constructor stubbing.\n     // We won't know what class they belong to so we can't validate them just yet.  \n     if (parameterTypes !=null && parameterTypes.length > 1 ) return;\n       if (answer instanceof ThrowsException) {\n            validateException((ThrowsException) answer, invocation);\n        }\n        else if (answer instanceof Returns) {\n            validateReturnValue((Returns) answer,invocation,wrapper);\n        }\n        else if (answer instanceof DoesNothing) {\n            validateDoNothing((DoesNothing) answer, invocation);\n        }\n}\n\nprivate static void validateReturnValue(final Returns returns,Invocation invocation,AnswerWrapper wrapper){\n     // Get real value that user stubbed in this method call\n     final Object resultToBeReturned = invocation.getArgumentAt(0,returns.getType());\n     try{\n          // Test if real returned value meets expectation\n          assertTrue(resultToBeReturned == returns.getValue() || returns.getValue().equals(resultToBeReturned));\n     }catch(AssertionError e){\n         fail(\"Expected:\" + returns.getValue()+\",but actually got:\" + resultToBeReturned );\n     }\n}",
