    "patch_code": "public int[] add(ReadablePartial incomplete, int fieldIndex, int[] values, int valueToAdd) {\n    if (valueToAdd == 0) {\n        return values;\n    }\n    long instant = 0L;\n    for (int i = 0, size = incomplete.size(); i < size; i++) {\n        instant = incomplete.getFieldType(i).getField(iChronology).set(instant, values[i);\n    }\n    instant = add(instant, valueToAdd);\n    return iChronology.get(in incomplete, instant);\n}",
