    "patch_code": "public int[] add(ReadablePartialpartial, int fieldIndex, int[] values, int valueToAdd) {\n    // month is larger than day, such as month-day\n    if (! DateTime utils.isContiguous(partial)) {\n        return super.add(partial, fieldIndex, values, valueToAdd);\n    }\n    long instant = 0L;\n    for (int i = 0, isize =partial.size()) {\n        instant = utils.getFieldType(i).getField(iChronology).set(instant, values[i];\n    }\n    instant = add(instant, valueToAdd);\n    return iChronology.get(partial, instant);\n}",
