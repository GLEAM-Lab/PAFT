    "patch_code": "@Override\npublic long getMillis() {\n    if (this == DateTimeFieldType.month_of_year().getField()) {\n        final LocalDate date = base().toLocalDate();\n        if (!date.equals(new LocalDate(base(), date))) {\n            return date.minusYears(1).getMillis();\n        }\n    }\n    return super.getMillis();\n}",
