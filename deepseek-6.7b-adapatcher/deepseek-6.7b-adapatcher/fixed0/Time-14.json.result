    "patch_code": "import org.joda.time.*;\nimport org.joda.time.format.*;\n\npublic class Main implements Comparable<Object>{\n    \n    public static void m7() {\n        try {\n            \n            DateTime now = new DateTime();\n            System.out.println(\"now : \" + now);\n            \n            Interval interval = new Interval(DateTime.parse(\"2020-08-01T00:00:00\"), now);\n            Period p = interval.toPeriod().normalizedStandard();\n            \n            int year = p.getYears();\n            int month = p.getMonths();\n            int day = p.getDays();\n            \n            StringBuilder sb = new StringBuilder();\n            \n            if (year != 0) {\n                String strYear = Integer.toString(year);\n                \n                int count = 0;\n                while(strYear.length() > 3) {\n                    if ((count + 1) % 3 == 0){\n                        sb.insert(0, \", \");\n                    }else {\n                        sb.insert(0, \"\");\n                        \n                    }\n                    count++;\n                }\n                sb.insert(0, strYear+\"\ub144\");\n            }\n            \n            if (month != 0) {\n                String strMonth = Integer.toString(month);\n                sb.insert(0, strMonth + \"\uac1c\uc6d4\");\n            }\n            \n            if (day != 0) {\n                String strDay = Integer.toString(day);\n                sb.insert(0, strDay + \"\uc77c\");\n            }\n            \n            String result = sb.toString();\n            \n            System.out.println(\"result : \" + result);\n        } catch (Exception e) {\n        }\n        \n    }\n    \n    \n    public static void main(String[] args) throws Exception{\n        \n        Thread t = new Thread(){\n            \n            @Override\n            public void run() {\n                m7();\n            }\n        };\n        t.start();\n        t.join();\n        \n    }\n    \n    \n    @Override\n    public int compareTo(Object o) {\n        \n        return 0;\n    }\n    \n    \n}",
