  {
    "patch_code": "private static final DateTimeZone UTC_ZONE = DateTimeZone.forID(\"UTC\");\n\nstatic void plusTest() {\n    final Chronology chrono = ISOChronology.getInstanceUTC();\n    System.err.printf(\"%1$4d %2$3d\\n\", 2008, 2);\n    chrono.dateTime(new LocalDate(2008, 2, 28)).plusMonths(1);\n    chrono.dateTime(new LocalDate(2008, 2, 28)).plusYears(1);\n    chrono.dateTime(new LocalDate(2008, 12, 30)).plusYears(1);\n    chrono.dateTime(new LocalDate(2008, 12, 30)).plusMonths(1);\n    System.err.printf(\"%1$4d %2$3d\\n\", 2008, 6);\n    chrono.dateTime(new LocalDate(2008, 6, 30)).plusMonths(1);\n    chrono.dateTime(new LocalDate(2008, 6, 30)).plusWeeks(1);\n    chrono.dateTime(new LocalDate(2008, 12, 28)).plusMonths(1);\n    chrono.dateTime(new LocalDate(2008, 12, 28)).plusDays(1);\n    System.err.printf(\"%1$4d %2$3d\\n\", 2008, 9);\n    chrono.dateTime(new LocalDate(2008, 9, 30)).plusMonths(1);\n    chrono.dateTime(new LocalDate(2008, 9, 30)).plusQuarters(1);\n    chrono.dateTime(new LocalDate(2008, 12, 31)).plusMonths(1);\n    chrono.dateTime(new LocalDate(2008, 12, 31)).plusYears(1);\n    System.err.printf(\"%1$4d %2$3d\\n\", 2016, 2);\n    chrono.dateTime(new LocalDate(2016, 2, 29)).plusYears(1);\n    chrono.dateTime(new LocalDate(2016, 2, 29)).plusDays(1);\n}",
