  {
    "patch_code": "public int[] add(ReadablePartial partial, int fieldIndex, int[] values, int valueToAdd) {\n    // overridden as superclass algorithm can't handle\n    // 2004-02-29 + 48 months -> 2008-02-29 type dates\n    if (valueToAdd == 0) {\n        return values;\n    }\n        // month is largest field and being added to, such as month-day\n    if (DateTimeUtils.isContiguous(partial)) {\n        long instant = 0L;\n        for (int i = 0, isize = partial.size(); i < isize; i++) {\n            instant = partial.getFieldType(i).getField(iChronology).set(instant, values[i]);\n        }\n        \n        boolean isLeapYear= YearMonth.from(iChronology.dateTime()).year().isLeap();\n        LocalDate localDate = LocalDate.of(values[1], values[0], values[2]);\n        while(valueToAdd != 0){\n            \n            localDate=localDate.plusDays(1);\n            \n            if(localDate.getDayOfMonth()==1 && localDate.lengthOfMonth()!=localDate.getDayOfMonth()) {\n                valueToAdd -- ;\n            }else if(localDate.getDayOfMonth()==1 && localDate.lengthOfMonth()==localDate.getDayOfMonth()&& isLeapYear) {\n                valueToAdd -- ;\n            }else if(localDate.equals(LocalDate.of(values[1], values[0], values[2])) ){\n                 break;\n            }\n        }\n        return new int[] {localDate.getMonthValue(),localDate.getYear(),localDate.getDayOfMonth()};\n    } else {\n        return super.add(partial, fieldIndex, values, valueToAdd);\n    }\n}",
