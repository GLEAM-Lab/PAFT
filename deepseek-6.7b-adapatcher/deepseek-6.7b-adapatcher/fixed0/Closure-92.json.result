    "patch_code": "void add() {\n  if (firstNode == null) {\n    // Don't touch the base case ( 'goog' ) or any provided symbol that is not\n    // in the first module ( ' goog. provide' ) or any symbol that is provided by\n    // multiple independent module ( ' goog. provide / Apps provide' ).\n    return;\n  }\n\n  if (explicitNode != null || minimum module != first module) {\n    return;\n  }\n\n  // Handle the case where there is no definition yet for an provided symbol.\n  if (candidate definition !=  null) {\n    if (explicit definition !=  null) {\n      // The provided symbol is defined by two independent module and is not\n      // defined by any module yet ( ' goog. provide / Apps provide' )\n      return;\n    }\n    if (first module !=  minimum module) {\n      // The provided symbol is defined by two independent module and is not defined by any module yet\n      return;\n    }\n    if (!is provided symbol) {\n      // The provided symbol is not provided yet ( ' foo. bar. C' )\nreturn;\n    }\n    // The provided symbol is defined by one module and is not defined yet ( ' foo. bar. C' )\n    return;\n  }\n  // The provided symbol is defined by one module and is already defined ( ' foo. bar. C' )\n  if (explicit definition !=  null) {\n    return;\n  }\n  if (first module !=  minimum module) {\nreturn;\n}\n  \n  // The provided symbol is defined by one module and is not defined yet ( ' foo. bar. C' )\n  return;\n}",
