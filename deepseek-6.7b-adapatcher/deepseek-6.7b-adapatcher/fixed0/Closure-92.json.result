    "patch_code": "void replace() {\n  if (firstNode == null || compiler.compilerOptions_.simplifyImports()) {\n    // Don't touch the base case ('goog').\n    replacementNode = candidateDefinition;\n    return;\n  }\n\n  if (candidateDefinition != null && explicitNode != null) {\n    explicitNode.detachFromParent();\n    compiler.reportCodeChange();\n    \n    if (NodeUtil.isExpressionNode(candidateDefinition)){\n      \n      Node expressionNode=candidateDefinition.getFirstChild();\n      \n      Node variableNode=expressionNode.getLastChild();\n      expressionNode.removeChild(variableNode);\n      \n      Node initializerNode=null;\n      while(!expressionNode.isEmpty()){\n        \n        initializerNode=expressionNode.getLastChild();\n        \n        expressionNode.removeChild(initializerNode);\n      }\n      ReplaceableNode.asReplaceableNode(initializerNode).unwrapComplexExpressions();\n      candidateDefinition.getParent().replaceChild(\n          candidateDefinition, initializerNode);\n      compiler.reportCodeChange();\n      \n    }else {\n      \n      replacementNode = candidateDefinition;\n      if (NodeUtil.isExpressionNode(candidateDefinition)) {\n        candidateDefinition.putBooleanProp(Node.IS_NAMESPACE, true);\n        Node assignNode = candidateDefinition.getFirstChild();\n        Node nameNode = assignNode.getFirstChild();\n        if (nameNode.getType() == Token.NAME) {\n          \n          NameReferencingVisitor nrv=new NameReferencingVisitor();\n          assignNode.visitChildren(nrv);\n          List<Reference> referencesList=nrv.references();\n          for(Reference ref:referencesList){\n            \n            String name=ref.getName();\n            String module=ref.module_;\n            \n            if(module.equalsIgnoreCase(\"\")){\n              \n              continue;\n            }\n            \n            boolean shouldAddImportStatement=true;\n            Import importInFile=importsInFile.getOrDefault(module, null);\n            if(importInFile!=null && importInFile.hasSymbol(name)){\n              \n              shouldAddImportStatement=false;\n            }\n            \n            if(shouldAddImportStatement){\n              \n              Import insertionPoint=null;\n              \n              int i=0;\n              for (;i<importsInFile.size();++i){\n                \n                InsertionResult result=insertionOrder.compare(importsInFile.get(i), module);\n                if(result==InsertionResult.BEFORE){\n                  break;\n                }else if(result==InsertionResult.AFTER){\n                  \n                  continue;\n                }\n              }\n              if (i < importsInFile.size()) {\n                throw new IllegalStateException();\n              }\n              importInFile = new Import();\n              importsInFile.add(i, importInFile);\n            }\n            importInFile.addProviderName(candidateProviderName);\n            referenceCountByReferenceId.increment(ref.referenceId_);\n            \n            ImportManager.Mark mark=manager.startManage(module);\n            manager.markNeededSymbolByReferenceIdAndMark(ref.referenceId_, mark);\n            \n          }\n        }\n      }\n    }\n  } else {\n    \n    if (!firstModule.equals(minimumModule)) {\n      \n      String[] names = namespace.split(\"\\\\.\");\n      for (int ii = 0; ii < names.length; ++ii) {\n        Import importInFile = importsInFile.getOrDefault(module + names[ii], null);\n        if (importInFile != null) {\n          break;\n        }\n        String subNamespace = \"\";\n        for (int jj = ii + 1; jj < names.length; ++jj) {\n          subNamespace += \".\"+names[jj];\n        }\n        addDependencyOnCurrentScript(module + subNamespace, \"goog\");\n      }\n    }\n    \n    replacementNode = createDeclarationNode();\n    if (explicitNode != null) {\n      explicitNode.detachFromParent();\n    }\n    compiler.reportCodeChange();\n  }\n}",
