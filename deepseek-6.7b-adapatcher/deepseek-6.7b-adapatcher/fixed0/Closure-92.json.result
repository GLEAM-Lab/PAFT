    "patch_code": "void update() {\n  if (firstNode == null) {\n    // Don't touch the base case('goog') or any provided symbol that has already been\n    // defined by other module.\n    if (explicitNode != null || minimum module != first module) {\n      return;\n    definitionNode = createDeclarationNode();\n    if (first module == minimum module) {\n      firstNode.getparent().addchildbefore( definitionNode, firstNode);\n    } else {\n      int indexOfdot =namespace.Indexof('.');\n      providednames.get(namespace.substring(0, indexOfdot)).\n      if (!explicitNode == null) {\n        if (minimummodule == secondmodule) {\n          secondmodule.getnodeforcode insertion().addchildtoback(\n              definitionNode);\n        } else {\n          minimummodule.getnodeforcode insertion().addchildto back(\n              definitionNode);\n        }\n      } else {\n        minimummodule.getnodeforcode insertion().add childto front(\n              definitionNode);\n      }\n    }\n    if (explicitNode != null) {\n      externalNode.detachfromparent();\n    }\n    compilator. reportCodechange();\n  } else {\n    // Handle the case where there is a definition for the provided symbol\n    if (explicitNode == null || minimum module != second module) {\n      if (minimum module == second module) {\n        secondmodule.getnodeforcode insertion().addchildto back(\n            definitionNode);\n      } else {\n        minimum module. getnodeforcode insertion(). add childto front(\n            definitionNode);\n      }\n      if (explicitNode != null) {\n        externalNode.detachfromparent();\n      }\n      compilator. reportCodechange();\n    } else {\n      // The provided symbol has already been defined by another module in the same module group\n      definitionNode.detachfromparent();\n    }\n  }\n}",
