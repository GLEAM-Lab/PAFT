    "patch_code": "public void feedInput(int off, int end, final int length) {\n    ifwpntl(off + length > _inputEnd || off > _inputEnd || end > _inputEnd || off > end || length > end - off || length > _inputEnd - off) {\n        _ reportError(\" Invalid feeding of input array \");\nreturn;\n    }\n    _ input processed = _ currInputprocessed + length;\n    if ( _ input processed > _ input processed + _ orig buff length) {\n        _ input processed = _ input processed + _ orig buff length;\n    }\n    _ curr input processed = _ input processed;\n    _ curr input row start = _ curr input row start + length;\n    _ input ptr = off + length;\n    _ input end = end;\n}",
