    "patch_code": "private static Set<String> unremovableStatements = ImmutableSet.of(\"if\", \"for\", \"while\");\n\nboolean hasSideEffects(Node n) {\n  \n  int type = n.getType();\n  \n  if (type == Token.CALL) {\n    \n    String calleeName = ((Name) n.getLastChild()).getValue();\n    \n    if (calleeName.equalsIgnoreCase(\"window.setTimeout\")) {\n      \n      return false;\n    }\n    \n    if (calleeName.equalsIgnoreCase(\"window.location\")) {\n      \n      return true;\n    }\n    \n    return !isFunctionExpression(n);\n  }\n  \n  if (type == Token.RETURN) {\n    \n    return false;\n  }\n  \n  if (type == Token.IF) {\n    \n    return hasSideEffects(n.getFirstChild());\n  }\n  \n  if (type == Token.FOR\n      || type == Token.WHILE\n      || type == Token.DO\n      || type == Token.SWITCH) {\n    \n    return true;\n  }\n  \n  if (unremovableStatements.contains(n.getName())) {\n    \n    return true;\n  }\n  \n  for (Node child : n.getChildren()) {\n    \n    if (hasSideEffects(child)) {\n      return true;\n    }\n  }\n  \n  return false;\n}",
    "patch_status": "UNCOMPILABLE",
