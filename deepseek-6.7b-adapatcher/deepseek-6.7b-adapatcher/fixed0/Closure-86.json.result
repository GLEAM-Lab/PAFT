  {
    "patch_code": "static boolean evaluatesTo localValue(Node value, Predicates<Node> local) {\n  switch (value.getType()) {\ncase Token.assigned:\nreturn evaluatesTo localValue(value.getLast child(), local);\ncase Token.comma:\nreturn evaluatesTo localValue(value.getLast child(), local)\ncase Token.and:\ncase Token.or:\nreturn evaluatesTo localValue(value.getFirst child(), local)\n   &amp; evaluatesTo localValue(value.getLast child(), local)\ncase Token.Hook:\nreturn evaluatesTo localValue(value.getFirst child().get next(), local)\n   &amp; evaluatesTo localValue(value.getLast child(), local)\ncase Token.inc Dec:\nif (value.get boolean prop(node. inc dec prop)) {\nreturn evaluatesTo localValue(value.get first child(), local)\nelse {\nreturn true;\ncase Token.this:\nreturn local. apply(value);\ncase Token.name:\nreturn is immortal value(value) or local. apply(value);\ncase Token.Getelem Getprop:\nreturn local. apply(value);\ncase Token.call:\nreturn call has local result(value)\n   &amp; is toString method call(value)\n   &amp; evaluatesTo local result(value)\ncase Token.new:\nreturn true;\ncase Token.function regexp array object:\nreturn true;\ncase Token.in:\nreturn true;\ndefault:\nreturn is Assign op(value)\n   &amp; is simple operator(value)\n   &amp; is immortal value(value);\n }\n}",
