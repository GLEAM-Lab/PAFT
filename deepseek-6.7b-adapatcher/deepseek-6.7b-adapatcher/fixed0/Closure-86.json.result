    "patch_code": "import com.google.javascript.rhino.*;\n\npublic class Main{\n   public static void main(String[] args){\n       Context cx = new Context();\n       \n       String program = \"var Foo = function () {\\n\" + \n               \"  var self = this;\\n\" + \n               \"  window.setTimeout(function() {\\n\" + \n               \"    window.location = self.location;}, 0);\\n\" + \n               \"};\\n\" + \n               \n               \"Foo.prototype.setLocation = function(loc) {\\n\" + \n               \"  this.location = loc;\\n\" + \n               \"};\\n\" + \n               \n               \"(new Foo()).setLocation('http://www.google.com/');\";\n\n        Scriptable scope = cx.initStandardObjects();\n        try {\n            cx.evaluateString(scope, program, null, 1, null);\n            \n            Object fooObject = ((JSObject)cx.runtime.findProperty(scope, \"foo\"));\n            JSFunction fooConstructor = (JSFunction)((JSObject)fooObject).getSlot(3).getPrototypeInstanceInfo().getInstance();\n            JSErrorReporter.reportErrorAndContinue(\"\");\n            \n            for (int i = 0 ; i < 4 ; i++ ) {\n                try {\n                    Scope closureScope = fooConstructor.closure.getSlot(i).asScope();\n                    String propertyName = closureScope.propertyNames[i].toString();\n                    System.out.println(propertyName+\": \"+closureScope.names[i]);\n                    \n                } catch(Throwable t) {}\n                \n            }\n            \n            \n        } finally {\n            \n            \n        }\n\n   }\n}",
