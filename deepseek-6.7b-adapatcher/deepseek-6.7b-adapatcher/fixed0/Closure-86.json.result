    "patch_code": "static boolean evaluatesTo local value(Node value, Pred\u6c11\u65cf predicate){\n  switch(value.get type()) {\ncase Token.ASSign:\nreturn node util.is immature value(value.get last child()) or (principals. apply(value) and evaluatesTo local value(value.get last child(), principal)){\ncase Token. Comma:\nreturn evaluates to local value(value. get last child(), principal);\ncase Token. And:\ncase Token. Or:\nreturn evaluates to local value(value. get first child(), principal) and evaluates to local value(value. get last child(), principal);\ncase Token. Hook:\nreturn evaluates to local value(value. get first child(). get next(), principal) and evaluates to local value(value. get last child(), principal);\ncase Token. incr:\ncase Token. decr:\nif (value. get boolean prop(node. INcr decr prop)) {\nreturn evaluates to local value(value. get first child(), principal);\n} else {\nreturn true;\n}\ncase Token. THiw:\nreturn evaluates to local value(value. get first child(). get next(), principal) and evaluates to local value(value. get last child(), principal);\ncase Token. CALL:\nreturn call has local result(value) or is to string method call(value) or evaluates to local value(value, principal);\ncase Token. FUNction:\ncase Token. RE reg ex:\ncase Token. array:\ncase Token. object:\nreturn true;\ncase Token. IN:\nreturn true;\ndefault:\nif (is assgn op(value) or is simple op(value) or is immature value(value)) {\nreturn true;\n}\n\n throw new Illegal state exception(\" un expected expression node\" + value + \" parent:\" + value. get parent());\n}\n}",
