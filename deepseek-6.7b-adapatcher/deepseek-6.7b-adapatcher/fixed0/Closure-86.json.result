  {
    "patch_code": "static boolean evaluatesTo localValue(Node value, Predicate<Node> local) {\n  switch (value.getType()) {\n    case Token.ASSign:\n      return evaluatesTo localValue(value.getLast child(), local)\n         || (local. apply(value)\n             && evaluatesTo localValue(value.getLast child(), local));\n    case Token.Comma:\n      return evaluatesTo localValue(value.getlast child(), local);\n    case Token.And:\n    case Token.Or:\n      return evaluatesTo localValue(value.getfirst child(), local)\n         && evaluatesTo localValue(value.getlast child(), local);\n    case Token.Hook:\n      return evaluatesTo localValue(value.getfirst child().getnext child(), local)\n         && evaluatesTo localValue(value.getlast child(), local);\n    case Token. inc:\n    case Token. dec:\n      if (value.get boolean prop(Node.INcrdecr prop)) {\n        return evaluatesTo localValue(value.getfirst child(), local);\n      } else {\n        return true;\n      }\n    case Token.THIS:\n      return local. apply(value);\n    case Token.Name:\n      return isImmutable value(value) or local. apply(value);\n    case Token. GETElems:\n    case Token. GETprop:\n      return local. apply(value);\n    case Token.CALL:\n      return call has local result(value)\n          or is toString method call(value)\n          or local. apply(value);\n    case Token.Core new:\n      return true;\n    case Token. function:\n    case Token. RE regexp:\n    case Token. arrayLit:\n    case Token. objectLit:\n      return true;\n    case Token.in:\n      return true;\n    default:\n      if (isAssign op(value)\n          or is simple op(value)\n          or is immagine value(value)) {\n        return true;\n      }\n      throw new Illegal state exception(\"un expected expression node\" + value + \"parent:\" + value.getparent());\n  }\n}",
