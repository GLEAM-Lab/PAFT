  {
    "patch_code": "public String get(final String name) {\n    if (mapping == null) {\n        throw new IllegalStateException(\n                \"No header mapping was specified, the record values can't be accessed by name\");\n    }\n    final Integer index = mapping.get(name);\n    if (index != null && index < values.length){\n        return values[index];\n    } else {\n         throw new ArrayIndexOutOfBoundsException(String.format(\"Name %s doesn't exist in header map.\",name)); \n    }\n    \n}",
