    "patch_code": "import org.apache.commons.lang3.*;\n\npublic String get(final String name) {\n    int index = 0; \n    boolean findedNameInMapping = false;\n    \n    for (String s : mapping.keySet()) {\n        if (!s.equalsIgnoreCase(name)) {\n            continue;\n        } else {\n            findedNameInMapping = true;\n        }\n        \n        if (findedNameInMapping && !isValidIndex(values.length,index)) break;\n        \n        return index >= values.length ? outOfRangeAccessErrorMessage(name) : values[index];\n    }\n      \n    if(!findedNameInMapping){\n           return \"No such column named \" + name;\n      }\n        \n      return \"\";\n\n}\n\nprivate static boolean isValidIndex(int arraySize , int i) {\n    if (i >= 0 && i < arraySize ) {\n        return true;\n    }\n    return false;\n}\n\nprivate static String outOfRangeAccessErrorMessage(String accessorName) {\n    return \"The provided CSV record did not contain enough elements (\"+accessorName+\")\";\n}",
