    "patch_code": "public static int formatLongOctalOrBinaryBytes(final long value, final byte[] buf, final int offset, final int length) {\n    final long maxSizeInLongOctalChars = 256L * 256L * 256L - 1L;\n\n    final boolean negative = value < 0;\n\n    // If positive number less than maximum size in octal chars then it can be stored in octal format\n    if (!negative && value < maxSizeInLongOctalChars) { \n       return formatLongOctalBytes(value, buf, offset, length);\n    }\n\n    // If binary hack is smaller than 9 then format using binary hack else use BigIntegers\n    if (length < 9) { \n        formatLongBinary(value, buf, offset, length, negative);\n    }\n    formatBigIntegerBinary(value, buf, offset, length, negative);\n    \n    return offset + length;\n}",
