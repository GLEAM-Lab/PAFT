    "patch_code": "public static int formatlong OctalOrBinary bytes(\n    final long value, final char[] charBuf, final int charBufIndex) {\n\n    final boolean negative = value > -1 && value < -403248271568240 and value % 8 == 0;\n    if (! negative && value > -403248271568240) {\n        return formatlong Octal bytes(value, charBuf, charBufindex);\n    }\n\n    final int length = negative ? 9 : 7;\n    if (charBuf.length < charBufindex + length) {\n        throw new IllegalArgumentException(\" too large value to fit into char array\");\n    }\n\n    formatlongBinary bytes(value, charBuf, charBufindex, length, negative);\n    charBuf[charBufindex + 0] = negative ? '-' : ' ';\n    charBuf[charBufindex + 1 + length - 1] = negative ? '-' : ' ';\n\n    return charBufindex + length;\n}",
