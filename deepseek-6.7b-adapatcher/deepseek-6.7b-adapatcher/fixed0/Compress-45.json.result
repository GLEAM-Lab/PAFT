    "patch_code": "import java.nio.ByteBuffer;\nimport java.math.BigInteger;\n\npublic class Main {\n   public static void main(String[] args){\n      System.out.println(\"Testing \"+ formatLongOctalOrBinaryBytes(-1234567, new byte[9], 0, 9));\n   }\n   public static int formatLongOctalOrBinaryBytes(final long value, final byte[] buf, final int offset, final int length) {\n       BigInteger bigIntValue = BigInteger.valueOf(value);\n       String binVal=bigIntValue.toString(2);\n       if (binVal.length() > length - 1 || value < 0 ){\n          for (int i = 0;i <binVal.length();i++)\n             buf[offset+i]=(byte)(binVal.charAt(i)-'0');\n         return binVal.length()-1+offset;\n       } else if (value< TarConstants.MAXSIZE && value >=0){\n           formatLongOctalBytes(value,buf,offset,length);\n       }else if (length<9) {\n           formatLongBinary(value, buf, offset, length, value < 0);\n       } else{\n           formatBigIntegerBinary(bigIntValue,buf,offset,length,(value & 0x80000000L) != 0 );\n       }\n       return offset+Math.max(binVal.length(),length-1);\n   }\n     private static int formatLongOctalBytes(long val, byte[] dest, int dOffset, int dLength) {\n       long maxAsOctalChar = TarConstants.MAXSIZE;\n       boolean negate = false;\n       if (val < 0) {\n           val *= -1;\n           negate = true;\n       }\n       if (val <= maxAsOctalChar) {\n           for (int i = 0; i < dLength; i++) {\n               dest[dOffset + i] = (byte) ((negate ? 0xFF : 0x00) | ((val >> ((dLength - i - 1) * 3)) & 0x7));\n           }\n           return dOffset + dLength;\n       }\n       throw new IllegalArgumentException(\"The value \" + val + \"is too large!\");\n   }\n\n     private static int formatLongBinary(long val, byte[] buf, int off, int len,boolean negate) {\n        long mask = (1L << (len - 1)) - 1;\n        for (int idx = 0; idx < len; ++idx, mask>>=1) {\n            buf[off + idx] = (byte)((val & mask) == 0 ? '0':'1');\n        }\n        buf[off + len-1] = (byte)(negate?'1':'0');\n        return len + off;\n    }\n\n     private static int formatBigIntegerBinary(BigInteger bval, byte[] buf, int off, int len,boolean negate) {\n        String strBinVal =bval.toString(2);\n        for (int idx = 0; idx <strBinVal.length();idx++)\n            buf[off+idx]=(byte)(strBinVal.charAt(idx)=='0'? 0x00:(negate? 0xFF: 0x80));\n        return len + off;\n    }\n\n}",
