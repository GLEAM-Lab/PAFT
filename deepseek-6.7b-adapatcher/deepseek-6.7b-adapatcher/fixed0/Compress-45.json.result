    "patch_code": "private static void formatBigIntegerBinary(final long value, final byte[] buf, final int offset, final int length, boolean negative){\n    String binStr= Long.toBinaryString(Math.abs(value));\n    while (binStr.length()<length){\n        binStr =\"0\"+binStr;\n    }\n    for(int i = 0;i < length;i++){\n         char c = binStr.charAt(i);\n         buf[offset + i] = (byte)(c - '0');\n    }\n     if (negative){\n         for (int j = 0;j < length;j++){\n            buf[offset + j]= ~buf[offset + j];\n         }\n     }\n}\n\npublic static int formatLongOctalOrBinaryBytes(long value, byte[] buf, int offset, int length) {\n    long maxIdSize;\n    boolean negative;\n    // Check whether we are dealing with UID/GID or SIZE field\n    if (Objects.equals(fieldName,\"UID\")){\n        maxIdSize = TarConstants.MAXID ;\n      \n    } else if (Objects.equals(fieldName,\"GID\") ){\n        maxIdSize =TarConstants.MAXID ;\n     \n    }else {\n        maxIdSize = TarConstants.MAXSIZE;\n    }\n\n    negative = value < 0;\n    if(!negative && value <= maxIdSize){\n        return formatLongOctalBytes((long)value,buf,offset,length);\n    }\n\n    if (length < 9) {\n        formatLongBinary(value, buf, offset, length,negative);\n        return offset + length;\n    }\n   formatBigIntegerBinary(value, buf, offset, length,negative);\n\n    return offset + length;\n\n}",
