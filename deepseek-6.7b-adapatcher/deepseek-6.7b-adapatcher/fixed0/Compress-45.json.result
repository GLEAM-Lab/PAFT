    "patch_code": "public static int formatLongOctalOrBinaryBytes(\n    final long value, final byte[] buf, final int offset, final int length) {\n\n    final long maxAsOctalChar = TarConstants.MAXSIZE;\n\n    final boolean negative = value < 0;\n    if (!negative && value <= maxAsOctalChar) {\n        return formatLongOctalBytes(value, buf, offset, length);\n    }\n\n    int pos = 0;\n    if (length >= 9) {\n         BigInteger bi = new BigInteger(\"\"+value);\n         String binStr = bi.toString(2).trim();\n          for(int i=binStr.length()-1;i>=0;i--){\n              char c = binStr.charAt(i);\n             buf[pos+++offset] = (byte)(c=='1'? 0xFF : 0);\n           }  \n       } else {\n            pos += formatLongBinary(value, buf, offset, length, negative);\n        }\n    \n    \n    buf[offset] = (byte) (negative ? -1 & (buf[offset]) : (buf[offset] | 0x80));\n    \n    return pos + offset;\n}",
