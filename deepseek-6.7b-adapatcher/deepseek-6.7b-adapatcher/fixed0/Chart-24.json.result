    "patch_code": "import java.awt.*;\n\npublic class GrayPaintScale{\n    \n    private double lowerBound;\n    private double upperBound;\n\n    public GrayPaintScale(double lowerBound, double upperBound){\n        this.lowerBound=lowerBound;\n        this.upperBound=upperBound;\n    }\n\n    public Paint getPaint(double value){\n        double v = Math.max(value, this.lowerBound);\n        v = Math.min(v, this.upperBound);\n        \n        int g = (int) ((v - this.lowerBound)/(this.upperBound - this.lowerBound)*255.0);  \n       // (v- this.lowerBound ) / (this.upperBound- this.lowerBound) gives us the proportion of the data within our bounds\n        //multiplying it by 255 gets the corresponding shade in grey scale\n        return new Color(g, g, g);  \n      //we assign r, g ,b the same values because we have a grayscale pallet\n    }\n    \n    public static void main(String args[]){\n        GrayPaintScale test = new GrayPaintScale(-10.0, 30.0);\n\tSystem.out.println(\"Testing with input: \" + \"-7\"+\", output should be: \"+test.getPaint(-7));\n\tSystem.out.println(\"Testing with input: \" + \"40\"+\", output should be: \"+test.getPaint(40));\n    }\n\n}",
