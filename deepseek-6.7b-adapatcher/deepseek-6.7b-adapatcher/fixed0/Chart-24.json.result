    "patch_code": "import java.awt.Color;\nimport org.jfree.data.Range;\n\npublic class GrayPaintScale extends AbstractPaintScale {\n   private static final long serialVersionUID = 1L;\n   public Range domain;\n   public int lowerBound;\n   public int upperBound;\n\n   public GrayPaintScale(String id) {\n      super(id);\n   }\n\n   public void setDomain(Range range){\n       if(range != null){\n           this.domain = range;\n           this.setLowerBound((int)Math.ceil(this.domain.getLowerBound()));\n           this.setUpperBound((int)Math.floor(this.domain.getUpperBound()));\n       }else{\n           throw new IllegalArgumentException();\n       }\n   }\n\n   @Override\n   public synchronized void setLowerBound(int lowerBound) {\n       if(lowerBound > this.upperBound){\n           throw new IllegalArgumentException(\"lowerBound > upperBound\");\n       }\n       this.lowerBound = lowerBound;\n   }\n\n   @Override\n   public synchronized void setUpperBound(int upperBound) {\n        if(upperBound < this.lowerBound){\n            throw new IllegalArgumentException(\"upperBound < lowerBound\");\n        }\n        this.upperBound = upperBound;\n   }\n\n   @Override\n   public Paint getPaint(double value) {\n     // Make sure that 'value' is within bounds\n       value = Math.max(value, domain.getLowerBound());\n       value = Math.min(value, domain.getUpperBound());\n\n       // Calculate gray level\n       int g = (int) ((value - domain.getLowerBound()) / (domain.getUpperBound() - domain.getLowerBound()) * 255.0);\n       \n       return new Color(g, g, g);\n   }\n}",
