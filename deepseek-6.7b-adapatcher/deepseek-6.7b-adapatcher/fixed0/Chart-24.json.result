    "patch_code": "public class GrayPaintScale {\n    private double lowerBound;\n    private double upperBound;\n    \n    \n    public GrayPaintScale(double lowerBound, double upperBound){\n        if (lowerBound < upperBound && lowerBound != upperBound){\n            this.lowerBound = lowerBound;\n            this.upperBound = upperBound;  \n        }else{\n             throw new IllegalArgumentException(\"Invalid bounds\");\n        }        \n    }\n    \n    public java.awt.Color getPaint(double value){\n        double v = value;\n        if (value<lowerBound){\n            v=lowerBound;\n        } else if (value>upperBound){\n            v=upperBound;\n        }\n        int grayLevel = (int)((v - lowerBound)/(upperBound - lowerBound)*255.0f);\n        return new java.awt.Color(grayLevel,grayLevel,grayLevel);     \n    }\n}",
