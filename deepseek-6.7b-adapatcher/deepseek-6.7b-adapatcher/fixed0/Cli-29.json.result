    "patch_code": "static String stripLeadingAndTrailingQuotes(String str)\n{\n    boolean startQuoteFound = false;\n    if (str.charAt(0) == '\"'){\n       startQuoteFound = true;\n       str = str.substring(1, str.length());\n   }\n   int endIndex = str.length()-1;\n   boolean endQuoteFound = false;\n   if(str.charAt(endIndex)=='\"'){\n      endQuoteFound = true;\n   }\n   if(!startQuoteFound && !endQuoteFound){\n         //do nothing as string does not have any quotation at both ends.\n        return str;\n   }else if (!startQuoteFound ){\n         //remove ending quote\n          return str.substring(0, endIndex);\n   } else {\n         //remove starting quote\n           return str.substring(1, str.length());\n   }\n}",
