  {
    "patch_code": "private static String stripLeadingAndTrailingQuotes(String input){  \n    final String QUOTE_STR = \"\\\"\";\n    //check if starts with quote  \n    if(input.startsWith(QUOTE_STR)){  \n      //trim the first quote  \n        input = input.substring(1);  \n    }  \n    if(input.endsWith(QUOTE_STR)){  \n        //trim the last quote  \n       input = input.substring(0, input.length()-1);  \n    }  \n    return input;  \n}",
