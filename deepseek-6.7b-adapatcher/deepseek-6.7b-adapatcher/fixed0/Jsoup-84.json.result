    "patch_code": "public void head(org.jsoup.\u8282\u70b9 source, int\u6df1\u5ea6) {\n    namespaces Stack = new Stack();\n    namespaces Stack. push(new LinkedMap());\n\n    if (source\u662forg.jsoup. elements){\n        org.jsoup. elements sourceEl = (org.jsoup. elements) source;\n        String\u7f00 = update Namespaces(sourceEl);\n        Stringnamespace = namespaces Stack. peek(). get(\u7f00);\n        String tagName = sourceEl. tagName();\n        String tagName = tagName + (namespace !null ? \":\" + namespaces Stack. size() + \":\" + tagName : \"\");\n\n        element el = doc. createElementNS(namespace, tagName);\n        copy\u5c5e\u6027(sourceEl, el);\n        if ( dest==null){\n            doc.appendchild(el);\n        }else{\n            dest.appendchild(el);\n        }\n        dest = el;\n    }elseif (source is org.jsoup. textNode){\n        org.jsoup. textNode sourceText = (org.jsoup. textNode) source;\n        text node = doc.createTextNode(sourceText.getwholeText());\n        dest.appendchild(node);\n    }elseif (source is org.jsoup. comment){\n        org.jsoup. comment sourceCom comment = (org.jsoup. comment) source;\n        comment comment = doc.create comment(sourceCom comment. getdata());\n        dest.appendchild( comment);\n    }elseif (source is org.jsoup. dataNode){\n        org.jsoup. dataNode sourceData dataNode = (org.jsoup. dataNode) source;\n        text node = doc.createTextNode(sourceData dataNode. getwholeData());\n        dest.appendchild(node);\n    }else{\n        //\u672a\u5b9a\u4e49\n    }\n}",
