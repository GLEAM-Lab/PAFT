    "patch_code": "import java.util.*;\nimport javax.xml.parsers.*;\nimport org.w3c.dom.*;\nimport org.jsoup.*;\nimport org.jsoup.nodes.*;\n\npublic class CustomW3CDocumentBuilder extends DocumentBuilderFactory implements DOMImplementationSource {\n    \n    private static final Map<String, String> NAMESPACES = new HashMap<String, String>() {{\n        put(\"html\", \"http://www.w3.org/1999/xhtml\");\n        put(\"fb\", \"http://ogp.me/ns/fb#\");\n    }};\n    \n    @Override\n    public Document build(org.jsoup.nodes.Node source, int depth) throws Exception {\n        DocumentBuilder builder = getDocumentBuilder();\n        org.w3c.dom.Document w3cDoc = builder.newDocument();\n        \n        processNode(source, w3cDoc, depth);\n        \n        return w3cDoc;\n    }\n    \n    private void processNode(org.jsoup.nodes.Node source, org.w3c.dom.Document w3cDoc, int depth) throws Exception {\n        if (source instanceof org.jsoup.nodes.Element) {\n            org.jsoup.nodes.Element element = (org.jsoup.nodes.Element) source;\n            \n            String namespaceURI = NAMESPACES.getOrDefault(element.normalName(), Objects.requireNonNull(element.baseUri()));\n            \n            Element w3cElement = w3cDoc.createElementNS(namespaceURI, element.tagName());\n            \n            for (Attribute attribute : element.attributes()) {\n                w3cElement.setAttributeNS(attribute.key(), attribute.getValue());\n            }\n            \n            w3cDoc.appendChild(w3cElement);\n        } else if (source instanceof org.jsoup.nodes.TextNode) {\n            Text textNode = (Text) source;\n            \n            NodeList childNodes = ((org.jsoup.nodes.TextNode) source).childNodes();\n            \n            for (int i = 0; i < childNodes.size(); i++) {\n                processNode(childNodes.get(i), w3cDoc, depth + 1);\n            }\n        } else if (source instanceof org.jsoup.nodes.Comment) {\n            Comment commentNode = (Comment) source;\n            \n            NodeList childNodes = ((org.jsoup.nodes.Comment) source).childNodes();\n            \n            for (int i = 0; i < childNodes.size(); i++) {\n                processNode(childNodes.get(i), w3cDoc, depth + 1);\n            }\n        } else if (source instanceof org.jsoup.nodes.DataNode) {\n            DataNode dataNode = (DataNode) source;\n            \n            NodeList childNodes = ((org.jsoup.nodes.DataNode) source).childNodes();\n            \n            for (int i = 0; i < childNodes.size(); i++) {\n                processNode(childNodes.get(i), w3cDoc, depth + 1);\n            }\n        }\n    }\n    \n    private DocumentBuilder getDocumentBuilder() throws ParserConfigurationException {\n        setFeature(\"http://apache.org/xml/features/nonvalidating/load-external-dtd\", false);\n        return newDocumentBuilder();\n    }\n}",
