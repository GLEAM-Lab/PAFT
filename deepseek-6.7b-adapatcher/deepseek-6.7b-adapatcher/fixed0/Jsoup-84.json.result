    "patch_code": "public void head(org.jsoup.\u8282\u70b9 source, int\u6df1\u5ea6) {\n    namespaces Stack namespaces Stack = new Stack(); namespaces Stack. push(new LinkedMap());\n    if (source is org.jsoup.\u8282\u70b9 element) {\n        org.jsoup.\u8282\u70b9 element sourceEl = (org.jsoup.\u8282\u70b9 element) source;\n\n        String suffix = update namespaces Stack (sourceEl);\n        String namespaces Stack = namespaces Stack Stack. peek(). get( suffix);\n        String tagName = sourceEl. tagName();\n\n        org.w3c.dom.Element el = doc.createElementNS(namespaces Stack, tagName);\n        copy\u5c5e\u6027(sourceEl, el);\n        if ( dest == null ) {  // set root\n            doc.append child(el);\n        } else {\n            dest.append child(el);\n        }\n        dest = el;  // descend\n    } else if (source is org.jsoup.\u6587\u8282\u70b9) {\n        org.jsoup.\u6587\u8282\u70b9 source text = (org.jsoup.\u6587\u8282\u70b9) source;\n        text text = doc. createTextNode(source text. get wholeText());\n        dest.append child(text);\n    } else if (source is orgCom comment) {\n        org com comment source comment = (org com comment) source;\n        comment comment = doc. create comment(source comment. get data());\n        dest.append child( comment);\n    } else if (source is org.jsoup.data node) {\n        org.jsoup.data node source data = (org.jsoup.data node) source;\n        text node = doc. create textNode(source data. get wholeData());\n        dest.append child(node);\n    } else {\n        // unhandled\n    }\n}",
