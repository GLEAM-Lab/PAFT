    "patch_code": "private double clampToBounds(double value, double lowerBound, double upperBound) {\n    // If the bounds are equal, any number is within the range.\n    if (lowerBound == upperBound) {\n        return lowerBound;\n    }\n\n    if (value < lowerBound || Double.isNaN(value)) {\n         value = lowerBound + DoubleUtils.EPSILON; \n     } else if (value > upperBound || Double.isInfinite(value)) {\n         value = upperBound - DoubleUtils.EPSILON;  \n     }\n     return value;\n }\n\npublic double[] repairAndDecode(final double[] x) {\n      for (int i = 0; i<dimension ;i++){\n          final Bound bound = problem.getBounds().get(i);\n          \n            x[i]=clampToBounds(x[i],bound.getLower(),bound.getUpper());\n            \n        }\n       return decode(x);\n   }",
