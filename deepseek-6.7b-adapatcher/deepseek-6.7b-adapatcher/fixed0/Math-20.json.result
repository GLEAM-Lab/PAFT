    "patch_code": "public class Main{\n   public static void main(String[] args){\n      Scanner scanner = new Scanner(System.in);\n      int cases = Integer.parseInt(scanner.nextLine());\n      \n      for(int i=0;i<cases;i++){\n         String strs = scanner.nextLine();\n         String sss[] = strs.split(\" \");\n         \n         int n = Integer.parseInt(sss[0]);\n         long m = Long.parseLong(sss[1]);\n         \n         int ns [] = new int [n];\n         \n         for(int j=0 ;j<n;j++){\n            ns[j] = scanner.nextInt();\n         }\n         \n         Arrays.sort(ns);\n         \n         boolean b = true;\n         for(int j = 0 ;j < ns.length -1;j++){\n            if((ns[j+1]-ns[j])*2 >m){\n               b = false;\n               break;\n            }else if ((ns[j+1]-ns[j])*2 == m && m%2==1 ){\n             \n             b = false;\n             break;\n           }\n         }\n     if(b){\n       System.out.println(\"Yes\");\n     } else {\n       System.out.println(\"No\");\n     }\n}}",
