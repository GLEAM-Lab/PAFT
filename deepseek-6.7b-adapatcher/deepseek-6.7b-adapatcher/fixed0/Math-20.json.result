    "patch_code": "public double[] decode( final double[] x ) {\n    final double[] result = new double[ x.length ] ;\n    for ( int i = 0 ; i < x.length ; i++ ) {\n      result[ i ] = decode( i , x[ i ] );\n    }\n    return result ;\n}\nprivate double decode( final int i , final double value ) {\n    final double lower bound = lowerbound[ i ] ;\n    final double upper bound = upperbound[ i ] ;\n    final double range = upper bound - lower bound ;\n    final double result = lower bound + range * value ;\nreturn result ;\n}",
