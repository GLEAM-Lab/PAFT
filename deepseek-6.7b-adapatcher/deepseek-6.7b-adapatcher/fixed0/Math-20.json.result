    "patch_code": "public double[] repairAndDecode(double[] x) {\n    final int n = getNumberOfParameters();\n    \n    // Clip values to lower and upper bound\n    for (int i = 0; i < n; ++i) {\n        \n      double value = x[i];\n      \n        if (Double.isNaN(value)) {\n            continue;\n        } else if (!hasLowerBound(i)) {\n            \n              while (value > Constants.POSITIVE_INFINITY){\n                  value -= 1;\n              }\n              \n          } else if(!hasUpperBound(i)){\n              \n                while (value <  Constants.NEGATIVE_INFINITY){\n                    value += 1;\n                }\n                \n            }else{\n                \n                if (value < getLowerBounds()[i] ){\n                   value=getLowerBounds()[i];\n                    \n                }else if(value >  getUpperBounds()[i]){\n                    value= getUpperBounds()[i];\n                    \n                }\n            }\n            \n        x[i]=value;  \n          \n        }//end for loop\n\n\n    return decode(x);\n    }",
