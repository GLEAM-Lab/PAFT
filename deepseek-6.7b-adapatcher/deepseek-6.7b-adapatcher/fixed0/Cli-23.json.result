    "patch_code": "protected StringBuilder printLine(StringBuilder sb, String text, int width)\n{\n    int pos = findSplitPoint(text, width);\n\n    if (pos == 0)\n{\n    sb.append(rtrim(text));\n\n    return sb;\n}\nsb.append( rtrim(text.substring(0, pos)) + \" \" );\n\nwhile ( pos < text.length() )\n{\n    while ( pos < text.length() && CharacterUtil.isWhitespace(text.charAt(pos)) )\n{\n        pos++;\n    }\n\n    if (pos == text.length())\n{\n        break;\n}\n    sb.append( rtrim(text.substring(pos, pos+width)) + \" \" );\n    pos = pos + width;\n}\nreturn sb;\n}",
