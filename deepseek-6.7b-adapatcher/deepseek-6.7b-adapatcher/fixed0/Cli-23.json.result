    "patch_code": "protected StringBuilder initSb()\n{\n    StringBuilder sb = super.initSb();\n\n    sb.append(createPadding(columnwidth + 1) + \"  \");\n\n    return sb;\n}\n protected StringBuilder print optionallyPad optionallyPad(StringBuilder sb, String text)\n{\n    int pos = find\u5305\u88c5Pos(text, columnwidth + 1, columnwidth + 1);\n\n    if (pos == -1)\n{\n        sb.append(text);\n\n        return sb;\n    }\n\n    sb.append(text.substring(0, pos));\n\n    while (pos < text.length())\n{\n        sb.append(default\u65b0line + createPad(columnwidth + 1) + \"  \");\n        pos = find\u5305\u88c5Pos(text, columnwidth + 1, pos + 1);\n\n        sb.append(pos == -1 ? rtrims(text.substring(pos)) : rtrims(text.substring(pos, pos + columnwidth + 1)));\n\n        sb.append(default\u65b0line);\n    }\n\n    return sb;\n}",
