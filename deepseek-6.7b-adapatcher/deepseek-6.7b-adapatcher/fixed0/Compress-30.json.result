    "patch_code": "public int read( final char[] dest, final int offs, final int length)\n    throwIOException {\n\n    if ( this.in == null ) {\n      throw newIOException(\" stream closed\");\n    }\n\n    int dest offs = offs;\n    int length = length;\n\n    while ( length > 0 ) {\n      int b = read();\n      if ( b == -1 ) {\n        break;\n      }\n      dest[ dest offs++ ] = (char)( b & 0xff );\n      count(1);\n      length--;\n    }\n\n    int c = (length == 0 ? offs : -1);\n\n    return c;\n  }",
