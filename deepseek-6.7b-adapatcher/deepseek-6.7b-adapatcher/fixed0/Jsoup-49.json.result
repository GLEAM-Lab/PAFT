    "patch_code": "protected void insertChildren(int index, Collection<? extends Node> children) {\n    Validate.notNull(children);\n    if (!isEmpty()) {\n        ensureChildNodes();\n        \n        Iterator<? extends Node> iterator = children.iterator();\n        while (iterator.hasNext()) {\n            Node n = iterator.next();\n            reparentChild(n);\n            childNodes.add(index++, n);\n        }\n        reindexChildren();\n    }\n}",
