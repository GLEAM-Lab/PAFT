    "patch_code": "public class RepairElementInsertChildren extends Element{\n    \n    /** Moves specified nodes as direct children of this node to the given position. The source node retains its original position. */\n    protected void addChildren(int index, Node... children){\n        Validate.noNullElements(children);\n        \n        // Remove nodes from their current parents\n        for(Node n : children){\n            if(!n.isRemoved() && n instanceof Element elm && elm.parent != null){\n                elm.parent.childNodes.remove(elm);\n            }\n        }\n        \n        // Add to new location\n        super.addChildren(index, children);\n        reindexChildren(index);\n    }\n}",
