    "patch_code": "protected <T extends Node> T[] moveChildren(int destStartingIndex, int srcStartingIndex, int count, T... items) {\n    ObjectUtil.requireMinMax(destStartingIndex, 0, childSize());\n    ObjectUtil.requireMinMax(srcStartingIndex, 0, childSize());\n    ObjectUtil.requireValidCount(count);\n    ObjectUtil.notEqual(\"Destination starting index\", \"Source starting index\", destStartingIndex, srcStartingIndex);\n    \n    if (!isSameOwnerDocument(items)) {\n      throw new IllegalArgumentException(\"Items must be owned by same document\");\n    }\n  \n    List<Node> itemList = Arrays.asList(items);\n  \n    // Remove nodes from current parent to avoid unintentional repositioning during iteration\n    List<Node> movedNodes = childNodes.subList(srcStartingIndex, srcStartingIndex + count);\n    childNodes.removeAll(movedNodes);\n  \n    childNodes.addAll(destStartingIndex, movedNodes);\n  \n    for (int ii = 0, nn = childSize(); ii < nn; ii++ ) {\n       Node nnn = getChild(ii);\n         nnn.attr(\"#siblingsIndex\");\n         \n    }\n  \n    return (T[])items;\n  }",
