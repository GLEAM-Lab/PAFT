    "patch_code": "protected void insertChildren(int index, Collection<? extends Node> children) {\n    Validate.noNullElements(children);\n    ensureChildNodes();\n    int count = 0;\n    for (Iterator<? extends Node> iterator = children.iterator(); iterator.hasNext();) {\n        Node node = iterator.next();\n        if (!isSameOwnerDocument((Node) node)) return;\n        reparentChild((Node) node);\n        childNodes.add(Math.min(index + count, childNodes.size()), node);\n        count++;\n    }\n    reindexChildren(index);\n}",
