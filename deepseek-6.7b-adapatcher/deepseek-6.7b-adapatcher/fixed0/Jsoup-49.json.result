    "patch_code": "/**\n * Inserts nodes at the specified position in this element. Nodes can be inserted between siblings or at the beginning or end of the child list. If the node being added is already part of a tree, it is removed from its current location.\n *\n * @param index Index where to add the nodes. Negative indexes count backwards from end of the list (e.g., -1 means last item).\n * @param children Nodes to add.\n */\npublic void insertChildren(int index, Collection<? extends Node> children) {\n    if (index < -size || index > size) {\n        throw new IndexOutOfBoundsException(\"Index out of range\");\n    } else if (children == null || children.isEmpty()) {\n        return;\n    }\n    // Ensure we have an array representation of our children collection\n    Node[] childArray = children instanceof List ? ((List<? extends Node>) children).toArray(new Node[0]) : NodeUtil.collectionToArray(children);\n    \n    if (index < 0) {\n        index += childNodes.size();\n    }\n\n    // Remove all existing nodes that might conflict with the supplied nodes\n    for (Node child : childArray) {\n        if (!child.hasChangedOwner()) {\n            child.remove();\n        }\n    }\n\n    boolean ownerDocumentDirty = !ownerDoc.equals(this);\n    for (Node child : childArray) {\n        if (!child.hasChangedOwner()) {\n            reparentChild(child);\n        }\n        \n        childNodes.add(index, child);\n        ownerDocumentDirty |= child.ownerDocument!=null && !child.ownerDocument.equals(ownerDoc);\n    }\n\n    if (ownerDocumentDirty) {\n        setChanged();\n    }\n    reindexChildren();\n}",
