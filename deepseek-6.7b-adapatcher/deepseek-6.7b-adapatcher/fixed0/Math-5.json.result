    "patch_code": "public Complex reciprocal() {\n    // Changed from isNaN to Double.isNaN\n    if (Double.isNaN(this.getReal()) || Double.isNaN(this.getImaginary())) {\n        return NaN;\n    }\n    \n    // Checked if it's zero\n    if (this.equals(ZERO)){\n         return NEGATIVE_INFINITY;  \n    }\n    \n     // If none of the above cases apply, compute the reciprocal normally.\n    if (FastMath.abs(this.getReal()) >= FastMath.abs(this.getImaginary())) {\n        double q = this.getImaginary() / this.getReal();\n        double scale = 1. / (q * this.getImaginary() + this.getReal());\n        return new Complex(scale*q , -scale);\n    } else {\n        double q = this.getReal() / this.getImaginary();\n        double scale = 1. / (q * this.getReal() - this.getImaginary());\n        return new Complex(-scale , -scale*q);\n    }\n}",
