    "patch_code": "public Complex reciprocal() {\n    if (isNaN()) {\n        return Complex.NaN;\n    }\n\n    if (isZero()) {\n        return new Complex(Double.POSITIVE_INFINITY, Double.POSITIVE_INFINITY);\n    }\n\n    if (getReal() == 0.0 && getImaginaryPart() == 0.0) {\n        return Complex.ZERO;\n    }\n\n    if (!isFinite()) {\n        return new Complex(Double.POSITIVE_INFINITY, Double.POSITIVE_INFINITY);\n    }\n\n    if (Math.abs(getReal()) < Math.abs(getImaginaryPart())) {\n        double q = getReal() / getImaginaryPart();\n        double scale = 1. / (getReal() * q + getImaginaryPart());\n        return new Complex(scale * q, -scale);\n    } else {\n        double q = getImaginaryPart() / getReal();\n        double scale = 1. / (getImaginaryPart() * q + getReal());\n        return new Complex(scale, -scale * q);\n    }\n}",
