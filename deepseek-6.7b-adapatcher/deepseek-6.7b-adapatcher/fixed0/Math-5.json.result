    "patch_code": "import java.util.*;\nimport java.lang.*;\n\npublic class Main{\n    \n\tpublic static void main (String[] args) throws java.lang.Exception{\n\t\t// your code goes here\n\t\t System.out.println(\"0 \u7684\u5012\u6570\u662f\uff1a\"+new Complex(0,0).reciprocal());\n\t}\n}\nclass Complex{\n       private final double re;   // the real part\n    private final double im;   // the imaginary part\n    public boolean flag=false;\n    public Complex(double re, double im){\n           this.re = re;\n        this.im = im;\n        \n    }\n    @Override\n    public String toString(){\n           if(flag==true){\n               return Double.toString((re*im)/((re)* (re)));\n           }else{\n               \n        if(Double.isNaN(im)){\n            return \"NaN\";\n        }\n        if(Double.isInfinite(im)){\n            return \"-NaNi\";\n        }\n        if(Double.isNaN(re)){\n            return \"NaN\";\n        }\n        if(Double.isInfinite(re)){\n            return \"NaNi\";\n        }\n        \n           return Double.toString(re)+\"+\"+Double.toString(im)+'i';\n           }\n    }\n\n    /** Returns the absolute value of this complex number. */\n    \n    \n    \n    \n    public Complex reciprocal(){\n       \n          if(Double.isInfinity(im)){\n              if(Double.isNaN(re)){\n                  return new Complex(-im,-re);\n              }\n              return new Complex(-im,(int)re);\n          }if(Double.isInfinity(re)){\n              if(Double.isNaN(im)){\n                  return new Complex(im,re);\n              }\n              return new Complex(im/(int)im ,re );\n          }\n      if(im!=0&&re!=0){\n          double r= Math.sqrt(re*re+im*im);\n         return new Complex(re/r,(-im)/r);\n      }if(im==0&&re>0){\n          \n          return new Complex(1,im);\n      }if(im==0&&re<0){\n          \n          return new Complex(-1,im);\n      }if(im==0&&re==0){\n          return new Complex(0,1);\n      }\n        return null;\n    }\n   \n    \n\n\n\n\n\n\n\n\n\n\n\n\n\n}",
