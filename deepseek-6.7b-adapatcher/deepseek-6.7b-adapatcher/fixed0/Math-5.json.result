    "patch_code": "public Complex reciprocal() {\n   if (!isFinite()) {\n       return NaN;\n   }\n   if (isZero()) {\n       return Complex.INFINITY;\n   }\n   double abs = this.norm();\n   return new Complex(-this.getReal(),-this.getImaginary()).divide(abs);\n}",
