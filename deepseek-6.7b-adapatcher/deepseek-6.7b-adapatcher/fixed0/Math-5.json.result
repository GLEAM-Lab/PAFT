    "patch_code": "public Complex reciprocal() {\n    if (Double.isNaN(this.getReal()) || Double.isNaN(this.getImaginary())) {\n        return new Complex(Double.POSITIVE_INFINITY, Double.NEGATIVE_INFINITY);\n    }\n\n    if (Double.isInfinite(this.getReal()) && Double.isFinite(this.getImaginary())){\n         return new Complex(- this.getReal(), -this.getImaginary());\n     }\n      \n    if (!(Double.isFinite(this.getReal()) && Double.isFinite(this.getImaginary()))) {\n        throw new ArithmeticException(\"Division by zero.\");\n    }\n  \n    final double absSqrd = MathUtil.square(this.getReal())+ MathUtil.square(this.getImaginary());\n     \n    // We have two solutions for each root. We want the one with positive real part.\n    final double real=this.getReal()/absSqrd ;\n    final double imag = - this.getImaginary() / absSqrd;\n    \n\n    return new Complex(real , imag );\n}",
