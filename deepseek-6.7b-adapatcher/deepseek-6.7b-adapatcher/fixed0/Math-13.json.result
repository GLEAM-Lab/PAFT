    "patch_code": "public double[][] squareRoot(double [][] m){\n    int len=m.length;\n    double sqrtM[][];\n    double sumEigenValues = 0;\n    double eigenValue[] = new double[len];\n    Vector v = new Vector(len,1);  \n     \n    for(int i = 0;i < len;i++){    \n        v.set(i,1);   \n    }  \n         \n    while(!allPositive(eigenValue)){\n        sumEigenValues = 0;  \n        for(int i = 0;i < len;i++){\n            eigenValue[i] = dotProduct(v,m[i]);\n            if(eigenValue[i] < 0){\n                eigenValue[i]*= -1;\n            } \n            sumEigenValues += eigenValue[i];\n        }\n        \n        double h = 1.0/(sumEigenValues + 1.0);\n        v.scale(h);  \n          \n    }\n    \n      \n    for(int i = 0;i < len;i++){\n        for(int j = 0;j < len;j++){\n             sqrtM[i][j] = v[i] * m[i][j];\n        }\n    }\n    \n    \n\treturn sqrtM;\n}\nboolean allPositive(double a[]){\n    for(int i = 0 ;i < a.length;i++){\n        if(a[i]<= 0 ){\n            return false;\n        }\n    }\n    return true;\n}\ndouble dotProduct(double a[],double b[]){\n    double c = 0;\n    for(int i = 0;i < a.length;i++){\n        c+=a[i]*b[i];\n    }\n    return c;\n}",
