[
  {
    "patch_code": "private RealMatrix squareRoot(RealMatrix m) throws NonPositiveSemiDefiniteOperatorException{\n        final EigenDecomposition dec = new EigenDecomposition(m);\n         if(!dec.isSPD()){\n             throw new NonPositiveSemiDefiniteOperatorException(NonPositiveSemiDefiniteOperatorException.Type.NOT_POSITIVE_DEFINITE,\"The matrix \" + m + \"is not positive definite\");\n         }\n      \n        double[][] array=new double[m.getRowDimension()][];\n           for (int i = 0; i <array.length ; i++) {\n               array[i]=new double[i+1];\n               for (int j = 0; j <=i ; j++) {\n                   array[i][j]=Math.sqrt(dec.getD().getEntry(i,j));\n               }\n          }\n      return new Array2DRowRealMatrix(array);  \n}",
