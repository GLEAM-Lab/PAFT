    "patch_code": "import org.apache.commons.math3.linear.*;\npublic void changeEigenValueToOne(EigenDecomposition ed){\n    RealVector ev=ed.getEigenvalues();\n    int vLen=ev.getDimension();\n    double[] dd=new double[vLen];\n    for(int i=0;i<vLen;i++){\n        if(dd[i]==0.0){\n            dd[i]=1.0;\n        }else{\n            dd[i]=ev.getEntry(i)/Math.abs(dd[i]);\n        }\n    }\n    ed.setA(ed.getV().multiply(MatrixUtils.createDiagonalMatrix(dd)).multiply(ed.getD().transpose()));    \n}",
