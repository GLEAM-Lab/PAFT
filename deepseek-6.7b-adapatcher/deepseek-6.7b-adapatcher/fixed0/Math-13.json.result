    "patch_code": "private RealMatrix squareRoot(final RealMatrix m) {\n    int order = m.getRowDimension();\n    \n    double[][] arrayOut = new double[order][order];\n    boolean notFullRank;\n\n    RealVector[] eVectors = new QRDecomposition(m).getQ().getColumnVectorArray();\n\n    for (int i = 0; i < order; i++){\n       double evNorm = eVectors[i].getNorm();\n       if (evNorm == 0.0){\n           continue;\n       } else {\n          for (int j = 0; j < order; j++){\n              arrayOut[j][i] = eVectors[i].getEntry(j)/evNorm;\n            }\n        }\n   }\n\n    // Trying to reduce the rank deficient case here \n    for (int i=0; i< order ; ++i){\n        boolean foundNonZero = false;\n        \n        for(int j= 0;j < order ;++j){\n            \n            if (!Utils.isNaN(arrayOut[i][j])){\n                \n                foundNonZero = true;\n            }\n        }\n        \n        if (!foundNonZero){\n            for(int j= 0;j < order;++j ){\n                \n                if ( ! Utils.isNaN(arrayOut[j][i])){\n                    \n                    arrayOut[i][i] = 1;\n                    break;\n                }\n                \n            }\n        }\n        \n    }\n\n\n\n    RealVector[] rv = new RealVector[order];\n    for(int i=0;i<rv.length;++i){\n        rv[i] = MatrixUtils.createRealVector(arrayOut[i]);\n        \n        \n        \n    }\n\n\n    RealMatrix rm = new Array2DRowRealMatrix(arrayOut , false);\n\n    return rm;\n    \n    \n    \n    \n}",
