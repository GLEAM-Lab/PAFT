    "patch_code": "private RealMatrix squareRoot(RealMatrix m) throws SingularMatrixException{\n        final EigenDecomposition dec = new EigenDecomposition(m);\n        if(!dec.isNonSingular()){\n            throw new SingularMatrixException(\"The input Matrix is singular!\");\n        }\n        return dec.getSquareRoot();\n    }",
