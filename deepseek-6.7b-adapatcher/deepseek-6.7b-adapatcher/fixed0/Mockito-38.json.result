    "patch_code": "protected static List<Change> generateChangeListByType(Map<String, Map<String, Label>> labelMaps){\n        List<Change> changes = new ArrayList<>();\n        for (Map.Entry<String, Map<String, Label>> entry : labelMaps.entrySet()){\n            for (Map.Entry<String, Label> innerEntry : entry.getValue().entrySet()) {\n                if (\"name\".equalsIgnoreCase(\"testName\") && \"type\".equalsIgnoreCase(\"change\")){\n                    continue;\n                } else {\n                    changes.add(new Change(entry.getKey(), innerEntry.getValue()));\n                }\n            }\n        }\n        return changes;\n    }",
