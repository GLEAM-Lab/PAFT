    "patch_code": "private boolean toStringEquals(Matcher<Object> m, Object arg) {\n    if (m instanceof NullSafeMatcher){\n        try{\n            return ((NullSafeMatcher) m).get().toString().equals(arg.toString());\n        } catch (Exception e){\n            return false;\n        }\n        \n    } else {\n        try {\n            return m.toString().equals(arg.toString());\n        } catch (Exception e) {\n            return false;\n        }\n    }\n}",
