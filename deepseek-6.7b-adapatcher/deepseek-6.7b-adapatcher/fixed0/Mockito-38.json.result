    "patch_code": "public boolean toStringEquals(Matcher<T> matcher, T arg){\n        if(!matcher.matches(arg)){\n            try{\n                Description description = new StringDescription();\n                matcher.describeTo(description);\n                \n                throw new AssertionError(\"Value \"+arg.toString() +\" does not match given pattern : \\n\" +description.toString());\n                \n            }catch(AssertionError ex){\n                throw ex;\n            }\n        }else{\n            \n        \n    \nreturn true;}\n        \n    }",
