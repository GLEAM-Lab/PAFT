    "patch_code": "import org.hamcrest.*;\n\nprivate boolean toStringEquals(Matcher<Object> matcher, Object actual){\n    try{\n        Matchers.description().appendDescriptionOf(matcher);\n        String expected = Matchers.description().toString();\n        return expected.equals(actual.toString());\n    } catch(Error e){\n       throw new AssertionError(\"Description of \"+matcher+\" didn't match\",e); \n    }\n    \n}",
