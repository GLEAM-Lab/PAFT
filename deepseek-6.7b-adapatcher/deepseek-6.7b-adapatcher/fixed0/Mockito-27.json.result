    "patch_code": "import static org.mockito.Mockito.*;\n\n@Test\npublic void testThrowException() {\n    Object o = mock(Object.class);\n    \n    // Stubbing the first time\n    doThrow(new IllegalArgumentException(\"Message\")).when(o).throwingMethod();\n    \n    // Now we want to override the previous stubs\n    try {\n        // This will now throw an IllegalArgumentException instead of RuntimeException\n        doThrow(new RuntimeException()).when(o).throwingMethod();\n    } catch (AssertionError e) {\n        \n        // To handle the AssertionError caused by trying to stub an already stubbed method\n        verifyNoMoreInteractions((MockitoSession) o);\n    }\n    \n    assertThrows(IllegalArgumentException.class, () -> {\n        try {\n            o.throwingMethod();\n        } catch (RuntimeException e1) {\n            \n            // TODO Add your additional checks here\n            \n            fail(\"Should have thrown illegal argument exception\");\n        }\n    });\n    \n    verifyNoMoreInteractions(o);\n}",
