    "patch_code": "import org.junit.*;\nimport org.mockito.*;\n\nimport java.lang.reflect.*;\nimport java.util.*;\n\npublic class Main {\n  public static class Foo {\n      int bar();\n  }\n  \n  @Test\n  public void example1(){\n      try{\n          Foo foo = Mockito.mock(Foo.class);\n          \n          Mockito.when(foo.bar()).thenReturn(23).thenThrow(NullPointerException.class);\n       \n      \n         Assert.assertEquals(23,foo.bar());\n     } catch (Exception ex){\n       System.out.println(\"Caught an expected exception\");\n     }\n    \n  \n\n  }\n  public static void main(String[] args) {\n    Example1();\n  }\n}",
