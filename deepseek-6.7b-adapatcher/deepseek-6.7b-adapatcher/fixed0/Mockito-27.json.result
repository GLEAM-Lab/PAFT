    "patch_code": "import java.lang.reflect.Method;\nimport java.lang.reflect.ParameterizedType;\n\npublic <T> void resetMock(T mock) {\n        try{\n        MockHandlerInterface<T> oldMockHandler = getMockHandler(mock);\n        MockHandler<T> newMockHandler = new MockHandler<>(oldMockHandler){\n            @Override\n            public Object handle(InvocationOnMock invocation) throws Throwable {\n                return handleCallRealMethod(invocation);\n            }\n        };\n        \n        ParameterizedType pt = (ParameterizedType) mock.getClass().getGenericSuperclass();\n        Type[] types = pt.getActualTypeArguments();\n        Class<? extends Answer<?>> answerClass = (Class<? extends Answer<?>>) types[1];\n       /* \n        if (!answerClass.isAssignableFrom(DefaultAnswers.returnsNull())) {\n            throw new Reporter(\"stubbing conflict detected:\" + mock + \" - trying to stub '\"+((Method) invocation.getMockedMethod()) + \"' while already stubbed\");\n        }*/\n\n        org.mockito.Mockito.reset(mock);\n        MockitoCore.substituteMock(mock);\n        MethodInterceptorFilter newFilter = new MethodInterceptorFilter(newMockHandler, null);\n        Factory factoryMock =  Mockito.mock(Factory.class);\n        Mockito.doAnswer(answer -> {factoryMock.setCallback(0, newFilter);return null;}).when(mock).toString();\n    }catch(Exception e){\n      System.out.println(\"Exception :\"+e.getMessage());  \n     }\n    }",
