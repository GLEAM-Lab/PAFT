    "patch_code": "public class RepairedMockito {\n    \n    public static <T> void resetMock(T mock) {\n        ResetableMock<T> resetableMock;\n        \n        if (mock instanceof Proxy && !((Proxy) mock).getClass().getName().startsWith(\"$\")){\n            try{\n                Class proxyMockClass =  (Class)  ((Proxy) mock).getClass().getField(\"$$proxyClass\").get(null);\n                Constructor constructor=proxyMockClass.getDeclaredConstructor();\n                constructor.setAccessible(true);\n                T newInstance=(T)constructor.newInstance();\n                \n                Method m1=mock.getClass().getMethod(\"getMockHandler\");\n                m1.setAccessible(true);\n                Object handlerObj=m1.invoke(mock);\n                MockHandler handler=(MockHandler)handlerObj;\n                MockBase<?, ?> base=handler.base;\n                \n                base.expectations.clear();\n                MockitoWriter.writer().visitResetStatementForSpy(resetableMock = base);\n            \n            }catch(Exception e){e.printStackTrace();}\n          \n        }else{\n              throw new UnsupportedOperationException(\"Cannot reset unproxied or JDK proxy instances.\");\n        }  \n      \n          /*\n            This was what we were trying to accomplish before:\n            MockHandlerInterface<T> oldMockHandler = getMockHandler(mock);\n            MockHandler<T> newMockHandler = new MockHandler<T>(oldMockHandler);\n            MethodInterceptorFilter newFilter = new MethodInterceptorFilter(newMockHandler, (MockSettingsImpl) org.mockito.Mockito.withSettings().defaultAnswer(org.mockito.Mockito.RETURNS_DEFAULTS));\n            ((Factory) mock).setCallback(0, newFilter);*/\n     \n    }\n}",
