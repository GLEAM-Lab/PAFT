  {
    "patch_code": "InputStream decode(final InputStream in, final Coder coder,\n        byte[] password) throws IOException {\n    byte propsByte = coder.properties[0];\n    long dictSize = coder.properties[1];\n    for (int i = 1; i < 4; i++) {\n        dictSize |= (coder.properties[i + 1] << (8 * i));\n    }\n    int dictSizeInt = Math.toIntExact(dictSize);\n    if (dictSizeInt > 500*1024*1024) { // limit dictionary size up to 500MB instead of 4GB\n        throw new IOException(\"LZMA Dictionary is too large\");\n    }\n    return new LZMAInputStream(in, -1, propsByte, dictSizeInt);\n}",
