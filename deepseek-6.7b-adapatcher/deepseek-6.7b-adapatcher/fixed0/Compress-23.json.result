    "patch_code": "public class SevenZHelper{\nprivate static int PPM_MAX=500;\npublic static OutputStream createEntry(String name,long compressedSize,long uncompressedSize){\ntry{\nRandomAccessFile raf=new RandomAccessFile(\"/dev/null\",\"rw\");\nOutputStream out=new BufferedOutputStream(raf.getChannel().map(FileChannel.MapMode.READ_WRITE,0,Math.max(compressedSize,uncompressedSize)));\nout.write('7');\nout.write('z');\nout.write('R');\nout.write(0); //version\nbyte cm1=0b1100_0000|((byte)(PPM_MAX>>8)),cm2=(byte)PPM_MAX;//ppm xy adler checksum crc32\nout.write(cm1);\nout.write(cm2);\nout.write(0xFFFF&name.length());\nout.write(name.getBytes());\nreturn new ArchiveOutputStream(out){\n@Override\nprotected void writeStoreBlock(byte b){\nthrow new UnsupportedOperationException();\n}\n@Override\nprotected void writeStoreBlock(byte[] b,int off,int len){\nif(len!=b.length||off!=0){\nthrow new IllegalArgumentException();\n}\nsuper.writeStoreBlock(b);\n}\n};\n}catch(IOException ex){\nex.printStackTrace();\n}\nthrow new AssertionError(\"Should not reach here!\");\n}\npublic static void main(String...argv){\ncreateEntry(\"hi\",55,6).close();\n}\n}",
