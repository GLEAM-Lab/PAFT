    "patch_code": "import java.io.IOException;\nimport java.io.InputStream;\n\npublic class CustomLZMAInputStream extends InputStream {\n    private int bufIndex;\n    private int bytesRead;\n    private byte[] buffer;\n    private LZMAInputStream lzmaIn;\n\n    public CustomLZMAInputStream(InputStream in, long headerOffset, byte propsByte, int dictSize) throws IOException {\n        buffer = new byte[4];\n        buffer[0] = propsByte;\n        boolean eof = false;\n        while ((propsByte & 0x80) != 0 || eof) {\n            readFully();\n            eof = readNextBlock();\n        }\n        resetBuffer();\n    }\n\n    @Override\n    public synchronized int available() throws IOException {\n        ensureOpen();\n        int avail = lzmaIn.available();\n        return (buffer.length - bufIndex + super.available()) % buffer.length;\n    }\n\n    @Override\n    public void close() throws IOException {\n        lzmaIn.close();\n    }\n\n    @Override\n    public synchronized int read() throws IOException {\n        ensureOpen();\n        updateCRC();\n        if (bufIndex == buffer.length) {\n            resetBuffer();\n        }\n        return bufIndex == buffer.length ? EOF : buffer[bufIndex++] & 0xFF;\n    }\n\n    @Override\n    public synchronized int read(byte[] b, int off, int len) throws IOException {\n        ensureOpen();\n        int totalBytesRead = 0;\n        while (totalBytesRead < len && ((bytesRead / 0xFFFFFFFFL) % 4) == 0) {\n            readFully();\n            int readNow = Math.min(len - totalBytesRead, buffer.length);\n            System.arraycopy(buffer, bufIndex, b, off + totalBytesRead, readNow);\n            totalBytesRead += readNow;\n            bufIndex += readNow;\n            if (bufIndex == buffer.length) {\n                resetBuffer();\n            }\n        }\n        return totalBytesRead;\n    }\n\n    protected void ensureOpen() throws IOException {\n        if (lzmaIn == null) {\n            throw new IOException(\"Stream closed\");\n        }\n    }\n\n    private boolean readNextBlock() throws IOException {\n        short blockType;\n        lzmaIn.skipBytes(((buffer[2] & 0xff) << 16) | ((buffer[3] & 0xff) << 8) | buffer[4]);\n        switch ((blockType = buffer[5])) {\n            case 'R':\n                break;\n            case '\\n':\n                return true;\n            default:\n                throw new IOException(\"Invalid or unsupported LZMA data format: \" + Integer.toHexString(blockType));\n        }\n        lzmaIn.setDictionarySize(getLongLE());\n        setDictionarySize((int) lzmaIn.getDictionarySize());\n        return false;\n    }\n\n    private void readFully() throws IOException {\n        int length = 0xFFFFFFFFL ^ bytesRead;\n        for (; ; ) {\n            int skippedBytes = lzmaIn.skipBytes(length);\n            length -= skippedBytes;\n            bytesRead += skippedBytes;\n            if (length <= 0) {\n                break;\n            }\n        }\n    }\n\n    private void resetBuffer() throws IOException {\n        bufIndex = 0;\n        int rv = lzmaIn.read(buffer, 0, buffer.length);\n        if (rv == -1) {\n            throw new IOException(\"Unexpected end of Stream\");\n        }\n    }\n}",
