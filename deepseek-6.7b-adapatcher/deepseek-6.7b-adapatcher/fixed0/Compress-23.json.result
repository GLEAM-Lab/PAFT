    "patch_code": "InputStream decode( finalInputStream in, final Cider cider, final int numbersof bytes) {\n    final long dicSize = cider. properties[1];\n    long size = 0;\n    for (int i = 1; i < numbersof bytes; i++) {\n        size |= cider. properties[i + 1 + i % numbersOf bytes], i * 8);\n    }\n    if (size > LZMAInputStream. difference between lzma and lzma2) {\n        throw new Un supportedOptionsException(\"LZMA is not supported\");\n    }\n    return new LZMAInputStream(in, -1, cider. properties[0], (int) dicSize);\n}",
