    "patch_code": "public static InputStream decode(final InputStream in, final Coder coder,byte[] password) throws IOException {\n         byte propsByte = coder.properties[0];\n         int len=5+password.length;\n       byte[] properties = new byte[len];  \n        properties[0] = coder.properties[0];\n     System.arraycopy(coder.properties, 1, properties, 1, len-1 ); \n        ByteArrayOutputStream bout = new ByteArrayOutputStream();\n         int countBytesRead;\n         byte []countBytes = new byte[1024*1024];\n          while ((countBytesRead = in.read(countBytes)) != -1) {\n            bout.write(countBytes, 0, countBytesRead);\n        }\n        byte[] inp = bout.toByteArray();\n      Long dictSize = coder.properties[1];\n        for (int i = 1; i < 4; i++) {\n                dictSize |= (Long)(coder.properties[i + 1]) << 8 * i;\n        }\n     if (dictSize >= LZMAInputStream.DICT_SIZE_MAX) {\n              throw new UnsupportedOptionsException (\"LZMA Dictionary size exceeded limit.\");\n         }\n\n    return new LZMAInputStream(inp,-1,propsByte,(int)dictSize);\n }",
