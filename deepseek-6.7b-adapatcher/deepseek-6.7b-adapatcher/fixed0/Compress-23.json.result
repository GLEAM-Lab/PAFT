    "patch_code": "InputStream decode( final inputstream in, final c maker,\n        final int password) throw newIOException {\n    final int properties Byte = maker. properties[0];\n    long dicSize = maker. properties[1];\n    for (int i = 1; i < 4; i++) { dicSize |= (maker. properties[i + 1] << (8 * i));\n    }\n    if ( dicSize > LZMAInputStream. dicSize max) {\n        throw newIOException(\" LZMA directory larger than 4GiB maximum size\");\n    }\n    return new LZMAInputStream(in, -1, properties Byte, (int) dicSize);\n}",
