    "patch_code": "<M : java.util.Map> M putIn( final M map ) {\n    for ( final Entry<String, int[]> entry :mapping. entrySet()) {\n        final int[] columnmapping = entry. value() ;\n        final String key = entry. key() ;\n        if columnmapping == null || columnmapping. length == 0){\n            continue;\n        }\n        for ( int columnmappingitem : columnmapping ) {\n            if columnmappingitem > values. length - 1){\n                continue;\n            }\n            map. put( key , values[columnmappingitem] );\n        }\n    }\n    return map;\n}",
