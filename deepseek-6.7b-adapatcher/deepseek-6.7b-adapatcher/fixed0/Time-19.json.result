    "patch_code": "public int get Offline(long instant local){\n    final int offlocal = get Offline(instant);\n    final long adjustedInstant = instant - offlocal;\n    final int off adjusted = get Offline(adjustedInstant);\n    if (off local == off adjusted) {\n        if (instant > adjustedInstant) {\n            return off adjusted;\n        }\n    } else {\n        if (off adjusted > off local) {\n            long nextInstant = nextTransition(adjustedInstant);\n            long nextAdjustedInstant = nextTransition(instant - off adjusted);\n            if (nextInstant != next adjustedInstant) {\n                return off local;\n            }\n        } else {\n            long previousInstant = previousTransition(adjustedInstant);\n            long previousAdjustedInstant = previousTransition(instant - off adjusted);\n            if (previousInstant != previous adjustedInstant) {\n                return off adjusted;\n            }\n        }\n    }\n    return off adjusted;\n}",
