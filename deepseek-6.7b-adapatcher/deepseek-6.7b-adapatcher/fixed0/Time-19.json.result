    "patch_code": "public int get Offline() {\n    int result = 0;\n    long nextAdjusted = nextTransition(instantAdjusted + MIN_L Minutes);\n    long previousAdjusted = previousTransition(instantAdjusted - MIN_L Minutes);\n    if (nextAdjusted == instantAdjusted) {\n        result = get Offline(instantAdjusted + MIN_L minutes);\n    } else if (previousAdjusted == instantAdjusted) {\n        result = get Offline(instantAdjusted - MIN_L minutes);\n    } else {\n        result = get Offline(instantAdjusted);\n    }\n    return result;\n}",
