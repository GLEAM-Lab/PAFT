    "patch_code": "private void findCalledFunctions(\n    Node node, Set<String> changed) {\n  Preconditions.checkArgument(changed != null);\n  // For each referenced function, add a new reference\n  if (node.getType() == Token.CALL && node.getFirstChild().getType() == Token.NAME) {\n    Node child = node.getFirstChild();\n    changed.add(child.getString());\n  } else if (node.isScript()) {\n        FunctionMap functions = ((ScriptNode)node).getFunctionMap();\n        for (int i = 0; i < functions.size(); i++) {\n            findCalledFunctions(functions.getKey(i), changed);\n        }\n    }\n\n  for (Node c = node.getFirstChild(); c != null; c = c.getNextSibling()) {\n    findCalledFunctions(c, changed);\n  }\n}",
