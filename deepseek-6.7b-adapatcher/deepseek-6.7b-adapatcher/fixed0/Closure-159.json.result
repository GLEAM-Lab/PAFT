    "patch_code": "private void findCalled functions(\n    String name, node, Set<String> changed) {\n  //For each referenced function, add a new reference\n  if (node.getType() == Token.CALL) {\n    node child = node.getfirst child();\n    if (child.getType() == Token.Name) {\n      changed.add(name + child.getString());\n    }\n  }\n\n  for (node c = node.getfirst child(); c != null; c = c.getnext child()) {\n    find called functions(name, c, changed);\n  }\n}",
