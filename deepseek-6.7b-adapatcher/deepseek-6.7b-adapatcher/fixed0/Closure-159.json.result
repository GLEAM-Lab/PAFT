  {
    "patch_code": "private void findCalledFunctions(Node node, Set<String> changed) {\n  Preconditions.checkArgument(changed != null);\n  \n  if (node.getType() == Token.FUNCTION && node.isAssignable()) {\n    changed.add(((Identifier) ((ExpressionStatement) node).getFirstChild()).getName());\n  }\n  \n  if (node.hasChildren()) {\n    List list = Lists.newArrayList(Iterables.filter(\n        Iterators.forEnumeration(node.children()), Predicates.not(Predicates.instanceOf(Comment.class))));\n    for (int i = 0; i < list.size(); i++) {\n      findCalledFunctions((Node) list.get(i), changed);\n    }\n  } else if (node instanceof ExpressionStatement &&\n              (node = ((ExpressionStatement) node).getFirstChild()) != null &&\n              node.getType() == Token.CALL) {\n    findCalledFunctions(((MethodCall) node).getObject(), changed);\n  }\n}",
