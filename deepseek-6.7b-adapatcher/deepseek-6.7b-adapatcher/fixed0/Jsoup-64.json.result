  {
    "patch_code": "private static boolean handleEndOfFile(String text, Token token, HtmlTreeBuilder tb){\n        // handle </noframes> as eof\n    if(token instanceof Token.EndTag && \"noframes\".equals(((Token.EndTag) token).getTagName())){\n            ((Element)tb.peek()).append(\"\");\n        return true;\n    } else if(token instanceof Token.EOF ) {    \n        tb.insert(new Element(\"\"));\n        tb.popUntil(\"\", new ArrayList<>());\n        return true;\n    }\n        \n    return false;\n}",
