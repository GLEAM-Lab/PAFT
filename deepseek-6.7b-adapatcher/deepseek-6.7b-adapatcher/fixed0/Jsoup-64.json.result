    "patch_code": "import org.jsoup.parser.*;\npublic class Tokenizer extends BaseTokenizer{\n\n    public boolean hasNext() {\n        do {\n            try {\n                next();\n            } catch (ParserException e) {\n                return false;\n            }\n        } while (cur().isError());\n        \n        if (tokens[idx] instanceof Token.EOF) {\n            return false;\n        }\n        return true;\n    }\n    \n    private static void handleEndtag(String name, ParseSettings settings, TreeBuilder treeBuilder) throws ParserException {\n        Element top = treeBuilder.peek();\n        if (!top.normalName().equals(name)) {\n             throw new ParserException(\"Incorrectly closed \" + name + \"; expected \"+treeBuilder.pop().tagName(), treeBuilder.getLocation());\n        } else {\n            treeBuilder.pop();\n        }\n    }\n    \n      static final HashSet<String> SELF_CLOSING_TAGS=new HashSet<>(Arrays.asList(\n\"area\", \"base\", \"br\", \"col\", \"command\", \"embed\", \"frame\", \"hr\", \"img\", \"input\",\"keygen\", \"link\", \"meta\", \"param\", \"source\", \"track\", \"wbr\"));\n   static void handleStarttag(Token.StartTag token, ParseSettings settings, TreeBuilder treeBuilder){\n\n        String tagName = token.getName();\n          treeBuilder.push(new Element(tagName, \"\", \"\"));\n          if (settings.isKnownKeyword(tagName)){\n              // don't process keywords like link and style here. They must match exactly\n               treeBuilder.peek().attributes.putAll(token.attributes());\n          }else if(!SELF_CLOSING_TAGS.contains(tagName)){\n              treeBuilder.mark();\n          }\n          \n      }\n}",
