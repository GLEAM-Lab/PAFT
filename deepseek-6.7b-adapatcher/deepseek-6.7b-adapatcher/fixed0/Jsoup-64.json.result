  {
    "patch_code": "private static void handleRawtext(Token.StartTag startTag, HtmlTreeBuilder tb) {\n    \n    if(((String)startTag.tagName()).equals(\"style\")||((String)startTag.tagName()).equals(\"title\")||((String)startTag.tagName()).equals(\"noframes\")){\n        Token token = new Token() {};\n        ((Token.EndTag)token).tagName=\"br\";\n         tb.handleToken(token);\n         return;\n    }\n    else{\n        tb.insert(startTag);\n    }\n   \n    tb.tokeniser.transition(TokeniserState.Rawtext);\n    tb.markInsertionMode();\n    tb.transition(Text);\n}",
