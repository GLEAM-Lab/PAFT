    "patch_code": "protected void handleSelfClosingTag(Token token){\n        Emitter e = treeBuilder.emit();\n        Element el = e.element(token.normalName());\n        e.attr(el, token.attributes().keySet(), token.attributes());\n        popActiveElement(treeBuilder);\n}",
