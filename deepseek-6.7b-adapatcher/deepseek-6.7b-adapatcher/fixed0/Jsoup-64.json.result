  {
    "patch_code": "private static boolean checkIfIsStyleOrTitleNoFrames(String name){\n        return \"style\".equalsIgnoreCase(name) || \"title\".equalsIgnoreCase(name) || \"noframes\".equalsIgnoreCase(name);        \n}\n\nprivate static void handleRawtext(Token.StartTag startTag, HtmlTreeBuilder tb) {\n    \n    if (!checkIfIsStyleOrTitleNoFrames(startTag.tagName())){\n            tb.insert(startTag);\n            tb.tokeniser.transition(TokeniserState.Rawtext);\n            tb.markInsertionMode();\n            tb.transition(Text);\n          } else {\n                tb.insert(startTag);        \n                \n            if (\"style\".equalsIgnoreCase(startTag.tagName()) ){\n                    tb.popInsertionMode();            \n                    \n            } else if (\"title\".equalsIgnoreCase(startTag.tagName()) && tb.top() instanceof Document.OutputSettings){     \n                  ((Document.OutputSettings)tb.top()).setTitle(new String(\"\"));                           \n               } \n             \n            if (\"noframes\".equalsIgnoreCase(startTag.tagName())){    \n                   tb.popInsertionModeUntil(HtmlTreeBuilder.TagNameMatches(\"frameset\")::match);  \n               \n                } else {\n                      tb.tokeniser.transition(TokeniserState.Initial);\n                        tb.markInsertionMode();\n                          tb.transition(Default);\n                }\n           }\n    }\n\n    private static class TagNameMatches implements Predicate<Token> {\n        \n        private final String tag;\n\n        TagNameMatches(String tag) {this.tag = tag;}\n\n        @Override\n        public boolean test(Token token) {\n            return Token.ELEMENT_NAME == token.type() && Objects.equals(token.asElement().getTag(), tag);\n        }\n    }",
