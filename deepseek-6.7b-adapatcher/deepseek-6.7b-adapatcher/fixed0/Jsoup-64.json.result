  {
    "patch_code": "private static boolean handleStyleOrTitleClosing(char c, Token nextToken, HtmlTreeBuilder tb){\n        if(!tb.tokenIs(nextToken, Token.Type.EndTag)){\n            return false;\n        }\n        String match = nextToken.toString();\n        if(!match.equals(\"style\") && !match.equals(\"title\")){\n            throw new IllegalArgumentException(\"tag name not 'style'/'title': \" + match);\n        }\n        Element e = tb.peekLastChild();\n        if(e == null || (!e.isValid() && !match.equals(\"title\"))){\n            e = new Element(match).wholeAttributes(\"\"); //Empty attrs, don't merge in real doc\n            tb.lastTreeNode().appendChild(e);\n        }else if(!match.equals(\"style\") ){\n            tb.removeLastTreeNode();\n        }\n        if(match.equals(\"style\")){\n            tb.popUntilReachToMatchingElementInStackOfOpenElements();\n        }else{\n            tb.consumeCharacter(c); //Consume close tag.\n        }\n        return true;\n    }\n\n\n\nprivate static void handleRawtextOrScript(Token.StartTag startTag, HtmlTreeBuilder tb){\n     tb.pushIntoMarkupInspectorFor(startTag,\"script\" );\n      if(tb.getConfiguration().isOmitCrushingOfScriptTags()) return ;\n        ScriptTokens tokens = tb.handleUnusualTokensAtBeginningOfTextBlock('\\n',ScriptTokens.EMPTY);\n        \n     /* This has some differences from JSoup sources.\n        * It avoids adding empty script elements as children\n        */\n        Element scriptElm=null;\n        if(!tokens.isEmpty()||tb.peekLastTreeNode() instanceof Comment){\n            scriptElm=new Element(startTag).wholeAttributes(\"\");\n            \n            tb.lastTreeNode().appendChild(scriptElm);\n            tb.setTempVal((CharSequence)\"\");\n          \n        } else {\n            \n          tb.popIntoAndStoreTemporaryValueFromMarkupInspectors();\n              scriptElm=  tb.getTempVal().toElement();\n             tb.resetTempVal();\n           \n        }\n        tb.addTrailingLineBreakIfNeeded(scriptElm);\n        tb.transition(Script);\n    }\n\nprivate static void handleNoframesClosing(char c, Token nextToken, HtmlTreeBuilder tb){\n        int depthBeforeTest = tb.depthOfCurrentData();\n        tb.handleFramesetSpecificProcessingOfEndtags();\n        if(depthBeforeTest == tb.depthOfCurrentData()+1){ //We closed last frame.\n            tb.transition(BeforeHead);\n            return;\n        }\n        tb.consumeCharacter(c);\n        tb.addNonConvertableText(c);\n    }",
