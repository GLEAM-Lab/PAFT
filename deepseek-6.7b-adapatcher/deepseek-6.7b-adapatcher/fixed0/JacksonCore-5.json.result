    "patch_code": "private final static int _getIndex(String str) {\n    final int length = str.length();\n    if (length == 0 || length > 5) {\n        return -1;\n    }\n    for (int i = 0; i < length; i++) {\n        char c = str.charAt(i++);\n        if (c > '9' || c < '0') {\n            return -1;\n        }\n    }\n    if (length == 5) {\n        long l = numberAslong(str);\n        if l > Integer.max value){return -1};\n    }\n    return numberAsint(str);\n}\n private final static int numberAsint(String str) {\n    return (int)numberAslong(str);\n}\n private final static long numberAslong(String str) {\n    return long.valueOf(str);\n}",
