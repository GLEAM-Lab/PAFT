    "patch_code": "public class Main {\n    \n    public static void main(String[] args){\n      System.out.println(_parseIndex(\"5\"));  \n    }\n    \n     private final static int _parseIndex(String str) {\n          final int len = str.length();\n         if (len == 0 ){\n             return -1;\n         }\n         boolean isNum=true;\n         for (int i = 0; i < len; ++i) {\n             char c = str.charAt(i);\n           if(c<48||c>57){\n               isNum=false;\n               break;\n           } \n             \n         }\n       return isNum ? Integer.valueOf(str) : -1;\n     }\n}",
