    "patch_code": "private static final Chronology DEFAULT_CHRONOLOGY = ISOChronology.getInstanceUTC();\n\n@TestOnly\npublic static Partial constructInvalidForTest() {\n    throw new UnsupportedOperationException(\"Not supported\");\n}\n\n/**\n * Creates a partial representation of a date or time within a chronology. The fields\n * passed in are ordered based on their supported units first, and then smallest units later.\n * This is used instead of multiple 'with' operations, which would create more instances.\n * @param chrono  the chronology to apply, not null\n * @param fields  the fields to include, not null and no duplicates\n */\nprotected Partial(Chronology chrono, DateTimeFieldType[] fields, int[] values) {\n    super(chrono, fields, values);\n}\n\npublic Partial(Chronology chrono, DateTimeFieldType[] fields, int[] values) {\n    assertFieldsNotNull(fields);\n    assertNoDuplicatesInArray(fields);\n    assertValuesCorrectLength(values, fields);\n    chrono = Objects.requireNonNull(chrono, \"The chronology must not be null\");\n    validateFieldsAndValues(chrono, fields, values);\n    this.iChronology = chrono;\n    iFields = fields;\n    iValues = values;\n}\n  \n// ... rest of class omitted for brevity ...",
