    "patch_code": "public Partial with(DateTimeFieldType fieldType, int value) {\n    if (fieldType == null) {\n        throw new IllegalArgumentException(\"The field type must not be null\");\n    }\n    \n    // Modify original code here\n    int index = indexOf(fieldType);\n    if (index != -1 && getValue(index) == value) {\n        return this;\n    }\n    \n    if (!containsKey(fieldType)) {\n        int size = size();\n        DateTimeFieldType[] newFields = Arrays.copyOf(getFields(), size + 1);\n        int[] newValues = Arrays.copyOf(getValueArray(), size + 1);\n        newFields[size] = fieldType;\n        newValues[size] = value;\n        return new Partial(iChronology, newFields, newValues);\n    } else {\n        return set(fieldType, value);\n    }\n}",
