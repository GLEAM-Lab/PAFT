  {
    "patch_code": "public Partial with(DateTimeFieldType fieldType, int value) {\n    Objects.requireNonNull(fieldType, \"The field type must not be null\");\n    Chronology chrono = getChronology();\n    List<DateTimeFieldType> tempTypes = new ArrayList<>(Arrays.asList(iTypes));\n    List<Integer> tempValues = new ArrayList<>(Arrays.asList(iValues));\n    \n    int index = tempTypes.indexOf(fieldType);\n    if (index != -1) {\n        if (tempValues.get(index) == value) {\n            return this;\n        }\n        tempValues.set(index, value);\n    } else {\n        DurationField unitField = fieldType.getDurationType().getField(chrono);\n        boolean supported = unitField.isSupported();\n        if (!supported) {\n            throw new UnsupportedTemporalTypeException(fieldType.getName());\n        }\n        \n        int i = 0;\n        while (i < tempTypes.size() && chrono.getInstantComparator().compare(tempTypes.get(i), fieldType) < 0) {\n            i++;\n        }\n        \n        tempTypes.add(i, fieldType);\n        tempValues.add(i, value);\n    }\n    \n    chrono.checkAllFieldsSet(tempTypes.toArray(new DateTimeFieldType[0]), tempValues.toArray(new Integer[0]));\n    validate(chrono, tempTypes.toArray(new DateTimeFieldType[0]), tempValues.toArray(new Integer[0]));\n    return new Partial(chrono, tempTypes.toArray(new DateTimeFieldType[0]), tempValues.toArray(new Integer[0]));\n}",
