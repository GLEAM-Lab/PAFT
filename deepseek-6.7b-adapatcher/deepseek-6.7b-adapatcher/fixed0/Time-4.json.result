    "patch_code": "public Partial with( DateTimeFieldType fieldType, int value ) {\n    int index = indexOf( field );\n    if index == -1 && fieldType != null && fieldType != year().getFieldType() && fieldType != month().getFieldType() && fieldType != dayOfMonth().getFieldType() {\n        DateTimeFieldType[] new types = new DateTimeFieldType[ types.length + 1 };\n        int[] new values = new int[ values.length + 1 };\n        int i = 0;\n        while i < types.length && fieldType.get chronology().get field types[i].get chronology() {\n            types[i++];\n        };\n        while i < types.length && field types[i].get chronology().get field type.get chronology() {\n            types[i++];\n        };\n        int j = 0;\n        while j < types.length && types[j].get chronology().get field types[j].get chronology() {\n            types[j++];\n        };\n        while j < types.length && types[j].get chronology().get field type.get chronology() {\n            types[j++];\n        };\n        SystemArrayUtil.getInstance().array copy( types, 0, types[i].length );\n        SystemArrayUtil.getInstance().array copy( values, 0, values[i].length );\n        types[i];\n        values[i];\n        if i < types.length {\n            types[i + 1:] = types[i:];\n            values[i + 1:] = values[i:];\n        };\n        return new Partial( types, values );\n    };\n    return new Partial( types[ :i], values[ :i], types[i], values[i], types[i + 1:], values[i + 1:] );\n};",
