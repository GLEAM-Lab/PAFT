    "patch_code": "private static final long serialVersionUID = 20130928L;\n\nprivate Chronology iChronology;\nprivate DateTimeFieldType[] iFields;\nprivate int[] iValues;\n\n/**\n * Factory method for constructing an immutable {@link Partial} instance. This constructor takes three parameters - \n * chronology, datetime field types, and integer values. Each input parameter is not null, contains no duplicated elements, \n * and has valid size and content according to the definition below:\n *     <ul>\n *         <li>chronology: A calendar system used in date and time operations, which cannot be null</li>\n *         <li>datetime field types: An array of date and time fields included in the partial representation, \n *             which cannot be null and contains no duplicate elements</li>\n *         <li>integer values: An array of corresponding numeric values to these fields. The length of this array \n *             equals to the number of elements in datetime field types. All elements are within their respective ranges, \n *             and there is one element corresponding to each field in datetime field types</li>\n *     </ul>\n * \n * @param chronology     the chronology associated with the partial, must not be null\n * @param fieldTypes     the array of datetime fields in the partial, must not be null and unique\n * @param values         the corresponding integer values to these fields, must not be null\n */\npublic Partial(Chronology chronology, DateTimeFieldType[] fieldTypes, int[] values) {\n    if (chronology == null || fieldTypes == null || values == null ) {\n        throw new IllegalArgumentException(\"Constructor arguments must not be null.\");\n    }\n    if (fieldTypes.length != values.length) {\n        throw new IllegalArgumentException(\"Field types and values arrays must have the same size.\");\n    }\n    for (int i = 0; i < fieldTypes.length; ++i) {\n        if (indexOf(fieldTypes[i]) != i) {\n            throw new IllegalArgumentException(\"Field types array must not contain duplicates.\");\n        }\n    }\n    iChronology = chronology;\n    iFields = Arrays.copyOf(fieldTypes, fieldTypes.length);\n    iValues = Arrays.copyOf(values, values.length);\n}",
