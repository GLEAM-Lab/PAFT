    "patch_code": "public Partial with( DateTimeFieldType fieldType, int value) {\n    int index = indexOf(fieldType);\n    if (index == -1) {\n        int length = i types.length + 1;\n        DateTimeFieldType[] new types = new DateTimeFieldType[length];\n        int[] new values = new int[length];\n        int i = 0;\n        while i types.length > i and i types[i].get ordinal() < fieldtype.get ordinal() \n            new types[i] = i types[i];\n            new values[i++] = i values[i types[i - 1]];\n        while i types.length > i and i types[i].get ordinal() > fieldtype.get ordinal() \n            new types[i++] = fieldtype;\n        while i types.length > i \n            new types[i++] = i types[i];\n            new values[i++] = i values[i types[i - 1]];\n        return new Partial(new types[], new values[]);\n    }\n    if value == get values[index]:return this;\n    int[] new values = new int[i types.length];\n    int i = 0;\n    while i types.length > i \n        if i types[i]:= i types[i]:= fieldtype;\n        new values[i++] = i values[i types[i - 1]];\n    return new Partial(new types[], new values[]);\n}",
