    "patch_code": "public final ObjectcomputeValue(EvalContext context) {\n    Object firstValue =args[0].computeValue(context);\n    Object secondValue =args[1].computeValue(context);\n    if (!(firstValue.isInstanceof(NodeSet) && secondValue.isInstanceof(NodeSet))){\nreturncomputeValueWithNumberAndNodeSet(firstValue, secondValue);\n }\n    boolean result = false;\n    for (int i = 0; i <((NodeSet) firstValue).size(); i++){\nresult |=computeValueWithNodeSet(firstValue.getNodeAt(i), secondValue) == null ? false : true;\n }\n return result ? booleanValueOf(true) : booleanValueOf(false);\n}",
