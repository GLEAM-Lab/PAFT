    "patch_code": "public final Object computeValue(EvalContext context) throws XPatherException {\n    \n    Object leftVal = args[0].computeValue(context);\n    Object rightVal = args[1].computeValue(context);\n\n    Number lnum = null;\n    Double rnum = null;\n        \n    boolean hasRightOperandNodes = false;\n    if (rightVal != null && rightVal instanceof NodeSet){\n      Iterator iter = ((NodeSet) rightVal).iterator();\n      while (!hasRightOperandNodes && iter.hasNext()) {\n          Object o = iter.next();\n          if (o != null && o instanceof Node) {\n              hasRightOperandNodes = true;  \n          }\n      }\n    }\n      \n    try {\n        if (leftVal instanceof NodeSet && hasRightOperandNodes) {\n            lnum = ((Number) XPathEngineUtils.convertObjectToNumber(((NodeSet) leftVal).get(0)).getValue());            \n        } else if (leftVal instanceof NodeSet && rightVal instanceof Double ) {\n            rnum =  (Double) rightVal ;\n        } else if (leftVal instanceof Double || rightVal instanceof Double ) {\n            lnum = new Double(((double)leftVal));\n            rnum = ((Double) rightVal ).doubleValue();\n        }\n        if (lnum == null || rnum == null ) {\n            throw new RuntimeException(\"Cannot compare value : \" + leftVal  + \", \" +  rightVal );\n        }\n    } catch (XPatherRuntimeException xre) {\n        throw new XPatherException(\"Error computing relational expression: \"\n                + xre.getMessage());\n    }\n\n    int cmpLt = Double.compare(lnum.doubleValue(), rnum);\n          \n    switch (operatorType) {\n    case GREATER_THAN:\n        return (cmpLt == 1)? Boolean.TRUE : Boolean.FALSE;\n    case LESS_THAN:\n        return (cmpLt == -1)? Boolean.TRUE : Boolean.FALSE;\n    case EQUALS:\n        return (cmpLt == 0)? Boolean.TRUE : Boolean.FALSE;\n    default:\n        break;\n    }\n    throw new RuntimeException(\"Unhandled operator type :\" + operatorType);\n}",
