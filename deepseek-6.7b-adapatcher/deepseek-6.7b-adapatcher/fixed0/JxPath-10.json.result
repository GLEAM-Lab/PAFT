    "patch_code": "public final Object computeValue(EvalContext context) {\n    Object lhsVal = args[0].computeValue(context);\n    Object rhsVal = args[1].computeValue(context);\n    \n    // Convert lhsVal to Double (for greater than and less than operations)\n    Double lhsNum =  null;\n    if(!(lhsVal instanceof NodeSet)){\n        try{\n             lhsNum = ((Number)lhsVal).doubleValue();\n         }catch (Exception e){\n              throw new RuntimeException(e);\n         }\n      } else {\n           List<Node> nodes = (List)(lhsVal);\n          if(nodes.size() > 0 ){\n               lhsVal = ((Node)nodes.get(0)).getNodeValue();\n             try{\n                  lhsNum = Double.parseDouble((String)lhsVal);  \n               }catch (Exception e){\n                    throw new RuntimeException(e);\n                }\n          }\n       }\n   \n    // Return false in case rhsVal is a node set and it's not empty \n    \n    if(!(rhsVal instanceof NodeSet)){\n       return Boolean.FALSE ;\n    } else {\n        List <Node> nodes = (List)rhsVal ;\n         if(nodes.size() != 0 ){\n             return Boolean.FALSE ;\n         }\n     } \n  \n    // Perform operation\n    Boolean retBool = (lhsNum == null || rhsVal == null) \n            ? Boolean.FALSE \n            : (lhsNum >= Double.parseDouble((String)rhsVal)) ;\n    return retBool ? Boolean.TRUE : Boolean.FALSE ;\n}",
