    "patch_code": "public final Object computeValue(EvalContext context) {\n    Object o1 = args[0].computeValue(context);\n    Object o2 = args[1].computeValue(context);\n    \n    if(o1 instanceof NodeSet && o2 instanceof NodeSet){\n        boolean boolVal = false;\n        \n        for(int i = 0 ; i < ((NodeSet) o1).size(); i++){\n            \n            for(int j = 0 ; j < ((NodeSet) o2).size(); j++){\n                \n                    Comparable c1 = Double.valueOf(Double.parseDouble(((XNumber) XPathUtils.numberFunction(((XMLNode) ((NodeSet) o1).get(i)).getNavigator())\n                            .toString()));\n                    \n                    Comparable c2 = Double.valueOf(Double.parseDouble(((XNumber) XPathUtils.numberFunction(((XMLNode) ((NodeSet) o2).get(j)).getNavigator())\n                            .toString()));\n                    \n                    if(c1.compareTo(c2) > 0){\n                        \n                        boolVal = true;\n                        break;\n                    }\n                }\n            }\n        \n        return boolVal ? Boolean.TRUE : Boolean.FALSE;\n    } else if(o1 instanceof NodeSet && !(o2 instanceof NodeSet)){\n       return ((Comparable)((XNumber) XPathUtils.numberFunction(((XMLNode) ((NodeSet) o1).get(0)).getNavigator()).toString()))\n      .compareTo(o2) > 0 ? Boolean.TRUE : Boolean.FALSE;\n    } else {\n      throw new IllegalArgumentException(\"Invalid arguments (\" + o1\n          + \", \" + o2 + \")\");\n    }\n   }",
