    "patch_code": "import java.util.*;\n\npublic class CoreOperationGreaterThan extends CoreOperationBinary {\n     public static int PRECEDENCE = 140;\n\n    @Override\n    protected boolean evaluateNodeSetAndNumberAsLeftOperand(ListIterator leftIter, NodeSet leftNodes, String rightOperand) {\n        throw new UnsupportedOperationException();\n    }\n\n    @Override\n    protected Object evaluateNodeSetAndStringAsRightOperand(ListIterator rightIter, List leftResult) throws NavigationError {\n        while (rightIter.hasNext()) {\n            Node rightNode = (Node) rightIter.next();\n            String valueOfParent = ((Element) getAncestorOrSelfByName(rightNode, \"node\")).getAttribute(\"name\");\n            Iterator iter = ((NodeSet) leftResult).iterator();\n            while (iter.hasNext()) {\n                Node leftNode = (Node) iter.next();\n                String name = \"\";\n                try{\n                    name = ((Element) getAncestorOrSelfByName(leftNode,\"node\")).getAttribute(\"name\");\n                }catch(NullPointerException e){\n                    \n                }\n                if (valueOfParent != null && valueOfParent.compareTo(name) > 0 ) {  \n                    return Boolean.TRUE;\n                }\n            }\n        }\n        return Boolean.FALSE;\n    }\n\n      @Override\n    public void visit(CoreExpressionVisitor v) {\n        v.visitGreaterThanOperator(this);\n    }\n\n}",
