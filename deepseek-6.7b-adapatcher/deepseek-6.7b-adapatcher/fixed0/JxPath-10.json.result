    "patch_code": "package com.example;\nimport java.text.DecimalFormat;\nimport org.apache.xpath.operations.*;\n\npublic class GreaterThan extends CoreBinaryOperator{\n     public static final long serialVersionUID = 1L;\n\n       @Override\n      public Object operate(Object left, Object right){\n           DecimalFormat decimalFormat = new DecimalFormat();\n            double lVal = 0;\n            double rVal = 0;\n            \n            //Handle case when right operand is not a node set\n            if(!(right instanceof NodeSet)){\n               try{\n                  lVal = Double.parseDouble(((JAXPTextNode)left).getNode().getFirstChild().getNodeValue());\n              }catch (Exception e){\n                     throw new RuntimeException(\"Incorect argument type: \" + left.getClass().getName(),e);\n              } \n                rVal = Double.parseDouble(decimalFormat.format(right));\n            }else if (!(left instanceof NodeSet && ((NodeSet)left).size() == 1)){\n                    throw new IllegalArgumentException(\"Incorrect arguments types\");\n          }else{\n                lVal = Double.parseDouble(((JAXPTextNode)((NodeSet)left).nodes().next()).getNode().getFirstChild().getNodeValue());\n              rVal = Double.parseDouble(decimalFormat.format(right));\n         }\n          \n        if(lVal >= rVal ){\n              return Boolean.TRUE;\n            }else{\n               return Boolean.FALSE;\n           }\n     }  \n   }",
