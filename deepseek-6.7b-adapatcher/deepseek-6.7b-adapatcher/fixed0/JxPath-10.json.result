    "patch_code": "public final Object computeValue(EvalContext context) {\n    Object leftArgVal = args[0].computeValue(context);\n    Object rightArgVal = args[1].computeValue(context);\n    \n    // Both are NodeSet\n    if((leftArgVal instanceof NodeSet) && (rightArgVal instanceof NodeSet)){\n        NodeSet lhsNodeSet = (NodeSet) leftArgVal;\n        NodeSet rhsNodeSet = (NodeSet) rightArgVal;\n        \n        boolean existsFlag =  false;\n        \n        // Compare each pair\n        for (int i = 0;i < lhsNodeSet.size();++i){\n           for (int j = 0;j < rhsNodeSet.size();++j){\n              double ld= Double.NaN;\n              try{\n                  ld  =Double.valueOf(lhsNodeSet.get(i).getNodeValue()).doubleValue();\n              }catch(Exception e){\n                  \n              }\n              \n              double rd= Double.NaN;\n              \n              try{\n                  rd  =Double.valueOf(rhsNodeSet.get(j).getNodeValue()).doubleValue();\n              }catch(Exception e){\n                  \n              }\n              \n             // Comparison with different types of rightOperands\n              if(!Double.isNaN(ld)&&!Double.isNaN(rd)){  \n                  if((Character) operator == '>'){\n                      if(ld>rd){\n                         existsFlag = true;\n                          break; \n                     }\n                   \n                }else if((Character)operator=='<'){\n                     if(ld<rd){\n                          existsFlag = true;\n                           break; \n                     }\n                      \n                }else if((Character)operator=='>='){\n                     if(ld>=rd){\n                          existsFlag = true;\n                            break; \n                     }\n                      \n                } else if ((Character) operator == '<='){\n                    if (ld <= rd) {\n                        existsFlag = true;\n                        break;\n                    }\n                } else if ((Character) operator == '=') {\n                    if (ld == rd) {\n                        existsFlag = true;\n                        break;\n                    }\n                } else if ((Character) operator == '!=') {\n                    if (ld != rd) {\n                        existsFlag = true;\n                        break;\n                    }\n                }\n              }\n          }\n      }\n      \n        return existsFlag  ? Boolean.TRUE : Boolean.FALSE; \n    }\n        \n    // First argument is NodeSet and second is Number\n    else if((leftArgVal instanceof NodeSet)&& (rightArgVal instanceof Double)){\n        NodeSet lhsNodeSet = (NodeSet) leftArgVal;\n        double rhsNumber = ((JXPathScalar)rightArgVal).getValueAsDouble();\n        \n        \n        for (int i = 0; i < lhsNodeSet.size(); ++i) {\n            double tmp = Double.NaN;\n            try{\n                tmp = Double.valueOf(lhsNodeSet.get(i).getNodeValue()).doubleValue();\n            }catch(Exception ex){\n                \n            }\n            \n            if (!Double.isNaN(tmp) && tmp >= rhsNumber) {\n                return Boolean.FALSE;\n            }\n        }\n        \n        return Boolean.TRUE;\n    }\n    \n    throw new IllegalArgumentException(\"Unsupported operation arguments \" + leftArgVal.getClass() + \",\" + rightArgVal.getClass());\n}",
