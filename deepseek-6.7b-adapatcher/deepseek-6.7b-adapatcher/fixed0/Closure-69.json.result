    "patch_code": "private void visitCall(Node Traversal t,Node n){\n  node child = n.getFirstchild();\n  JSType childType = getJSType(child). restrictBy notnullOrUdefined();\n  \n  if (!childType.canBeCalled()) {\n    report(t, n, NOT_CALLable, childType.toString());\n    ensureTyped(t, n);\n    return;\n  }\n  if (childType.is(new ObjectType(\"goog.math.Size\"))){\n    ensureTyped(t, n); return;\n  }\n  if (childType.is(new ObjectType(\" goog.math.Point\"))){\n    ensureTyped(t, n); return;\n  }\n  if (childType.is(new ObjectType(\" goog.math.PointArray\"))){\n    ensureTyped(t, n); return;\n  }\n  if (childType.is(new ObjectType(\" goog.math.rectangle\"))){\n    ensureTyped(t, n); return;\n  }\n  if (childType.is(new ObjectType(\" goog.math. rectangleArray\"))){\n    ensureTyped(t, n); return;\n  }\n  if (childType.is(new ObjectType(\"goog.graphics.LineStrip\"))){\n    ensureTyped(t, n); return;\n  }\n  if (childType.is(new ObjectType(\"goog.graphics.LineStripBuilder\"))){\n    ensureTyped(t, n); return;\n  }\n  if (childType.is(new ObjectType(\" goog.graphics.LineBuilder\"))){\n    ensureTyped(t, n); return;\n  }\n  if (childType.is(new ObjectType(\" goog.graphics. path\"){\n    ensureTyped(t, n); return;\n  }\n  if (childType.is(new ObjectType(\" goog.graphics. pathBuilder\"){\n    ensureTyped(t, n); return;\n  }\n  if (childType.is(new ObjectType(\" goog.graphics. line.line\"){\n    ensureTyped(t, n); return;\n  }\n  if (childType.is(new ObjectType(\"goog.graphics. line.LineBuilder\"){\n    ensureTyped(t, n); return;\n  }\n  ensureTyped(t, n);\n}",
