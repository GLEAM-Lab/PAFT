    "patch_code": "private class TypeCheckVisitor extends TreeTranslatingVisitor {\n...\n@Override protected Node translateMethodCall(NodeTree tree, MethodCall call) {\n  ...\n  Object result;\n  if ((result = resolveMemberAccessorForReceiver(call)) != null) {\n    ...\n  } else if (call.getTarget().getKind() == SyntaxKind.IDENTIFIER) {\n    ...\n  } else if (call.getTarget().hasPropertyDereference()\n            || call.getTarget().getSyntaxType() == SyntaxType.COMPILATION_UNIT\n            || call.getTarget().getKind() == SyntaxKind.GETPROPERTY\n            || call.getTarget().getKind() == SyntaxKind.NEW) {\n    reportIncompatible(tree, call, RECEIVER_INCOMPATIBLE,\n                       JSUtils.typeToString(((Expression) call.getTarget()).getType()),\n                       0);\n  } else {\n    reportError(new CompilationError(\"unknown target kind\", call));\n  }\n\n  assert result != null;\n  return (Node) result;\n}\n...\n}",
