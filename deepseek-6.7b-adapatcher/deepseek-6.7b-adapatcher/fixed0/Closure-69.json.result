    "patch_code": "private static int CONTEXT = 3;\npublic class TypeCheck extends TreeTranslatingPass {\n@Override\nprotected JSToken processToken(JSToken token) {\nreturn token;\n   }\n@Override\nprotected JSNode postOrderTraverse(TreeTranslator t, JSNode node) {\nnode = super.postOrderTraverse(t, node);\nif (node == null)\nreturn null;\nif (AST.isAssignExpr(node)) {\n  if(!((AssignExpr) node).getTarget().hasContext(CONTEXT)){\n    throw new RuntimeException(\"Can't assign instance methods\");\n  }else{\n     ((AssignExpr) node).getTarget().setHasContext(true);\n  }\n}\n return node;\n }\n @Override\n public PassResult process(JSProgram jsProgram) {\n try {\n    addVisitor(new NodeFilter(){\n       public boolean enter(NodeTraversal t, Node n){\n          return true;\n       }\n       public boolean leave(NodeTraversal t, Node n){\n          if (n instanceof GetProp){\n              JSAccess accessor = ((GetProp) n).getValue();\n               if (accessor.isComputed() && !accessor.getObject().getJSType().canBeDereferenced()){\n                  throw new IllegalStateException (\"Can't operate on undereferencable \" + accessor.getObject().getJSType());\n                }else if(!accessor.getQualifier().getJSType().isHostObject()&& (accessor.getMethodExpr()!=null||(accessor.getDelegateName()==null ^ accessor.getName()==null))) {\n                    throw new IllegalStateException (\"Invalid context \"+accessor.getQualifier().toSourceString());\n                 }\n            }\n           return true;\n      }});\n    super.process(jsProgram);\n} catch (RuntimeException e) {\n   reportError(e.getMessage(), 0);\n   return PassResult.CHANGED;\n }\n return PassResult.UNCHANGED;\n}\n}",
