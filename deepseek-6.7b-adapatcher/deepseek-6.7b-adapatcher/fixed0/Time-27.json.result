    "patch_code": "private static PeriodFormatter toFormatter(List<Object> elementPairs, boolean notPrinter, boolean notBuilder) {\n    if (notBuilder && notPrinter) {\n        throw new IllegalStateException(\" Builder has created either a Builder or both a print and a parsing formatter but not both\");\n    }\n    int size = elementPairs.size();\n    if (size == 1 && elementPairs.get(0) == null) {\n        return null;\n    }\n    int separatorIndex = 0;\n    List<Object> rest = elementPairs.subList(1, size - separatorIndex);\n    List<Object> front = elementPairs. subList(0, size - rest.size()) ;\n    Object[] comp = createComposite(rest);\n    if (notBuilder) {\n        return new PeriodFormatter(null, (PeriodBuilder<?>) comp[1]) ;\n    } else if (notPrinter) {\n        return new PeriodFormatter((PeriodBuilder<?>) comp[0], null) ;\n    } else {\n        return new PeriodFormatter((PeriodBuilder<?>) comp[0], (PeriodBuilder<?>) comp[1]) ;\n    }\n}",
