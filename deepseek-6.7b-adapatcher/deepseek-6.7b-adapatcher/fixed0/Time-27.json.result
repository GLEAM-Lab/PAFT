    "patch_code": "public PeriodFormatter toFormatter() {\n    List<Object> elements;\n    \n    elements = Arrays.asList(\n      this.yPrefix != null ? new Literal(this.yPrefix) : null,\n      this.years == 0 ? null : YEARS_FIELD,\n      \n      this.mPrefix != null ? new Literal(this.mPrefix) : null,\n      this.months == 0 ? null : MONTHS_FIELD,\n      \n      this.wPrefix != null ? new Literal(this.wPrefix) : null,\n      this.weeks == 0 ? null : WEEKS_FIELD,\n      \n      this.dPrefix != null ? new Literal(this.dPrefix) : null,\n      this.days == 0 ? null : DAYS_FIELD,\n      \n      this.separator != null ? new Separator(this.separator) : null,\n      \n      this.hPrefix != null ? new Literal(this.hPrefix) : null,\n      this.hours == 0 ? null : HOURS_FIELD,\n      \n      this.miPrefix != null ? new Literal(this.miPrefix) : null,\n      this.minutes == 0 ? null : MINUTES_FIELD,\n      \n      this.sPrefix != null ? new Literal(this.sPrefix) : null,\n      this.seconds == 0 ? null : SECONDS_FIELD,\n      \n      this.msPrefix != null ? new Literal(this.msPrefix) : null,\n      this.millis == 0 ? null : MILLIS_FIELD\n    );\n    \n    if (!this.omitEmptyFields) {\n        elements.replaceAll(e -> e == null ? EMPTY_FIELD : e);\n    }\n    \n    return Formats.periodFormatter().withElements(elements).create();\n}",
