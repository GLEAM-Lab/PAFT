    "patch_code": "public PeriodFormatterBuilder appendYears(){  \n    DateTimeField year = new AbstractDateTimeField() {\n      @Override public String getName() {\n        return \"year\";\n      }\n      @Override public int getDurationType() {\n        return YEARS;\n      }\n      @Override public long getDifference(long time) {\n        return getInstant(time).get(YEAR);\n      }\n      @Override public long set(long baseTime, long value) {\n        return setYear(baseTime, (int)value);\n      }\n    }; \n    appendField(year); \n    return this;\n}\n\n\npublic PeriodFormatterBuilder appendSeparatorIfFieldsAfter(String separator){  \n    OptionalFields after=new OptionalFields() { \n      public void appendFields(Appendable buffer,long period,PeriodFormatter formatter) throws IOException { \n         if(formatter.fields().size()-fields.size()>0){\n             buffer.append(separator);\n         }for(DateTimeField field : fields){ \n             long value=field.getDifference(period); \n              if(value!=0){ \n                 field.serialize(buffer,value);\n             }\n          }\n       }}; \n     after.setFields(fields); \n     append(after); \n    return this;\n}",
