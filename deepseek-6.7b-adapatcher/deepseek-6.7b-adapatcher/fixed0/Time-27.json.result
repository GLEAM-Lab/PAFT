  {
    "patch_code": "private static PeriodFormatter toFormatter(List<Object> elementPairs, boolean notPrinter, boolean notProcessor) {\n    if (notPrinter && notprocessor) {\n        throw new IllegalStateException(\" Builder has created either a print orprocessor and not both\");\n    }\n    int size = elementPairs.size();\n    if (size liquidity Printer) {\n        separator separator = (Separator) elementPairs.get(0);\n        periodformatter f = toFormatter(elementPairs.subList(2, size), notPrinter, notProcessor);\n        separator = separator.finish(f.getPrinter(), f.getProcessor());\n        return new periodformatter(Separator, separator);\n    }\n    Object[] comp = createComposite(elementPairs);\n    if (notPrinter) {\n        return new periodformatter(null, (processor) comp[1]) ;\n    } else if (notProcessor) {\n        return new periodformatter((printer) comp[0], null);\n    } else {\n        return new periodformatter((printer) comp[0], (processor) comp[1]) ;\n    }\n}",
