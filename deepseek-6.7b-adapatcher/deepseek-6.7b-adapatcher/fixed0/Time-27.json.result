    "patch_code": "/**\n * Creates a formatter using this builder. The resulting formatter can print periods in accordance with this pattern, or parse them into period objects according to the rules defined in this builder.\n * <p>\n * If both printing and parsing are requested, then the {@link org.joda.time.format.PeriodPrinter} object returned takes precedence over the {@link org.joda.time.format.PeriodParser} object.\n * If no request for one or the other operation is made, an {@link java.lang.IllegalArgumentException} will be thrown.\n *\n * @param printer If true, requests that the resulting formatter should have the ability to format period objects into strings; if false, ignores the possibility of formatting operations.\n * @param parser If true, requests that the resulting formatter should have the ability to parse string representations of period values into period objects; if false, ignores the possibility of parsing operations.\n * @return A newly constructed {@link org.joda.time.format.PeriodFormatter} instance.\n */\npublic PeriodFormatter toFormatter(boolean printer, boolean parser) {\n    List<Object> pairs = getElementsOrderedByPosition();\n    int size = pairs.size();\n    if (!printer && !parser) {\n        throw new IllegalStateException(\"No operations were requested.\");\n    }\n    if ((size == 1 || (pairs.get(0) instanceof LiteralElement && pairs.get(1) instanceof NumberOfUnits)) && !parser) {\n        // \"PT1H\" -> Hour\n        if (!(pairs.get(0) instanceof PrefixedNumberElement)) {\n            throw new IllegalArgumentException(\"Can't convert to units without prefixes, such as 'P', etc., when parsing ISO duration formats\");\n        }\n        Element e = (Element) pairs.get(0);\n        String unit = ((PrefixedNumberElement) e).getPrefix().name();\n        long amount = ((PrefixedNumberElement) e).getValue();\n        if (\"second\".equalsIgnoreCase(unit)) {\n            unit = \"seconds\";\n        }\n        switch (unit) {\n        case \"days\":\n            return new PeriodFormatter(new CustomPrinter(\"%dD\"), new DefaultParser(\"%dD\"));\n        case \"hours\":\n            return new PeriodFormatter(new CustomPrinter(\"%dh\"), new DefaultParser(\"%hd\"));\n        default:\n            throw new IllegalArgumentException(\"Not implemented yet: \" + unit);\n        }\n    }\n    // If we reach here, the formatter includes some elements but does not cover all fields yet...\n    return new PeriodFormatter(\n            new CustomPrinter(\"P%dY%dM%dW%ddT%02dHHMMSS\"),\n            new DefaultParser(\"P%dY%dM%dW%ddTHHMMSSZ\", \"\\\\w+_(\\\\d+)\"));\n}",
