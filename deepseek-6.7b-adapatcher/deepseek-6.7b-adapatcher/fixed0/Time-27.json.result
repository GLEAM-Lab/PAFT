    "patch_code": "public static void main(String args[]){  \n    DateTime date=new DateTime(2019, 10, 18, 0, 0 ); \n     DateTime now = new DateTime();\n     System.out.println(now.minus(date).getYears());\n     \n     DateTime d1=new DateTime(2017, 5, 10, 13, 22 ); \n     DateTime d2=new DateTime(2017, 5, 10, 13, 0 );\n     System.out.println(d1.minus(d2).getMinutes());\n      \n    Period period=new Period(date, now);\n   // PeriodFormatter fmt=pfmtbuilder1.print(period);\n   // System.out.println(fmt);\n    \n    \n  //  System.out.println(pfmt1.print(period));\n    \n  //  System.out.println(pfmt2.parse(\"P300DT\").toString());\n    \n    SimpleDateFormat sdf = new SimpleDateFormat(\"yyyy-MM-dd HH:mm\");\n    try {\n        Date date1 = sdf.parse(\"2019-10-18 00:00\");\n        Date date2 = sdf.parse(\"2019-09-18 00:00\");\n        long diff = date1.getTime() - date2.getTime();\n        long diffSeconds = diff / 1000 % 60;\n        long diffMinutes = diff / (60 * 1000) % 60;\n        long diffHours = diff / (60 * 60 * 1000);\n        long diffDays = diff / (24 * 60 * 60 * 1000);\n        System.out.print(diffDays + \" days, \");\n        System.out.print(diffHours + \" hours, \");\n        System.out.print(diffMinutes + \" minutes, \");\n        System.out.print(diffSeconds + \" seconds.\");\n    } catch (ParseException e) {\n        e.printStackTrace();\n    }\n}",
