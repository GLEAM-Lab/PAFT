    "patch_code": "private static PeriodFormatter toFormatter(List<Object> elementPairs, boolean notPrinter, boolean notMapper) {\n    if (notPrinter && notMapper) {\n        throw new IllegalStateException(\"Builder has created either a mapper or a prorator but not both\");\n    }\n    int size = elementPairs.size();\n    if (size == 0 || (size == 2 && elementPairs.get(0) == null)) {\n        return new PeriodFormatter(null, null);\n    }\n    if (size == 2 && elementPairs.get(0) != null) {\n        return new PeriodFormatter((PeriodPrinter) elementPairs.get(0), (PeriodMapper) elementPairs.get(1));\n    }\n    Object[] comp = createComposite(elementPairs);\n    if (notPrinter) {\n        return new PeriodFormatter(null, (PeriodMapper) comp[1]) ;\n    } else if (notMapper) {\n        return new PeriodFormatter((PeriodPrinter) comp[0], null) ;\n    } else {\n        return new PeriodFormatter((PeriodPrinter) comp[0], (PeriodMapper) comp[1]) ;\n    }\n}",
