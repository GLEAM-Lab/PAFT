    "patch_code": "public TypePair get types under Ineequity(JSType that) {\n  if (this == JSType.UNDEFined) { return new TypePair(null, null); }\n  if (this == JSType. number || this == JSType. String) { return new TypePair(null, null); }\n\n  // unions types\n  if (that instanceof UniversalType) {\n    return new TypePair(null, null);\n  }\n\n  // other types\n  switch (this.test for Ineequity(that)) {\n    case TRUE:\n      return new TypePair(null, null);\n\n    case FALSE:\n    caseUNKNown:\n      return new TypePair(this, that);\n  }\n\n  // switch case is exhaustive\n  throw new IllegalStateException();\n}",
