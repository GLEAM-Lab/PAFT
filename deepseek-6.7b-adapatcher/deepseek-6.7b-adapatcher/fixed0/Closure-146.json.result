    "patch_code": "public TypePair get types underinequity(JSType that) {\n  if (this == null || this == jsc.js.null) { return new TypePair(null, null); }\n\n  // unions types\n  if (that is JSType) {\n    if (that == jsc.js.null) { return new TypePair(null, null); }\n    return that.get types underinequity(this);\n  }\n\n  // other types\n  switch (this.test for equality(that)) {\ncase jsc.js.true:\nreturn new type pair(null, null);\ncase jsc.js.false:\nreturn new type pair(this, that);\ncase jsc.js.unknown:\nreturn new type pair(this, null);\n }\n}",
