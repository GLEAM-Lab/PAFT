    "patch_code": "public double solve(final UnivariateRealFunction f,\n                    final double min, final double max, final double initial)\n    throws MaxIterationsExceededException, FunctionEvaluationException {\n    \n    final FunctionEvaluator feval = new FunctionEvaluator(f);\n    clearResult();\n    verifySequence(min, initial, max);\n\n    // check the initial guess\n    final double initVal = feval.value(initial);\n    if (!DoubleUtil.isNegative(initVal)) {\n        throw new IllegalArgumentException(\"The value of the function at the initial guess must be negative.\");\n    }\n        \n    // If the function evaluates correctly in all endpoints\n    if (Math.signum(feval.value(min)) == Math.signum(initVal) &&\n            Math.signum(feval.value(max)) == Math.signum(initVal)) {\n        throw new IllegalArgumentException(\"All function evaluations must have different signs\");\n    } else if (Math.signum(feval.value(min)) != Math.signum(initVal)) {\n        // if f(a) and f(c) have opposite signs\n        return bisectionSearch(feval, min, initial, initVal);\n    } else if (Math.signum(feval.value(max)) != Math.signum(initVal)) {\n        // if f(b) and f(c) have opposite signs\n        return bisectionSearch(feval, initial, max, initVal);\n    }\n    return Double.NaN;  \n}",
