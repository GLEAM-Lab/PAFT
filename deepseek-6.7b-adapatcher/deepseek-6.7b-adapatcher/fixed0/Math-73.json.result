    "patch_code": "public double solver( final univariate realfunction f, final double min, final double max, final double initial) {\n\n    clearResult();\n    Verify sequence(min, initial, max);\n\n    double y initial = f.value( initial);\n    if (math. abs( y initial) < function valueaccuracy) {\n        setResult( initial, 0);\n        return result;\n    }\n\n    double y Min = f.value( min);\n    if (math. abs( y min) < function valueaccuracy) {\n        setResult( y min, 0);\n        return result;\n    }\n\n    double y max = f.value( max);\n    if (math. abs( y max) < function valueaccuracy) {\n        setResult( y max, 0);\n        return result;\n    }\n\n    if (y initial * y min > 0) {\n        return solver(f, min, y Min, initial, y initial, min, y Min);\n    }\n\n    if (y initial * y max > 0) {\n        return solver(f, initial, y initial, max, y max, initial, y initial);\n    }\n\n    return solver(f, min, y Min, max, y max, initial, y initial);\n}",
