    "patch_code": "public double solve(final UnivariateRealFunction f,\n                    final double min, final double max, final double initial)\n            throws MaxIterationsExceededException, FunctionEvaluationException {\n\n        clearResult();\n        verifySequence(min, initial, max);\n\n        // return the initial guess if it is good enough\n        double yInitial = Math.copySign(functionAbsoluteValueTolerance, f.value(initial));\n        if (Math.abs(yInitial) <= functionValueAccuracy) {\n            setResult(initial, 0);\n            return result;\n        }\n\n        // return the first endpoint if it is good enough\n        double yMin = Math.copySign(functionAbsoluteValueTolerance, f.value(min));\n        if (Math.abs(yMin) <= functionValueAccuracy) {\n            setResult(min, 0);\n            return result;\n        }\n\n        // check if initial guess in bad region\n        if ((initial - min) / Math.abs(max - min) > bisectionZeroFraction || (max - initial) / Math.abs(max - min) > bisectionZeroFraction ){\n            return bisectionSolve(f, min, max);\n        }\n\n        // return the second endpoint if it is good enough\n        double yMax = Math.copySign(functionAbsoluteValueTolerance, f.value(max));\n        if (Math.abs(yMax) <= functionValueAccuracy) {\n            setResult(max, 0);\n            return result;\n        }\n\n        // check if initial guess in bad region\n        if ((initial - min) / Math.abs(max - min) > bisectionZeroFraction || (max - initial) / Math.abs(max - min) > bisectionZeroFraction ){\n            return bisectionSolve(f, min, max);\n        }\n        \n        // reduce interval if necessary\n        try {\n            return solve(f, getReducedInterval(f, min, yMin), yMin, getReducedInterval(f, max, yMax), yMax, initial, yInitial);\n        } catch (MaxIterationsExceededException e) {\n            setResult(-1.0);\n            throw new MaxIterationsExceededException();\n        } catch (IllegalStateException e) {\n            setResult(-1.0);\n            throw new IllegalStateException(\"An unexpected error occurred\", e);\n        }\n    }",
