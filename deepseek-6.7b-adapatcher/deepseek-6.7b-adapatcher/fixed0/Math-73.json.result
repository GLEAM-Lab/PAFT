    "patch_code": "private void checkSameSign(double value1, double value2) {\n    if (!sameSign(value1, value2)) {\n        throw new IllegalArgumentException(\"The values at the endpoints have different signs.\");\n    }\n}\n\nprivate boolean sameSign(double a, double b) {\n    return (a > 0 && b > 0) || (a == 0 && b == 0) || (a < 0 && b < 0);\n}\n\n\npublic double solve(final UnivariateRealFunction f, final double min, final double max, final double initial) {\n    checkSameSign(f.value(min), f.value(max));\n    double res=new BrentSolver().solve(f, min, max, initial);\n    return res;\n    \n}",
