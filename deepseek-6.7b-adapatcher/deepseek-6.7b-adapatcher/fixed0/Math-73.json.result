    "patch_code": "public double solve(final UnivariateRealFunction f,\n                    final double min, final double max, final double initial)\n            throws MaxIterationsExceededException, FunctionEvaluationException {\n        \n        verifyInputData(f, min, max, initial);\n\n        return findRoot(f, min, max, initial);\n    }\n\nprivate void verifyInputData(UnivariateRealFunction f, double min, double max, double initialGuess) {\n    \n    checkIntervalContainRoot(f, min, max);\n\n    validateBracketingAndOrderOfConvergenceToRoot(f, min, max, initialGuess);\n}\n\nprivate void checkIntervalContainRoot(UnivariateRealFunction f, double lowerLimit, double upperLimit){\n   double valueAtLowerLimit= f.value(lowerLimit);\n   double valueAtUpperLimit = f.value(upperLimit);\n    \n   Preconditions.checkArgument((Double.compare(MathUtil.sign(valueAtLowerLimit), MathUtil.sign(valueAtUpperLimit))) != 0,\"The function values at both endpoints have the same sign\");\n}\n\nprivate void validateBracketingAndOrderOfConvergenceToRoot(UnivariateRealFunction f, double a, double b,double c){\n    boolean isValidOrderForCandidateA = DoubleUtils.isNonNegative(b - a) && DoubleUtils.isNonNegative(c - a);\n    boolean isValidOrderForCandidateB = DoubleUtils.isNonNegative(a - b) && DoubleUtils.isNonNegative(c - b);\n    boolean isNotSmallPositiveNumberAfterSubstitution = !isSmallPositiveNumber(getNewtonRaphsonApproximation(f, a));\n    boolean doesNotHaveSameSignInTwoBracketings = getSign(f.value(a))!= getSign(f.value(b));\n    Preconditions.checkArgument((isValidOrderForCandidateA||isValidOrderForCandidateB )&& isNotSmallPositiveNumberAfterSubstitution&&doesNotHaveSameSignInTwoBracketings);\n}\n\n private double findRoot(UnivariateRealFunction function, double lowerBoundary, double upperBoundary, double middlePoint) {\n    int numberOfSteps = 1;\n    do{\n      numberOfSteps++;\n      double oldMiddlePoint=middlePoint;\n      computeNextStepWithinThreePoints(function,lowerBoundary ,upperBoundary,middlePoint );\n      if (Double.compare(oldMiddlePoint, middlePoint) == 0) break;\n    }while(!isAbsoluteZero(function.value(middlePoint)));\n    updateLastGoodEstimateIfNeeded(numberOfSteps,function.value(middlePoint));\n    lastBracket = null;\n    return  lastGoodEstimate;\n  }\n\n\n private double getNewtonRaphsonApproximation(UnivariateRealFunction function, double x_n) {\n    return x_n - function.value(x_n) / derivative(function).value(x_n);\n}\n\nprivate static double derivative(UnivariateRealFunction f) {\n    try {\n        DerivativeIterator derivativeFinder = new DerivativeIterator(new Spole(32, 16, true));\n        return derivativeFinder.getDerivative(f);\n    } catch (DimensionMismatchException ex) {\n        System.err.println(\"Cannot differentiate this function!\");\n    }\n    return null;\n}",
