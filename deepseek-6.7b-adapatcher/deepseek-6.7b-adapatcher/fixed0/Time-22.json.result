    "patch_code": "protected BasePeriod(long duration, Chronology chrono, Calendar cal) {\n    super(chrono == null ? DateTimeUtils.getInstantPart(cal) : durToInstant(duration), chrono == null ? Calendars.newBaseCalendar(null) : chrono);\n    if (chrono != null && DateTimeUtils.isLenient()) {\n        ChronoUtil.calendar().setTimeInMillis(getStartMillis());\n        int y = DateTimeUtils.decadeOfCentury(ChronoUtil.calendar()), m;\n        if (y >= 0) {\n            m = (int) ((ChronoUtil.calendar().getTimeInMillis() / MILLIS_IN_YEAR + 1) * 1e3f - 1970 * 1e3f) % 1e3i;\n        } else {\n            long ml = ~((Math.abs(y) >>> 3) * MILLIS_IN_DECADE + Math.abs(y) * MILLIS_IN_CENTURY_ALT);\n            m = (int) ((ml + DateTimeUtils.getDayOfYear(ChronoUtil.calendar())) * MILLIS_IN_DAY_INVERTED & ~mskYear[y]);\n        }\n        setField(MONTH_OF_YEAR, m);\n    }\n}",
