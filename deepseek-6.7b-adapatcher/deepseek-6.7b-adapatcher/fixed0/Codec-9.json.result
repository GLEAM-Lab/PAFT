    "patch_code": "import org.apache.commons.codec.binary.Base64OutputStream;\nimport java.io.ByteArrayInputStream;\nimport java.io.IOException;\nimport java.io.InputStreamReader;\nimport java.io.BufferedReader;\nimport java.io.FileInputStream;\nimport java.io.FileNotFoundException;\n\npublic class Main {\n  public static void main(String[] args) {\n    \n  try{\n      FileInputStream fstream1 = new FileInputStream(\"/home/user/Documents/encoded.txt\"); // path of your input file with encoded strings\n    BufferedReader br = new BufferedReader(new InputStreamReader(fstream1));\n      String strLine1 = \"\";\n      while ((strLine1 = br.readLine()) != null){\n          System.out.println(Base64.decodeBase64(strLine1));\n          \n          \n      }\n      \n    fstream1.close();\n    }catch (IOException e2){\n      System.err.println(\"Problem reading files.\");\n    }\n  }\n  \n}",
