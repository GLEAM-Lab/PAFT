    "patch_code": "import org.apache.commons.codec.binary.Base64;\n\npublic static byte[] encodeBase64(byte[] binaryData, boolean isChunked, boolean urlSafe, int maxResultSize) throws IllegalArgumentException{\n    if (binaryData == null || binaryData.length == 0) {\n        return binaryData;\n    }\n\n    \n    long len = getEncodeLength(binaryData, MIME_CHUNK_SIZE, CHUNK_SEPARATOR);\n    if (!isChunked){\n        if ((int) len != len){\n            throw new IllegalArgumentException(\"Input array too big, the output array would be bigger (\" +\n                len +\n                \") than the specified maxium size of \" +\n                maxResultSize);\n        } else if (len > maxResultSize) {\n            throw new IllegalArgumentException(\"Input array too big, the output array would be bigger (\" +\n                len +\n                \") than the specified maxium size of \" +\n                maxResultSize);\n        }\n    }\n        \n    if (isChunked && urlSafe ) {\n        return Base64.encodeBase64Chunked(binaryData, true );\n    } else if (isChunked && !urlSafe ) {\n        return Base64.encodeBase64Chunked(binaryData, false );\n    } else if (!isChunked && urlSafe ) {\n        return Base64.encodeBase64URLSafe(binaryData);\n    } else  {\n        return Base64.encodeBase64(binaryData);\n    }\n}",
