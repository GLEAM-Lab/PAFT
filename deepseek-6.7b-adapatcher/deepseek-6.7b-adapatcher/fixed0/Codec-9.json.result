    "patch_code": "import java.util.Arrays;\nimport org.apache.commons.codec.binary.Base64;\nimport org.apache.commons.codec.binary.StringUtils;\n\npublic class RepairClass{ \n    \n       public static String encodeBase64(byte[] binaryData, boolean isChunked, boolean urlSafe, int maxResultSize) {\n           try {\n               if (isValidMaxResultSize(maxResultSize)) {\n                   if (!isChunked && binaryData != null && binaryData.length > maxResultSize) {\n                       throw new IllegalArgumentException(\"Maximum result size exceeded\");\n                   }\n                   int flags = urlSafe ? Base64.URL_SAFE : 0;\n                   flags |= isChunked ? Base64.MIME_CHUNKED : 0;\n                   byte[] encodedBytes = Base64.encodeBase64(binaryData, 0, binaryData.length, flags);\n                   return Arrays.equals(encodedBytes, binaryData) ? \"\" : StringUtils.newStringUtf8(encodedBytes);\n               } else {\n                   throw new IllegalArgumentException(\"Invalid maximum result size value provided\");\n               }\n           } catch (Exception e) {\n               throw new RuntimeException(e);\n           }\n       }\n       \n      private static boolean isValidMaxResultSize(int maxResultSize) {\n           if (maxResultSize < 1) {\n               return false;\n           }\n           //Checking for a number that's too large to handle\n           if (maxResultSize > 2^31 - 1) {\n               return false;\n           }\n           return true;\n       }\n}",
