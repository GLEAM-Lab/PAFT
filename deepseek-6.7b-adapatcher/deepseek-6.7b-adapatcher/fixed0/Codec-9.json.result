    "patch_code": "import java.util.Arrays;\npublic class Main{\n    public static void main(String args []){\n        try {\n           byte [] arr1 = {72, 97, 83};\n           System.out.println(Arrays.toString(base64encoder(arr1,false,false,Integer.MAX_VALUE)));    \n         }catch (Exception e) {\n            System.err.println(e);\n        } \n    }\n\n   public static byte[] base64encoder(byte[] binaryData, boolean isChunked,boolean urlSafe ,int maxResultSize)throws IndexOutOfBoundsException{\n       if (binaryData == null || binaryData.length == 0||maxResultSize<=0) {\n           return binaryData;\n       }\n       int len = getEncodeLength(binaryData, Integer.MAX_VALUE,null);\n       if (len>maxResultSize) {\n           throw new IndexOutOfBoundsException();\n       }\n          org.apache.commons.codec.binary.Base64 b64  =isChunked ? new org.apache.commons.codec.binary.Base64():new org.apache.commons.codec.binary.Base64(0, null, urlSafe);\n\n       return b64.encode(binaryData);\n   }\n      private static final int getEncodeLength(byte[] binaryData, int chunkSize, byte[] chunkSeparator) {\n        int len = binaryData.length;\n        int chunks = len / chunkSize;\n        if (chunks > 0 && chunkSeparator != null) {\n            len += chunks * chunkSeparator.length;\n        }\n        return len;\n    }\n}",
