    "patch_code": "import java.io.*;\n\npublic class Main {\n    public static void main(String []args){\n        try{\n         File f=new File(\"/path/to/file\");//specify your file path here \n         FileInputStream fis=new FileInputStream(f);\n         byte[] bytes=new byte[(int)f.length()];\n         fis.read(bytes);\n           System.out.println(new String(base64encode(bytes)));  \n          }catch(IOException e){\n             e.printStackTrace();\n          }    \n       }\n\nprivate static byte[] base64encode(byte[] binaryData) throws IOException{\n      ByteArrayOutputStream bos = new ByteArrayOutputStream();\n\tBase64OutputStream b64os = new Base64OutputStream(bos);\n\n\ttry {\n\t    b64os.write(binaryData);\n\t} finally {\n\t    b64os.close();\n\t}\n\n\treturn bos.toByteArray();\n   }\n}",
