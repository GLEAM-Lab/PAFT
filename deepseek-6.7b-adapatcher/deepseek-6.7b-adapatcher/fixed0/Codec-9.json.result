    "patch_code": "import org.apache.commons.codec.binary.*;\n\npublic static String encodeBase64(byte[] binaryData, boolean isChunked, boolean urlSafe, int maxResultSize) throws IllegalArgumentException{\n    if (!isChunked && (binaryData == null || binaryData.length > maxResultSize)) {\n        throw new IllegalArgumentException();\n    }\n    \n    Base64 base64 = new Base64();\n    if (isChunked){\n        base64.setChunkSeparator(\"\\r\\n\".getBytes());\n        base64.setUrlSafe(urlSafe);\n        \n        return new String(base64.encode(binaryData));\n    }else{\n        return new String(Hex.encodeHexString(binaryData).getBytes()).replaceAll(\"\\\\s*\", \"\"); \n    }  \n}",
