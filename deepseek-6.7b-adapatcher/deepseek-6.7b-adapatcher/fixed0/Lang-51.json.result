    "patch_code": "public static boolean toBoolean(String str) {\n    // Previously used equalsIgnoreCase, which was fast for interned 'true'.\n    // Non interned 'true' matched 15 times slower.\n    // \n    // Optimisation provides same performance as before for interned 'true'.\n    // Similar performance for null, 'false', and other strings not length 2/3/4.\n    // 'true'/'TRUE' match 4 times slower, 'tRUE'/'True' 7 times slower.\n    if (str != null && str.equalsIgnoreCase(\"true\")) {\n        return true;\n    }\n    if (str == null || str.isEmpty()) {\n        return false;\n    }\n    switch (str.length()) {\n        case 2: {\n            char ch0 = Character.toLowerCase(str.charAt(0));\n            char ch1 = Character.toLowerCase(str.charAt(1));\n            return \n                (ch0 == 'o' )&&\n                (ch1 == 'n' );\n        }\n        case 3: {\n            char ch = Character.toLowerCase(str.charAt(0));\n            if (ch == 'y') {\n                return \n                    (Character.toLowerCase(str.charAt(1))  == 'e'  )&&\n                    (Character.toLowerCase(str.charAt(2))  == 's'  );\n            }\n            if (ch == 'Y') {\n                return \n                    (Character.toLowerCase(str.charAt(1))  == 'E'  )&&\n                    (Character.toLowerCase(str.charAt(2))  == 'S'  );\n            }\n        }\n        case 4: {\n            char ch = Character.toLowerCase(str.charAt(0));\n            if (ch == 't') {\n                return \n                    (Character.toLowerCase(str.charAt(1))  == 'r'  )&&\n                    (Character.toLowerCase(str.charAt(2))  == 'u'  )&&\n                    (Character.toLowerCase(str.charAt(3))  == 'e'  );\n            }\n            if (ch == 'T') {\n                return \n                    (Character.toLowerCase(str.charAt(1))  == 'R'  )&&\n                    (Character.toLowerCase(str.charAt(2))  == 'U'  )&&\n                    (Character.toLowerCase(str.charAt(3))  == 'E'  );\n            }\n        }\n    }\n    return false;\n}",
