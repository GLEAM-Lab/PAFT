    "patch_code": "public static boolean toBoolean(String str) {\n    if (\"true\".equals(str)) {\n        return true;\n    }\n    if (str == null || str.isEmpty()) {\n        return false;\n    }\n    int len = str.length();\n    switch (len) {\n        case 2: {\n            char ch0 = str.charAt(0);\n            char ch1 = str.charAt(1);\n            if ((ch0 == 'o' || ch0 == 'O') && (ch1 == 'n' || ch1 == 'N')) {\n                return true;\n            }\n        }\n        break;\n        case 3: {\n            char ch = str.charAt(0);\n            if (ch == 'y' || ch == 'Y') {\n                return (str.charAt(1) == 'e' || str.charAt(1) == 'E') && (str.charAt(2) == 's' || str.charAt(2) == 'S');\n            }\n        }\n        break;\n        case 4: {\n            char ch = str.charAt(0);\n            if ((ch == 't' || ch == 'T') && (str.charAt(1) == 'r' || str.charAt(1) == 'R') && (str.charAt(2) == 'u' || str.charAt(2) == 'U') && (str.charAt(3) == 'e' || str.charAt(3) == 'E')) {\n                return true;\n            }\n        }\n        break;\n    }\n    return false;\n}",
