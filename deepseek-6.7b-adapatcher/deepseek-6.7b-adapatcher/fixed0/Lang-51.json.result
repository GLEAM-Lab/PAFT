    "patch_code": "public static boolean toBoolean(String str) {\n    \n    if (\"true\".equals(str)) {\n        \n        return true;\n        \n    } else if (\"false\".equals(str)) {\n        \n        return false;\n        \n    } else if (str != null && (str.length() == 2 ||  str.length() == 3 || str.length() == 4)){\n        \n       char ch;\n      int l;\n            \n        switch (str.length()) {\n          \n          case 2 : \n              \n              ch = Character.toLowerCase(str.charAt(0));\n              if ((ch == 'o'|| ch== 'O')){\n                 \n                 ch =Character.toLowerCase( str.charAt(1));\n                 if((ch == 'n' || ch == 'N')){\n                    \n                     return true ;\n                 }  \n              }else {\n                  \n                 return false;\n             }\n                \n            break;\n\n            case 3 : \n                \n                ch = Character.toLowerCase(str.charAt(0));\n              if ((ch == 'y' || ch =='Y')){\n                 ch =Character.toLowerCase( str.charAt(1));\n                 if((ch == 'e'|| ch == 'E')){\n                      ch =Character.toLowerCase( str.charAt(2));\n                      \n                        return  (ch == 's' || ch == 'S');\n                         \n                 }else {\n                  \n                     return false;\n                 }\n                } else {\n\n                    return false;\n                }\n         \n             break;\n            \n            case 4 : \n                \n                ch = Character.toLowerCase(str.charAt(0));\n                if ((ch == 't' || ch =='T')){\n                    ch =Character.toLowerCase( str.charAt(1));\n                    if((ch == 'r' || ch == 'R')){\n                         ch =Character.toLowerCase( str.charAt(2));\n                         if((ch == 'u'|| ch == 'U')){\n                            \n                            ch =Character.toLowerCase(str.charAt(3));\n                            return  (ch == 'e'|| ch == 'E');\n                             \n                         }else {\n\n                            return false;\n                         }\n                        }else {\n\n                        return false;\n                      }\n                    \n                    }else {\n\n                     return false;\n                 }\n                 \n                 break;\n                 \n        }\n        \n    }\n\n    return false;\n\n}",
