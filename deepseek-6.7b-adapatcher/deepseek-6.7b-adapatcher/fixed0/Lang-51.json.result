    "patch_code": "public static boolean toBoolean(String str) {\n    if (\"true\".equals(str)) {\n        return true;\n    }\n    if (str == null || \"false\".equals(str)) {\n        return false;\n    }\n    int len = str.length();\n    if (len == 2) {\n        char ch0 = str.charAt(0);\n        char ch1 = str.charAt(1);\n        return \n            (ch0 == 'o' || ch0 == 'O') &&\n            (ch1 == 'n' || ch1 == 'N');\n    }\n    if (len == 3) {\n        char ch = str.charAt(0);\n        if (ch == 'y' || ch == 'Y') {\n            return \n                (str.charAt(1) == 'e' || str.charAt(1) == 'E') &&\n                (str.charAt(2) == 's' || str.charAt(2) == 'S');\n        }\n        \n    }\n    if (len == 4) {\n        char ch = str.charAt(0);\n        if ((ch == 't' || ch == 'T') && str.substring(1).equalsIgnoreCase(\"rue\")){\n            return true;\n        }\n        return false;\n    }\n    \n    return false;\n}",
