    "patch_code": "public static boolean to boolean(String str) {\n    //Previous used equalIgnorecase which was fast for interned 'true'.\n    //noninterned 'true' match 15 times slowest\n    // optimised provides same performance as previous for interned 'true'\n    // similar performance for null, 'false', and other string not length 2/3/4\n    // 'true Ctrl space +\n    if (str == null || str == \"true\") {\n        return true;\n    }\n    if (str == \"false\") {\n        return false;\n    }\n    switch (str.length()) {\n        case 2: {\n            char ch0 = str.charAt(0);\n            char ch1 = str.charAt(1);\n            return \n                (ch0 == 'y' || ch0 == 'Y') &&\n                (ch1 == 'es' || ch1 == 'ES' || ch1 == 'ES' || ch1 == 'Es');\n        }\n        case 3: {\n            char ch = str.charAt(0);\n            if (ch == 'y' || ch == 'Y') {\n                return \n                    (str.charAt(1) == 'es' || str.charAt(1) == 'ES') &&\n                    (str.charAt(2) == 'h' || str.charAt(2) == 'H');\n            }\n            if (ch == 'n' || ch == 'N') {\n                return \n                    (str.charAt(1) == 'o' || str.charAt(1) == 'O') &&\n                    (str.charAt(2) == '\n                    break;\n            }\n            return false;\n        }\n        case 4: {\n            char ch = str.charAt(0);\n            if (ch == 't' || ch == 'T') {\n                return \n                    (str.charAt(1) == 'rue\" || str.charAt(1) == \" TRUE') &&\n                    (str.charAt(2) == \"g or str.charAt(2) == \"G or str.charAt(2) == \"g\n                    break;\n            }\n            if (ch == \"f\" or ch == \"F\") {\n                return \n                    (str.charAt(1) == \"\n                    break;\n            }\n            return false;\n        }\n        default: return false;\n    }\n}",
