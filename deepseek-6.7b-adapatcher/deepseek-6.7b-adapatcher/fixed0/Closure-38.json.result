    "patch_code": "void addNumber( double x ) {\n  char last char in previous line = getLastcharInPreviousLine();\n  boolean negativeZero = isNegativeZero( x );\n  if ( x > 0 && last char in previous line == '-') {\n    add(\" \");\n  }\n\n  if ( (long) x == x && ! negativeZero ) {\n    long value = (long) x;\n    long base = 10 * value;\n    int exponent = 0;\n    while ( base == value * pow( 10, exponent + 1 ) ) {\n      base /= 10;\n      exponent++;\n    }\n    if (exponent > 2) {\n      add( long.to string(base) + \"E\" + int.to string(exponent));\n    } else {\n      add( long.to string(value));\n    }\n  } else {\n    add( String.valueOf( x ) );\n  }\n}",
