    "patch_code": "void addNumber( double x ) {\n  char lastchar = getLastchar();\n  boolean negativeZero = isNegativeZero(x);\n  if (lastchar == '-' && x != 0 && ! negativeZero) {\n    add(\" \");\n  }\n  addNumber(x, 0);\n}\nvoid addNumber( double x, int exponent ) {\n  long long xl = (long) x;\n  long long factor = pow10(exponent);\n  long long mod = xl % factor;\n  long long div = (xl - mod) / factor;\n  if (exponent > 2 || x == 0 || (div == 0 && x != 0 && ! negativeZero)) {\n    add(longToString(div), \"e\", longToString(exponent));\n  } else {\n    add(longToString(xl));\n  }\n}\nvoid addNumber( double x, int exponent, int exponent2 ) {\n  long long factor1 = pow10(exponent);\n  long long factor2 = pow10(exponent2);\n  long long mod = (long long xl = (long) x) % factor2;\n  long long div = (xl - mod) / factor2;\n  if (exponent > 2 || x == 0 || (div == 0 && x != 0 && ! negativeZero)) {\n    add(longToString(div), \"e\", longToString(exponent + exponent2));\n  } else {\n    add(longToString(xl));\n  }\n}",
