    "patch_code": "public void println() throws IOException {\n    if (!isPrintedHeader) {\n        writeObject(header);\n        isPrintedHeader = true;\n    }\n    \n    Object[] objs = getObjectsForWrite(false);\n    for (int i = 0; i < objs.length; i++) {\n        Object obj = objs[i];\n        if (obj == null) {\n            continue;\n        } else {\n             out.append(((String) objs[i]));     \n        }\n        \n        if (i != objs.length - 1){\n            out.append(format.getFieldDelimiter());\n        }else{\n           final String recordSeparator = format.getRecordSeparator();\n           out.append(recordSeparator);\n        }\n    }\n    newRecord = true;\n}",
