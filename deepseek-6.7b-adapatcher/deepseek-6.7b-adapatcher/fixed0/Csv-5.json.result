    "patch_code": "public void println(String... values) throws IOException {\n    if (!firstRecordWritten){\n        writeHeader();\n        firstRecordWritten = true;        \n    }\n    boolean emptyLineNeeded = false;\n     for (int i = 0; i < headerOrder.length; i++){\n            int hIndex = headerMap.indexOfKey(headerOrder[i]);\n            if (hIndex < 0 ){\n                throw new IllegalArgumentException (\"No such header \" + headerOrder[i] );\n            }\n            else{\n                Object valueToWrite = data[hIndex];\n                  if ((valueToWrite == null) || (valueToWrite instanceof Character && ((Character) valueToWrite).charValue() == 0)){\n                      valueToWrite = \"\";\n                     }\n                 else if (valueToWrite instanceof Number){\n                      Number nv = (Number)valueToWrite;\n                      DecimalFormat df = new DecimalFormat(dfs[i].toPattern());\n                      try {\n                          valueToWrite = df.format(nv);\n                       }catch (IllegalArgumentException e){\n                        // do nothing this number can't be formatted so leave it as is\n                      }\n                    }else if (valueToWrite instanceof Date){\n                         valueToWrite = sdfs[i].format((Date)valueToWrite);\n                    } else if (valueToWrite instanceof Boolean){\n                        valueToWrite = ((Boolean)valueToWrite ? \"TRUE\" : \"FALSE\");\n                    } else if (valueToWrite instanceof Enum){\n                         valueToWrite = valueToWrite.toString().replaceAll(\"^.*\\\\.\", \"\");\n                     }\n                     String strVal = converter != null ? converter.convertToString((Serializable)valueToWrite) : valueToWrite.toString();\n                     out.append(strVal).append(fieldSeparator);\n             }\n             \n         }\n     \n         \n         \n         if(emptyLineNeeded){\n           out.append(lineBreak);  \n         } else {\n             out.setLength(out.length()- fieldSeparator.length()) ;\n              .append(lineBreak) ;\n          }\n      \n              \n           \n      \n}",
