    "patch_code": "public boolean nextLineMatches(@Nullable Pattern pattern) throws IOException {\n  String line = getRemainingJSDocLine();\n  if(line == null){\n      throw new ParseException(\"Unexpected EOF while trying to parse JSDoc comment\");\n  }\n  Matcher matcher = pattern.matcher(line);\n  if (!matcher.lookingAt()) {\n     return false;\n  } else{\n       int index = matcher.end();\n        skipSpaces();\n        if(!isEndOfLine() && peek() != '*'){\n            index = matcher.start();\n             throw new ParseException(\"Unfinished JSDoc comment after \" + line.substring(index));\n        } \n  }\n  return true;\n}",
