  {
    "patch_code": "private String getRemainingJSDocLine() {\n  while(true){\n      if(!stream.hasNext()) break;\n      \n      if(!Character.isWhitespace(stream.peek())){\n          break;\n      } else{\n          \n        stream.skipSpaces();\n     continue;\n      }\n  }\n  String result = stream.getRemainingJSDocLine();\n  return result;\n}",
