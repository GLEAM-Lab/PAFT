  {
    "patch_code": "public String getRemainingJSDocLine(){\n        StringBuilder res = new StringBuilder(stream.getRemainingJSDocLine());\n         int startIndex=0,endIndex=res.length()-1;\n          if(res.charAt(startIndex)=='{'){\n            while(!(res.charAt(endIndex)=='}')){\n                endIndex--;\n               }\n            \n            res.replace(startIndex,endIndex+1,\"\");\n          \n            \n        }else if(res.indexOf(\"//\")>=0){\n              int index = res.indexOf(\"//\");\n               res.replace(index,res.length(),\" \");\n            \n        } else if (!Character.isWhitespace(res.charAt(0))) {\n          for (int i = 0; i < res.length(); i++) {\n            if (res.charAt(i)!=' '&&res.charAt(i!='*')) {\n              break;\n            }else{\n                 res.deleteCharAt(i);\n                 \n            }\n          }\n        }\n      return res.toString().trim();\n    \n}",
