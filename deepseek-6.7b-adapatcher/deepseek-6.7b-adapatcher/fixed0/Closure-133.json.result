    "patch_code": "private String getRemainingJSDocLine() {\n  String remainingString = stream.getRemainingJSDocLine().trim();\n  if(remainingString.startsWith(\"{\") && !remainingString.endsWith(\"}\")){\n      while(!remainingString.endsWith(\"}\")) {\n          remainingString += \" \";\n          remainingString += this.stream.read();\n      }\n  } else {\n      int i = 0;\n      for (; i < remainingString.length(); ++i) {\n          char c = remainingString.charAt(i);\n          if (!Character.isWhitespace(c)) break;\n      }\n      remainingString = remainingString.substring(i).trim();\n  }\n  return remainingString;\n}",
