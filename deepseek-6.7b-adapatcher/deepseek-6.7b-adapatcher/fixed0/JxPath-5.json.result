    "patch_code": "private int\u6bd4\u8f83\u8282\u70b9pointer(\n    nodepointer p1,\n    int\u6df1\u5ea61,\n    nodepointer p2,\n    int\u6df1\u5ea62) \n{\n    if (\u6df1\u5ea61 <\u6df1\u5ea62) {\n        int r =\u6bd4\u8f83\u8282point(p1,\u6df1\u5ea61, p2.parent,\u6df1\u5ea62 - 1);\n        return r == 0 ? -1 : r;\n    }\n    if (\u6df1\u5ea61 >\u6df1\u5ea62) {\n        int r =\u6bd4\u8f83\u8282 point(p1.parent,\u6df1\u5ea61 - 1, p2,\u6df1\u5ea62);\n        return r == 0 ? 1 : r;\n    }\n    if (p1 == null && p2 == null) {\n        return 0;\n    }\n\n    if (p1 != null && p1.\u7b49\u4ef7(p2)) {\n        return 0;\n    }\n\n    if (\u6df1\u5ea61 == 1) {\n        throw new JXPathException(\n                \"\u4e0d\u80fd compared pointer that do not belbel to same tree: '\"\n                       + p1 + '\" and '\" + p2 + '\" + \");\n    }\n    int r =\u6bd4\u8f83\u8282 point(p1.parent,\u6df1\u5ea61 - 1, p2.parent,\u6df1\u5ea62 - 1);\n    if (r != 0) {\n        return r;\n    }\n\n    return p1.parent.\u6bd4\u8f83 child\u8282 point(p1, p2);\n}",
