    "patch_code": "public Object answer(InvocationOnMock invocation) throws Throwable {\n       try{\n           // try calling as normal\n            return invocation.callRealMethod();\n       } catch(AbstractMethodError e){\n          // if we got AbstractMethodErrors it means that the called method was an abstract one in the real object\n           Method method = invocation.getMethod();\n           Object mock = invocation.getMock();\n           // then we search for the overridden method in the mocked object\n           for(Method m : mock.getClass().getDeclaredMethods()){\n               if(m.getName().equals(method.getName())){\n                   return m.invoke(mock);\n               }\n           }\n           throw new RuntimeException(\"Could not find overridden method for \" + method.getName());\n       }\n    }",
