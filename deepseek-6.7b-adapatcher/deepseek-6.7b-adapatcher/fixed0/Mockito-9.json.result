    "patch_code": "public Object answer(InvocationOnMock invocation) throws Throwable {\n        try{\n            Class<?> clazz=Class.forName(\"javax.management.ObjectName\");\n            if(clazz.isAssignableFrom(invocation.getMethod().getDeclaringClass())){\n                //this block of code means we are spying on abstract class so we need to call super method here.\n                 Method[] methods = clazz.getDeclaredMethods(); \n                for(int i = 0;i < methods.length;i++){\n                    String name  = methods[i].getName();\n                    if(name.equals(invocation.getMethod().getName())){\n                        return methods[i].invoke(invocation.getMock(), invocation.getArguments());\n                    \n                    }\n                }\n            }\n            \n        }catch(Exception e){\n           throw new RuntimeException(e); \n        }  \n        return invocation.callRealMethod();\n        \n    }",
