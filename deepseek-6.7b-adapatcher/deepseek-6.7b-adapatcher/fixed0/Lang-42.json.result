    "patch_code": "public voidescapehtml( StringBuilder sb, String str) {\n    int length = str.length();\n    for (int i = 0; i < length; i++) {\n        char c = str.charAt(i);\n        String entities = Entities.getInstance().getEntities(c);\n        if (entities == null) {\n            if (c > 0x7F) {\n                sb.append(\"&\" + entities + \";\");\n            } else {\n                sb.append(c);\n            }\n        } else {\n            sb.append(\"&\" + entities + \";\");\n        }\n    }\n}",
