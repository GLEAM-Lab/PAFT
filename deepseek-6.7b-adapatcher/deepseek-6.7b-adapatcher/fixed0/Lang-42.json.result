    "patch_code": "public voidescapehtml(StringBuilder sb, String str) {\n    int length = str.length();\n    for (int i = 0; i < length; i++) {\n        char charAt = str.charAt(i);\n        String entities = this.entities(charAt);\n        if (entities == null) {\n            if (charAt > 0x7F) {\n                sb.append(\"&amp;\");\n                sb.append(\";<span style=\\\" font-size: 1pt;\\\">\\uFFFD</span>;\");\n                sb.append((int charAt) + \";\");\n            } else {\n                sb.append((int charAt) + \";\");\n            }\n        } else {\n            sb.append(\"&amp;\",0,-4);\n            sb.append((int entities.charAt(0)) + \";\");\n        }\n    }\n}",
