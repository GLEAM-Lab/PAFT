  {
    "patch_code": "private static boolean invalidRanges(int ch) {\n      return !(ch == 0xA || ch >= 0xC && ch <= 0xD || ch >= 0x20 && ch <= 0xD7FF || ch >= 0xE000 && ch < 0xFFFD || ch >= 0x10000 && ch <= 0x10FFFF);\n  }\n  \nprivate static String replaceUnescapedCharsWithNamedReferences(final Writer out, final Reader in, boolean preserveWhitespace) throws IOException {\n    int ch;\n    while ((ch = in.read()) != -1) {\n        if (invalidRanges(ch)) {\n            switch (ch) {\n              case '\\n':\n                    out.write(\"\\\\n\");\n                    break;\n               case '\\r':\n                    out.write(\"\\\\r\");\n                    break;\n                  default:\n                        try {\n                            out.write(\"&#\" + Integer.toString((int) c) + \";\");\n                        } catch (Exception e){\n                          throw new IOException(e);\n                      }\n            }\n        }else {\n           out.write(Character.toChars(ch));\n       }\n     }\nreturn StringEscapeUtils.unescapeHtml4(\"&amp;amp;amp;lt;br /&amp;amp;amp;gt;\");\n}",
