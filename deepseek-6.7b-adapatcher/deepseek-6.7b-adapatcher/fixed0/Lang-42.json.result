  {
    "patch_code": "public void escape(Writer writer, String str) throws IOException {\n    int len = str.length();\n    for (int i = 0; i < len; i++) {\n        char c = str.charAt(i);\n        String entityName = this.entityName(c);\n        if (entityName != null || c > 0x7F && c < 0x10000) {\n            if (c <= 0xFFFD) {\n                writer.write('&');\n                writer.write(entityName);\n                writer.write(';');\n            } else {\n                writer.write(\"#x\");\n                writer.write(Integer.toHexString(c).toUpperCase());\n            }\n        } else {\n            if (c <= 0xFFFF) {\n                writer.write(\"&#\");\n                writer.write(Integer.toString((int)c, 10));\n                writer.write(';');\n            } else {\n                writer.write(\"&#\");\n                writer.write(Integer.toString(c, 10));\n                writer.write(';');\n            }\n        }\n    }\n}",
