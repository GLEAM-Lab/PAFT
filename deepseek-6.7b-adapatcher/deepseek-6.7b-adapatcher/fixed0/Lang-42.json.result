    "patch_code": "public void escape(Writer writer, String str) throws IOException {\n    int len = str.length();\n    for (int i = 0; i < len; i++) {\n        char c = str.charAt(i);\n        String entityName = this.entityName(c);\n        if (entityName == null) {\n            if (c <= 0x7FF) {\n                writer.write(\"&#\");\n                writer.write(Integer.toString((int) c, 10));\n                writer.write(';');\n            }else if(c>0x7FF&&c<=0xFFFF){\n                 writer.write(\"&#\");\n                 Integer.parseInt(String.valueOf(Character.toChars(c)),10);\n                writer.write(String.valueOf(Integer.parseInt(String.valueOf(Character.toChars(c)),10)));\n                writer.write(';');\n                 \n            }else if(c>=0x10000&&c<=0x10FFFF){\n                \n                 writer.write(\"&#\");\n                Integer.parseInt(String.valueOf(Character.toChars(c - 0x10000 + 0x10000)),10);\n                 writer.write(String.valueOf(Integer.parseInt(String.valueOf(Character.toChars(c - 0x10000 + 0x10000)),10)));\n                 writer.write(';');\n            }\n             \n            else {\n                writer.write(c);\n            }\n        } else {\n            writer.write('&');\n            writer.write(entityName);\n            writer.write(';');\n        }\n    }\n}",
