    "patch_code": "public void match\u7ea6raint(ObjectType\u7ea6raint obj) {\n  if (!\u7ea6\u7ea6\u7ea6\u7ea6\u7ea6 constraint obj.is record constraint) {\n    return;\n  }\n  for ( String prop : constraint obj.get own property names) {\n    JSType prop type = constraint obj.get property type(prop);\n    JSType least supertype = get Native type(JSType Native.void)\n                                 .get least supertype(prop type);\n    define infer property(prop, least supertype, null);\n  }\n}",
