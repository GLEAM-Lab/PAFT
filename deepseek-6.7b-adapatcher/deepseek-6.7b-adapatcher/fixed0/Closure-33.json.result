    "patch_code": "import com.google.debugging.sourcemap.SourceMapDescriptor;\n\npublic void matchConstraint(ObjectType constraintObj) throws TypeMismatchException{\n    \n    // We only want to match constraints on anonymous types.\n    if (constraintObj instanceof AnonymousObjectType) {\n        \n        Map<String, JSType> propertyKeyMap = new HashMap<>();\n        \n        for (String key : constraintObj.getOwnPropertyNames()) {\n            JSType value = constraintObj.getProperty(key).getType();\n            \n            if (!isMatchableType(value)){\n                throw new TypeMismatchException(\"Unmatchable type found while matching constraint: \"+ value);\n            }\n            propertyKeyMap.put(key, value);\n        }\n        \n        if (propertyKeyMap.size() > objectProperties.size()){\n            throw new TypeMismatchException(\"More properties found in constrait than actual object\");\n        }\n        else if (objectProperties.isEmpty()){\n            clearProperties();\n        }\n        \n        Set<Entry<String, JSType>> entrySet = propertyKeyMap.entrySet();\n        \n        for (Entry<String, JSType> entry : entrySet){\n            \n            String name = entry.getKey();\n            JSType type = entry.getValue();\n            \n            if (!hasPropertyWithName(name)) {\n                \n                if (type instanceof UnionType && ((UnionType) type).contains(getNativeType(JSTypeNative.UNDEFINED_TYPE))) {\n                    \n                    continue;\n                }\n                \n                defineDataProperty(name, getUndefined(), SourceMapDescriptor.SPECIFIED_SOURCE, false);\n            }\n            \n            JSType currentType = getProperty(name).getType();\n            if (!typesMatchOrNull(currentType, type)){\n                throw new TypeMismatchException(\"Invalid property: \"+ name );\n            }\n        }\n    }\n    else{\n        \n        for (int i = 0; i < objectProperties.size(); i++ ) {\n            \n            DataProperty property = objectProperties.get(i);\n            removePropertyAtIndex(i);\n            addPropertyNamed(property.getName(), property.getValue().getType());\n        }\n    }\n}\n\nprivate boolean isMatchableType(JSType type) {\n    return !(type instanceof AnyType ||\n               type instanceof NullType ||\n               type instanceof ObjectLiteralType ||\n               type instanceof DefinitelyTypedFunctionType);\n}\n\nprivate JSType getProperty(String name) {\n    if (definedProperties.containsKey(name)) {\n        return definedProperties.get(name).getInitializer();\n    } else if (overrides.containsKey(name)) {\n        try {\n            return overrides.get(name).getGetterReturnType();\n        } catch (RuntimeException e) {\n            return getNativeType(JSTypeNative.VOID_TYPE);\n        }\n    } else if (parent == null) {\n        return getNativeType(JSTypeNative.UNDEFINED_TYPE);\n    } else {\n        return parent.getProperty(name);\n    }\n}",
