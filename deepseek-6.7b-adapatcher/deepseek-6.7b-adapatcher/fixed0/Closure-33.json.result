    "patch_code": "public void matchConstraint(ObjectType constraintObj) {\n  // We only want to match contraints on anonymous types.\n\n  // Handle the case where the constraint object is a record type.\n  //\n  // param constraintObj {{prop: (number|undefined)}}\n  // function f(constraintObj) {}\n  // f({});\n  //\n  // We want to modify the object literal to match the constraint, by\n  // taking any each property on the record and trying to match\n  // properties on this object.\n  if (constraintObj.isRecordType()) {\n     Map<String, JSType> newPropertiesMap = new HashMap<>();\n      List<String> deleteList = new ArrayList<>();\n      \n    for (String prop : constraintObj.getOwnPropertyNames()) {\n      JSType propType = constraintObj.getPropertyType(prop);\n      \n      if (!isPropertyTypeDeclared(prop)) {\n        JSType typeToInfer = propType;\n        \n        if (!hasProperty(prop)) {\n          \n            typeToInfer = getNativeType(JSTypeNative.VOID_TYPE).getLeastSupertype(propType);\n            \n        } else if(getPropertyType(prop).supers(propType)){\n                deleteList.add(prop);\n                    \n        }\n          newPropertiesMap.put(prop,typeToInfer );\n        }\n      }\n\n    \nfor (String key:deleteList){\n     deleteProperty_(key);\n}\n      \n      replaceByMergedConstrainedData_(newPropertiesMap);\n  }\n}",
