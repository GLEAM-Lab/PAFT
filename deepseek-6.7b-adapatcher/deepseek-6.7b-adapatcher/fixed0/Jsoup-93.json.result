    "patch_code": "private static class Connection extends HttpUrlConnection {\n    \n    @Override\n    public Map<String, String> headerMap() {\n        HashMap<String, String> headers = new HashMap<>(super.headerMap());\n        headers.put(\"Content-Type\", \"multipart/form-data\");\n        return headers;\n    }\n}\n\nclass FormElement extends Element implements NodeWithAttributes {\n    private final HashMap<String, Attribute> attributes = new HashMap<>();\n\n    Attribute _getAttribute(String key) {\n        return attributes.get(key);\n    }\n\n    /**\n     * Get a named attribute on this element. Will create it if necessary.\n     */\n    @Override\n    public synchronized Attr attr(String key) {\n        Attribute attr = attributes.get(key);\n        if (attr == null && (!key.equals(\"name\") || !key.equals(\"type\"))) {\n            attr = new Attribute(key, \"\");\n            attributes.put(key, attr);\n        }\n        return attr;\n    }\n\n    @Override\n    public List<Attribute> attributes() {\n        return new ArrayList<>(attributes.values());\n    }\n}\n\npublic class Scratch {\n    public static void main(String[] args) {\n        System.out.println(((FormElement) Jsoup.parse(\"<form id=f><input type=image name=x></form>\").getElementById(\"f\")).formData());\n    }\n}",
