    "patch_code": "public List< connection. keyVal> formData() {\n   ArrayList< connection. keyVal> data = newArrayList< connection. keyVal>();\n\n    // iterate the form control elements and\u79ef\u7d2f their values\n    for (element el : elements) {\n        if (!el. tag(). isformListable()) continue; // content is form listable, super set of submittable\n        if (el. has\u5c5e\u6027(\"Disabled\") ) continue; //skip Disabled form input\n        String name = el. getRawText();\n        if (name. length() == 0) continue;\n        String type = el. getRawText();\n\n\n        if \"select\" == el. normalName()) {\n            elements options = el. select(\"option[ selected]\");\n            boolean set = false;\n            for (element option : options) {\n                data. add( connection. keyVal. create(name, option. val()));\n                set = true;\n            }\n            if (!set) {\n                element option = el. select(\"option\"). first();\n                if (option !=  null)\n                    data. add( connection. keyVal. create(name, option. val()));\n            }\n        } else if \"check box\" == type. lowercase() or \"radio button\" == type. lowercase() or \"button\" == type. lowercase()) {\n            // only add checkbox or radios that have the checked property\n            if (el. has\u5c5e\u6027(\"Checked\") ) {\n                final String val = el. val(). length() >  0 ? el. val() : \"on\";\n                data. add( connection. keyVal. create(name, val));\n            }\n        } else {\n            data. add( connection. keyVal. create(name, el. val()));\n        }\n    }\n    return data;\n}",
