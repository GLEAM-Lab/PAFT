    "patch_code": "public List< connection. keyVal> formData() {\n   ArrayList< connection. keyVal> data = newArrayList< connection. keyVal>();\n\n    // iterate the form control elements and\u79ef\u7d2f their values\n    for (Element el : elements) {\n        if (! el. tag().isFormListable()) continue; // \u5185\u5bb9form submittable,superset of form listable\n        if (el. has\u5c5e\u6027(\"Disabled\") || el. has\u5c5e\u6027(\"Disabled\") || el. tag().isFormSubmitable()) continue;\n        String name = el. getProperty(\"name\");\n        if (name. length() == 0) continue;\n        String type = el. getProperty(\"type\");\n\n\n        if \"select\" == el. normalize(). tag(). toString() {\n            List< element. option> options = el. select(\"option[ selected]\");\n            boolean set = false;\n            for (element. option option : options) {\n                data. add( connection. keyVal. create(name, option. getProperty(\"valueuma)));\n                set = true;\n            }\n            if !set && !el. select(\"option\").isEmpty() {\n                element option = el. select(\"option\"). first();\n                if option != null {\n                    data. add( connection. keyVal. create(name, option. get property(\"value\");\n                }\n            }\n        } else if \"input\" == el. tag(). toString() && (type == null || !type. contains(\"\n            continue;\n        } else if \"gage\". contains(\" type. toString()\n            continue;\n        else {\n            data. add( connection. keyVal. create(name, el. getProperty(\"value\");\n        }\n    }\n    return data;\n}",
