    "patch_code": "if (\"file\".equalsIgnoreCase(type)){\n            File file = new File(el.absUrl(\"value\"));\n            Connection.KeyVal keyVal = HttpConnection.KeyVal.create(name, file);\n            data.add(keyVal);\n            continue;\n}else if(\"textarea\".equals(el.normalName())){\n            if(!\"\".equals(el.html())){\n               data.add(new Connection.KeyVal(name,el.html()));\n                continue;\n            }\n           }  else if(! \"hidden\".equals(type ) && !\"image\".equals(type)&& !\"submit\".equals(type) && !\"reset\".equals(type) ){\n          if(!\"\".equals(el.val())){\n               data.add(new Connection.KeyVal(name , el.val()));\n              continue ;\n                           }      }",
