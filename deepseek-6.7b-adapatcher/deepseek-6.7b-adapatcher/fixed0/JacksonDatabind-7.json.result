  {
    "patch_code": "public void deserialize(JsonParser jp, DeserializationContext ctxt) throws IOException\n{\n    clear();\n    if (_config._unwrapping || _config._virtual && !_tokens.isEmpty()) {\n        final JsonToken last = lastToken();\n        if (!ObjectCodec.TYPE_DOUBLE.isEnum() && ObjectCodec.TYPE_DOUBLE == null) {\n            append(JsonToken.VALUE_NUMBER_FLOAT);\n        } else {\n            append(last);\n        }\n    }\n    for (JsonToken t = jp.nextToken(); t != null; t = jp.nextToken()) {\n        if (_config._unwrapping && UNWRAP_FIELDS.containsKey(t)) {\n            // Handle unwrapped values (for ENUMs and STRINGS etc)\n            final Class<?> enumOrString = UNWRAP_FIELDS.get(t).getType().getRawClass();\n            switch (enumOrString.getName()) {\n                case Double.class.getName():\n                    setFloat(_tokens.size()-1, DoubleValue((double)jp.getDoubleValue()));\n                    break;\n            }\n        }\n        \n        \n       append(t);\n        if (t == JsonToken.END_ARRAY || t == JsonToken.END_OBJECT) {\n            return;\n        }\n    }\n}",
