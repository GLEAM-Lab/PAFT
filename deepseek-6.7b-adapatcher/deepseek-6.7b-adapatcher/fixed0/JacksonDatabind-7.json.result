    "patch_code": "public TokenBuffer deserialize(JsonParser jp, DeserializationContext ctxt) throws IOException\n{\n       if (_index != 0 && _tokens[0] == JsonToken.FIELD_NAME){\n           //We are starting from a field name, so pretend there was no previous token at all\n          System.arraycopy(_tokens, 1, _tokens, 0, _size - 1);\n            --_index;\n            ++_offset;\n        } else if (_index == 0){\n            copyCurrentStructure(jp);\n        }\n     \n    return this;\n}",
