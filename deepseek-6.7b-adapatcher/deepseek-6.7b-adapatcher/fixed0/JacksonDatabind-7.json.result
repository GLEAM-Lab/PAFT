  {
    "patch_code": "public void copyCurrentStructure(JsonParser jp) throws IOException {\n    if (_tokenCount < 0) {\n        _tokens = new JsonToken[DEFAULT_TOKEN_BUFFER_SIZE];\n    }\n    for (;;) {\n        final JsonToken t = jp.getCurrentToken();\n        if (t == null || t == JsonToken.END_ARRAY || t == JsonToken.END_OBJECT) {\n            break; // Done\n        } else if (t == JsonToken.FIELD_NAME) {\n            appendEntry(_bufferOffset + 1, t);\n            continue;\n        } else if (t != JsonToken.VALUE_NULL && t != JsonToken.VALUE_TRUE && t != JsonToken.VALUE_FALSE && t != JsonToken.VALUE_STRING && t != JsonToken.VALUE_NUMBER_FLOAT && t != JsonToken.VALUE_NUMBER_INT && t != JsonToken.START_OBJECT && t != JsonToken.START_ARRAY) {\n            throw ctxt.mappingException(\"Unexpected token (\" + t + \"), expected a property name\");\n        }\n        appendEntry(_bufferOffset, t);\n    }\n    assertInvariants();\n}",
