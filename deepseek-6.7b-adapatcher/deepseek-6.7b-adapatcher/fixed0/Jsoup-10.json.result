  {
    "patch_code": "public String absUrl(String attributeKey) {\n    Validate.notEmpty(attributeKey);\n    \n    String relUrl = attr(attributeKey);\n    if(!hasAttr(attributeKey)){\n       throw new UnsupportedOperationException(\"Attribute does not exist in node \"+this.nodeName()); \n    }else{\n         if(relUrl.startsWith(\"#\")){\n             Document ownerDoc = this.ownerDocument();\n              Element element  = ownerDoc.getElementById(relUrl.substring(1));\n               if(element!=null){\n                  relUrl = element.attr(\"href\");\n               }\n         }else if(relUrl.startsWith(\"/\")||relUrl.startsWith(\"?\")){\n             URL base;\n             try {\n                 base =  new URL(baseUri);\n             }catch(MalformedURLException e){\n                 return null;\n             }\n             return new URL(base,relUrl).toString();\n         }else if(relUrl.startsWith(\"?\")){\n             URL base;\n             int qIndex = baseUri.indexOf('?');\n             if(qIndex > -1){\n                 baseUri = baseUri.substring(0,qIndex);\n             }\n             try {\n                 base =  new URL(baseUri);\n             }catch(MalformedURLException e){\n                 return null;\n             }\n             return new URL(base,relUrl).toString();\n         }\n      if(relUrl.startsWith(\".\")){\n          return \"error\";\n          \n     }else if(relUrl.startsWith(\"..\")){\n         int cIndex = baseUri.lastIndexOf('/');\n          if(cIndex < -1){\n              baseUri = \"/\"+relUrl.substring(2);\n          }else{\n               baseUri = baseUri.substring(0,cIndex);\n          }\n        \n    }else if(!relUrl.matches(\"^(https|http|ftp|mailto|javascript):.*$\")){\n        return \"error\";\n     }else {\n         return relUrl;\n      }\n    }\n    return relUrl;\n}",
