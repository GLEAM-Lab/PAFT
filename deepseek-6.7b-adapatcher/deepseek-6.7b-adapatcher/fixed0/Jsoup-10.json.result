    "patch_code": "public String absUrl(String attributeKey) {\n    \n    Validate.notEmpty(attributeKey);\n\n    Element e = this;\n    while(!e.tagName().equalsIgnoreCase(\"html\")){\n        String relUrl = e.attr(attributeKey);\n        if (!e.hasAttr(attributeKey)) {\n            \n            e = e.parent();\n            continue;\n        } else {\n            try {\n                URL base;\n                try {\n                    base = new URL(e.baseUri());\n                } catch (MalformedURLException ex) {\n                    \n                    URL abs = new URL(relUrl);\n                    return abs.toExternalForm();\n                }\n                \n                URL abs = new URL(base, relUrl);\n                return abs.toExternalForm();\n            } catch (MalformedURLException e1) {\n                \n                return \"\";\n            }\n        }\n        \n    }\n    return \"\";\n\n}",
