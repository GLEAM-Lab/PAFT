    "patch_code": "public String absUrl(String attributeKey) {\n     Validate.notEmpty(attributeKey);\n    String relUrl = attr(attributeKey);\n    if (!\"\".equals(relUrl)){\n         relUrl =  relUrl.startsWith(\"/\")? \"http://www.oschina.net\"+ relUrl : relUrl;\n    }else{\n       Element parent =  this.parent();\n      while (parent != null && !\"a\".equalsIgnoreCase(parent.tagName())){\n          relUrl = parent.absUrl(attributeKey);\n          parent  = parent.parent();\n      }\n    }\n    return relUrl;\n}",
