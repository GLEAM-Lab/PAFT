    "patch_code": "public String absUrl(String attributeKey) {\n    Validate.notEmpty(attributeKey);\n\n    String relUrl = attr(attributeKey);\n    if (!hasAttr(attributeKey)) {\n        return \"\"; // nothing to make absolute with\n    } else {\n        if(!HtmlTreeBuilder.isAbsoluteUrl(relUrl)){\n        \ttry{\n        \t\t URL base = new URL(baseUri);\n    \t\t\t String fullPath= HtmlTreeBuilder.normalizeUrl(base+relUrl);\n    \t\t\t return fullPath;\n        \t}catch (MalformedURLException e) {\n                // the base is unsuitable, but the attribute may be abs on its own, so try that\n            \treturn \"\";\n            }\n        }else{\n        \treturn relUrl;\n        }\n      \n    }\n}\n\npublic static boolean isAbsoluteUrl(String url) {\n    int indexOfDotDot =  url.indexOf(\"..\");\n    int indexOfSlashSlash = url.indexOf(\"//\");\n    if ((indexOfDotDot != -1 && indexOfDotDot < indexOfSlashSlash ) || indexOfSlashSlash == 0) {\n      return true;\n    }\n    if (url.startsWith(\"/\")) {\n        return true;\n    }\n    if (indexOfSlashSlash != -1 && indexOfSlashSlash < url.length()-3 && url.charAt(indexOfSlashSlash + 2)==':') {\n        return true;\n    }\n    return false;\n}\n\nprivate static String normalizeUrl(String input) {\n  URI uri;\n  try {\n    uri = new URI(input);\n    return uri.toASCIIString();\n  } catch (URISyntaxException e) {\n    throw new IllegalArgumentException(\"Input is not valid:\" + input);\n  }\n}",
