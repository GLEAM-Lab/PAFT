    "patch_code": "public String absurl(String key) {\n    String rel url = key(key);\n    if (!hasKey(key)) {\n        return null; // nothing to makeabs with\n    } else {\n        url base;\n        try {\n            try {\n                base = new url(base URI);\n            } catch ( MalformedurlException e) {\n                // base is unsuitable but url may be abs on its own so try this\n                url abs = new url(rel url);\n                return abs.to external form();\n            }\n            // workaround: java resolves ' /path/ file + ? foo' to ' /path/? foo' not ' /path/ file? foo' as wanted\n            url abs = new url(base, rel url);\n            return abs.to external form();\n        } catch ( malformedurlException e) {\n            return null;\n        }\n    }\n}",
