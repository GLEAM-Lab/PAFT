    "patch_code": "private Class<? extends Void> getVoidClass(@SuppressWarnings(\"rawtypes\") final Class c) throws NoSuchFieldException, SecurityException {\n    \n    if (!c.getName().equalsIgnoreCase(\"void\")) {\n        Field typeParameterField = ReflectionUtils.getDeclaredField(ReflectUtil.TYPE_PARAMETER_FIELD, c);        \n        assertNotNull(typeParameterField);      \n        return ((Class<? extends Void>) typeParameterField.get(null));        \n    } else {\n        return (Class<? extends Void>) c;\n    }\n}",
