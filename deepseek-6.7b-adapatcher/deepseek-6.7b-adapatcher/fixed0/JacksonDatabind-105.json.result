    "patch_code": "private final Class<T> resultType = null;\n    \n@SuppressWarnings(\"unchecked\")\npublic static <T> JsonDeserializer<T> find(Class<T> rawType, String clsName)\n{\n   if (_classNames.contains(clsName)) {\n       JsonDeserializer<T> d = FromStringDeserializer.findDeserializer(rawType);\n       if (d != null) {\n           return d;\n       }\n       if (rawType == UUID.class) {\n           return (JsonDeserializer<T>) new UUIDDeserializer();\n       }\n       if (rawType == StackTraceElement.class) {\n           return (JsonDeserializer<T>) new StackTraceElementDeserializer();\n       }\n       if (rawType == AtomicBoolean.class) {\n           // (note: AtomicInteger/Long work due to single-arg constructor. For now?\n           return (JsonDeserializer<T>) new AtomicBooleanDeserializer();\n       }\n       if (rawType == ByteBuffer.class) {\n           return (JsonDeserializer<T>) new ByteBufferDeserializer();\n       }\n   }\n   return null;\n}",
