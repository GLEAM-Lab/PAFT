    "patch_code": "private boolean shouldWarnIllegalAccess() {\n        final SecurityManager sm = System.getSecurityManager();\n        if (sm != null) {\n            try {\n                ClassLoader rl = Thread.currentThread().getContextClassLoader();\n                Object o = rl.loadClass(\"sun.reflect.Reflection\")\n                        .getDeclaredConstructor().newInstance();\n                Method m = rl.loadClass(\"jdk.internal.module.IllegalAccessLogger\")\n                        .getDeclaredMethod(\"isAllow\");\n                return Boolean.TRUE.equals(m.invoke(o));\n            } catch (Exception ex) {\n                /* no-op */\n            }\n        }\n\n        /* fallback policy, change with caution - we want to prevent JDK bugs from\n         * leaking into general use of JSON-lib itself. This typically means we allow\n         * \"illegal\" things like having fields public for serialization */\n        return false;\n    }",
