    "patch_code": "import org.apache.commons.math3.util.FastMath;\n\npublic Complex add(Complex rhs)\n    throws NullArgumentException {\n    MathUtils.checkNotNull(rhs);\n    \n    double realValue = getReal();\n    double imagValue = getImaginary();\n    double otherRealValue = rhs.getReal();\n    double otherImagValue = rhs.getImaginary();\n    boolean realInvalid = Double.isNaN(realValue) || Double.isInfinite(realValue);\n    boolean imagInvalid = Double.isNaN(imagValue) || Double.isInfinite(imagValue);\n    boolean otherRealInvalid = Double.isNaN(otherRealValue) || Double.isInfinite(otherRealValue);\n    boolean otherImagInvalid = Double.isNaN(otherImagValue) || Double.isInfinite(otherImagValue);\n\n    if ((realInvalid && !imagInvalid)\n        || (!realInvalid && imagInvalid)\n        || (otherRealInvalid &&!otherImagInvalid)\n        || (!otherRealInvalid && otherImagInvalid)) {\n        return NaN;\n    } else if (realInvalid && imagInvalid) {\n        return new Complex(Double.NaN, Double.NaN);\n    } else if (otherRealInvalid && otherImagInvalid) {\n        return new Complex(Double.NaN, Double.NaN);\n    }\n  \n    return createComplex(realValue + otherRealValue,\n       imagValue + otherImagValue );\n}",
