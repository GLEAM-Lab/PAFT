    "patch_code": "public Complex add(Complex rhs)\n        throws NullArgumentException {\n    MathUtils.checkNotNull(rhs);\n\n    boolean realNotANumber = Double.isNaN(this.real) || Double.isNaN(rhs.getReal());\n    boolean imaginaryNotANumber = Double.isNaN(this.imaginary) || Double.isNaN(rhs.getImaginary());\n\n    if (!realNotANumber && !imaginaryNotANumber){\n        return createComplex(real + rhs.getReal(),\n                imaginary + rhs.getImaginary());\n    } else{\n        return Complex.NaN;\n    }\n\n}",
