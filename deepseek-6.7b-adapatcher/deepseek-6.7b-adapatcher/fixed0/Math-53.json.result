    "patch_code": "import org.apache.commons.math3.util.FastMath;\n\npublic Complex add(Complex rhs) throws NullArgumentException {\n    MathUtils.checkNotNull(rhs);\n    double real = Double.isNaN(this.real) || Double.isNaN(rhs.getReal()) ? Double.NaN : this.real + rhs.getReal();\n    double imaginary = Double.isNaN(this.imaginary) || Double.isNaN(rhs.getImaginary()) ? Double.NaN : this.imaginary + rhs.getImaginary();\n    return FastMath.isNaN(real) || FastMath.isNaN(imaginary) ? Complex.NaN : createComplex(real, imaginary);\n}",
