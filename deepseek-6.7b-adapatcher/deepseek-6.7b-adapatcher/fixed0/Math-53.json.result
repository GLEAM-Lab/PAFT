    "patch_code": "import org.apache.commons.math3.util.FastMath;\n\npublic Complex add(Complex rhs)\n    throws NullArgumentException {\n    MathUtils.checkNotNull(rhs);\n    double real1 = this.getReal();\n    double imag1 = this.getImaginary();\n    double real2 = rhs.getReal();\n    double imag2 = rhs.getImaginary();\n   // restore the isNaN comparison to avoid NaN output\n    boolean nana = FastMath.isNaN(real1) || FastMath.isNaN(imag1) || FastMath.isNaN(real2) || FastMath.isNaN(imag2);\n    if (!nana) {\n        return createComplex(real1 + real2, imag1 + imag2);\n    } else {\n        return createComplex(Double.NaN, Double.NaN);\n    }\n}",
