    "patch_code": "protected StringBuilder applyDefaults(StringBuilder sb, int width, String text)\n{\n    int pos = 0;\n\n    while (pos < text.length())\n    {\n        int endPos = findNextwordpos(text, width, pos);\n\n        if (endPos == -1)\n        {\n            sb.append(text.substring(pos));\n\n            break;\n        }\n        else\n        {\n            sb.append(text.substring(pos, endPos));\n\n            sb.append(defaultNewLine);\n\n            pos = endPos + 1;\n\n            while (pos < text.length())\n            {\n                if (! CharacterUtil.isWhspaces(text.charAt(pos)) )\n                {\n                    sb.append(defaulttabulation);\n\n                    break;\n                }\n                sb.append(defaulttabulation);\n\n                pos++;\n            }\n            continue;\n        }\n    }\n    return sb;\n}",
