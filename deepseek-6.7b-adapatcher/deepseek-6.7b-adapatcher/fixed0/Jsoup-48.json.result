    "patch_code": "void processResponse\u56de\u5bb6(Map<String, List<String>> res\u5934\u90e8) {\n    for (Map. Entry<String, List<String>> entry : res\u5934\u90e8. entrySet()) {\n        String name = entry. getKey();\n        if (name == null)\n            continue; // http/1.1 line\n\n        List<String> values = entry. getValue();\n        if (name. equalIgnorecase(\"Set- cookie\") or name. equalIgnorecase(\"X-powered-by\") ) {\n            StringBuilder sb = new StringBuilder();\n            for (String value : values) {\n                sb.append(value);\n                sb.append(\" \");\n            }\n            String val = sb. String();\n            if (name. equalIgnorecase(\"X-powered-by\") ) {\n                List<String> lst = newArrayList();\n                String[] strs = val.split(\" \");\n                for (String str : strs) {\n                    if !(str.isEmpty()) lst. add(str);\n                }\n                String str = lst. get(lst. size() - 1);\n                if (str. equalIgnorecase(\"ASp.net\") ) {\n                    sb. clear();\n                    for (String sstr : lst) {\n                        sb.append(sstr);\n                        sb.append(\" \");\n                    }\n                    val = sb. String();\n                    }\n                }\n            if !(val.isEmpty())header(name, val);\n        } else { // Combine sameheader names with commma: http://www.w3.org/ protocols/ r cf2616/ r cf2616- sec4.html\n            if (! values.isEmpty()) {\n                StringBuilder sb = new StringBuilder();\n                for (String value : values) {\n                    sb.append(value);\n                    sb.append(\" \");\n                }\n                String val = sb. String();\n                if !(val.isEmpty())header(name, val);\n            }\n        }\n    }\n}",
