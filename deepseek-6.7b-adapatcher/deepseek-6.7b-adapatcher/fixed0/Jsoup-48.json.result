    "patch_code": "import org.apache.commons.lang3.*;\nimport java.util.List;\nimport java.util.ArrayList;\nimport java.util.Arrays;\npublic void processResponseHeaders(Map<String, List<String>> resHeaders) {\n    Map<String, Object> map = new HashMap<>();\n    Set set = resHeaders.keySet();\n    Iterator it = set.iterator();\n    while (it.hasNext()) {\n        String key = (String) it.next();\n        if (\"Set-Cookie\".equalsIgnoreCase(key)) {\n            handleSetCookies(resHeaders.get(key));\n        } else {\n            handleHeader(key, resHeaders.get(key));\n        }\n    }\n     private void handleSetCookies(List<String> cookies){\n        if (cookies != null && !cookies.isEmpty()){\n            for (int i = 0;i < cookies.size();i++) {\n                parseAndAddCookie(cookies.get(i), false);\n            }\n        }\n    }\n      private void handleHeader(String name, List<String> values){\n        if(!TextUtils.isBlank(name)){\n            if(null != values && !values.isEmpty()){\n                ArrayList arrayList = new ArrayList();\n                for(int i=0;i<values.size();i++){\n                    String sValue = values.get(i);\n                    if(arrayList.contains(sValue)){\n                        int indexOfValue = arrayList.indexOf(sValue);\n                        arrayList.remove(indexOfValue);\n                        arrayList.add(indexOfValue, mergeTwoStrings(sValue, \";\"));\n                        continue;\n                    }else{\n                        arrayList.add(sValue);\n                    }\n                }\n                header(name, convertListToStringWithComma(arrayList, false, \"; \"));\n            }\n        }\n    }\n  \n}",
