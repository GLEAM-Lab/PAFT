    "patch_code": "public void printWrapped(PrintWriter pw, int width, int nextLineTabStop, String text)\n    {\n        StringBuffer sb = new StringBuffer(text.length());\n        \n        // Adding spaces for leading indentation\n        if (!text.contains(\"\\n\"))\n        {\n            String spaces = \"\";\n            \n            for (int i = 0; i < nextLineTabStop - 1; i++)\n            {\n                spaces += \" \";\n            }\n            \n            text = spaces + text;\n        }\n\n        renderWrappedText(sb, width, nextLineTabStop, text);\n        pw.println(sb.toString());\n    }",
