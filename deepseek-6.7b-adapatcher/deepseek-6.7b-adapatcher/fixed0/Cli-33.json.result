    "patch_code": "void printIndented(PrintWriter pw, int indentation, int nextLineTabStop, String text){\n    String[] lines = text.split(\"\\n\");\n    for (String line : lines) {\n        // Add required number of spaces or tabs at beginning of each line\n        if (!line.isEmpty()) { \n            char firstChar = line.charAt(0);\n            if (firstChar == '\\t') {  \n                line = line.replaceFirst(\"\\\\t\", \" \".repeat((indentation / INDENT_SPACES)));\n            } else {\n                line = \" \".repeat((indentation / INDENT_SPACES)) + line;\n            }\n        }\n        \n        pw.println(line);\n    }\n}",
