    "patch_code": "public void printWrapped(PrintWriter pw, int width, int nextLineTabStop, String text)\n    {\n        String[] lines = text.split(\"\\\\n\");\n        \n        for (int i = 0; i < lines.length; ++i)\n        {\n            StringBuffer sb = new StringBuffer(lines[i].length());\n            \n            if(i > 0){\n                appendCharToRightPadBufferedString(sb, ' ', nextLineTabStop - indentLength(), true);\n            }else{\n               //No tab stop if it's first line \n                 appendCharToRightPadBufferedString(sb, ' ', nextLineTabStop , true); \n            }\n            \n            renderWrappedText(sb, width, nextLineTabStop, lines[i]);\n            pw.println(sb.toString());\n        }\n    }\n\nprivate void appendCharToRightPadBufferedString(StringBuffer buffer, char ch, int padLen, boolean rightAlign)\n    {\n        if (rightAlign && buffer.length() < padLen)\n        {\n            int delta = padLen - buffer.length();\n            IntStream.rangeClosed(1,delta).forEach(e->buffer.insert(0,ch));\n        }\n        else if (!rightAlign && buffer.length() <= padLen)\n        {\n            buffer.append(ch);\n        }\n    }\n    \nprivate int indentLength(){\n        return OptionUtils.initialMatcherIndentLength + OptionUtils.matcherIndentLength;\n    }",
