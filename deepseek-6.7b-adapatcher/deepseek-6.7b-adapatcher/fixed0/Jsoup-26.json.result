    "patch_code": "public Document clean(Document dirtyDocument) {\n   if(dirtyDocument == null || dirtyDocument.body()==null){\n       throw new IllegalArgumentException(\"Document can't be null\");\n   }\n    \n   Document clean = Document.createShell(dirtyDocument.baseUri());\n   if(!isFrameset(dirtyDocument)){\n        clean.html(dirtyDocument.html());\n   }else{\n         cleanSafeFramesets(dirtyDocument, clean);\n   }\n   \n    return clean;\n}",
