    "patch_code": "public Document clean(Document dirtyDocument) throws IOException{\n    if (dirtyDocument == null){\n        throw new IOException(\"Dirty Document cannot be null\");\n    }\n    \n    if (!dirtyDocument.hasText() && !dirtyDocument.hasChild()) {\n        return null;\n    }\n\n    Document clean = Document.createShell(dirtyDocument.baseUri());\n    Elements eAry = dirtyDocument.select(\"frameset > frame\").remove();\n    for (Element element : eAry) {\n        String url1 = element.attr(\"longdesc\");\n        String url2 = element.attr(\"src\");\n        clean.appendElement(\"span\").text(\"[Frame - \" + url1 + \"-\" + url2+\"]\");\n    }\n\n    clean.setBaseUri(dirtyDocument.baseUri());\n        \n    \n   copySafeNodes(dirtyDocument.body(), clean.body());\n   \n    return clean;\n}\n\nprivate void copySafeNodes(Element sourceNode, Element destinationNode) {\n    if (sourceNode instanceof TextNode) {\n       if(!((TextNode) sourceNode).getWholeText().trim().equals(\"\") )\n            destinationNode.appendChild(sourceNode.clone());\n        return;\n    }\n\n    // add more conditions here to ignore script, style tag etc..\n    \n    if (\"script\".equalsIgnoreCase(sourceNode.nodeName())){\n        return;\n    }else if(\"style\".equalsIgnoreCase(sourceNode.nodeName())){\n        return;\n    }else if(\"noscript\".equalsIgnoreCase(sourceNode.nodeName())){\n        return;\n    } else if (sourceNode instanceof Comment || \"head\".equalsIgnoreCase(sourceNode.nodeName())) {\n        return;\n    }\n\n    for (int i = 0; i < sourceNode.childrenSize(); i++) {\n        copySafeNodes(sourceNode.child(i), destinationNode);\n    }\n}",
