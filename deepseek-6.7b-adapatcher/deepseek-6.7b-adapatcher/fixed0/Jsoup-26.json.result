    "patch_code": "import org.jsoup.nodes.*;\nimport org.jsoup.select.NodeTraversor;\nimport org.jsoup.select.NodeVisitor;\n\nclass CleaningVisitor implements NodeVisitor {\n    private final Node cleanNode;\n    \n    public CleaningVisitor(Node cleanNode){\n        this.cleanNode = cleanNode;        \n    }  \n    \n    @Override \n    public void head(Node node, int depth) {\n       /* If tag is frame - replace it with text */\n      if(\"frameset\".equalsIgnoreCase(node.tagName()) || \"frame\".equalsIgnoreCase(node.tagName())){ \n            Text txt=new Text(node.html());                \n            node.parent().children().replaceWith(txt);            \n      }else if (\"a\".equalsIgnoreCase(node.tagName())) { // change href\n           Attribute link =  node.attributes().get(\"href\");         \n           if(link !=null && link.contains(\"/\")) {                 \n               StringBuilder sbLink = new StringBuilder();               \n               for(int i=0 ;i < link.length() ; ++i) {                    \n                   char c= link.charAt(i);                          \n                   if('\\\\' ==c ) {                                        \n                       c=  '/';                                         \n                                   }                                 \n                          sbLink.append(c);                           \n                      }                                                 \n                      node.attr(\"href\",sbLink.toString());             \n           }\n      } else {                             \n         for (int i = 0; i < node.attributes().size(); i++) {\n             Attribute attr = node.attributes().get(i);\n             if (!isSafeAttribute(attr)) {\n                 node.removeAttr(attr.getKey());\n             }\n         }\n     }\n     } \n        \n   @Override public void tail(Node node, int depth) {}     \n} \n\n\n\npublic class SafeFrameSet extends Cleaner{\n    @Override\n    public Document clean(Document input) {\n\n        if(input==null||input.body()==null)return null;\n\n         Document outDoc = Document.createShell(input.baseUri()).normalise();\n       \n        \n        CleaningVisitor cleaner = new CleaningVisitor(outDoc.body());       \n        NodeTraversor traversor= new NodeTraversor(cleaner);\n       \n        traversor.traverse(input);\n        return outDoc;\n\n    }\n    \n\n}",
