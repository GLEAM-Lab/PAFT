  {
    "patch_code": "public Document clean(Document dirtyDocument) throws Exception {\n        if (dirtyDocument == null || dirtyDocument.html()==null)\n            throw new IllegalArgumentException(\"Document can't be null!\");\n    \n       Validate.notNull(dirtyDocument);\n        \n        Document cleanDoc ;\n        //check the type of input dirtyDocument whether it is fragments or whole document. \n        if(dirtyDocument.title() != null && !dirtyDocument.title().equals(\"\")){//whole documents \n             cleanDoc =  new Document(dirtyDocument.baseUri()){{\n                 setTitle(dirtyDocument.title());  \n                body().appendChild(createElement(\"html\")).appendChild(createElement(\"head\")).appendChild(createElement(\"body\"));\n            }};\n             \n        }else if(dirtyDocument.baseUri() != null && !dirtyDocument.baseUri().equals(\"\")){\n          //fragments\n           cleanDoc=  new Document(dirtyDocument.baseUri()){{body()}};\n            \n        }else {\n            throw new Exception (\"The input Document is neither full pages nor fragments\");\n        }\n     \n   \n        for(int i = 0;i <16;i++ ){\n        visitNode(dirtyDocument.body(),cleanDoc.body(),dirtyDocument);\n    }\n        \n      \n        return cleanDoc;\n    }",
