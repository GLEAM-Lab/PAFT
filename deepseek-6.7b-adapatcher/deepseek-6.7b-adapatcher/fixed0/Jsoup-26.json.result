    "patch_code": "public Document clean(Document dirtyDocument) {\n    Validate.notNull(dirtyDocument);\n    //handle the frameset document\n    if (dirtyDocument.head() != null &&\n            \"frameset\".equalsIgnoreCase(dirtyDocument.head().selectFirst(\"meta[http-equiv=content-type]\").attr(\"content\"))) {\n        Logger.getLogger(getClass().getName()).log(Level.INFO,\"frameset document\");\n        Document clean = Document.createShell(dirtyDocument.baseUri());        \n        return clean;\n    } else {\n        Document clean = Document.createShell(dirtyDocument.baseUri());        \n        copySafeNodes(dirtyDocument.body(), clean.body());\n    \treturn clean;\n\t}\n}",
