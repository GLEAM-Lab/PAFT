[
  {
    "patch_code": "public void clean(Document dirtyDocument){\n    Validate.notNull(dirtyDocument);\n    \n    // Handle Framesets\n    Elements iframes = dirtyDocument.select(\"frameset > frame\");\n    for (Element el : iframes) {\n        String urlStr = el.attr(\"longdesc\");\n        org.jsoup.nodes.Document.Element urlDocElm = new org.jsoup.nodes.Document(urlStr).getElementById(\"#f1\");\n        Element cloneFrame = Jsoup.parse(String.valueOf(urlDocElm)).getElementsByTag(\"body\").first();\n        \n        el.after(cloneFrame);\n        el.remove();\n    }\n  \n      \n      Deque<Node> stack = new ArrayDeque<>();\n    stack.push(dirtyDocument.html());\n    \n    while(!stack.isEmpty()){\n        Node node=stack.pop();\n        if(node instanceof TextNode && ((TextNode) node).parent() instanceof HtmlNode ){\n            continue;\n        }else if (!(node instanceof Comment)){\n          \n               if (((Element)node).hasAttr(\"style\")){\n                 ((Element)node).removeAttr(\"style\");\n                }\n             if (((Element)node).hasAttr(\"class\")){\n                  ((Element)node).removeAttr(\"class\");\n              }\n             if (((Element)node).hasAttr(\"id\")){\n                  ((Element)node).removeAttr(\"id\");\n              }\n         \n        }\n        if(node instanceof Element){\n            List<Attribute> attributes=new ArrayList<>();\n           attributes.addAll(((Element) node).attributes().asList());\n           for (Attribute attribute : attributes){\n              \n               if (attribute.isUrl()|| attribute.isMediaQuery())continue;\n               \n               else ((Element) node).removeAttr(attribute.getKey());\n           }\n           \n        }\n        if(node instanceof Document){\n            for (int i = 0;i < ((Document) node).childNodesCount(); i++){\n                stack.push(((Document) node).childNode(i));\n            }\n        }\n        if(node instanceof HtmlNode){\n            stack.push(((HtmlNode) node).childNode(0));\n        }\n    \n    }\n  \n  \n}",
    "patch_status": "TRIGGER_ERROR",
