    "patch_code": "import org.apache.commons.lang3.StringUtils;\nimport org.jsoup.nodes.*;\n\n    void copySafeNodes(Node nodeFrom, Node parentTo){\n        if(!(nodeFrom instanceof TextNode)){\n            Attributes attributes = nodeFrom.attributes();\n            \n            String tagName = nodeFrom.nodeName();\n            if (!isAllowedTag(tagName)) {\n                Node noopNode=new NoOpNode(\"\");  \n                setParentAndLinks(parentTo ,noopNode); \n            } else {\n                \n                if (!\"frameset\".equalsIgnoreCase(tagName)) {\n                    for (int i = 0; i < attributes.size(); i++) {\n                        Attribute attr = attributes.get(i);\n                        if (!isAllowAttribute(attr.getKey())) {\n                            nodeFrom.removeAttr(attr.getKey());\n                            continue ;\n                        }\n                    }\n                }\n                \n                 \n                    \n              \n                setParentAndLinks(parentTo , new Element(tagName));\n             \n                \n            }\n        }else{\n            ((Element)parentTo).appendText(nodeFrom.toString());\n        \n        }\n    \n        int childNums = nodeFrom.childNodeSize();\n        \n        for (int i = 0; i < childNums; i++) {\n         \n          \n            Node child  = nodeFrom.childNode(i);\n     \n          \n            copySafeNodes(child,parentTo);\n      \n        }\n  \n    }",
