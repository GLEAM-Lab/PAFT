    "patch_code": "private static int findKeyword(String value, List<String> keywords){\n    for (int k=0; k<keywords.size(); k++){\n        if (value.toLowerCase().contains(keywords.get(k).toLowerCase())) return k;\n    }\n    return -1;\n}",
