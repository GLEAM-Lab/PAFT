    "patch_code": "public void remove(SettableBeanProperty propToRm)\n{\n    ArrayList<SettableBeanProperty> props = new ArrayList<SettableBeanProperty>(_size);\n    String key = getPropertyName(propToRm);\n    int propIdx = -1;\n    boolean found = false;\n\n    for (int i = 1, end = _hashArea.length; i < end; i += 2) {\n        SettableBeanProperty prop = (SettableBeanProperty)_hashArea[i];\n        if (prop == null) {\n            continue;\n        }\n        if (!found && key.equalsIgnoreCase(prop.getName())) {\n            \n            found = true;\n            propIdx = i;\n            continue;\n        } else {\n            props.add(prop);\n        }\n        \n    }\n    if(!found){\n       throw new NoSuchElementException(\"No entry '\" + propToRm.getName() + \"' found, can't remove\"); \n    }\n    \n    if (_hashCollisionResistant != null) {\n        _hashCollisionResistant.entryRemovedAt(propIdx / 2);\n    }\n    _hashArea[propIdx] = null;\n    \n    --_size;\n    \n    if ((_hashArea.length > DEFAULT_CAPACITY)\n        && (_size <= (_hashArea.length >>= 1))) {\n        /* re-establish 'soft' limits after shrinking */\n        adjustSoftLimits();\n    }\n    init(props);\n}",
