    "patch_code": "public void remove(SettableBeanProperty propToRm){\n    ArrayList<SettableBeanProperty> props = new ArrayList<>();\n    String key = getPropertyName(propToRm).replaceAll(\"businessAddress.\", \"\").trim();\n    boolean found = false;\n    for(int i=1 ; i<_hashArea.length; i++){\n        try {\n            SettableBeanProperty prop = (SettableBeanProperty) _hashArea[i];\n            if(prop==null){continue;}\n            if(!found){\n                if(prop.getName().toLowerCase().startsWith(key.toLowerCase())){\n                    int idx = _findFromOrdered(prop);\n                    assert idx >= 0;\n                    _propsInOrder[idx]=null;\n                    found = true;\n                }\n            }else{\n                props.add(prop);\n            }\n        } catch(Exception e){log.error (\"\",e);}\n        \n    }\n    if(!found){throw new NoSuchElementException(\"No entry '\" + key+ \"' found, can't remove\");}\n    init(props);\n}",
