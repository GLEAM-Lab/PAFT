[
  {
    "patch_code": "private void handleBlockComment(Comment comment) {\n  String value = comment.getValue();\n  boolean valid;\n  \n  // Check whether the block comment contains \"/* @\" or \"\\n * @\".\n  int indexOfAt = value.indexOf('@');\n  int lastSlashIndex = value.lastIndexOf('/');\n  if ((indexOfAt == -1 && value.charAt(lastSlashIndex + 1) == '*') || \n      (value.indexOf(\"\\n * @\") != -1)) {\n    errorReporter.warning(SUSPICIOUS_COMMENT_WARNING,\n            sourceName,\n            comment.getLineno(), \"\", 0);\n  } else {\n    valid = true;\n  }\n  \n  // If the comment is not preserved, remove all whitespace from its content.\n  if (!valid) {\n    for (int i = 0, n = value.length(); i < n; i++) {\n      char c = value.charAt(i);\n      if (!Character.isWhitespace(c)) {\n        continue;\n      }\n      // Preserve one whitespace within each line.\n      if (value.charAt(i - 1) != '\\n') {\n        continue;\n      }\n      value = value.substring(0, i) + value.substring(i + 1);\n      i--;\n      n--;\n    }\n    comment.setValue(value);\n  }\n}",
