  {
    "patch_code": "private static boolean isStartOfCommentPreservingAnnotation(String text) {\n  return text.startsWith(\"/* @preserve\") || \n         text.contains(\"\\n * @preserve\");\n}\n\nprivate void handleBlockComment(Comment comment) {\n  String value = comment.getValue();\n  if (value.endsWith(\"/\")){\n      if (!isStartOfCommentPreservingAnnotation(value)) {\n          errorReporter.warning(SUSPICIOUS_COMMENT_WARNING, sourceName, comment.getLineno(), \"\", 0);\n          value = value + \"\\n\";\n      } else if (isStartOfCommentPreservingAnnotation(value)) {\n          int index = value.indexOf(\"\\n * @preserve \");\n          if (index > -1){\n              value = value.substring(0 ,index + 1 )+ \"\\n\";\n          }else {\n              index = value.indexOf(\"\\n\\n\");\n              value = value.substring(0, index < 0 ? value.length() : index );\n              \n          }\n      }\n  } else if (value.contains(\"*\\n\")|| value.endsWith(\"*/\\n\") || value.contains(\" *\\n\")  || value.contains(\"\\n*/\")   ) {\n      if (!isStartOfCommentPreservingAnnotation(value)){\n            errorReporter.warning(SUSPICIOUS_COMMENT_WARNING,sourceName,comment.getLineno(),\"\" ,0);\n      }\n      \n  } else if (!value.contains(\"@preserve \") && !value.contains(\"\\n * @preserve \")){\n        errorReporter.warning(INCONSISTENT_HANDLING_OF_NON_JSDOC_COMMENTS_WARNING,sourceName,comment.getLineno());\n  }\n  \n}",
