  {
    "patch_code": "private void handleBlockComment(Comment comment) {\n  int indexOfSlashStar = comment.getValue().indexOf(\"/*\");\n  int indexOfAsteriskSlash = comment.getValue().indexOf(\"*/\");\n  boolean containsAtSign = false;\n  \n  // Check if there is an annotation in the block comment\n  if ((indexOfSlashStar != -1 && indexOfSlashStar < indexOfAsteriskSlash) || \n      (indexOfAsteriskSlash != -1 && indexOfAsteriskSlash < indexOfSlashStar)) {\n    \n    String[] lines = comment.getValue().split(\"\\n\");\n    for (String line : lines) {\n      \n      // Find a line containing an annotation\n      if (line.trim().startsWith(\"@\")) {\n        containsAtSign = true;\n        break;\n      }\n    }\n    \n    // Report a warning if there is an annotation\n    if (!containsAtSign) return;\n  }\n  \n  // Preserve normal block comments not containing annotations\n  if (indexOfSlashStar == -1 && indexOfAsteriskSlash == -1) return;\n  \n  errorReporter.warning(\n      SUSPICIOUS_COMMENT_WARNING,\n      sourceName,\n      comment.getLineno(), \"\", 0);\n}",
