    "patch_code": "private boolean inPreserve = false;\n\npublic void init() {\n\tsuper.init();\n\tthis.inPreserve = this.sourceName != null && this.sourceName.endsWith(\".preserve\");\n}\n\n@Override\nprotected Token handleText(String text) throws ParseException {\n\tif (!inPreserve) {\n\t\treturn super.handleText(text);\n\t}\n\tfinal int firstDotIndex = text.indexOf('.');\n\tif (firstDotIndex >= 0) {\n\t\tString candidate = text.substring(0, firstDotIndex).trim();\n\t\tif (\"goog\".equalsIgnoreCase(candidate)) {\n\t\t\tcandidate += text.charAt(firstDotIndex);\n\t\t} else if ((this.tokenizer.nextChar() == '.') && (\"window\".equalsIgnoreCase(candidate))) {\n\t\t\tcandidate += '.';\n\t\t} else {\n\t\t\treturn super.handleText(text);\n\t\t}\n\t\tToken token = makeIdentifierOrKeyword(candidate);\n\t\ttoken.setFlags((short) (token.flags & ~TOKEN_UNCLOSED));\n\t\treturn token;\n\t}\n\t// This means there's some garbage after dot, ignore it.\n\treturn null;\n}\n\nprivate Token makeIdentifierOrKeyword(String name) {\n\tassert !name.isEmpty(): \"Empty names not allowed\";\n\tswitch (name) {\n\tcase \"package\":\n\t\treturn new PackageToken();\n\tcase \"import\":\n\t\treturn new ImportToken();\n\t}\n\treturn new Identifier(makeSourceInfo(null, -1, -1), name);\n}",
