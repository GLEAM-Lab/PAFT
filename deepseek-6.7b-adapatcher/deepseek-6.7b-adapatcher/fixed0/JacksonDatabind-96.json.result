    "patch_code": "public static class BasicDeserializerFactory_ extends BasicDeserializerFactory {\n    @Override\n    protected void _addExplicitAnyCreator(DeserializationContext ctxt,\n                                          BeanDescription beanDesc, CreatorCollector creators,\n                                          CreatorCandidate candidate)\n            throws JsonMappingException {\n        if (candidate.getConstructor().length == 1){\n            AnnotatedParameter param = candidate.parameters()[0];\n            JacksonInject.Value injectId = candidate.injections()[0];\n            PropertyName paramName = candidate.explicitNames()[0];\n            BeanPropertyDefinition paramDef = candidate.properties()[0];\n            \n            if((paramName != null || injectId != null) && paramDef != null ){\n                \n                SettableBeanProperty[] properties = new SettableBeanProperty[] {\n                        constructCreatorProperty(ctxt, beanDesc, paramName, 0, param, injectId)\n                };\n                creators.addPropertyCreator(candidate.creator(), true, properties);\n                \n                return;\n            }else if(paramDef != null && paramDef.getName() != null && paramDef.couldSerialize()){\n                \n                String name = paramDef.getName();\n                PropertyName newName = ctxt.getConfig().getPropertyNamingStrategy().translate(name);\n                \n                SettableBeanProperty[] properties = new SettableBeanProperty[] {\n                        constructCreatorProperty(ctxt, beanDesc, newName, 0, param, injectId)\n                };\n                creators.addPropertyCreator(candidate.creator(), true, properties);\n                \n                return;\n            }\n            \n        }\n        \n        super._addExplicitAnyCreator(ctxt, beanDesc, creators, candidate);\n    \n        BeanPropertyDefinition propDef = candidate.propertyDefinition();\n        if (propDef != null) {\n            ((POJOPropertyBuilder) propDef).removeConstructors();\n        }\n    \n    }\n}",
