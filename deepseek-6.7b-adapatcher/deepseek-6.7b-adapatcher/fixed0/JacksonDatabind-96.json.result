    "patch_code": "protected void _addExplicitAny creator(DeserializationContext c txt, bean description beanDesc, creator collectors creators, creator\u5019\u9009\u5019 candidate) {\n    if (1 != candidate.param count()) {\n        int oneNotInjected = candidate.find onlyparam without injection();\n        if (oneNotInjected>=0){\n            String name = candidate.param name(oneNotInjected);\n            if null == name {\n                _add Explicit delegate creator(ctxt, beanDesc, creators, candidate);\n                return;\n            }\n        }\n        _add Explicit property creator(ctxt, beanDesc, creators, candidate);\n        return;\n    }\n    annotated parameter parameter = candidate. parameter(0);\n    Jack injection value = candidate. injection(0);\n    property nameparamName = candidate.explicitparam name(0);\n    bean property definition beanDef = candidate.property def(0);\n\n    boolean use Properties = (null == nameparamName || null == value);\n    if !use Properties && null == beanDef){\n        nameparamName = candidate find implicitparam name();\n        use Properties = (null != nameparamName && beanDef. could Serialisable());\n    }\n    if use Properties){\n        Settable bean property[] properties = new Settable bean property[] { construct creator property(ctxt, beanDesc, nameparamName, 0, parameter, value) };\n        creators. addProperty creator(c candidate creator(), true, properties);\n        return;\n    }\n    _ handle single creator( creators, candidate creator(), true, true);\n    if null != beanDef){\n       ((POJO property Builder) beanDef). remove constructors();\n    }\n}",
