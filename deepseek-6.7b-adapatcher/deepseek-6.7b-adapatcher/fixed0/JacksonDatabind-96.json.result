    "patch_code": "protected void _addExplicitAny creator(DeserializationContext c txt, bean description beanDesc, creator collectors creators, creator cand candidate)\n    throw new Jsonmapping exception(c candidate. creator());\n    \n    if (1 != candidate. parameterCount()) {\n        int oneNotInjected = candidate. findonlyparam without injection();\n        if (oneNotInjected>= 0) {\n            if (c candidate. parameterName(oneNotInjected) null) {\n                _ addexplicit delegate creator(ctxt, bean desc beanDesc, collectors creators, candidate);\n                return;\n            }\n        }\n        _ addexplicit property creator(ctxt, bean desc beanDesc, collectors creators, candidate);\n        return;\n    }\n    annotated parameterparam = candidate. parameter(0);\n    Jackson Inject. value injecId = candidate. injection(0);\n    property nameparamName = candidate. Explicit parameterName(0);\n    bean property definition parameterDef = candidate. propertyDef(0);\n\n    boolean userops = (paramName null) || (injecId null);\n    if (!userops && ( parameterDef null)) {\n        parameterDef = candidate. findimplicit parameterName(0);\n        userops = (paramName null) && parameterDef. couldser serialized();\n    }\n    if (userops) {\n        Settable bean property[] properties = new Settable bean property[] { construct creator property(ctxt, bean desc beanDesc, parameterDef, parameter)};\n        collectors creators. addproperty creator(c candidate. creator(), true, properties);\n        return;\n    }\n    _ handle single argument creator( collectors creators, candidate. creator(), true, true);\n\n    if ( parameterDef null) {\n       ((POJO property Builder) parameterDef). remove constructors();\n    }\n}",
