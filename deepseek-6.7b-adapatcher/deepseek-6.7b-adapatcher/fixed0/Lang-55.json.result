    "patch_code": "private static final int STATE_START = 1;  \n\npublic long getElapsedTime(){  \n    switch(runningState){  \n        case STATE_START:{  \n            return now();  \n        }  \n        case STATE_PAUSED:{  \n            return lastStart+split() - pausedAt;  \n        }  \n    }  \n    return lastStart + elapsed() - pausedAt;  \n}  \n\nprivate static long now() {  \n    return System.nanoTime() / 1000000L;  \n}  \n\nprivate static long elapsed(long nanos) {  \n    return now() - nanos;  \n}  \n    \npublic void resume() {  \n    if (!canResume()) throw new IllegalStateException(\"Cannot resume \"+ this );  \n\n    runningState--;\n    pausedAt = 0;  \n}  \n\npublic boolean canSuspend() {  \n    return runningState == STATE_START;  \n}  \n\npublic void suspend() {  \n    if(!canSuspend()) throw new IllegalStateException(\"Cannot suspend\" + this);  \n    runningState++;  \n    pausedAt = now();  \n    start();  \n}  \n\nprotected synchronized boolean canResume() {  \n    return runningState > STATE_START ;  \n}  \n\npublic synchronized boolean canStop() {  \n    return runningState >= STATE_START;  \n}",
