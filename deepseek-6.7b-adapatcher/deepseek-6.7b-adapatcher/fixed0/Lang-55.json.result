    "patch_code": "private long lastSplitTime = 0L;\nprivate boolean suspendedBeforeLastSplitOrResume = false;\n    \npublic synchronized void suspend(){\n   if(this.runningState == STATE_RUNNING){\n       this.lastSplitTime = elapsed();\n       this.suspendedBeforeLastSplitOrResume = true;\n       this.runningState = STATE_SUSPENDED;\n   } else{\n        throw new IllegalStateException (\"Stopwatch has already been suspended.\");\n   }\n}\n    \npublic synchronized void resume() {\n   if(this.runningState ==STATE_SUSPENDED){\n      this.startTime +=System.currentTimeMillis() - lastSplitTime ;\n      this.suspendedBeforeLastSplitOrResume = false;\n      this.runningState  =STATE_RUNNING;\n   }else{\n         throw new IllegalStateException (\"Stopwatch isn't being suspended.\");\n   }\n}\n    \npublic synchronized void stop() {\n    getElapsedTimeIfRunning();\n    if(!suspendedBeforeLastSplitOrResume){\n        super.stop();\n    }\n    this.runningState =STATE_STOPPED;\n}",
