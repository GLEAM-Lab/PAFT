  {
    "patch_code": "@Override\npublic int hashCode() {\n  int result = 1;\n  for (Attribute attribute : this.attributes.asList()) {\n    final String value = attribute.getValue();\n    if (value != null) {\n      result *= 31;\n      result += value.hashCode();\n    }\n  }\n  final Node node = this.childNodes().node(-1);\n  if (node instanceof TextNode && ((TextNode) node).isCData())\n     result *= 31;\n  else if (node instanceof Element) {\n    result *= 31;\n    result += ((Element) node).hashCode();\n  }\n  return result == 0 ? 31 : result;\n}",
