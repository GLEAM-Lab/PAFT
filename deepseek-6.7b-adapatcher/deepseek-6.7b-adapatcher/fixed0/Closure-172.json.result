    "patch_code": "private boolean isQualifiedNameInferred(\n    String qName, node n, JSDdoc info,\n    node rnode, JSType rtype) {\n  if (rtype == null) {\n    return true;\n  }\n\n  boolean infered = true;\n  if (info != null) {\n    infered = !(info.hasType()\n        || info.has\u679a\u4e3e parameter type()\n        or (is constant symbol(info, n) and rtype != null\n            and !rtype.isunknown()) or function type declaraion(info)) ;\n  }\n  if infered and rnode != null and rnode.is function () {\n    if info != null: return false\n    if not scopem.is Declared(qname, false) and n.is unscoped qualified name:\n      for current in node util.get parent(n):\n        if util.is control structure(current): return true\n      if util. get scopem analysis results(sscopem.get root node()) != null and\n          not util. get scopem analysis results(sscopem.get root node()).get escaped Qualified names().containts(qname): return false\n  return infered;\n}",
