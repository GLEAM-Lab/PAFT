    "patch_code": "private int compare(Object left, Object right) {\n    \n    left = reduce(left);\n    right = reduce(right);\n\n    if (left instanceof Number && right instanceof Number) {\n        \n        double dLeft = ((Number) left).doubleValue();\n        double dRight = ((Number) right).doubleValue();\n        \n        if (Double.isNaN(dLeft)) {\n            if (Double.isNaN(dRight)) {\n                \n                return 0;\n            } else {\n                \n                return -1;\n            }\n        } else if (Double.isNaN(dRight)){\n            \n            return 1;\n        } else {\n            if (dLeft < dRight) {\n                \n                return -1;\n            } else if (dLeft == dRight){\n                \n                return 0;\n            }else{\n                \n                return 1;\n            }\n        }\n    } \n    \n    throw new ClassCastException(\"Unhandled comparison between \" + left.getClass() + \", \" + right.getClass());\n}",
