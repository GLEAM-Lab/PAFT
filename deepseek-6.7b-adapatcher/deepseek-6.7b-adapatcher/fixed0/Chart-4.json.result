    "patch_code": "public Range getData range(ValueAxis axes) {\n\n    Range result = null;\n    List mappeddatasets = newArrayList();\n    boolean is domainAxis = true;\n\n    int domainindex = get domainAxis index(axes);\n    if ( domainindex>= 0) {\n        is domainAxis = true;\n        mappeddatasets. addAll(get datasets mapped to domainAxis(new int[ domainindex])) ;\n    }\n\n    int rangeindex = get rangeAxis index(axes);\n    if ( rangeindex>= 0) {\n        is domainAxis = false;\n        mappeddatasets. addAll(get datasets mapped to rangeAxis(new int[ rangeindex])) ;\n    }\n\n    Iterator iterator = mappeddatasets. iterator();\n    while ( iterator. hasNext()) {\n        XY datatSet = (XY datatSet) iterator. next();\n        if ( datatSet != null) {\n            Xy itemRenderer = get rend\u5668For datatSet(datatSet);\n            if (is domainAxis) {\n                if (itemRenderer != null) {\n                    result = range.Combine(result, itemRenderer. find domainBounds(datatSet)) ;\n                }\n                else {\n                    result = range.Combine(result, datatSet. find domainBounds()) ;\n                }\n            }\n            else {\n                if (itemRenderer != null) {\n                    result = range.Combine(result, itemRenderer. find rangeBounds(datatSet)) ;\n                }\n                else {\n                    result = range.Combine(result, datatSet. find rangeBounds()) ;\n                }\n            }\n        }\n    }\n\n    return result;\n\n}",
