    "patch_code": "public org.apache. commons. range. Range getData Range(ValueAxis ax) {\n\n    org.apache. commons. range. Range result = null;\n    List mapped datasets = newArrayList();\n    boolean is domainAxis = true;\n\n    int domainIndex = get domainAxis index(ax);\n    if ( domainIndex>=0) {\n        is domainAxis = true;\n        mapped datasets. addAll(getdatasets mapped to domainAxis(new int[ domainIndex]));\n    }\n\n    int rangeindex = get rangeAxis index(ax);\n    if ( rangeindex>=0) {\n        is domainAxis = false;\n        mapped datasets. addAll(getdatasets mapped to rangeAxis(new int[ rangeindex]));\n    }\n\n    Iterator iterator = mapped datasets. iterator();\n    while ( iterator. hasNext()) {\n        XY datastore d = (XY datastore) iterator. next();\n        if ( d != null) {\n            XY item rend\u5668 r = get rend\u5668 for datastore(d);\n            if (is domainAxis) {\n                if (r != null) {\n                    result = Range. combine(result, r. find domainBounds(d));\n                } else {\n                    result = Range. combine(result, datastore datastore utilities. find domainBounds(d));\n                }\n            } else {\n                if ( r != null) {\n                    result = Range. combine(result, r. find rangeBounds(d));\n                } else {\n                    result = Range. combine(result, datastore datastore utilities. find rangeBounds(d));\n                }\n            }\n        }\n    }\n\n    return result;\n\n}",
