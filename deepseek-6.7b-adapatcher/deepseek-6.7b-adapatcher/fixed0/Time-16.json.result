    "patch_code": "if (!chrono.hasPrecision(DateTimeConstants.year())) {\n    instant.setYears(bucket.getYear());\n}\nif (!chrono.hasPrecision(DateTimeConstants.monthOfYear())) {\n    instant.setMonths(bucket.getMonthOfYear());\n}\nif (!chrono.hasPrecision(DateTimeConstants.dayOfMonth()) ||\n    instant.compareTo(DateUtil.safeClip(bucket.toDateTime(), \n        chrono.minSupportedInstant(), chrono)) > 0) {\n    instant.setDays(bucket.getDayOfMonth());\n}\nif (!chrono.hasPrecision(DateTimeConstants.hourOfDay())) {\n    instant.setHours(bucket.getHourOfDay());\n}\nif (!chrono.hasPrecision(DateTimeConstants.minuteOfHour())) {\n    instant.setMinutes(bucket.getMinuteOfHour());\n}\nif (!chrono.hasPrecision(DateTimeConstants.secondOfMinute())) {\n    instant.setSeconds(bucket.getSecondOfMinute());\n}\nif (!chrono.hasPrecision(DateTimeConstants.millisOfSecond())) {\n    instant.setMillis(bucket.getMillisOfSecond());\n}\nreturn newPos;",
