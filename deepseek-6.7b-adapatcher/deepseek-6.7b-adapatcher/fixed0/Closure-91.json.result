    "patch_code": "import com.sun.tools.javac.util.Context;\nimport javax.lang.model.element.ElementKind;\nimport javax.lang.model.element.VariableElement;\nimport org.checkerframework.checker.nullness.qual.Nullable;\n\npublic class CheckGlobalThis extends AbstractScanner4 {\n\n  private final Context context;\n  public @Nullable VariableElement lastFieldOrMethodElement;\n\n  CheckGlobalThis(Context context) {\n    super(context);\n    this.context = context;\n  }\n\n  @Override\n  protected void process(Token t, boolean atStart) {\n    if ((t.toString().equals(\"foo\") || t.toString().equals(\"bar\")) &&\n        lastFieldOrMethodElement != null &&\n        lastFieldOrMethodElement.getEnclosingElement().getKind() == ElementKind.CLASS) {\n      context.report(Diagnostic.Kind.ERROR, \"\", t);\n    }\n  }\n\n  @Override\n  protected boolean shouldProcess(Token t) {\n    if (t instanceof Name) {\n      String name = t.toString();\n      if (\"class\".equals(name) || \"function\".equals(name)) {\n        return true;\n      }\n    }\n    if (lastFieldOrMethodElement != null &&\n        lastFieldOrMethodElement.getKind() == ElementKind.METHOD) {\n      return !\"extends\".equals(t.toString()) &&\n          !\"@constructor\".equals(t.toString());\n    }\n    return false;\n  }\n\n  @Override\n  protected void postProcess(Token t) {\n    if (\"@\".equals(t.toString())) {\n      tokenizer.advance();\n      if (\"lends\".equals(tokenizer.currentToken().toString())) {\n        tokenizer.advance();\n        while (shouldProcess(tokenizer.currentToken())) {\n          process(tokenizer.currentToken(), true /*at start*/);\n          tokenizer.advance();\n        }\n      }\n    }\n  }\n}",
