    "patch_code": "public boolean shouldTraverse(NodeTraversal t, Node n, Node parent) {\n  if (n.getType() == Token.FUNCTION) {\n    JSDocInfo jsdoc = n.getJsDoc();\n    if (jsdoc != null && (jsdoc.hasAnnotationWithName(\"constructor\") || \n                           jsdoc.hasAnnotationWithName(\"interface\") || \n                           jsdoc.hasAnnotationWithName(\"this\") || \n                           jsdoc.hasAnnotationWithName(\"override\"))){\n      return false;\n    }\n    \n    int pType = parent.getType();\n    if (!((pType == Token.STATEMENT_LIST)||\n          ((pType == Token.OBJECT_LITERAL)&&(\n          \t\t(parent.getFlags() & Node.FLAG_CONSTRUCTOR_CALL)!= 0))) ){\n      return false;\n    }\n      \n    if(!(n instanceof FunctionExpression)){\n    \treturn false;\n    }\n  }else if(n.getType()==Token.METHODDEFINITION){\n    String name =  n.getName();\n    if( (name.equalsIgnoreCase(\"toString\"))  ||\n        (name.equalsIgnoreCase(\"valueOf\"))){\n      return false;\n    }\n  }\n\n  if( parent!=null){\n    switch(parent.getType())\n    {\n    case Token.ANONYMOUS_FUNCTIONEXPRESSION : \n    case Token.ARROWFUNCTIONEXPRESSION : \n    case Token.RETURN : \n    case Token.FORIN : \n    case Token.WHILE : \n    case Token.DO :\n    case Token.IF : \n    case Token.ELSE :\n    case Token.SWITCH :\n    case Token.TRY : \n    case Token.WITH :return false ;\n    default : break;\n    }\n\n  }\n  return true;\n}",
