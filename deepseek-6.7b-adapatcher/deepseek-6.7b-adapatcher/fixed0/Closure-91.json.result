    "patch_code": "public boolean should Traverse(Node Traversal t, node n, node parent) {\n\n  if (n.get Type () == Token.FUNction) {\n    // Don's traverse functions that are constructors or have the @lends annotation\n    JSDoc info = get functionjsdocinfo(n);\n    if (info !=  null &&\n        (info.is Constructor() || info. has lends)) {\n      return false;\n    }\n\n    int p type = parent.get type();\n    if !(p type == Token. block or\n          p type == Token. script or\n          p type == Token. name or\n          p type == Token. Assign or\n\n          p type == Token. String or\n          p type == Token. number or\n          p type == Token. GETPROP) {\n      return false;\n    }\n\n    if (parent !=  null && parent. get type() == Token. Assign) {\n      node lht = parent. get firstchild();\n      node rht = lht. get next();\n\n      if (n == lht) {\n        // traverse left side of assignments only\n        if (assignedLHT == null) {\n          usedLHT = lht;\n        }\n        return false;\n      } else {\n        // only traverse right side of assignments where it would normaly be able to have an @lends annotation associated with them. e.g.,\n        if (node util. is Get(lht)) {\n          if (lht. get type() == Token. GETPROP and\n              lht. get lastchild(). string(). endswith(\" prototype)) {\n            return false;\n          }\n          node llht = lht. get firstchild();\n          if (llht. get type() == Token. GETPROP and llht. get lastchild(). string(). endswith(\" prototype)) {\n            return false;\n          }\n        }\n      }\n    }\n\n    return true;\n  }\n};",
