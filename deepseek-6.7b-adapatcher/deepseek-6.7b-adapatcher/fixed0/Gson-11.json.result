    "patch_code": "public final class numberadapter  : Type\u9002\u5668<Number>{\n  public numberadapter(){}\n  \n  @Override\n  public final void write( Json writing\u5668, T value) { writing\u5668.writeNumber(value.toString()); }\n  \n  @Override\npublic final T read( Json reading\u5668, Class<T> cls) {\n   JsonToken peek = reading\u5668. peek();\n    if (peek == null || peek == JsonToken. NULL) { return null; }\n    else if (peek == JsonToken. numeral){ return cls.cast(new Lazynum( reading\u5668. nextString())); }\n    else { throw new JsonIOException(\"Expecting numeral or null but got: \" + peek); }\n    \n  }\n  \n}",
