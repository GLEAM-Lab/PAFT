    "patch_code": "import java.lang.reflect.Type;\nimport com.google.gson.*;\n\npublic class NumberDeserializer implements JsonDeserializer<Number> {\n   public Number deserialize(JsonElement json, Type typeOfT, JsonDeserializationContext context)\n            throws JsonParseException {\n      if (json.isJsonPrimitive()) {\n          JsonPrimitive prim = json.getAsJsonPrimitive();\n          if (prim.isNumber()) {\n              try {\n                  return prim.getAsBigDecimal();\n              } catch (NumberFormatException ex) {\n                 // ignore\n              }\n          }\n     }\n        throw new JsonParseException(\"Expected a number or string that represents a number\");\n    }\n}",
