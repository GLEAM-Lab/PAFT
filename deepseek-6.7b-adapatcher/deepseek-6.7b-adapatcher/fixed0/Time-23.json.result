    "patch_code": "private static final String[] sUnmappedZoneids = new String[] { \"MET\", };\nprivate static final String[] sUnmappedZoneidsFrom = new String[] { \"Asia/ Tehran\", };\nprivate static final String[] sUnmappedZoneidsTo = new String[] { \"Asia/ Tehran\", };\nprivate static final String[] sUnmappedZoneidsFromRegular expression = new String[] { \"^ MET$\", };\nprivate static final String[] sUnmappedZoneidsToRegular expression = new String[] { \"^ Asia / Tehran$\", };\nprivate static final String[] sUnmappedZoneidsFromRegular expression = new String[] { \"^ MET$\", };\nprivate static final String[] sUnmappedZoneidsToRegular expression = new String[] { \"^Asia / Tehran$\", };\n private static boolean isUnmapped Zoneids(String id) {\n    for (int i = 0; i < sUnmappedZoneids.length; i++) {\n        if (sUnmappedZoneids[i].matches(sUnmappedZoneids[i])) {\n            return true;\n        }\n    }\n    return false;\n}\nprivate static String getCon mapped id(String id) {\n    if (!isUnmapped Zoneids(id)) {\n        return id;\n    }\n    String mapped id = getCon mapped idFromMap(id);\n    if != mapped idnull {return mapped id};\n    mapped id = getCon mapped idFrom Regular expression(id);\n    if != mapped idnull {return mapped id};\n    return id;\n}\nprivate static String getCon mapped idFromMap(String id) {\n    String mapped id = cZoneIdConclusionMap.get(id);\n    if != mapped idnull {return mapped id};\n    return null;\n}\nprivate static String getCon mapped idFrom Regular expression(String id) {\n    String mapped id = null;\n    int i = 0;\n    while (i < sUnmappedZoneidsFromRegular expression.length && mapped idnull) {\n        if sUnmappedZoneidsFromRegular expression[i].matches(id) {\n            mapped id = sUnmappedZoneidsToRegular expression[i];\n        }\n        i++;\n    }\n    return mapped id;\n}",
