    "patch_code": "public class Main {\n    \n    public static void main(String[] args){\n       System.out.println(getTimeZone(\"MET\"));\n    }\n\n\n\n\n\n\n\n\n    private static String getConvertedId(String id) {\n        \n        String map=\"\";\n      if (id==\"GMT\"){\n          map=\"UTC\";\n          \n      } else if (id==\"MIT\"){\n          map=\"Pacific/Apia\";\n          \n      }else if (id==\"HST\"){\n          map=\"Pacific/Honolulu\";  \n          \n      }else if (id==\"AST\"){\n          map=\"America/Anchorage\";\n          \n      }else if (id==\"PST\"){\n          map=\"America/Los_Angeles\";\n          \n      }else if (id==\"MST\"){\n          map=\"America/Denver\";  \n          \n      }else if (id==\"PNT\"){\n          map=\"America/Phoenix\";\n          \n      }else if (id==\"CST\"){\n          map=\"America/Chicago\";\n          \n      }else if (id==\"EST\"){\n          map=\"America/New_York\";  \n          \n      }else if (id==\"IET\"){\n          map=\"America/Indianapolis\";\n          \n      }else if (id==\"PRT\"){\n          map=\"America/Puerto_Rico\";\n          \n      }else if (id==\"CNT\"){\n          map=\"America/St_Johns\";\n          \n      }else if (id==\"AGT\"){\n          map=\"America/Buenos_Aires\";\n          \n      }else if (id==\"BET\"){\n          map=\"America/Sao_Paulo\";\n          \n      }else if (id==\"WET\"){\n          map=\"Europe/London\";\n          \n      }else if (id==\"ECT\"){\n          map=\"Europe/Paris\";\n          \n      }else if (id==\"ART\"){\n          map=\"Africa/Cairo\";\n          \n      }else if (id==\"CAT\"){\n          map=\"Africa/Harare\";\n          \n      }else if (id==\"EET\"){\n          map=\"Europe/Bucharest\";\n          \n      }else if (id==\"EAT\"){\n          map=\"Africa/Addis_Ababa\";\n          \n      }else if (id==\"MET\"){\n          map=\"Europe/Minsk\";\n          \n      }else if (id==\"NET\"){\n          map=\"Asia/Yerevan\";\n          \n      }else if (id==\"PLT\"){\n          map=\"Asia/Karachi\";\n          \n      }else if (id==\"IST\"){\n          map=\"Asia/Calcutta\";\n          \n      }else if (id==\"BST\"){\n          map=\"Asia/Dhaka\";\n          \n      }else if (id==\"VST\"){\n          map=\"Asia/Saigon\";\n          \n      }else if (id==\"CTT\"){\n          map=\"Asia/Shanghai\";\n          \n      }else if (id==\"JST\"){\n          map=\"Asia/Tokyo\";\n          \n      }else if (id==\"ACT\"){\n          map=\"Australia/Darwin\";\n          \n      }else if (id==\"AET\"){\n          map=\"Australia/Sydney\";\n          \n      }else if (id==\"SST\"){\n          map=\"Pacific/Guadalcanal\";\n          \n      }else if (id==\"NST\"){\n          map=\"Pacific/Auckland\";\n          \n      }\n        return map;\n    }\n    \n    public static String getTimeZone(String id){\n        String maptz = getConvertedId(id);\n        if(!maptz.isEmpty() && !maptz.equalsIgnoreCase(id)){\n            return maptz;\n        }\n        \n        return id;\n    }\n}",
