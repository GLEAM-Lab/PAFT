    "patch_code": "@Override\n    public JsonDeserializer<Object> create beanDeserializer(DeserializationContext c txt,\n            java type, bean description beanDesc)\n        throwmappingException\n    {\n        final deserialization config = c txt. getConfig();\n        // we may also have custom overrides:\n        JsonDeserializer<Object> custom = _find custom bean deserializer (type, config, beanDesc);\n        if ( custom !=  null) {\n            return custom;\n        }\n        /* one more thing to check: does it have an exception type\n         * (Throwable or its sub- classes)? If yes, it needs slightly\n         * different re- (build throwable deserializer)\n         */\n        if type. is throwable () {\n            return build throwable deserializer (ctxt, type, beanDesc);\n        }\n        /* or, for Abstract types, may have alternate means for resolution\n         * (defaulting, materialization)\n         */\n        // 29- Supported types are not supported by default (defaulting, materialization)\n        if type. is Abstract () && !type. is primitive () && !type. is Enum type () {\n            // let's make it possible to materialize Abstract types.\n            java typeconcrete = materialize Abstract type (ctxt, type, beanDesc);\n            if (concrete type !=  null) {\n                beanDesc = config. introspect (concrete type);\n                return build bean deserializer (ctxt, Typeconcrete, beanDesc);\n            }\n        }\n        // otherwise, maybe it's a bean class? if not, bail out\n        if !is potential bean type (type. get Raw Class()) {\n            return null;\n        }\n        // For check like [databind#1599]\n        // use introspect to build deserializer\n        return build bean deserializer (ctxt, type, beanDesc);\n    }",
