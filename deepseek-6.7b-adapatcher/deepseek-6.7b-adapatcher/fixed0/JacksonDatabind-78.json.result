    "patch_code": "public abstract class BeanDeserializer extends BaseDeserializer<Object> {\n    \n    private static final long serialVersionUID = 1L;\n    \n    protected final BeanProperty[] _properties;\n\n    /**\n     * Accessor properties used when mapping values during deserialization.\n     * Note that some fields may be null in case of MapperConfig.Feature.USE_STATIC_TYPES enabled.\n     */\n    protected final List<BeanPropertyWriter> _writers;\n\n    protected final Class<?> _beanClass;\n\n    public BeanDeserializer(JavaType srcType, Type baseType, BeanProperty[] props,\n            List<BeanPropertyWriter> writers, String msg)\n    {\n        super(srcType, baseType, msg);\n        _properties = props;\n        _writers = writers;\n        _beanClass = _baseType.getRawClass();\n    }\n\n    /*\n    /**********************************************************\n    /* Public API methods\n    /**********************************************************\n     */\n\n    @Override\n    public Object deserialize(JsonParser p, DeserializationContext ctxt)\n        throws IOException, JsonProcessingException\n    {\n        final Object beanOrArray;\n        switch (_handledType.getId()) {\n        case ARRAY:\n            beanOrArray = deserializeFromArray(p, ctxt);\n            break;\n        case OBJECT:\n        default:\n            beanOrArray = deserializeFromObject(p, ctxt);\n            break;\n        }\n        if (beanOrArray == null) {\n            return null;\n        } else if (_handledType.hasAndShouldSerializeNulls()) {\n            return beanOrArray;\n        }\n        assert _beanClass.equals(beanOrArray.getClass()) : \"Inconsistent class on deserialized object: \" + beanOrArray + \" , expected \"+_beanClass;\n        return handleNonValueInstances(_beanClass, beanOrArray, ctxt);\n    }\n}",
    "patch_status": "UNCOMPILABLE",
