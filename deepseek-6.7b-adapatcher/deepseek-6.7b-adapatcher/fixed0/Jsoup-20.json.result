    "patch_code": "static Document parseByteData(ByteBuffer byteData, String charsetName, String baseUri, Parser parser) throws IOException {\n    String docData;\n    Document doc = null;\n    if (charsetName == null) { \n        \n        docData = new BufferedReader(new InputStreamReader(new ByteArrayInputStream(byteData.array()), StandardCharsets.UTF_8)).readLine();\n      if(!docData.contains(\"/head>\")){\n          System.out.println(\"head was empty, no image sources needed.\");  \n       return new Document(\"\");\n        }else{\n          doc = Jsoup.parse(docData);\n            \n        }\n    } else { \n        \n        docData = new BufferedReader(new InputStreamReader(new ByteArrayInputStream(byteData.array()), Charset.forName(charsetName))).readLine();\n     if(!docData.contains(\"/head>\")){\n          System.out.println(\"head was empty, no image sources needed.\");  \n       return new Document(\"\");\n        }else{\n           doc =  Jsoup.parse(docData);\n        }\n       \n    } \n        return doc;\n}",
