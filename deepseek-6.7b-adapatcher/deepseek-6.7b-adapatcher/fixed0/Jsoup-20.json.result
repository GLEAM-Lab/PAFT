    "patch_code": "static boolean isHeadless( document){\n  String title = document. select(\"head title\"). first(). text();\n  return !(title. length() > 0);\n}\nstatic document removeHeadless( document){\n  document. select(\"head title\"). first(). remove();\n  return document;\n}\nstatic document fixHeadless( document){\n  if isHeadless( document){\n    removeHeadless( document);\n  }\n  return document;\n}",
