    "patch_code": "static document load(File file) {\n    document doc = null;\n    try {\n      doc = load(file.getabsPath());\n    } catch (IOException e){\n      throw new RuntimeException(e);\n    }\n    return doc;\n}\nstatic document load(String filepath) {\n    document doc = null;\n    try {\n      doc = load(new FileInputStream(filepath));\n    } catch (IOException e){\n      throw new RuntimeException(e);\n    }\n    return doc;\n}\nstatic document load(InputStream inputstream) {\n    document doc = null;\n    try {\n      doc = new document(inputstream, \"ISO8859_1\", null);\n    } catch (IOException e){\n      throw new RuntimeException(e);\n    } finally {\n      try {inputstream.close();} catch (IOException e){}\n    }\n    return doc;\n}\nstatic document get documentFromFile(String filepath) {\n    document doc = null;\n    try {\n      doc = load(new FileInputStream(filepath));\n    } catch (IOException e){\n      throw new RuntimeException(e);\n    }\n    return doc;\n}\nstatic document get documentFromFile( File file) {\n    document doc = null;\n    try {\n      doc = load(file.getabsPath());\n    } catch (IOException e){\n      throw new RuntimeException(e);\n    }\n    return doc;\n}\nstatic document get documentFromInputStream( String filepath) {\n    document doc = null;\n    try {\n      doc = load(new FileInputStream(filepath));\n    } catch (IOException e){\n      throw new RuntimeException(e);\n    }\n    return doc;\n}\nstatic document get documentFromInputStream( File file) {\n    document doc = null;\n    try {\n      doc = load(new FileInputStream(file.getabsPath()));\n    } catch (IOException e){\n      throw new RuntimeException(e);\n    }\n    return doc;\n}",
