    "patch_code": "import org.jsoup.nodes.*;\nimport java.util.*;\nimport java.io.*;\npublic class Test{\n    public static void main(String[] args) throws Exception{\n        File f = new File(\"C:/Users/user/Desktop/test.html\");//\u8def\u5f91\u6539\u70ba\u60a8\u7684HTML\u6a94\u6848\u4f4d\u7f6e\n        BufferedReader br = new BufferedReader(new FileReader(f));  \n        StringBuilder sb = new StringBuilder();  \n        String line;  \n        while ((line = br.readLine()) != null) {  \n             System.out.println(line);\n              sb.append(line);  \n         }  \n         br.close();  \n         org.jsoup.Jsoup.parse(sb.toString());\n         ArrayList<Element> linkElements = new Documment(sb.toString()).select(\"link\");\n          ArrayList<Element> scriptElements = new Document(sb.toString()).select(\"script\");\n           ArrayList<Element> headElements = new Document(sb.toString()).select(\"head\");\n            ArrayList<Element> bodyElements = new Document(sb.toString()).select(\"body\");\n             Element metaviewport = new Document(sb.toString()).select(\"meta[name=viewport]\").first();\n              Element metaauthor = new Document(sb.toString()).select(\"meta[name=author]\").first();\n               Element metadescription = new Document(sb.toString()).select(\"meta[name=description]\").first();\n                Element titleElement = new Document(sb.toString()).select(\"title\").first();\n                 Element baseElement = new Document(sb.toString()).select(\"base\").first();\n                 \n                   System.out.println(\"\\nLINK ELEMENTS:\\n\");\n                    Iterator itr_l= linkElements.iterator();\n                     while(itr_l.hasNext()){\n                          System.out.println(itr_l.next());\n                      }\n                       System.out.println(\"\\nSCRIPT ELEMENTS:\\n\");\n                        Iterator itr_s= scriptElements.iterator();\n                         while(itr_s.hasNext()){\n                              System.out.println(itr_s.next());\n                           }\n                            System.out.println(\"\\nHEAD ELEMENTS:\\n\");\n                             Iterator itr_h= headElements.iterator();\n                              while(itr_h.hasNext()){\n                                   System.out.println(itr_h.next());\n                               }\n                                 System.out.println(\"\\nBODY ELEMENTS:\\n\");\n                                  Iterator itr_b= bodyElements.iterator();\n                                   while(itr_b.hasNext()){\n                                        System.out.println(itr_b.next());\n                                     }\n                                       System.out.println(\"\\nVIEWPORT META TAG:\\n\");\n                                        System.out.println(metaviewport);\n                                         System.out.println(\"\\nAUTHOR META TAG:\\n\");\n                                          System.out.println(metaauthor);\n                                           System.out.println(\"\\nDESCRIPTION META TAG:\\n\");\n                                            System.out.println(metadescription);\n                                             System.out.println(\"\\nTITLE ELEMENT:\\n\");\n                                              System.out.println(titleElement);\n                                                System.out.println(\"\\nBASE ELEMENT:\\n\");\n                                                 System.out.println(baseElement);\n    }\n}",
