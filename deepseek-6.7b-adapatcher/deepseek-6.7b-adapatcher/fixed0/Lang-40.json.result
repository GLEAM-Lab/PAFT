    "patch_code": "public static boolean containsIgnoreCase(String str, String searchStr) {\n    if (str == null || searchStr == null) {\n        return false;\n    }\n    int i = str.length();\n    int j = searchStr.length();\n    char[] data1 = str.toCharArray();\n    char[] data2 = searchStr.toCharArray();\n    \n    for (int k = 0; k < i - j + 1; k++) {\n        int m = 0;\n        while (m < j && Character.toUpperCase(data1[k + m]) == Character.toUpperCase(data2[m])) {\n            m++;\n        }\n        if (m >= j){\n            return true;\n        }\n    }\n    return false;\n}",
