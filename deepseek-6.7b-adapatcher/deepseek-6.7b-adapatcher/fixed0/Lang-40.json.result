    "patch_code": "public class Main {\n    public static void main(String[] args) {\n        System.out.println(containsIgnoreCase(\"Hello World\", \"hello\"));\n    }\n    \n    public static boolean containsIgnoreCase(String str, String searchStr) {\n        if(str==null||searchStr==null){return false;}\n        int l1 = str.length();\n        int l2 = searchStr.length();\n        if(l2>l1){return false;}\n        char[] array1 = new char[l1];\n        char[] array2 = new char[l2]; \n        for(int i = 0 ;i<array1.length;i++){\n            array1[i]=Character.toUpperCase(str.charAt(i));\n            \n        }\n         for(int j= 0 ;j <array2.length;j++){\n               array2[j]= Character.toUpperCase(searchStr.charAt(j));\n           }\n        for (int i = 0; i <= l1 - l2; i++) {\n            \n                int k;\n                for (k = 0; k < l2; k++) {\n                    if (array1[i + k] != array2[k]) {\n                        break;\n                    }\n                }\n                 if(k==l2){\n                     return true;\n                  }  \n             \n            }\n      \n       return false;\n    }\n}",
