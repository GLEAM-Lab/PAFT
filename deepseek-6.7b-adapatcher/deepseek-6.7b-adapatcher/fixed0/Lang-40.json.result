    "patch_code": "import org.apache.commons.lang3.StringUtils; \npublic class Main {  \n      public static void main(String args[]){\n         System.out.println(containsIgnoreCase(\"Hello world\",\"hello\"));  //Return true\n         \n       }\n    \n        /**\n     * <p>Checks if a String contains another String irrespective of the case</p>\n     *\n     * @param str  the source String\n     * @param searchStr  the String to check for\n     * @return {@code true} if the target String is found in the source String, otherwise {@code false}\n     * @see java.lang.String#indexOf(java.lang.String)\n     * @since 2.4\n     */\n    public static boolean containsIgnoreCase(final CharSequence str, final CharSequence searchStr) {\n        if ((str == null) || (searchStr == null)) {\n            return (str == null) && (searchStr == null);\n        }\n        int len = searchStr.length();\n        int start = 0;\n        do {\n            int index = str.toString().indexOf(searchStr.toString(), start);\n            if (index < 0) {\n                return false;\n            }\n            start = index + len;\n        } while (start <= str.length());\n        return true;\n    }\n\n}",
