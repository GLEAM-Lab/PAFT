    "patch_code": "import org.apache.commons.lang3.*;\npublic class Main {\n  public static void main(String[] args) {\n    \n  System.out.println(containsIgnoreCase(\"Hello World\", \"he\"));\n  System.out.println(containsIgnoreCase(\"HELLO WORLD\", \"HE\"));\n  System.out.println(containsIgnoreCase(\"HELLO WORLD\", \"RE\"));\n  \n}\n  public static boolean containsIgnoreCase(String s1, String s2){\n           if(!s1.isEmpty()&&!s2.isEmpty()) {              \n            int i =0;\n              while (i+s2.length()<=s1.length()){\n                String sub = s1.substring(i,i+s2.length());      \n                 if(sub.equalsIgnoreCase(s2)) {        \n                     return true;\n                   } else {\n                      i++;\n                 }\n             }\n         } else{\n            return !\"\".equals(s1);\n          }\n          return false;\n      }\n}",
