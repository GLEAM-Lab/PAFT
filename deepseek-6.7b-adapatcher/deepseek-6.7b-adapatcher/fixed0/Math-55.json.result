    "patch_code": "import java.lang.Math;\n\npublic class Main {\n  public static void main(String[] args) {\n    Vector3D v1 = new Vector3D(9070467121.0, 4535233560.0, 1);\n    Vector3D v2 = new Vector3D(9070467123.0, 4535233561.0, 1);\n    \n    Vector3D cross = crossProduct(v1, v2);\n    \n    System.out.println(\"{\" + cross.getX() + \", \" + cross.getY() + \", \" + cross.getZ() + \"}\");\n  }\n  \n  public static Vector3D crossProduct(final Vector3D v1, final Vector3D v2) {\n      \n      double absX = Math.abs(v1.getX());\n      double absY = Math.abs(v1.getY());\n      double absZ = Math.abs(v1.getZ());\n      \n      int signX = 1;\n      int signY = 1;\n      int signZ = 1;\n      \n      if (absX < absY && absX < absZ) {\n          signX *= -1;\n      } else if (absY < absZ) {\n          signY *= -1;\n      } else {\n          signZ *= -1;\n      }\n      \n      double x = v1.getY() * v2.getZ() - v1.getZ() * v2.getY();\n      double y = v1.getZ() * v2.getX() - v1.getX() * v2.getZ();\n      double z = v1.getX() * v2.getY() - v1.getY() * v2.getX();\n      \n      return new Vector3D(signX * x, signY * y, signZ * z);\n  }\n  \n  private static class Vector3D {\n    private double x;\n    private double y;\n    private double z;\n\n    public Vector3D(double x, double y, double z) {\n      this.x = x;\n      this.y = y;\n      this.z = z;\n    }\n\n    public double getX() {\n      return x;\n    }\n\n    public double getY() {\n      return y;\n    }\n\n    public double getZ() {\n      return z;\n    }\n  }\n}",
