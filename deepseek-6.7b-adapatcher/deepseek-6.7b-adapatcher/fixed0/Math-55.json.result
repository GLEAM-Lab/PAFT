    "patch_code": "import java.lang.Math;\npublic static Vector3D crossProduct(final Vector3D v1, final Vector3D v2) {\ndouble x=v1.getX(),y=v1.getY(),z=v1.getZ();\n    double x0=v2.getX(),y0=v2.getY(),z0=v2.getZ();\n    \n    double rho = 0.5+0.5*((x*x0 + y*y0)/(x0*x00+y0*y0+z0*z0)-1e-7);\n    \n    Vector3D vs=new Vector3D(-rho*x0,-rho*y0,-rho*z0);\n    \n    return Vector3D.add(vs,v2).rotateX(y*z0,x*z-y*x0,y*y0).subtract(v1);\n}",
