    "patch_code": "import java.lang.*;\npublic class Main {\n   public static void main(String[] args){\n      Vector3D v1=new Vector3D(9070467121.0, 4535233560.0, 1);\n      Vector3D v2=new Vector3D(9070467123.0, 4535233561.0, 1);\n      Vector3D c;\n      c= Vector3D.subtract(v1, Vector3D.multiply(v2,Vector3D.dotProduct(v1,v2)/Vector3D.normSquared(v2)));\n     System.out.print(\"{ \");\n     System.out.printf(\"%+e\",c.getX());\n     System.out.print(\",\");\n     System.out.printf(\"%+e\",c.getY());\n     System.out.print(\",\");\n     System.out.printf(\"%+e\",c.getZ());\n     System.out.print(\" }\\n\");\n   }\n}\nclass Vector3D{\n   private double x;\n   private double y;\n   private double z;\n   public Vector3D(double xx, double yy, double zz){\n      this.x =xx;\n      this.y =yy;\n      this.z =zz;\n   }\n   public double getX(){\n      return x;\n   }\n   public double getY(){\n      return y;\n   }\n   public double getZ(){\n      return z;\n   }\n\n   /**\n    * Add two vectors\n    */\n   public static Vector3D add(Vector3D a, Vector3D b){\n      return new Vector3D(a.x +b.x , a.y +b.y , a.z +b.z);\n   }\n\n   /**\n    * Multiply vector by scalar s\n    */\n   public static Vector3D multiply(Vector3D v, double s){\n      return new Vector3D(v.x*s , v.y*s , v.z*s);\n   }\n\n   /**\n    * Dot product between two vectors\n    */\n   public static double dotProduct(Vector3D a, Vector3D b){\n      return a.x*b.x +a.y*b.y +a.z*b.z ;\n   }\n\n   /**\n    * Norm squared of vector\n    */\n   public static double normSquared(Vector3D v){\n      return dotProduct(v,v);\n   }\n\n   /**\n    * Subtract vector b from a\n    */\n   public static Vector3D subtract(Vector3D a, Vector3D b){\n      return add(a,multiply(b,-1));\n   }\n}",
