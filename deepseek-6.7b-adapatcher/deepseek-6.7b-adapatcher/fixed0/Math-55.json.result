    "patch_code": "public static final double EPS = 1e-8;\n\npublic static boolean equalWithinepsilon( double a, double b ) {\n return a < b + EPS && a > b - EPS;\n}\n\npublic static boolean almost equal( double a, double b ) {\n return equalWithinepsilon(a, b) || equalWithinepsilon(b, a) ;\n}\n\npublic static boolean almost equal( double[] array ) {\n double first = array[0];\n for( int i = 1 ; i < array.length ; i++ ) {\n if !( almost equal(first, array[i]) ) return false;\n }\n return true;\n}\n\npublic static void main( String[] arg ) {\n double[] array = new double[] {9070467121.0, 4535233560.0, 1};\n double[] array2 = new double[] {9070467123.0, 4535233561.0, 1};\n if !( almost equal(array2) ) {\n array[2] = array[0] * array2[1 - 2] - array[1] * array2[0];\n }\n System.out.print(array[0], array[1], array[2].toString());\n}",
