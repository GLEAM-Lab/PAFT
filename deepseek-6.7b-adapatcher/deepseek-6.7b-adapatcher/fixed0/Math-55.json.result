    "patch_code": "import org.apache.commons.math3.util.*;\nimport java.lang.Math;\n\npublic static Vector3D crossProduct(final Vector3D v1, final Vector3D v2) {\n    \n    double x = v1.getX();\n    double y = v1.getY();\n    double z = v1.getZ();\n    \n    double tx = v2.getX();\n    double ty = v2.getY();\n    double tz = v2.getZ();\n\n  \tdouble absx = Math.abs(x);\n  \tdouble absy = Math.abs(y);\n  \tdouble absz = Math.abs(z);\n\n\t// estimate rho without loss of precision\n\tdouble ax = Decimal64.valueOf(absx).rounded();\n\tdouble ay = Decimal64.valueOf(absy).rounded();\n\tdouble az = Decimal64.valueOf(absz).rounded();\n\t\n\tdouble mn = Math.min(ax*ay, Math.min(ax*az, ay*az));\n\tdouble pwr = Double.longBitsToDouble(((Decimal64) Double.doubleToLongBits(mn)).round());\n\t\n\tdouble st = 1 + pwr;\n\tst *= st;\n\t\n\tdouble rhx = ax * st;\n\tdouble rhy = ay * st;\n\tdouble rhz = az * st;\n\t\t\n\tdouble dpdxa_bya_bza = ax*(rhx/(Double.longBitsToDouble(((Decimal64)Double.doubleToLongBits(rhx*rhx + rhy*rhy + rhz*rhz)).round())))/pwr;\n    \n    return new Vector3D(ty*dpdxa_bya_bza - tz*(rhx*tpdy_bpzz),tz*(rhx*tdpx_bpzz) - tx*(rhx*tpdy_bpzz),tx*(rhx*tpx_bpy)) ;\n}",
