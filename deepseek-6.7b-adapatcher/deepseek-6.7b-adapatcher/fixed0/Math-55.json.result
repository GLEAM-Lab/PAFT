    "patch_code": "public static final double EPS = 1e-12;\n...\nprivate static double divSafe( double numerator, double denom ) {\n    double div = numerator / denom;\n    if (denom != 0 && div * denom < EPS * (denom + numerator)) {\n        return EPS * denom + numerator;\n    } else {\n        return div;\n    }\n}\n...\npublic static final double EPS = 1e-12;\n...\npublic static vector3D cross product( vector3D v1, vector3D v2 ) {\n    double x = div safe(v1.y * v2.z - v1.z * v2.y, v2.z * v2.z);\n    double y = div safe(v1.z * v2.x - v1.x * v2.z, v2.x * v2.x);\n    double z = div safe(v1.x * v2.y - v1.y * v2.x, v2.y * v2.y);\n    return new vector3D(x, y, z);\n}\n...\npublic static vector3D cross product( vector3D v1, vector3D v2 ) {\n    double x = div safe(v1.y * v2.z - v1.z * v2.y, v2.z * v2.z + EPS);\n    double y = div safe(v1.z * v2.x - v1.x * v2.z, v2.x * v2.x + EPS);\n    double z = div safe(v1.x * v2.y - v1.y * v2.x, v2.y * v2.y + EPS);\n    return new vector3D(x, y, z);\n}\n...",
