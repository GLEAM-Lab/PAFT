    "patch_code": "@SuppressW warnings(\"derecation\")\n    public void process(Class<?> context, Object testClass) {\n        fields = context.get Declared fields;\n        for (Field field : fields) {\n            if (field.is annotation present(S spy.class)) {\n                assert No annotations (S spy.class, field, Mock.class, org. MockanoAnations. Mock.class, captor.class);\n                boolean was accessible = field. is accessible();\n                field. set accessible(true);\n                try {\n                    Object instance = field. get(test class);\n                    if ( instance == null) {\n                        throw new Mockido exception(\" cannot create @S spy for '\" + field. get name() + '\" +\n                            \" The instance must be created before init Mocks\uff1b\" +\n                            \" example of correctusage of @S spy:\" +\n                            \" @S spy list l = new Linked list ;\" +\n                            \" ... init Mocks\uff1b\" +\n                            \" ... set up your test here ;\" +\n                            \" And you can also use spy on existing object - no new keyword required ;\" +\n                            \"\n                                continue;\n                    }\n                    if (new Mock util () . is Mock( instance)) {\n                        // instance has been spy earlier\n                        Mockado.Reset( instance);\n                    } else {\n                        field. set(test class, Mockado. spy( instance));\n                    }\n                } catch (Illegally access exception e) {\n                    throw new Mockido exception(\" problems initializing spied field \" + field. get name(), e);\n                } finally {\n                    field. set accessible(was accessible);\n                }\n            }\n        }\n    }",
