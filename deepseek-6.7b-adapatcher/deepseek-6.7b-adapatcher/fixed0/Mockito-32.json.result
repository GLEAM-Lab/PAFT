    "patch_code": "@SuppressWarnings({ \"rawtypes\", \"unchecked\" })\npublic <T> T mock(Class<T> clazz) {\n    ClassLoader classloader = Thread.currentThread().getContextClassLoader();\n    MockSettings settings = new MockSettings(configurableModeFor(clazz), noOpAdditionalInterfacesFor(clazz));\n    if (!settings.isMockCreationEnabled()) {\n        failBecauseOfConfiguration(\"Unable to create mock using Mockito for class: \" + clazz);\n    }\n    \n    // Create Proxy or spy based on settings.\n    final Object result;\n    if ((result = createMockOrNullProxyBasedOnSettingsAndConfigs(clazz, settings)) != null) {\n        return (T) result;\n    }\n    checkNotClosed(session, sessionOpenMarker, \"An attempt was made to reuse the Mockito Session.\");\n    \n    // Checking for interface types is necessary as Mockito mocks implement all their interfaces, even those which do not exist in the actual class hierarchy.\n    if (clazz.isInterface()) {\n        MockitoSession activeMockitoSession = getActiveMockitoSession(session);\n        if (activeMockitoSession.hasRegisteredMockFor(clazz)) {\n            return (T) activeMockitoSession.registeredMocksByType().get(clazz);\n        }\n        \n        MockTypeFactory factory = new MockTypeFactory(typeErasureResolver());\n        Class<?> mockType = factory.createStubOrSpyFor(clazz);\n        if (!clazz.equals(mockType)) {\n            // If we found another class from which a proxy should be created - delegate to that one.\n            return mock(mockType);\n        }\n        \n        addRegisteredMockToCurrentSessionIfPossible(session, typeErasureResolver().resolveRawType(clazz), result);\n        return (T) result;\n    }\n    assertMockCreationIsAllowedFor(clazz, settings);\n    \n    final StubbingRecorder<T> record = recordingStubbingOf(mock(clazz));\n    ...\n}",
