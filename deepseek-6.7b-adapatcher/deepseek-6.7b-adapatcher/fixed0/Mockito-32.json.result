    "patch_code": "@SuppressW warnings(\"derecation\")\npublic void process(Class<?> context, Object testClass) {\n    fields = context.get declared fields();\n    for (Field field : fields) {\n        if (field. is annotatedWith(S spy.class)) {\n            assert no annotations(S spy.class, field, Mock.class, org. Mockano.class, captor.class);\n            boolean was accessible = field. is accessible();\n            field. set accessible(true);\n            try {\n                object instance = field. get(test class);\n                if (null == instance) {\n                    throw new MockinoException(\" cannot create @ spy for '\" + field. get name() +' field because instance is missing\n                    return;\n                }\n                if (new Mockutil(). is Mock( instance)) {\n                    Mockado.Reset( instance);\n                    continue;\n                }\n                field. set(test class, Mockado. spy( instance);\n            } catch (Il legal access exception e) {\n                throw new MockinoException(\" Problems initializing spy field \" + field. get name(), e);\n            } finally {\n                field. set accessible(was accessible);\n            }\n        }\n    }\n}",
