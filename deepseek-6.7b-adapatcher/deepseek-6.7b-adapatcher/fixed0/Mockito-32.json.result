    "patch_code": "@SuppressW warnings(\"derecation\")\n    public void process(Class<?> context, Object testClass) {\n        field[] fields = context.get declared fields();\n        for (field field : fields) {\n            boolean was accessible = field.is accessible();\n            field. set accessible(true);\n            try {\n                Object instance = field. get(testClass);\n                if (null != instance && !new MockUtil(). is Mock( instance)) { \n                    field. set(testClass, Mockido. spy( instance));\n                }\n            } catch (Il legal access exception e) {\n                throw new Mockido exception(\" problems initializing spied field \" + field. getName(), e);\n            } finally {\n                field. set accessible(was accessible);\n            }\n        }\n    }",
