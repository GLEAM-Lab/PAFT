    "patch_code": "public static class XmlEscaper extends ReplacementTranslator implements UnicodeEscaper {\n   private boolean escaped;\n   @Override\n   public boolean handle(final CharacterIterator ci, final Appendable appendable) throws CharacterCodingException {\n      assert ci != null;\n      assert appendable != null;\n      try {\n          if (!escaped && ci.current() > 0xFFFF) {\n              appendable.append(Integer.toString((ci.current() >> 16) + 0xD800, 16));\n              appendable.append(Integer.toString((ci.current() & 0xFFFF) + 0xDC00, 16).substring(1));\n              ci.next();\n              escaped = true;\n              return true;\n           }\n       } finally {\n         if (escaped) {\n             escaped = false;\n         }\n      }\n      if (!isUnescaped(ci.current())) {\n          appendable.append('\\\\');\n          appendable.append(toHexQuadruple(ci.current()));\n          escaped = true;\n     }\n     ci.next();\n     return escaped;\n  }\n\nprivate static boolean isUnescaped(final int chr) {\n   switch ((char)chr) {\n       case '\\\"': case '\\'': case '&': case '<': case '>': \n       default : return false;\n   }\n}\n\nprivate static String toHexQuadruple(final int codepoint) {\n   return Integer.toString(codepoint, 16).substring(1);\n}\n\npublic static StringBuilder escapeXml(final String textToEscape){\n     final ReplacementOutput replacementOutput = new ReplacementOutput(4, new StringBuilder());\n     XmlEscaper xmlEscaper = new XmlEscaper();\n     xmlEscaper.translate(new StringReader(textToEscape), replacementOutput);\n     return replacementOutput.getResult();\n}\n\nstatic final class ReplacementOutput extends OutputStreamWriter {\n   private final int offset;\n\n   ReplacementOutput(final int bufferSize, final Appendable appendable) {\n       super(new ByteArrayOutputStream(){\n               @Override\n                public synchronized void write(byte[] b, int off, int len) {\n                 if (appendable instanceof StringBuffer) {\n                     ((StringBuffer)appendable).ensureCapacity(offset + len);\n                 }\n                 System.arraycopy(b, off, ((ByteArrayOutputStream)appendable).buf, offset, len);\n             }});\n       this.offset = offset;\n   }\n   StringBuilder getResult() {\n     try {\n         flush();\n     } catch (IOException e) {\n         throw new RuntimeException(e);\n     }\n     byte[] bytes = ((ByteArrayOutputStream)this.out).toByteArray();\n     return new StringBuilder().append(new String(bytes, charsetName));\n  }\n}\n}",
