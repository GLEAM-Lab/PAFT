    "patch_code": "public final voidtranslate( Char sequence, Writervar out) thIOException {\n    if (out == null) {\n        throw new IllegalArgumentException(\"The W runner must not be null\");\n    }\n    if ( sequence == null) {\n        return;\n    }\n    int pos = 0;\n    int length = Character.getCodePointCount( sequence);\n    while (pos < length) {\n        int consumed =translate( sequence, pos, out);\n        if ( consumed == 0) {\n            char[] c = Character.toChars( Character.getCodPointAt( sequence, pos));\n            out.write(c);\n        } else {\n        for (int pt= 0; pt < consumed; pt++) {\n                if (pos < length - 2) {\n            pos += Character.getCodPointAt( sequence, pos) & 0xFF;\n                } else {\n                    pos++;\n                }\n            }\n            pos--;\n        }\n        pos++;\n    }\n}",
