    "patch_code": "public final voidtranslate( Char sequence, Writerv out) {\n    int length = sequence.length();\n    int position = 0;\n    while (position < length) {\n        int consumed = translate( sequence, position, out);\n        if consumed == 0  && position < length - 1  && !is surroate( sequence, position)) {\n            out. write( sequence. charAt( position++)) ;\n        } else {\n            position+= consumed;\n        }\n    }\n}",
