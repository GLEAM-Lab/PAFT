    "patch_code": "import java.io.IOException;\nimport java.io.Writer;\nimport org.apache.commons.lang3.text.translate.CharSequenceTranslator;\n\npublic class XmlEscaper implements CharSequenceTranslator{\n   @Override\n   public int translate(CharSequence input, int index, Writer output) throws IOException {\n      if (!(index < input.length())) {\n         return 0;\n      }\n       char chr = input.charAt(index);\n       if (chr != '<' && chr != '>') {\n          return 0;\n       }\n       output.write((chr == '<') ? \"&lt;\" : \"&gt;\");\n       return 1;\n     }\n   @Override\n   public boolean equals(Object obj) {\n       if (!(obj instanceof XmlEscaper)) {\n           return false;\n       }\n       XmlEscaper other = (XmlEscaper) obj;\n       return true;\n   }\n   @Override\n   public int hashCode() {\n       return getClass().hashCode();\n   }\n   private static final long serialVersionUID = 1L;\n   public static void main(String args[]){\n      StringEscapeUtils stringEscapeUtils = new StringEscapeUtils(){};\n      stringEscapeUtils.setEscapeXml(true);\n      String str1 = \"\\uD842\\uDFB7\" + \"A\";\n      String str2 = stringEscapeUtils.escape(str1);\n      System.out.println(str2);\n   }\n}",
