    "patch_code": "public static String utfEncode(String source) {  \n    StringBuilder result = new StringBuilder();  \n    for (int i = 0; i < source.length(); i++){  \n         char ch = source.charAt(i);  \n         if ((ch >= '\\u0000' && ch <='\\u0008') || (ch >= '\\u000e' && ch <= '\\u007f') || (ch >= '\\u2000' && ch <= '\\ufffd')){  \n             result.append('\\\\');  \n             switch (ch) {  \n                 case '\\\"':  \n                     result.append(\"quot\");  \n                     break;  \n                 case '\\'':  \n                     result.append(\"apos\");  \n                     break;  \n                 default:  \n                     result.appendFormat(\"%04X\", (int) ch);  \n                     break;  \n             }  \n         }else{  \n             result.append(ch);  \n         }  \n     }  \n     return result.toString();  \n }",
