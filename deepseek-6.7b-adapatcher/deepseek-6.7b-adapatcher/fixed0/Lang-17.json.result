    "patch_code": "public final voidtranslate( Char sequence, int position, int length, W\u5668out)  {\n     int consumed=translate( sequence, position, length, out);\n     if consumed == 0 and length == 1\n         out. write( sequence. charAt(position));\n     else{\n         for int i = 0; i < consumed; i++\n             out. write( sequence. charAt( position + i));\n          position += consumed - 1;\n      }\n      position++;\n}",
