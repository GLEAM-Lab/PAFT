    "patch_code": "import java.io.IOException;\nimport java.util.HashMap;\nimport java.util.Iterator;\nimport java.util.LinkedList;\nimport java.util.List;\nimport java.util.Map;\nimport org.apache.commons.lang3.text.translate.*;\n\npublic class CustomStringEscapeUtils extends StringEscapeUtils {\n    \n    private static final Map<Integer, String> XML_ESCAPE = new HashMap<>();\n\n    /**\n     * Customize init to support supplementary planes U+FFFF and beyond.\n     */\n    static {\n         XML_ESCAPE.put((int) '&', \"&amp;\");\n         XML_ESCAPE.put((int) '\"', \"&quot;\");\n         XML_ESCAPE.put((int) '\\'', \"&apos;\");\n         XML_ESCAPE.put((int) '<', \"&lt;\");\n         XML_ESCAPE.put((int) '>', \"&gt;\");\n         \n         XML_ESCAPE.put(0xfffd, \"&#xFFFD;\");   // REPLACEMENT CHARACTER \ufffd\n       /*\n         XML_ESCAPE.put(' ', \" \");  // If you want to keep space, comment this line\n        */\n    }\n\n    public static final String escapeXml(final CharSequence input) {\n        return translate(new LookupTranslator(XML_ESCAPE), input.toString());\n    }\n    \n    protected static class LookupTranslator implements Translator {\n\n        private final Map<Integer, String> lookup;\n\n        protected LookupTranslator(final Map<Integer, String> map) {\n            super();\n            if ((map == null) || (map.size() <= 0)) {\n                throw new IllegalArgumentException(\"The supplied map is empty or null.\");\n            }\n            this.lookup = map;\n        }\n\n        @Override\n        public int translate(final int chr, final StringBuilder out) {\n            Integer e = lookup.get(chr);\n            \n            if (e != null) {\n                out.append(e);\n                return 1;\n            }\n            return 0;\n        }\n\n    }\n\n}",
