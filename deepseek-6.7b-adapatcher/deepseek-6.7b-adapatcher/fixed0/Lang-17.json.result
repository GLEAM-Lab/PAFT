    "patch_code": "import java.io.IOException;\nimport org.apache.commons.lang3.text.translate.*;\nimport java.io.Writer;\n\npublic class CustomEscaper extends Escaper {\n\n    private static final long serialVersionUID = 1L;\n    private static final int UTF_16_SUPPLEMENTARY_MIN = 0x10000;\n\n    @Override\n    public boolean translate(int codePoint, Writer out) throws IOException {\n        \n        if (codePoint >= UTF_16_SUPPLEMENTARY_MIN && codePoint <= 0x10FFFF) {\n            \n            int utf16SupplementaryHighSurrogate = 0xd800 + ((codePoint - 0x10000) >> 10);\n            int utf16SupplementaryLowSurrogate  = 0xdc00 + (codePoint & 0x3ff);\n            \n            out.write(utf16SupplementaryHighSurrogate);\n            out.write(utf16SupplementaryLowSurrogate);\n            \n            return true;\n        }\n        \n        return false;\n    }\n    \n}\n\n\npublic class Test{\n    \n      public static void main(String[] args){\n          \n          try {\n              String str1 = \"\\uD842\\uDFB7\" + \"A\";\n              System.out.println(str1);\n              \n              Writer writer = new StringWriter();\n              CustomEscaper customEscaper = new CustomEscaper();\n              customEscaper.translate(str1,writer);\n              System.out.println(writer.toString());\n          } catch (Exception e) {\n              e.printStackTrace();\n          }\n      \n      }\n\n}",
