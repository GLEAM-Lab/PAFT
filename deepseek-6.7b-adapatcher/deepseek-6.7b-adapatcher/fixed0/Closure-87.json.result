    "patch_code": "protected void createFormItem(List<String> inputs) throws JspException{\n\t\ttry {\n\t\t\tString itemId = HtmlUtil.createUniqueElementId(\"formitem\");\n\t\t\tprintStartTag(TAG_INPUT, ATRTIBUTE_ID + itemId + ATRTIBUTE_NAME+ ATTRIBUTENAME);\n\t\t\t\n\t\t\tif(inputs != null && !inputs.isEmpty()){\n\t\t\t\tfor(String s : inputs){\n\t\t\t\t\tprintEndBracketAndText(TAG_OPTION, \"\", s, true);\n\t\t\t\t}\n\t\t\t}\n\t\t\t\n\t\t\tprintEndBracketAndText(TAG_SELECT, ATRTIBUTE_NAME, itemName, true);\n\t\t\tprintJspText(\"<br /><br /><span style=\\\"color:red;font-style:italic;\\\">${errorMessage}</span>\");\n\t\t\t\n\t\t} catch (IOException ex) {\n\t\t\tthrow new JspException(\"Can't write HTML\", ex);\n\t\t}\n\t}",
