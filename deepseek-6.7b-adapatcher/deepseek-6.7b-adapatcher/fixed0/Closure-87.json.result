    "patch_code": "private static int countChildren(AstNode n) {\n  if (!(n instanceof AstArrayLiteral || n instanceof AstBinaryExpression || n instanceof AstCallExpression)) {\n    return 0;\n  }\n  \n  List children = AstTraversing.getChildren(n);\n  for(int i = 0; i < children.size(); i++) {\n    children.set(i, null);\n  }\n  \n  return children.size();\n}",
