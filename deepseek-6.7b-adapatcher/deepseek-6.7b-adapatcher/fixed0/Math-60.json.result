    "patch_code": "import org.apache.commons.math.*;\nimport org.apache.commons.math.exception.*;\nimport org.apache.commons.math.util.*;\n\npublic class NormalDistributionImpl extends RealDistribution implements NormalDistribution {\n    \n    public double cumulativeProbability(double x) throws MathException {\n        final double dev = x - getMean();\n        \n        try {\n            return 0.5 * (1.0 + Erf.erf(dev / (getStandardDeviation() * FastMath.sqrt(2.0))));\n        } catch (ConvergenceException ce) {\n            \n            if (!DoubleUtils.isFinite(dev)) {\n                \n                throw new NotStrictlyPositiveException(\n                        LocalizedFormats.NOT_POSITIVE_NUMBER);\n            }\n            \n            double tailArea = 0;\n            \n            if (dev > 0) {\n                tailArea = 1;\n            }\n            \n            return tailArea;\n        }\n    }\n    \n    private Double[] parameter = null;\n    \n    protected String[] getParameterNames() {\n        return new String[]{\"mean\", \"standard deviation\"};\n    }\n    \n    @Override\n    public void setParameters(Double... parameters) throws MathIllegalArgumentException {\n        if ((parameters == null) || (parameters.length != 2)){\n            throw new MathIllegalArgumentException();\n        }\n        this.parameter[0] = parameters[0];\n        this.parameter[1] = parameters[1];\n    }\n    \n    @Override\n    public Double[] getParameters() {\n        return this.parameter;\n    }\n    \n    public double getMean() {\n        return this.parameter[0].doubleValue();\n    }\n    \n    public double getStandardDeviation() {\n        return this.parameter[1].doubleValue();\n    }\n    \n    @Override\n    public double density(double x) throws MathException {\n        return super.density(x);\n    }\n}",
