    "patch_code": "public double cumulativeProbability(double x) throws MathException {\n    final double dev = x - mean;\n    try {\n        return 0.5 * (1.0 + org.apache.commons.math.special.Erf.erf((dev) /\n                (getStandardDeviation() * FastMath.sqrt(2.0))));\n    } catch (ConvergenceException ex) {\n        if (x < (mean - 20 * getStandardDeviation())) { // JDK 1.5 blows at 38\n            return 0;\n        } else if (x > (mean + 20 * getStandardDeviation())) {\n            return 1;\n        } else {\n            throw ex;\n        }\n    }\n}",
