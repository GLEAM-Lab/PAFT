  {
    "patch_code": "public double cumulativeProbability(double x) throws MathException {\n    if (Double.isNaN(x))\n        throw new NotANumberException(LocalizedFormats.VALUE_IS_NOT_A_NUMBER);\n    if ((mean == Double.NEGATIVE_INFINITY && x >= 0) || (mean == Double.POSITIVE_INFINITY && x <= 0)) {\n       return 0;\n    }\n    if ((mean == Double.NEGATIVE_INFINITY && x <= 0) || (mean == Double.POSITIVE_INFINITY && x >= 0)) {\n         return 1;\n     }\n    final double cdf = Phi(-(mean - x) / standardDeviation);\n    return cdf == 1 ? Double.ONE_MINUS_EPSILON : cdf;\n  \n  private static double Phi(double value) {\n      if (!Double.isFinite(value)) {\n           throw new ConvergenceException(LocalizedFormats.SERIES_CONVERGE_ABSOLUTE, 0, 0);\n     }\n      return Erf.erfc(-value / Math.sqrt(2.0));\n }\n}",
