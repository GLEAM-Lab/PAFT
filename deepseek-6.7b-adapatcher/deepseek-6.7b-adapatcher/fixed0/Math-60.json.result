    "patch_code": "import org.apache.commons.math.util.*;\n\npublic class RepairedNormalDistribution extends NormalDistributionImpl {\n    \n    public RepairedNormalDistribution(){\n        super();\n    }\n\n@Override\n    public double cumulativeProbability(double x) throws MathException {\n        \n        \n          /* This is where we add handling code for infinite or NaN inputs. */\n          \n      \n        if (!DoubleUtils.isFinite(getMean()) && !DoubleUtils.isFinite(getStandardDeviation())) {\n            \n          \n            return DoubleUtils.isNaN(x)?Double.NaN:Double.POSITIVE_INFINITY;\n        }\n     \n  \n        final double dev = x - getMean();\n\n        try {\n            return 0.5 * (1.0 + Erf.erf((dev) /\n                    (getStandardDeviation() * FastMath.sqrt(2.0))));\n        } catch (ConvergenceException ex) {\n            if (FastMath.isNaN(x) || FastMath.isInfinite(x)){\n              \n                 return Double.NaN ;\n            }else {throw ex;}\n        }catch (MaxIterationsExceededException ex){\n            \n              if ((x<=Double.MAX_VALUE )&& (x>=Double.MIN_VALUE)  &&\n                        (dev / getStandardDeviation() <= Double.MAX_VALUE) &&\n                        (dev / getStandardDeviation() >= Double.MIN_VALUE)) {\n                   return FastMath.abs(dev) >= 4 * getStandardDeviation() ? Double.POSITIVE_INFINITY : 0.5;\n              }\n            throw ex;\n        }\n    }\n\n\n\n}",
