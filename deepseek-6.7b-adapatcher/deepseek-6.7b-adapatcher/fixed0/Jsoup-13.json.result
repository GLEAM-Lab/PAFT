  {
    "patch_code": "public boolean hasAttr(String attributeName) {\n    Validate.notEmpty(attributeName);\n    \n    if(attributeName.startsWith(\"xml:\")){\n        String key = attributeName.replaceFirst(\"xml:\",\"\");\n        return hasAttribute(key);\n    }else{\n        Attributes attributes=this.attributes;\n        int index=attributeName.indexOf(':');\n        if(index>0&&attributeName.length()>1){\n            String uri = attributeName.substring(0, index);\n            String localName = attributeName.substring(index + 1);\n            NamedNodeMap nnm = attributes();\n            \n            for (int i = 0; i < nnm.getLength(); i++) {\n                Attr attr=nnm.item(i);\n                \n                if ((Utils.isBlank(uri) && attr.getName().equals(localName))||\n                    (!Utils.isBlank(uri) && \n                     (attr.getName().endsWith(uri + \":\"+ localName))) ){\n                    return true;\n                }\n            }\n        } else {\n           return this.attributes != null && this.attributes.getNamedItem(attributeName)!=null;\n        }\n        \n    }\n   return false;\n}",
