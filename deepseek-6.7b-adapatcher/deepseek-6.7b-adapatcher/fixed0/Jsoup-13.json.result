    "patch_code": "/**\n * Return the named data or pseudo-element's attribute value. If no attribute with this name exists, return null.\n *\n * @param name Attribute name.\n * @return Attribute value or null if no such attribute exists.\n */\n@Override\npublic String attr(final String name) {\n  if (!name.contains(\":\")) {\n    final Attribute attribute = attributes.getNamedItemNS(SVGNamespace.XML_NAMESPACE);\n    return attribute != null ? attribute.getValue() : null;\n  } else {\n      int indexOfColon = name.indexOf(':');  \n      String namespacePrefix = name.substring(0, indexOfColon);  // \"abs\" in our case\n      String localName = name.substring(indexOfColon + 1);     // \"href\" in our case\n      \n      String actualNamespace = SVGSyntax.lookupNamespace(namespacePrefix);\n      \n      Node nodeWithAttribute = attributes.getNamedItemNS(actualNamespace);\n      if (nodeWithAttribute == null) {\n          return \"\";\n      }\n      if (!nodeWithAttribute.hasAttributes()) {\n          return \"\";\n      }\n      \n      Attribute att = new Attribute();\n      att.setName(localName);\n      att.setValue(attributes.getNamedItemNS(actualNamespace).getLocalPart());\n      \n      return att.getValue();\n  }\n}",
