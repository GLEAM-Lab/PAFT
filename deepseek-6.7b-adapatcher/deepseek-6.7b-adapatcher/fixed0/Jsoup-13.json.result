  {
    "patch_code": "public String attr(String key) {\n        if (!key.contains(\":\")) {\n            throw new IllegalArgumentException();\n        }\n        String ns = null;\n        int idx = key.indexOf(':');\n        if (idx != -1) {\n            ns = key.substring(0, idx);\n            key = key.substring(idx + 1);\n        } else {\n            throw new IllegalArgumentException();\n        }\n        if (\"abs\".equalsIgnoreCase(ns)) {\n            ns = \"\"; // Empty namespace corresponds to no namespace\n        } else if (\"xml\".equalsIgnoreCase(ns)) {\n            ns = \"http://www.w3.org/XML/1998/namespace\"; // xml namespace\n        } else {\n            throw new IllegalArgumentException();\n        }\n\n        Attribute attribute = attributes.getNamedItemNS(ns, key);\n        return attribute == null ? \"\" : attribute.getValue();\n    }",
