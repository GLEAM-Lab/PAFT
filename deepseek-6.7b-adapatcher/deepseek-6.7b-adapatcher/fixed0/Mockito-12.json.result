  {
    "patch_code": "import java.lang.reflect.*;\n\npublic class GenericMaster {\n\n  public static Class<?> getGenericType(Field field) {\n    final Type type = field.getGenericType();\n  \n      if (type == null) {\n          throw new NullPointerException(\"field type\");\n      } else if (type instanceof ParameterizedType) {\n        final ParameterizedType parameterizedType = (ParameterizedType) type;\n        final Type rawType = parameterizedType.getRawType();\n        if (rawType instanceof Class) {\n            final Class<?> rawTypeAsClass = (Class<?>) rawType;\n                if (\"List\".equals(rawTypeAsClass.getName())) {\n                    return (Class<Object>) parameterizedType.getActualTypeArguments()[0];\n                  }\n                 }\n           } \n      \n\n    if (!(type instanceof Class)) {\n      throw new RuntimeException(String.format(\"Not expecting this kind of type: %s\", type));\n    }\n\n    return (Class<Object>) type;\n  }\n\n}",
