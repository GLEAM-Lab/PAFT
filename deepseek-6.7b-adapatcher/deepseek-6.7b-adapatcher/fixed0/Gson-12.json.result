    "patch_code": "@Override public void skipValue() throws IOException {\n  final int previousDepth = depth;\n  do {\n    int tokenId = peek();\n    switch (tokenId) {\n      case NAME:\n        nextName();\n        break;\n        \n     case BEGIN_ARRAY:\n      beginArray();\n      continue;\n      \n    case END_OBJECT:\n      endObject();\n      return;\n      \n    default:\n      throw new UnsupportedOperationException(String.valueOf((char) tokenId));\n  }\n  \n  /* Increment path index */\n  pathIndices[depth] ++;\n } while (!closeOnePropertyOrEnd());\n  \n   // Reset indices for this level after breaking out of loop.\n   Arrays.fill(pathNames, previousDepth, depth, null);\n  Arrays.fill(pathIndices, previousDepth, depth, -1);\n}",
