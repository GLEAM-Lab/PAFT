    "patch_code": "@Override public void skipValue() throws IOException {\n  if (!hasNext()) return; // avoid IndexOutOfBoundExceptions\n\n  final int indexToSkip = streamIndex--;\n  \n  switch (nextToken()) {\n  case BEGIN_ARRAY:\n    endArray(indexToSkip);\n    break;\n    \n  case BEGIN_OBJECT:\n    endObject(indexToSkip);\n    break;\n    \n  default:\n    if (tokenStream.isNumberScalar(peak())) tokenStream.moveToNextNumberField(indexToSkip);\n    else tokenStream.moveToNextNonNumericField(indexToSkip);\n    break;\n  }\n}",
