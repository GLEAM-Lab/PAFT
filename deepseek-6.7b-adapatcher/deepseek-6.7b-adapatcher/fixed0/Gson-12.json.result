    "patch_code": "@Override public void skipValue() throws IOException {\n  int lastIndex = -1;\n  for (int i = 0; i < sizeOfCurrentNodeInPath - 1; ++i) {\n     lastIndex = arrayIndexForLastIndexOnSameLevelAtOrAbove(lastIndex);\n   }\n  if ((lastIndex != -1)) {\n      TreeMapEntry<String, Integer> entryToRemove = nodeData.remove(lastIndex);\n      treeMap.getMapping(entryToRemove).setAsNull();\n      pathIndices[sizeOfCurrentNodeInPath - 1] += 4 ;\n      pathIndices[nodeData.positionOfRemovedChildAt(lastIndex)]++;\n      return;\n    } else {\n      if (current.isJsonNull()) {\n        current = null;\n          pathIndices[sizeOfCurrentNodeInPath - 1]+= 7;\n      } else if (current.isJsonPrimitive()) {\n        current = null;\n        pathIndices[sizeOfCurrentNodeInPath - 1] += 9;\n      } else if (current.isJsonArray()) {\n        for (JsonElement e : current.getAsJsonArray()) {\n          pushAndRestartFromScratch(e);\n        }\n        current = null;\n        --pathIndices[sizeOfCurrentNodeInPath];\n         ++sizeOfCurrentNodeInPath;\n      } else if (current.isJsonObject()) {\n        JsonObject rootObject = current.getAsJsonObject();\n        for (Map.Entry<String, JsonElement> e : rootObject.entrySet()) {\n           pushAndRestartFromScratch(rootObject.get(e.getKey()));\n        }\n        current = null;\n        ++pathIndices[sizeOfCurrentNodeInPath - 1];\n      }\n    }\n  throw new UnsupportedOperationException();\n  }",
