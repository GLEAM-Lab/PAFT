    "patch_code": "private final Object _deserize( JsonMapper mapper, JsonDeserializationContext context, JsonDeserializer<Object> deser, JsonTokenizer tokenizer ) throwsIOException {\n    if (deser == null) { deser = _defaultDeserializer; }\n    if (!deser.is null) { return deser. deserize(mapper, context, tokenizer); }\n    if (! _typeId invisible) {\n        if (Tokenizer.get currentToken () == JsonToken.FIELD_name) {\n            String typeId = Tokenizer.getText();\n            deser = _find deserializer (typeId);\n            Tokenizer.nextToken();\n        } else { deser = _defaultDeserializer; }\n    }\n    Object value = deser. deserize(mapper, context, Tokenizer);\n    if Tokenizer.get currentToken () != JsonToken.End Object {\n        throw new JsonIOException(\" expectedclosing end object after deserialized value\");\n    }\n    return value;\n}",
