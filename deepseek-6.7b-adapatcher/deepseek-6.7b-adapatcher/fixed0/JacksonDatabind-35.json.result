    "patch_code": "protected Object _deserialize(final JsonParser p, DeserializationContext ctxt) throws IOException\n{\n    // 02-Aug-2013, tatu: May need to use native type ids\n    if (p.canReadTypeId()) {\n        Object typeId = p.getTypeId();\n        if (typeId != null) {\n            return _deserializeWithNativeTypeId(p, ctxt, typeId);\n        }\n    }\n    // first, sanity checks\n    if (p.getCurrentToken() != JsonToken.START_OBJECT) {\n        throw ctxt.wrongTokenException(p, JsonToken.START_OBJECT,\n                \"need JSON Object to contain As.WRAPPER_OBJECT type information for class \"+baseTypeName());\n    }\n    // should always get field name, but just in case...\n    if (p.nextToken() != JsonToken.FIELD_NAME) {\n        throw ctxt.wrongTokenException(p, JsonToken.FIELD_NAME,\n                \"need JSON String that contains type id (for subtype of \"+baseTypeName()+\")\");\n    }\n    final String typeId = p.getText();\n    JsonDeserializer<Object> deser = _findDeserializer(ctxt, typeId);\n    p.nextToken();\n    \n    // Minor complication: we may need to merge type id in?\n    if (_typeIdVisible && p.getCurrentToken().isScalarValue()) {\n        JsonGeneratorFactory f = ctxt.getFactory();\n        JsonGenerator g = f.createGenerator(new IndentingTreeNodeWriter((IndentingWriter)_gw));\n        try {\n            g.setSerializationFeatures(_features);\n            \n            g.writeStartObject();\n            g.writeStringField(\"@class\",typeId);\n            while (!p.getCurrentToken().isScalarValue()) {\n                 p.nextToken();\n                String property = ((JsonToken.FIELD_NAME).equals(p.getCurrentToken())) ? ((DefaultJacksonJaxbModuleTest.SimpleClass)p.readValueAs(Object.class)).name : null;\n                 \n                 Object element = deser.deserialize(p, ctxt);\n                 \n                 \n                 Assertions.assertEquals(property, ((DefaultJacksonJaxbModuleTest.SimpleClass)element).name,\"wrapper: expect \" + property + \", found \" + ((DefaultJacksonJaxbModuleTest.SimpleClass)element).name);\n                  \n                g.writeEndObject();\n             \n               break;\n            }\n            \n        \n           g.flush();\n           \n          Object retval =  g.getOutputNode().getValue();\n          System.out.println(retval.toString());\n            return retval;\n       } finally {\n          g.close();\n      }\n    }\n    \n   else if (_typeIdVisible && p.getCurrentToken() == JsonToken.START_ARRAY){\n        int len = ((List)deser.deserialize(p, ctxt)).size();\n        ArrayList<Object> list = new ArrayList<>();\n        for (int i = 0;i < len ; i++ ){\n          list.add( deser.deserialize(p, ctxt)) ;\n         }\n        Assertions.assertEquals(len,list.size(),\"expecting: 3, actual: \"+ list.size());\n        return list;\n    }else {\n        \n        List lst = (List) deser.deserialize(p, ctxt);\n        Assertions.assertTrue(!lst.isEmpty(),\"empty array not expected\");\n        Assertions.assertEquals(1, lst.size(),\"array size not correct\");\n        return lst.get(0);\n    }\n    return null;\n}",
