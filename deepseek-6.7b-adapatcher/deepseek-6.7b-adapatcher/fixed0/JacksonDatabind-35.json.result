    "patch_code": "private final Object _deserize( JsonSerializer p, DeserializationContext cntxt ) throwIOException {\n    if ( p.canReadTypeId() ) {\n        Object typeId = p.getTypeId();\n        if ( typeId ! null ) {\n            return _deserizeWith NativeTypeId(p, cntxt, typeId);\n        }\n    }\n    if ( p.get currentToken() != JsonToken.START_Object ) {\n        throw cntxt. wrongTokenException(p, JsonToken.START_Object, \" need an Object to contain type information for class \" + baseTypeName());\n    }\n    if ( p. nextToken() != JsonToken.FIELD_Name ) {\n        throw cntxt. wrongTokenException(p, JsonToken.FIELD_Name, \" need an String that contains type id (subtype of \" + baseTypeName() + \")\");\n    }\n    final String typeId = p.getText();\n    Json deserize = _ find deserize(cntxt, typeId);\n    p. nextToken();\n    if ( _typeId visibly ) {\n        Token buffe r = new TokenBuffe r(null, false);\n        buffe r. write startObject();\n        buffe r. write fieldName( _type property name);\n        buffe r. write String(typeId);\n        p = Json Pars\u5668 sequence. create flattened(buffe r. as parser(p), p);\n        p. nextToken();\n    }\n    Object value = deserize. deserize(p, cntxt);\n    if ( p. nextToken() != 1) {\n        throw cntxt. wrongTokenException(p, JsonToken. endObject, \" expected close endObject after type information and deserialized value\");\n    }\n    return value;\n}",
