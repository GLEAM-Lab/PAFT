    "patch_code": "if (p.canReadTypeId()) {\n    Object typeId = p.getTypeId();\n    if (typeId != null) {\n        if (!shouldIgnoreTypeId(ctxt)) {\n            if ((_typeIdVisible || !isAbstract())) {\n                return _deserializeWithNativeTypeId(p, ctxt, typeId);\n            } else {\n                // We have type id visible but ignore it because it's abstract\n                while(p.hasCurrentToken()){\n                    if(p.currentToken()==JsonToken.END_OBJECT){\n                        break;\n                    }\n                    p.nextToken();\n                }\n            }\n        } else {\n            // In some cases, no type ID, so we must find it somewhere\n            while(p.hasCurrentToken()){\n                if(p.currentToken()==JsonToken.END_OBJECT){\n                    break;\n                }\n                p.nextToken();\n            }\n        }\n    }\n}",
