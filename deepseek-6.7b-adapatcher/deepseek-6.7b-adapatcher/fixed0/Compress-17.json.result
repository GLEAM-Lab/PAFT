    "patch_code": "public static long get Octal ( final String str) {\n    long result = 0;\n\n    final char[] characters = str.to charArray();\n    final int length = characters.length;\n\n    for (int i = 0; i < length; i++) {\n        final char character = characters[i];\n        if ( Character.isWhitespace( character)) {\n            continue;\n        }\n        if ( character < '0' || character > '7') {\n            throw new IllegalArgumentException(\" Invalid entry \" + str + \" at position \" + i);\n        }\n        result = (result << 3) + (long)( character - '0');\n    }\n\n    return result;\n}\npublic static long get Octal ( final String str) {\n    final char[] characters = str.to charArray();\n\n    long result = 0;\n    boolean leading = true;\n\n    for (int i = 0; i < characters.length; i++) {\n        final char character = characters[i];\n        if ( Character.isWhitespace( character)) {\n            continue;\n        }\n        if ( leading && character == '0') {\n            continue;\n        }\n        leading = false;\n        if ( character < '0' || character > '7') {\n            throw new IllegalArgumentException(\" Invalid entry \" + str + \" at position \" + i);\n        }\n        result = (result << 3) + ( long)( character - '0');\n    }\n\n    return result;\n}",
