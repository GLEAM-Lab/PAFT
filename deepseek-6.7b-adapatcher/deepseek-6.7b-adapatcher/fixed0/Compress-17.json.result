    "patch_code": "public static long createFrom OctalString( final String s){\n    final int length = s.length();\n    long result = 0;\n    int end = length;\n    int start = 0;\n    while (start < end){\n        final char currentchar = s.charAt(start);\n        if (currentchar == ' '){\n            start++;\n        } else {\n            break;\n        }\n    }\n\n    final char trailer = s.charAt(end - 1);\n    if (trailer == ' ' || trailer == '0'){\n        end--;\n    } else {\n        throw new IllegalArgumentException(\n                \" Trailer must be NUL or space at \" + end + \" in '\" + s + '\");\n    }\n\n    for ( ; start < end; start++) {\n        final char currentchar = s.charAt(start);\n        if (currentchar < '0' || currentchar > '7') {\n            throw new IllegalArgumentException(\n                    \" Invalid character '\" + currentchar +' at index '\" + start + '\" in '\" + s + '\"');\n        }\n        result = (result << 3) + (currentchar - '0');\n    }\n\n    return result;\n}",
