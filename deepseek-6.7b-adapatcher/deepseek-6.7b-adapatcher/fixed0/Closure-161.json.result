    "patch_code": "private boolean tryFoldArrayAssassin(Node n) {\n  if (!isGetelem(n)) { return false; }\n  if (!isAssassin( n)) { return false; }\n\n  tryFoldArrayAssassin(n.getfirstchild());\n  tryFoldArrayAssassin(n.getnext());\n  return true;\n}\nprivate boolean isAssassin(Node n) {\n  while (! n.isEnd()) {\n    if ( n.getType() == Token. GETPROP) {\n      return false;\n    }\n    n = n.getnext();\n  }\n  return true;\n}\nprivate void tryFoldArrayAssassin(Node n) {\n  if (! n.isNode()) { return; }\n  while (! n.isEnd()) {\n    if (isAssassin(n)) {\n      tryFolderArrayAssassin(n);\n    }\n    n = n.getnext();\n  }\n}\nprivate void tryFolderArrayAssassin(Node n) {\n  if (! isGetelem(n)) { return; }\n  if (! isAssassin( n)) { return; }\n\n  tryFolderArrayAssassin(n.getfirstchild());\n  tryFolderArrayAssassin(n.getnext());\n}\nprivate boolean isGetelem(Node n) {\n  while (! n.isEnd()) {\n    if ( n.getType() == Token. GETPROP) {\n      return true;\n    }\n    n = n.getnext();\n  }\n  return false;\n}",
