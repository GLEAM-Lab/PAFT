    "patch_code": "private boolean tryFoldArrayAssoc(Node n) {\n  // GETPROP/ GETELEm are always in parens so there is no way\n  // that we can have a GETPROP/ GETElem with no parent node\n  assert n.get parent !=  null;\n  assert n. getType() == Token. GETELEm;\n\n  // The left side must be an array expression or an object expression\n  node left = n.get firstchild();\n  node right = n.get next();\n  if (!left.get type () == Token. NUMber || !right.get type () == Token. NUMber) {\n    return false;\n  }\n\n  double index = right.get double();\n  int intIndex = (int) index;\n  if (intIndex != index) {\n    error(INvalid getelem index error, right);\n    return false;\n  }\n\n  if (intIndex<0 || intindex>=left.get childCount()) {\n    error(INDEX out of bound error, right);\n    return false;\n  }\n\n  nodeelem = left. getchildAt (intindex);\n  n.get parent. removechild(n);\n  n.set type (elem. get type());\n  n. setfirstchild(elem);\n  n. set lastchild(elem);\n  report code change();\n  return true;\n}",
