    "patch_code": "public Node processForInLoop(ForInLoop loopNode) {\n\n        List<AstNode> childrenList = new ArrayList<>();\n        \n        AstNode iterator = createVariableDeclaration(0);\n        ((VariableDeclaration)iterator).setInitializer(transform(loopNode.getIterator(), true));\n        childrenList.add(iterator);\n         \n        AstNode iterableExpression = createVariableDeclaration(1);\n        ((VariableDeclaration)iterableExpression).setInitializer(transform(loopNode.getIteratedObject(), true));\n        childrenList.add(iterableExpression);\n        \n        \n    \n       // Statement list for the body of the for...in loop.\n        ChildrenWrapper cw = transformStmtsAndDeclareVariables(loopNode.getBody());\n        childrenList.addAll(cw.children());\n       \n        AstNode block = createBlock((Statement[]) childrenList.toArray(new AstNode[childrenList.size()]));\n        block.setParent(this);\n    \n        return block;\n    }",
