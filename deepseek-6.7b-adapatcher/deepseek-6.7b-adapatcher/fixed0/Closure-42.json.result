    "patch_code": "Node processForEachLoop(ForEachLoop loopNode) {\n        TokenType ttype = getTokenizer().current().ttype();\n         if ((ttype == TokenType.IDENTIFIER && tokenMatches(\"in\")) || (ttype != null && ttype.isLiteral() && tokenMatches(\"null\"))) {\n            // This looks like for-in loop processing\n            Node iterator = transform(loopNode.getRightHandSide());\n             if (!isKeywordIdentifier(iterator)) {\n                throw unexpectedExpressionStatementAtEndOfInput();\n              }\n            ExpressionStatement result = statementFactory_.createForInStatement(transform(loopNode.getLeftHandSide()), iterator);\n            ifLooseCatchTargets(result);\n            return result;\n        } else {\n            getErrors().addError(\"Unxpected for-each loop\");\n            eatDeclarationList();\n            return null;\n        }\n    }\n    \nprivate boolean tokenMatches(String s) {\n    return getTokenizer().matchesLiteral(s);\n}\n   private StringBuilder eatLiteralOrParens() throws ParseProblem {\n    if (getTokenizer().current().ttype() == null) {\n      throw new ParseProblem(\"EOF inside parentheses.\");\n    } else if (getTokenizer().current().ttype().isLiteral()) {\n      return getTokenizer().eatLiteralOrParens();\n    } else {\n      throw new ParseProblem(\"Unexpected \" + getTokenizer().current());\n    }\n  }\n    \n   private void ifLooseCatchTargets(Node n) {\n    LooseCatchTargets looseTargets = new LooseCatchTargets(n);\n    looseTargets.process(this);\n  }",
