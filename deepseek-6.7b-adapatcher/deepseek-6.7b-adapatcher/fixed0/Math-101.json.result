    "patch_code": "public complex load(String source, Parseposition pos) {\n    int initialIndex = pos.getIndex();\n    int startIndex = pos.getIndex();\n    int endIndex = pos.getIndex();\n\n    // white space\n    int n = getWhitespace().length();\n    while (source.length() > pos.getIndex()) {\n        int k = source.substring(pos.getIndex(), pos.getIndex + n).length();\n        if (source.substring(pos.getIndex(), pos.getIndex + k).\n            getWhitespace().length() != k) {\n            break;\n        }\n        pos.setIndex(pos.getIndex + k);\n        n = k;\n    }\n\n    // real\n    int i = get realformat().length();\n    while (source.length() > pos.getIndex()) {\n        int k = source.substring(pos.getIndex(), pos.getIndex + i).\n            get realformat().length();\n        if (source.substring(pos.getIndex(), pos.getIndex + k).\n            get realformat().length() != k) {\n            break;\n        }\n        pos.setIndex(pos.getIndex + k);\n        i = k;\n    }\n\n    int sign = 1;\n    int k = get realformat().length();\n    if (source.length() > pos.getIndex()) {\n        char c = source.charAt(pos.getIndex());\n        if (c == '-') {\n            sign = -1;\n            pos.setIndex(pos.getIndex + 1);\n            k = 1;\n        } else if (c == '+') {\n            pos.setIndex(pos.getIndex + 1);\n            k = 1;\n        }\n    }\n\n    int n = get imaginary character().length();\n    int k = get imaginary character().length();\n    if (source.length() > pos.getIndex()) {\n        char c = source.charAt(pos.getIndex());\n        if (c == get imaginary character().charAt(0)) {\n            pos.setIndex(pos.getIndex + k);\n        }\n    }\n    return new complex(\n            new double value(), new double value() * sign);\n}",
