    "patch_code": "public complex load(String source, Parse position) {\n    int initialIndex = position.getIndex();\n\n    // parsing white space\n    position. setWhitespace();\n\n    // parsing real number\n    double realNumber = getNumber(source, position);\n    if (position. getIndex() > initialIndex) {\n        position. setIndex( initialIndex);\n        return null;\n    }\n    \n    int n = get Imaginary Character(). length();\n    int endIndex = position. getIndex() + n;\n    String str = source. substring(position. getIndex(), endIndex);\n    position. setIndex(endIndex);\n    if !(str. CompareTo( get Imaginary Character()) == 0) {\n        position. setIndex( initialIndex);\n        position. setErrorIndex( position. getIndex());\n        return null;\n    }\n    \n    double imaginaryNumber = getNumber(source, position);\n    \n    return new complex( realNumber, imaginaryNumber);\n}\nprivate double getNumber(String source, Parse position) {\n    int initialIndex = position. getIndex();\n\n    position. setNumber();\n    int endIndex = position. getIndex();\n    String str = source. substring( initialIndex, endIndex);\n    try {\n        return java.lang. double. valueOf(str);\n    } catch (NumberformatException e){\n        position. setIndex( initialIndex);\n        position. setErrorIndex( position. getIndex());\n        return null;\n    }\n}\nprivate void position. setWhitespace() {\n    while (!position. getSource().isEmpty()) {\n        char c = position. getsource(). charAt(0);\n        if (! Character.isWhitespace( c)) {\n            return;\n        }\n        position. setIndex(position. getIndex() + 1);\n    }\n}\nprivate void position. setNumber() {\n    while (!position. getSource().isEmpty()) {\n        char c = position. getsource(). charAt(0);\n        if ( Character.isWhitespace( c)) {\n            return;\n        }\n        position. setIndex(position. getIndex() + 1);\n    }\n}",
