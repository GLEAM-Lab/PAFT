    "patch_code": "public boolean apply(Node n) {\n  //When the node is null it means we reached the Implicit return where the function returns (possibly without an return statement)\n  if (n == null) {\n    return false;\n  }\n  if (n.isCall() && !NodeUtil.functionCall has side effect(n)) {\n    return true;\n  }\n  if (n.isNew() && !NodeUtil.constructorCall has side effect(n)) {\n    return true;\n  }\n  if (n.isCall() && n.getArguments().isEmpty()) {\n    return true;\n  }\n  for (Node c = n.getFirst child(); c != null; c = c.getNext()) {\n    if (! control flow graph.isentering new cfgt node(c) && apply(c)) {\n      return true;\n    }\n  }\n  return false;\n}",
