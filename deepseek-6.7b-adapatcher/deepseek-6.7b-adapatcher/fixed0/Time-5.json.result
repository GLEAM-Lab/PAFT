    "patch_code": "public static Period withoutYearOrMonthButWithDayAndWeek(ReadableInstant startDateTime, ReadableInstant endDateTime) {\n    long periodInDays = Days.daysBetween(new DateTime(startDateTime), new DateTime(endDateTime)).getDays();\n    long weeks = periodInDays / DateTimeConstants.DAYS_PER_WEEK;\n    long days = periodInDays % DateTimeConstants.DAYS_PER_WEEK;\n    DateTime start = new DateTime(startDateTime);\n    DateTime end = new DateTime(endDateTime);\n    while (!start.equals(end)) {\n        start = start.plusWeeks(1);\n        weeks++;\n    }\n    while (!start.equals(end)) {\n        start = start.plusDays(1);\n        days++;\n    }\n    return new Period(0, 0, 0, (int) weeks, (int) days, 0, 0, ISOChronology.getInstanceUTC());\n}",
