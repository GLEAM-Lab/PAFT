    "patch_code": "private static final DurationFieldType[] FIELD_TYPES = \n         {DurationFieldType.days(), DurationFieldType.hours(), DurationFieldType.minutes()};\n\n    private static PeriodType periodTypeForFields(final Iterable<DurationFieldType> types) {\n        List<DurationFieldType> list = Lists.newArrayList(types);\n        Collections.addAll(list, FIELD_TYPES);\n        Set<DurationFieldType> set = Sets.newLinkedHashSet(list);\n        return new AbstractPeriodType(\"Custom\") {\n            @Override\n            public int getLengthOfPeriodInMilliseconds() {\n                throw new UnsupportedOperationException(\"Not implemented\");\n            }\n            \n            @Override\n            public int getValueCount() {\n                return set.size();\n            }\n            \n            @Override\n            public DurationFieldType getDurationFieldType(int index) {\n                return set.get(index);\n            }\n            \n            @Override\n            public PeriodType withNormalizationRule(NormalizationRule rule) {\n                throw new UnsupportedOperationException(\"Not implemented\");\n            }\n        };\n    }\n    \n    @Test\n    public void testNoneStandardPeriodTypeWithoutYear() {\n        DateTime date1 = new DateTime(2013, 07, 01, 12, 12, 12);\n        DateTime date2 = new DateTime(2014, 08, 30, 12, 12, 12);\n        System.out.println(date1 + \" -> \" + date2);\n        Period period = new Period(date1, date2, periodTypeForFields(Lists.newArrayList(DurationFieldType.months(), DurationFieldType.weeks())));\n        Assert.assertEquals(-1, period.getMonths());\n    }",
