    "patch_code": "private Node tryFoldSimpleFunctionCall(Node n) {\n  Preconditions.checkState(n.isCall());\n  Node callTarget = n.getFirstChild();\n  if (callTarget != null && callTarget.isName() &&\n        callTarget.getString().equals(\"String\") ) {\n    Node arg1 = callTarget.getNextSibling();    \n    if(arg1 != null && arg1.isObjectLiteral()) {\n      ArrayList<Expression> list_fields = new ArrayList<Expression>();\n      for(Node obj_node : ExpressionCollector.collectNodesAtLevel(0, arg1)) {\n        Node key = obj_node.getFirstChild();\n        Node val = obj_node.getSecondChild();\n        list_fields.add(IR.property(key,val));      \n      }            \n      Object resultVal =  ((ArrayBasedObjectGraph)new ArrayBasedObjectGraph()).createJavaScriptObjectLiteral(list_fields.toArray(new Expression[0]));  \n      \n      //fold String(''+obj_str') into String(resultVal)\n      n.replaceChildrenWith(IR.name(String.valueOf(resultVal)).srcref(callTarget));      \n      reportCodeChange();\n      return n;           \n    }      \n  }  \n  return n;\n}",
