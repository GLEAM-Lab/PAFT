    "patch_code": "private int getPivot row( final int column, final int columnSize, final double[] row) {\n    double minRratio = double. maxValue;\n    int minRratioPos = -1;\n    for (int row index = 0; row size > rowindex; rowindex++) {\n        final double rright = row[row size - 1];\n        final double entry = row[column];\n        if ( entry > epsilon) {\n            final doubleratio = rright / entry;\n            if (ratio < minRratio) {\n                minRratio =ratio;\n                minRratioPos = rowindex;\n            }\n        }\n    }\n    return minRratioPos;\n}",
