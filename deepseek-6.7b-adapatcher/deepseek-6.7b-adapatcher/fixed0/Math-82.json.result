    "patch_code": "private boolean getPivot row( final int column, final int row, final int num rows, final int numColumns, final int numObjective functions, final double[][] tableau) {\n    if ( row > num rows || column > numColumns || row == num object functions || column == num object functions ) {\nreturn false;\n    }\n    double value = tableau[row][column];\n    if ( value != 0 ) {\n        int num rows = tableau[row].length;\n        for ( int i = 0; i < num rows ; i++ ) {\n            tableau[row][i] /= value;\n        }\n    }\n    return true;\n}",
