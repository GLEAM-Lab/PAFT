  {
    "patch_code": "private Integer getPivotRow(final int col, final SimplexTableau tableau) {\n    double minRatio = Double.MAX_VALUE;\n    Integer minRatioPos = null;\n    boolean foundValidRatio = false;\n    for (int i = tableau.getNumObjectiveFunctions(); i < tableau.getHeight(); i++) {\n        final double rhs = tableau.getEntry(i, tableau.getWidth() - 1);\n        final double entry = tableau.getEntry(i, col);\n        // If entry == 0 then we skip this row because it cannot be pivoted\n        if (!Double.isNaN(rhs / entry)) {\n            \n            if (MathUtils.compareTo(entry, 0, epsilon) >= 0) {\n                final double ratio = rhs / entry;\n                if (ratio < minRatio && !foundValidRatio) {\n                    minRatio = ratio;\n                    minRatioPos = i; \n                    foundValidRatio = true;\n                }\n            } else if ((minRatio == Double.MAX_VALUE || minRatio > Math.abs((rhs - Double.POSITIVE_INFINITY)/entry))){\n                foundValidRatio = true;\n                minRatio = (rhs - Double.NEGATIVE_INFINITY)/entry;\n                minRatioPos = i;\n                \n            }  \n         }    \n    }\n    \n    return minRatioPos;\n}",
