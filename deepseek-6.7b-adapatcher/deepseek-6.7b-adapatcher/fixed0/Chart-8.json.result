    "patch_code": "import java.util.*;\n\npublic class Week{\n     public Week(long time, TimeZone zone){\n         Calendar cal = new GregorianCalendar();\n        cal.setFirstDayOfWeek(Calendar.MONDAY);\n        cal.setMinimalDaysInFirstWeek(4);         \n        Date d = new Date();        \n        Calendar c1 = Calendar.getInstance();\n         c1.setTime(d);  \n      int i =   c1.getWeekYear();\n         Calendar c2 = Calendar.getInstance();\n           c2.set(Calendar.WEEK_OF_YEAR,-30 );\n            System.out.println(\"last week : \" + c2.getTime());\n       }\n  public static void main (String[] args){\n             Week ww = new Week(1609459200L ,TimeZone.getTimeZone (\"America/New_York\"));\n           }\n    }",
