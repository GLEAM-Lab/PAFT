    "patch_code": "import java.util.*;\nimport org.jfree.data.time.*;\n\npublic class Week extends RegularTimePeriod implements Serializable {\n    \n   public static final int DEFAULT_WEEKDAY = 1;\n   private int weekday = DEFAULT_WEEKDAY;\n   \n   public Week(Date date, TimeZone tz, Locale loc){\n       super(date, tz, 7*24*60*60*1000L);\n       this.weekday=DEFAULT_WEEKDAY;\n   }\n\n   public void setWeekDay(int dayOfWeek) {\n      if(dayOfWeek>=1 && dayOfWeek<=7){\n           this.weekday=dayOfWeek;\n      }else{\n          throw new IllegalArgumentException(\"The input should be between 1 and 7\");\n      }\n   }\n\n   public String getWeekDay() {\n        return switch (weekday) {\n            case 1 -> \"Monday\";\n            case 2 -> \"Tuesday\";\n            case 3 -> \"Wednesday\";\n            case 4 -> \"Thursday\";\n            case 5 -> \"Friday\";\n            case 6 -> \"Saturday\";\n            case 7 -> \"Sunday\";\n            default -> \"\";\n        };\n    }\n}",
