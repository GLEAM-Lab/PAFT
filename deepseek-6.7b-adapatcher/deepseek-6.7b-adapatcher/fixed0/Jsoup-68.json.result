    "patch_code": "private boolean inSpecificScope(String[] targetNames, String[] baseTypes, String[] extraTypes) {\n    // https://html.spec.whatwg.org/multipage/parsing.html#has-an-element-in-the-specific-scope\n    int bottom = Math.min(stack.size()-1,MaxScopeSearchDepth);\n    \n    \n    if (bottom < 0 ) {\n       // stack size can never be less than zero here\n         throw new IndexOutOfBoundsException();\n         \n    }\n    final int top =  bottom>MaxScopeSearchDepth ? bottom - MaxScopeSearchDepth : 0 ;\n    \n  \n    // don't walk too far up the tree\n    for (int pos = bottom; pos >= top; pos--){\n        final String elName = stack.get(pos).nodeName();\n        if (inSorted(elName, targetNames)){\n            return true;}\n             else if (inSorted(elName,baseTypes)){\n                    return false;}\n               else if(extraTypes!=null&&inSorted(elName,extraTypes)){\n                   return false;}\n     \n        \n}}\n     \n    //Validate.fail(\"Should not be reachable\"); // would end up false because hitting 'html' at root (basetypes)\n    \n return false;\n\n}",
