    "patch_code": "public static class Stack extends LinkedList<Element>{\n    public void removeLastOccurrenceOf(Element e){\n      Element lastElement = getLast();\n      while (!lastElement.equals(e)){\n          lastElement = getPreviousElement();\n      }\n      remove(indexOf(lastElement));\n     }\n   }",
