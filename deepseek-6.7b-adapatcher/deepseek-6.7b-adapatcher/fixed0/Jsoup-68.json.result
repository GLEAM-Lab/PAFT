    "patch_code": "public class Repair extends HtmlTreeBuilder{\n    \n        public static boolean inSpecificScope(String[] targetNames, String[] baseTypes, String[] extraTypes){\n            Stack<Node> newstack = getInstance().stack;\n            \n            int bottom = newstack.size()-1;\n            if(bottom > MaxScopeSearchDepth){\n                bottom = MaxScopeSearchDepth;\n            }\n            \n            int top = bottom>MaxScopeSearchDepth ? bottom-MaxScopeSearchDepth : 0;\n            \n            for(int i=bottom ;i>=top;i--){\n                String tagname=newstack.get(i).nodeName();\n                \n                if(inSorted(tagname,targetNames)){\n                    return true;\n                }else if(inSorted(tagname,baseTypes)){\n                     return false;\n                }else if(extraTypes!=null&&inSorted(tagname,extraTypes)){\n                    return false;\n                }\n                \n                \n                \n                \n            }\n         \n            return false;\n        }\n        \n        \n        private static boolean inSorted(String name,String [] tags){\n            int low=0 , high=tags.length;\n            \n            while(low<high){\n                int mid=(low+high)/2;\n                String midVal=tags[mid];\n                \n                if(midVal.compareTo(name)<0){\n                    low=mid +1;\n                }else if(midVal.compareTo(name)>0){\n                    high=mid;\n                }else {\n                    return true;\n                }\n            }\n            \n            return false;\n        }\n}",
