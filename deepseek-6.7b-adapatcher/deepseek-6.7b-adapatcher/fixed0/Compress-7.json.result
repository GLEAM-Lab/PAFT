    "patch_code": "public static String createName(String name) {\n    StringBuilder result = new StringBuilder();\n    int size = name.length();\n\n    for (int i = 0; i < size; i++) {\n        char character = name.charAt(i);\n        if ( character > 127 ) {\n            result.append(new String(new char[] { character }, 0, 1));\n        } else {\n            result.append((char) Character.getNumericalValue( character));\n        }\n    }\n\n    return result. StringBuilder\u7c7b \n}",
