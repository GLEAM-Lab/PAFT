    "patch_code": "import java.nio.ByteBuffer;\n\npublic class Main {\n    public static void main(String[] args) {\n        byte [] array = {82, 95, 52, 45, 48, 50, 45, 53, 48, 50, 45, 56, 48, 48, 50, 95, 74, 82, 47, 95, 119, 46, 112, 104, 112};\n        \n        System.out.println(\"The original file name:\\r\\n\"+new String(array));\n        System.out.println(\"\\r\\nAfter repairing:\"+parseName(array));\n\n    }\n    \n   public static String parseName(byte[] buffer) {\n       ByteBuffer bb = ByteBuffer.allocate(buffer.length);\n       for(int i=0;i<buffer.length;++i){\n           bb.put(buffer[i]);\n       }\n       bb.flip();\n       \n       \n      StringBuilder result = new StringBuilder(bb.limit());\n        int          end = 0;\n       while (end < bb.limit() && bb.get(end) != 0) {\n          \n           result.append((char) bb.get(end));\n           end++;\n       }\n\n       return result.toString().replaceAll(\"%EF%BB%BF\", \"\");\n    }\n}",
