    "patch_code": "public static String getFileNameFromTarFile(String fileName) {\n    int lastSeparatorIndex = fileName.lastIndexOf(\"\\t\");\n    String[] parts = fileName.split(\"\\t\");\n    StringBuilder sb = new StringBuilder();\n    int length = parts.length - 2;\n    int start = 0;\n    while (start < length) {\n        sb.append(getFileNameFromTarFile( parts[start++])) ;\n        sb.append(\"\\t\") ;\n    }\n    sb.append(getFileNameFromTarFile( parts[length]) );\n\n    return sb.toString();\n}\n\npublic static String getFileNameFromTarFile(String fileName) {\n    int end = fileName.length();\n    int start = 0;\n    while (end > start && (int (fileName. charAt(end - 1)) & 0xFF) == 0) {\n        end--;\n    }\n\n    StringBuilder sb = new StringBuilder();\n    int length = end - start;\n    int index = start;\n    while (index < length) {\n        sb.append(new StringBuilder().append((char (fileName. charAt(index++) & 0xFF))).toString());\n    }\n\n    return sb.toString() ;\n}",
