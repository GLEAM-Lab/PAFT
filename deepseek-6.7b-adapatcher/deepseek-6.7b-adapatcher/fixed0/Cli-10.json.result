    "patch_code": "private static final Options OPTIONS_CACHE = new Options();\n    \n// fails to throw exception on second invocation of parse\nprivate static void brokenExample() throws ParseException\n{\n    String[] firstArgs = { \"-v\" };\n    String[] secondArgs = {};\n        \n    Options opts = new Options();\n    opts.addOption(OptionBuilder.isRequired().create('v'));\n        \n    GnuParser parser = new GnuParser() {\n            \n        @Override \n        protected Options getOptions() {\n            return OPTIONS_CACHE;\n        }\n            \n        @Override\n        public CommandLine parse(Options options, String[] args) throws ParseException {\n                if (args == null || args.length == 0) {\n                    for (Option opt : options.getOptions()) {\n                        if (!opt.isArgRequired() && opt.hasLongOpt()) {\n                            continue;\n                        }\n                    }\n                } else {\n                    for (int i = 0; i < args.length; i++) {\n                        Option o = getOptionFromLongName(options, args[i]);\n                        if (o != null && !argIsValue(args[i])) {\n                            i++;\n                            argList.remove(argList.size()-1);\n                            continue;\n                        }\n                    }\n                }\n                    \n            CommandLine cline = new DefaultCommandLine(this.programName, argList);\n            argList.clear();\n                \n            return cline;\n        }\n\t};\n    CommandLine firstCL = parser.parse(opts, firstArgs);\n    CommandLine secondCL = parser.parse(opts, secondArgs);\n\n    System.out.println(\"Done brokenExample\");\n}",
