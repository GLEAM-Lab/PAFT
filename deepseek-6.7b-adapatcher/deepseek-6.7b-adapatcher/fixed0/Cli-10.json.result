    "patch_code": "private static void setProperlyParsed(CommandLine line) {\n        if (line != null) {\n            int indexOfLastNonParsableArgument = -1;\n            for (int i = 0; i < line.getArgList().size(); ++i) {\n                String arg = line.getArgList().get(i);\n                if (!arg.startsWith(\"-\")) {\n                    continue;\n                }\n                String optionStr = OptionBuilder.removeLeadingHyphens(arg);\n                if (optionStr.length() == 0) {\n                    throw new IllegalArgumentException(\"Empty option string\");\n                }\n                ++indexOfLastNonParsableArgument;\n                char optionChar = optionStr.charAt(0);\n                if (optionChar == 'h') {\n                    ++indexOfLastNonParsableArgument;\n                    break;\n                } else {\n                    indexOfLastNonParsableArgument += OptionBuilder.splitAndStoreOptionParts(line.getOptionValues(),\n                            optionStr);\n                }\n            }\n            line.setParsableArguments(new ArgumentList() {\n                @Override\n                public List<String> subList(int fromIndex, int toIndex) {\n                    return ArgumentList.super.subList(fromIndex, toIndex);\n                }\n\n                @Override\n                public int size() {\n                    return ArgumentList.this.size() - indexOfLastNonParsableArgument;\n                }\n\n                @Override\n                public String get(int index) {\n                    return ArgumentList.this.get(indexOfLastNonParsableArgument + index);\n                }\n\n                @Override\n                public Iterator<String> iterator() {\n                    return new Iterator<String>() {\n                        private int current = indexOfLastNonParsableArgument;\n\n                        @Override\n                        public boolean hasNext() {\n                            return current < size();\n                        }\n\n                        @Override\n                        public String next() {\n                            return get(current++);\n                        }\n\n                        @Override\n                        public void remove() {\n                            throw new UnsupportedOperationException(\"Not supported yet.\");\n                        }\n                    };\n                }\n            });\n        }\n    }",
