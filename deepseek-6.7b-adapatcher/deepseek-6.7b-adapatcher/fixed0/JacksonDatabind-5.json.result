    "patch_code": "protected boolean _hasVisibleMethodsExcludingAllFromSuperClasses(Class<?> cls, Class<?> superToCheckForVisibility) {\n    for (Class<?> c = cls; c!=null && c!=superToCheckForVisibility ;c = c.getSuperclass()) {\n      Method[] meths = c.getDeclaredMethods();\n      int count = 0;\n      if (meths.length > 0) {\n          for (Method method : meths) {\n              if (!Modifier.isAbstract(method.getModifiers())) {\n                  if(!_isIgnorableMethodNameOrAnnotation(method)){\n                      count++;\n                  }\n              }\n          }\n       }\n     if (count > 0) {\n         return true;\n     }\n   }\n  return false;\n}",
