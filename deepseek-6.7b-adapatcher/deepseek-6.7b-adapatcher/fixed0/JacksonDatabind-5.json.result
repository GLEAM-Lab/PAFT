    "patch_code": "protected void _addMethodMixIns(Class<?> targetClass, AnnotatedMethodMap methods,\n        Class<?> mixInCls, AnnotatedMethodMap mixIns)\n{\n    Set<String> seenParents = new HashSet<String>();\n    List<Class<?>> parents = new ArrayList<Class<?>>();\n    parents.add(mixInCls);\n    ClassUtil.findSuperTypes(mixInCls, targetClass, parents);\n    boolean processAll = false;\n    int max = 0;\n    while (true) {\n        int startSize = seenParents.size();\n        List<Class<?>> todoAdditions = new ArrayList<Class<?>>();\n        for (Class<?> current : parents) {\n            if (!seenParents.contains(current.getName())) {\n                seenParents.add(current.getName());\n                todoAdditions.addAll(Arrays.asList(current.getInterfaces()));\n                if (_shouldProcessJavaNIOClasses && ((current == FileDescriptor.class) || (current == Channel.class))) {\n                    // special case handling; these classes contain only static fields / methods\n                    processAll = true;\n                } else {\n                    for (Method m : current.getDeclaredMethods()) {\n                        if (!processAll && (!_isIncludableMemberMethod(m))) {\n                            continue;\n                        }\n                        AnnotatedMethod am = methods.find(m);\n                        if (am == null) {\n                            methods.add(new SimpleEntry<>(m,\n                                MethodSerializer.forCreator(mixInCls, m).withView(null)));\n                        } else {\n                            methods.update(m, mixIns.get(am.getPlainName()).value());\n                        }\n                    }\n                    if (!processAll) {\n                        break;\n                    }\n                }\n            }\n        }\n        max += seenParents.size()-startSize;\n        if ((max >= MAX_LOOKUP_DEPTH) || (todoAdditions.isEmpty())) {\n            break;\n        }\n        parents.clear();\n        parents.addAll(todoAdditions);\n    }\n}",
