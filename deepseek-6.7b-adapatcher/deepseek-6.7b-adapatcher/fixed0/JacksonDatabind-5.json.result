    "patch_code": "protected void _addMethodMixIns(Class<?> targetClass, AnnotatedMethodMap methods,\n        Class<?> mixInCls, AnnotatedMethodMap mixIns)\n{\n    // Original logic to construct the parent classes list was incomplete\n    Set<Class<?>> parents = new LinkedHashSet<>();\n    parents.addAll(ClassUtil.findSuperClasses(targetClass));\n    parents.removeIf(x -> x == Object.class || x == Comparable.class);\n    \n    // Add back the mixInCls at the end of the list\n    parents.add(mixInCls);\n        \n    for (Iterator<Class<?>> itr = parents.iterator(); itr.hasNext(); ) {\n        Class<?> currentParent = itr.next();\n        boolean foundWithJsonProperties = false;\n        if (_methodExportsByInterfaceType.containsKey(currentParent)) {\n            // special case for Interfaces: they define exports AND inherit from them\n            foundWithJsonProperties = true;\n            Collection<String[]> defsForCurrIfc = _methodExportsByInterfaceType.get(currentParent);\n            if (defsForCurrIfc != null && !defsForCurrIfc.isEmpty()) {\n                List<JsonProperty> propDefList = _propsPerInterfaceType.get(currentParent);\n                Iterator<String[]> iterProps = defsForCurrIfc.iterator();\n                while (iterProps.hasNext()) {\n                    try {\n                        Method toAdd = _methodFromDefinition(iterProps.next(), currentParent);\n                        if ((toAdd != null) && (_methodsToExportOrIgnore.indexOf(toAdd) < 0)) {\n                            mixIns.add(_constructMethod(toAdd));\n                            foundWithJsonProperties = true;\n                        }\n                    } catch (NoSuchMethodException e) {\n                        throw new IllegalArgumentException(\"Illegal call w/ undefined method in introspection data\");\n                    }\n                }\n            }\n        }\n        if (!foundWithJsonProperties) {\n            for (Method m : currentParent.getDeclaredMethods()) {\n                if (!_isIncludableMemberMethod(m)) {\n                    continue;\n                }\n                AnnotatedMethod am = methods.find(m);\n                /* Do we already have a method to augment (from sub-class\n                 * that will mask this mixIn)? If so, add if visible\n                 * without masking (no such annotation)\n                 */\n                if (am != null) {\n                    _addMixUnders(m, am);\n                } else {\n                    mixIns.add(_constructMethod(m));\n                }\n            }\n        }\n    }\n}",
