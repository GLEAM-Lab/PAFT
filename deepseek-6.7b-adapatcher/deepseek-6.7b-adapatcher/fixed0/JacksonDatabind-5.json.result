    "patch_code": "protected void _addMethodMixIns(Class<?> targetClass, AnnotatedMethodMap methods,\n        Class<?> mixInCls, AnnotatedMethodMap mixIns)\n{\n    LinkedList<Class<?>> parents = new LinkedList<>();\n    ClassUtil.findSuperClasses(targetClass, parents::addFirst);\n    Iterator<Class<?>> iter = parents.iterator();\n    \n    while (iter.hasNext()) {\n        Class<?> nextParent = iter.next();\n        \n        if (mixInCls == nextParent || modules.hasMixIn(_config, mixInCls, nextParent)) {\n            break;\n        }\n        for (Method m : nextParent.getDeclaredMethods()) {\n            if (_isExcludedByDefault(m)) {\n                continue;\n            }\n            \n            boolean overrideIfExists = false;\n            boolean requiredForAll = false;\n            int j = 0;\n            int k = mixIns.size();\n            int l = m.getModifiers() & Modifier.ABSTRACT;\n            \n            final AccessorOverride[] overrides;\n            try {\n                overrides = getAccessorOverrides(targetClass, nextParent);\n            } catch (NoSuchMethodException ex) {\n                throw new IllegalStateException(\"Failed to read accessor override information: \" + ex,\n                        ex);\n            }\n            assert overrides != null;\n            \n            for (;;) {\n                if (j >= k && l > 0) {\n                    _skipUnoverriddenMethod(targetClass, m);\n                    break;\n                }\n                if (j < k) {\n                    final AnnotatedMethod existing = methods.find(overrides[j]);\n                    if ((existing != null && !_canSkipMethod(_config, mixIns, existing, requiredForAll, false))\n                            || l <= 0) {\n                        break;\n                    }\n                    ++j;\n                    continue;\n                }\n                if (!modules.hasMixInOrIgnore(mixInCls, nextParent)) {\n                    break;\n                }\n                requiredForAll = true;\n                l -= mixIns.addIgnoringClassInfo(m).size();\n                break;\n            }\n        }\n    }\n}",
