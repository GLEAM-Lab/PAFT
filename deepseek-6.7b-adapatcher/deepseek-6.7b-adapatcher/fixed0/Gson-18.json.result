    "patch_code": "static Type getSupertype(Type context, Class<?> contextRawType, Class<?> supertype) {\n    // Wildcards can't cause problems here - they are handled when expanding class parameters or method parameters\n   if (!supertype.equals(contextRawType)) {\n     Preconditions.checkState(!supertype.isInterface(), \"Context must not be an interface\");\n     try {\n       Object o = contextRawType.newInstance();\n       if (supertype.isInstance(o)) {\n         return ParameterizedTypeImpl.make(context, supertype, new Type[]{});\n       } else {\n         Field[] fields = contextRawType.getDeclaredFields();\n         for (int i = 0; i < fields.length; i++) {\n           Class<?> fieldRawType = fields[i].getType();\n           if (fieldRawType != null && fieldRawType == supertype) {\n             int modifiersAfterFieldDeclaration = FIELD_DECLARATION_MODIFIERS & ~Modifier.FINAL;\n             if ((fields[i].getModifiers() & modifiersAfterFieldDeclaration) == 0) {\n               return ParameterizedTypeImpl.make(context, FieldParameterizedType.forField(fields[i]), new Type[]{});\n             }\n           }\n         }\n       }\n     } catch (InstantiationException e) {\n       throw new AssertionError(e);\n     } catch (IllegalAccessException e2) {\n       throw new AssertionError(e2);\n     }\n   }\n   return context;\n}",
