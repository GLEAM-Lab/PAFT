    "patch_code": "private static final class WildcardMatchingAdapterFactory implements JsonDeserializer<Object> {\n\n  public Object deserialize(JsonElement json, Type typeOfT, JsonDeserializationContext context) throws JsonParseException {\n    \n    if (!(typeOfT instanceof ParameterizedType)) {\n      throw new JsonParseException(\"cannot handle \" + typeOfT);\n    }\n    ParameterizedType parameterizedType = (ParameterizedType) typeOfT;\n\n    if ((parameterizedType.getRawType() != Map.class && !(parameterizedType.getRawType() == ArrayList.class)) ||\n        Arrays.asList(parameterizedType.getActualTypeArguments()).size() != 2 || \n        parameterizedType.getActualTypeArguments()[0] != String.class) {\n      throw new JsonParseException(\"Expecting a map of string key to list value\");\n    }\n\n    Type entryType = parameterizedType.getActualTypeArguments()[1];\n    if (!(entryType instanceof ParameterizedType)) {\n      throw new JsonParseException(\"cannot handle \" + entryType);\n    }\n    entryType = ((ParameterizedType)entryType).getActualTypeArguments()[0];\n      \n    if (entryType != SmallClass.class) {\n      throw new JsonParseException(\"Unexpected Entry Class \" + entryType);\n    }\n      \n    return context.deserialize(json, Map.class);\n  }\n}\n\npublic class Test {\n  private static Gson gson = new GsonBuilder()\n                             .registerTypeAdapter(Object.class,new WildcardMatchingAdapterFactory())\n                             .create();\n\n  public static void main(String args[]){\n    String s = \"{\\\"inBig\\\": {\\\"key\\\": [{\\\"inSmall\\\": \\\"hello\\\"}]}}\";        \n    System.out.println(gson.fromJson(s, BigClass.class).inBig.get(\"key\").get(0).inSmall);  \n  }\n}",
