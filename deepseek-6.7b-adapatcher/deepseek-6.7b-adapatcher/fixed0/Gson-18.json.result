    "patch_code": "static Type getSupertype(Type context, Class<?> contextRawType, Class<?> supertype) {\n   if(supertype != null && Collection.class.isAssignableFrom(supertype)){\n        //For cases like List<T> or Set<T> \n       return GenericTypeResolver.resolveTypeArgument(context.getTypeName(), Collection.class);\n   }else{\n         //In other cases, it's already been processed. Ignore it now.\n       return context;\n   }\n    \n}",
