    "patch_code": "public class TypesTest {\n     static void testGetSupertype() throws Exception {\n         try {\n             System.out.println(\"------------------------\");\n             System.out.println(\"| getSupertype\");\n             System.out.println();\n         \n             testGetSupertype_a();\n             testGetSupertype_b();\n         \n             System.out.println(\"DONE!\");\n         } catch (AssertionError e) {\n             System.err.print(e.getMessage());\n         }\n     }\n      \n   private static void testGetSupertype_a() {\n        Class<?> rawContext = ArrayList.class;\n        Class<?> rawTypeVariable = Iterable.class;\n        Type context = new ArrayList<>();\n        Type actual = getSupertype(context, rawContext, rawTypeVariable);\n        assertSame(\"/Iterable\", context.toString(), ((ParameterizedTypeImpl) actual).getActualTypeArguments()[0].toString());\n    }\n  \n    private static void testGetSupertype_b() {\n        Class<?> rawContext = Collection.class;\n        Class<?> rawTypeVariable = Iterable.class;\n        Type context = new ArrayList<>();\n        Type actual = getSupertype(context, rawContext, rawTypeVariable);\n        assertSame(\"Ljava.lang.Object;\", ((ParameterizedTypeImpl) actual).getActualTypeArguments()[0].toString());\n    }\n\n    /** @throws java.lang.ClassCastException if {@code type} isn't assignable from {@code rawType}. */\n    public static Type getSupertype(Type context, Class<?> rawContext, Class<?> rawTypeVariable) {\n        if (!rawTypeVariable.isAssignableFrom(rawContext)) {\n            throw new AssertionError(\"\\n\" +\n                    \"\\n  Expected:\\n\\n\" +\n                    \"      \" + rawTypeVariable + \".class.isAssignableFrom(\" + rawContext + \".class)\\n\" +\n                    \"\\n  But was:\\n\\n\" +\n                    \"      !\" + rawTypeVariable + \".class.isAssignableFrom(\" + rawContext + \".class)\\n\");\n        }\n        \n        ParameterizedType parameterizedType = null;\n        if (context instanceof ParameterizedType) {\n            parameterizedType = (ParameterizedType) context;\n        } else if (context instanceof GenericArrayType) {\n            Type componentType = ((GenericArrayType) context).getGenericComponentType();\n            if (componentType instanceof ParameterizedType) {\n                parameterizedType = (ParameterizedType) componentType;\n            }\n        } else if (context instanceof TypeVariable) {\n            Type superclass = ((TypeVariable) context).getBounds()[0];\n            if (superclass instanceof ParameterizedType) {\n                parameterizedType = (ParameterizedType) superclass;\n            }\n        }\n\n        if (parameterizedType == null || !rawTypeVariable.equals(parameterizedType.getRawType())) {\n            // Return Object.class as a fallback. This could happen when working with interfaces or simple classes.\n            return Object.class;\n        }\n        return parameterizedType;\n    }\n    \n    private static void assertSame(String expected, String actual) {\n        if (!Objects.equals(expected, actual)) {\n            throw new AssertionError(\"\\nExpected: \\\"\" + expected + \"\\\"\\n\" +\n                    \" but was: \\\"\" + actual + \"\\\"\");\n        }\n    }\n    \n    interface IExtendsIterable extends Iterable {}\n    \n    static class MyList implements IExtendsIterable {\n\n        @Override\n        public Iterator iterator() {\n            return new Iterator() {\n                \n                int i = 0;\n                \n                @Override\n                public boolean hasNext() {\n                    return i < 3;\n                }\n\n                @Override\n                public Object next() {\n                    ++i;\n                    return \"Hello\";\n                }\n            };\n        }\n        \n    }\n}",
