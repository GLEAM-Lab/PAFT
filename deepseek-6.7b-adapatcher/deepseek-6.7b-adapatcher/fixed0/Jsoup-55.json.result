    "patch_code": "void read(Tokeniser t, CharacterReader r) {\n    char c = r.consume();\n    switch (c) {\n        case '/':{\n            if(!t.tagPending.attributes.isEmpty()) {\n                String key = t.tagPending.attributes.peekLast().key;\n                String value = t.tagPending.attributes.peekLast().value;\n                key += \"/\";\n                value = value.substring(1);\n                t.tagPending.attributes.removeLast();\n                t.tagPending.attributes.add(new Attribute(key, value));\n            }else {\n               t.tagPending.selfClosing = true; \n            }\n            \n            t.transition(AfterSelfClosingSlashInTag);\n            break;\n        }\n        case '>':\n            t.tagPending.selfClosing = true;\n            t.emitTagPending();\n            t.transition(Data);\n            break;\n        case eof:\n            t.eofError(this);\n            t.transition(Data);\n            break;\n        default:\n            t.unexpectedCharacterError(c);\n            t.transition(AfterAttributeName);\n    }\n}",
