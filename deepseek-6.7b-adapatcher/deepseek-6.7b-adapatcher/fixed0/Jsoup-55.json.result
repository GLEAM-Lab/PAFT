    "patch_code": "void read(Tokeniser t, CharacterReader r) {\n    char c = r.consume();\n    switch (c) {\n        case '/':\n            t.previousTokenType = Token.TagEnd;\n            t.returnConsumedCharacter();\n            t.tagPending.close = true;\n            t.emitTagPending();\n            t.transition(Data);\n            break;\n        case '>':\n            t.tagPending.selfClosing = true;\n            t.emitTagPending();\n            t.transition(Data);\n            break;\n        case eof:\n            t.eofError(this);\n            t.transition(Data);\n            break;\n        default:\n            t.error(this);\n            t.transition(BeforeAttributeName);\n    }\n}",
