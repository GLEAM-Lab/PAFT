    "patch_code": "void read(Tokenised t, Character Reader r) {\n    char c = r. consume();\n    switch (c) {\ncase '>':\n    t. tagPending. selfClapping = true; t. emit tag Pending(); t. transition(data); break;\ncase ' /':\n    t. transition(before <br> after space); break;\ncase eof: t. eofError(this); t. transition(data); break;\ndefault: t. error(this); t. transition(before <br> after space); break;\n    }\n}",
