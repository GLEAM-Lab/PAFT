  {
    "patch_code": "void read(Tokeniser t, CharacterReader r) throws IOException {\n    char c = r.read();\n    if (Character.isWhitespace(c)) {\n        throw new IOException(\"Parse error at \" + t.line + \":\" + t.col);\n    } else if (c == '>') {\n        t.tagPending.selfClosing = !r.markSupported() || r.getMark() == 0;\n        t.emitTagPending();\n        t.transition(Data);\n    } else if (c == eof) {\n        t.eofError(this);\n        t.transition(Data);\n    } else {\n        StringBuilder attributeValueBuffer = new StringBuilder();\n        do {\n            attributeValueBuffer.append(c);\n            c = r.read();\n            if (c < 0) throw new IOException(\"Unexpected EOF\");\n        } while (!(c instanceof Characters.EQUALS));\n        \n        // The previous part was the same as before. This part deals with attributes with slashes.\n        String attrVal = attributeValueBuffer.toString();\n        int splitIdx = attrVal.indexOf(\"/\");\n        if (splitIdx >= 0 && splitIdx + 1 < attrVal.length()) {\n            String leftPart = attrVal.substring(0, splitIdx).trim();\n            String rightPart = attrVal.substring(splitIdx+1).trim();\n            String name = t.tagPending.name + \"/\" + leftPart;\n            \n            Token token = new StartTag(name, false);\n            t.tokens.add(token); \n            \n            t.attrKeyPending = null;\n            t.attributeValues.push(new AttributeValue(rightPart));\n        } else {\n            t.attributes.put(t.tagPending.name + \"/\" + t.attrKeyPending, attrVal);\n            t.attrKeyPending = null;\n        }\n        \n        t.transition(AfterAttributeValueQuoted);\n    }\n}",
