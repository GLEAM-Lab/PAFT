  {
    "patch_code": "void read(Tokeniser t, CharacterReader r) {\n    char c = r.consume();\n    StringBuilder sb = new StringBuilder();\n    boolean hasSlash = false;\n    while(!Character.isWhitespace(c)){ \n        if(c == '/'){\n            hasSlash = true;  \n        }else if (!hasSlash && !Character.isLetterOrDigit(c)) {\n            throw error(r);\n        } else if (hasSlash && !Character.isLetterOrDigit(c)) {\n            throw error(r);\n        }else{\n            sb.append(c);    \n        }\n        \n        c = r.next();\n    }\n    if (!Character.isUpperCase(sb.charAt(0))) {\n        t.attrKeyPending.setLength(0);\n        t.emitAttrKeyPending(sb.toString());\n        t.emitCurrentNodeIfNecessary(true);\n        t.currentNode.attributes.put(sb.toString(), \"\");\n        t.transition(AfterAttributeValue);\n    } else {\n        t.tagPending.name = sb.toString().toLowerCase();\n        t.emitTagPending();\n        t.currentNode = null;\n        t.stateHistory.push(t.state);\n        t.state = BeforeStartTag + 1;\n    }\n}",
