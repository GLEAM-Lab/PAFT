    "patch_code": "void read(Tokenised t, Character Reader r) {\n    char c = r. consume();\n    switch (c) {\ncase '>':\n    t. tagPending. selfClinging = true;\n    t. emit TagPending();\n    t. transition(data);\n    break;\ncase ' /' :\n    t. transition(beforePairwiseValue);\n    break;\ncase eof:\n    t. eof error(this);\n    t. transition(data);\n    break;\ndefault:\n    t. error(this);\n    t. transition(before pairwise value);\n    break;\n}\n}",
