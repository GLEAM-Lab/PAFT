    "patch_code": "private static final int ERROR_HANDLE = 1024 + 36; // this number doesn't have any special meaning\n\npublic class Tokenizer extends AbstractTokenizer{\n    \n    @Override\n    public Token nextToken(){\n        \n        ...\n        if (slash){\n            \n            if (!inTag && !atEndOfInput){\n                \n                inTag = true;\n                tagStartedAt = inputOffset - 1;\n                emit(new StartTagToken(\"\"));\n            }else {\n                \n                error(ERROR_HANDLE,\"Unexpected slash\");\n            }\n            consume();\n            continue;\n        }\n        \n        ...\n      \n        if (isLetter() || c == '\\'' || c == '_') {\n                    startTagName = append(startTagName, c);\n                    lastWasQuoteOrUnderScore = c == '\\'';\n                    lastWasEqualsSignAfterTagName = false;\n                    eatLettersAndSymbol('\\'', false);\n                    eatLettersAndSymbol('_');\n                    return null;\n                } else if (Character.compare(c, '-') == 0) { \n                    inComment = true;\n                    return null;\n                } else if (lastWasQuoteOrUnderScore && Character.compare(c,'>')==0){\n                    \n                    String name  = text().substring(tagStartedAt+1 , inputOffset - 1).toLowerCase();\n                    currentToken = new EndTagToken(name);\n                    reset();\n                    state = DATA_STATE;\n                    return currentToken;\n                }else{\n                    return tokenFromCurrent();\n                }\n    }\n    \n    private boolean lastWasQuoteOrUnderScore;\n    private boolean lastWasEqualsSignAfterTagName;\n    private void eatLettersAndSymbol(char quotMark, boolean checkLastCharacterAlso){\n        while(!atEndOfInput){\n            char chr = more();\n            if(chr == quotMark){\n                if((checkLastCharacterAlso ? lastChar() : characterAt(inputOffset))!=quotMark )break;\n            }else if(!isLetterOrDigit(chr)){\n                break;\n            }\n        }\n    }\n\n    private boolean isLetter(){\n        return !atEndOfInput&&(characterAt(inputOffset) >= 'A' && characterAt(inputOffset) <= 'Z' || \n                               characterAt(inputOffset) >= 'a' && characterAt(inputOffset) <= 'z');\n    }\n\n    private boolean atEndOfInput(){\n        return characterAt(inputOffset) == -1;\n    }\n\n    private boolean eat(int cp){\n        return peek(0) == cp && consume();\n    }\n\n    private char nextChar(){\n        if(!atEndOfInput){\n            throw new ArrayIndexOutOfBoundsException(position + \":\" + stringPosition);\n        }\n        return data[position++];\n    }\n    \n}",
