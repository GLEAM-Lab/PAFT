    "patch_code": "private InputStream getCurrentStream() throws IOException {\n    if (deferredBlockStreams.isEmpty()) {\n        throw new IllegalStateException(\"No current 7z entry (call getNextEntry() first).\");\n    }\n    \n    int i = 0;\n    boolean endOfBlocksFound = false;\n    while (i < deferredBlockStreams.size()) {\n        final InputStream stream = deferredBlockStreams.get(i);\n        \n        if (!endOfBlocksFound && stream instanceof BlockInputStream) {\n            final long skipBytes = ((BlockInputStream) stream).getSkipBytesCount();\n            \n            if (skipBytes == -1L) {\n                // Skip until EOF\n                IOUtils.skipFully(stream);\n            } else if (skipBytes > 0L) {\n                // If skip count isn't zero or EOF, then this isn't just an\n                // artificial block input stream but rather contains real data.\n                endOfBlocksFound = true;\n            }\n        }\n        \n        if (endOfBlocksFound || i + 1 >= deferredBlockStreams.size()) {\n            final InputStream resultStream = deferredBlockStreams.remove(i);\n            \n            if (!endOfBlocksFound && stream != null && resultStream != stream) {\n                stream.close();\n            }\n            \n            return resultStream;\n        }\n        \n        i++;\n    }\n\n    assert(false);\n    return null;\n}",
