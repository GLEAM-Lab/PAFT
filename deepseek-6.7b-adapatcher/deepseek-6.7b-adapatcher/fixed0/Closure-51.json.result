    "patch_code": "void addNumber(double x) {\n  if (!Character.isDigit(getLastChar())) {\n    if (x == 0) return;\n    if (Double.isInfinite(x)) {\n      add((x < 0 ? \"-\" : \"\") + \"Infinity\");\n    } else if (Double.isNaN(x)) {\n      add(\"NaN\");\n    } else if (x < 0 || x >= Long.MAX_VALUE) {\n      assert false;\n    } else if (x > -Long.MIN_VALUE) {\n      assert false;\n    } else {\n      add(String.format(\"%.\" + 2 /* DIGITS - 1 */ + \"g\", x));\n    }\n  } else {\n    super.addNumber(x);\n  }\n}",
