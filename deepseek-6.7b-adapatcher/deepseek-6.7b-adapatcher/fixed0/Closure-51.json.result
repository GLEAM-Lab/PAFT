    "patch_code": "void addNumber(double x) {\n  String formatX = String.format(\"%f\", x);\n  \n  if(formatX.indexOf('-', 2)!= -1){\n    \n    int index_minus = formatX.indexOf('-');\n    int index_dot = formatX.indexOf('.');\n    \n    for(int i = formatX.length()-1; i >= index_dot;i-- ){\n      \n      \n      if((formatX.charAt(i))=='0'){\n        \n        continue ;\n        \n      }else {\n        \n        break ;\n        \n      }\n    }\n    \n    \n    add(formatX);\n  }else {\n    if ((long) x == x) {\n      long value = (long) x;\n      long mantissa = value;\n      int exp = 0;\n      if (Math.abs(x) >= 100) {\n        while (mantissa / 10 * Math.pow(10, exp + 1) == value) {\n          mantissa /= 10;\n          exp++;\n        }\n      }\n      if (exp > 2) {\n        add(Long.toString(mantissa) + \"E\" + Integer.toString(exp));\n      } else {\n        add(Long.toString(value));\n      }\n    } else {\n      add(String.valueOf(x));\n    }\n  }\n\n}",
