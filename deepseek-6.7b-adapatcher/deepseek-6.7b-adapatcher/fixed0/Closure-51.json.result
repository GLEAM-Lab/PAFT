    "patch_code": "import java.math.BigDecimal;\nimport java.text.DecimalFormat;\n\npublic class CodeConsumer extends JavaScriptCodeGenerator{\n    \n   void addNumber(double x){\n       DecimalFormat df = new DecimalFormat(\"#\");\n       String output = df.format(x);\n       boolean negativeFlag = false;\n       if (output.charAt(0) == '-'){\n           negativeFlag = true;\n       }\n\n       try {\n           Long.parseLong(df.format(x));\n\n           BigDecimal b = new BigDecimal(Double.toString(x));\n\n           if (!negativeFlag && b.signum() == 0) {\n               out.write(' ');\n           } else {\n               out.write(output);\n           }\n       }catch (Exception e){\n           double mantisa;\n           \n           mantisa = Double.parseDouble(output);\n           int exp = 0;\n\n           while((mantisa -= Math.floor(mantisa))!=0){\n               exp++;\n               mantisa *= 10;\n           }\n\n           if(exp<=2 || !negativeFlag ) {\n               out.write(Double.toString(Double.parseDouble(output)));\n           }else{\n               String numPart  = Double.toString(mantisa / 10);\n               \n               while(numPart.endsWith(\"0\")){\n                   numPart = numPart.substring(0 , numPart.length()-1);\n               }\n               \n               if(!negativeFlag){\n                    out.write(numPart+\"E-\"+(exp-1));\n               }else{\n                   out.write(\"-\"+numPart+\"E-\"+(exp-1));\n               }\n           }\n       }\n   }\n}",
