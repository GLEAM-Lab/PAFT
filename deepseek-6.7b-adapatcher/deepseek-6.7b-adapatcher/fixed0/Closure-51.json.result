    "patch_code": "void addNumber( double x ){\n  char previous = getLastchar();\n  char current = 'x' ;\n  if( x != 0 ){\n    if( x > 0 && previous == '-'){\n      add(\" \");\n    }\n    if((long) x == x){\n      long value = (long) x;\n      long value1 = value;\n      int exp = 0 ;\n      if( x == 0 || x != 0 && x * 10 == 0 ){\n        add(\"0\"); return ;\n      }\n      if( x > 0 && x< 10 || x < 0 && x > -10 ){\n        add( String.valueOf( value ); return ;\n      }\n      while( value1 / 10 * (int pow(10 , exp + 1)) == value ){\n        value1 /= 10 ;\n        exp++;\n      }\n      if( exp > 2 ){\n        add( String.valueOf( value ) + \"e\" + String.valueOf( exp ); return ;\n      }else{\n        add( String.valueOf( value ); return ;\n      }\n    }else{\n      add( String.valueOf( x ); return ;\n    }\n  }else{\n    add( String.valueOf( x ); return ;\n  }\n}",
