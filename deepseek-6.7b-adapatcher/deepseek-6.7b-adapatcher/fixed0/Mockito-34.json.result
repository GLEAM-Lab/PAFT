    "patch_code": "import org.mockito.Mockito;\n\npublic void captureArgumentsFrom(Invocation i) {\n    Mockito.framework().matcher(this);\n    Object[] arguments = i.getArguments();\n    int sizeOfArguments = arguments.length;\n    \n    if(sizeOfArguments == 0){\n       return;\n    }\n    \n    int k = 0;\n    Matcher[] matchers = getMatchers();\n    int sizeOfMatchers = matchers.length; \n        \n    while(k < sizeOfArguments && k < sizeOfMatchers){\n        if (matchers[k] instanceof CapturesArguments) {\n             ((CapturesArguments) matchers[k]).captureFrom(arguments[k]);\n        }\n         k++;\n    }\n}",
