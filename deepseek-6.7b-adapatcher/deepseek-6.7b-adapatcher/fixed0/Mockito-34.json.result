    "patch_code": "import org.mockito.exceptions.Reporter;\nimport org.mockito.internal.invocation.Invocation;\nimport org.mockito.internal.matchers.CapturesArguments;\nimport org.mockito.internal.matchers.Matcher;\n\nimport java.util.List;\n\npublic class InvocationMatcher implements Matcher<Object> {\n  private final List<Matcher<?>> matchers;\n\n  public InvocationMatcher(List<Matcher<?>> matchers) {\n    this.matchers = matchers;\n  }\n\n  @Override\n  public boolean matches(Object o) {\n      throw new UnsupportedOperationException(\"Stub!\");\n  }\n  \n  @Override\n  public void describeTo(Reporter reporter) {\n      throw new UnsupportedOperationException(\"Stub!\") ;\n  }\n    \n  public void captureArgumentsFrom(Invocation i){\n      int j=0;\n      for(Matcher m:matchers){\n          if(m instanceof CapturesArguments){\n              try{\n                  ((CapturesArguments) m).captureFrom(i.getArguments()[j]);\n              } catch (IndexOutOfBoundsException e){\n                  Reporter. reporting(new IndexOutOfBoundsException(\"Argument index \" + j + \" does not exist.\"));\n              }\n              \n          }\n          j++;\n      }\n  }\n  \n}",
