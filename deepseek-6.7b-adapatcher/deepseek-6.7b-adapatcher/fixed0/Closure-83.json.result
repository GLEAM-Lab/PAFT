    "patch_code": "import java.util.*;\npublic class CommandLineRunner extends com.google.javascript.jscomp.AbstractCompiler {\n  List<String> errors = new ArrayList<String>();\n  boolean verboseFlag = false;\n  \n  public int run() {\n    try {\n      Parameters parameters = getParameters();\n      for(String param : parameters) {\n        if(!parseArgument(param)){\n          printUsageAndExit();\n        }\n      }\n      \n      if (!initialize()) {\n        exit(COMPILATION_ERROR);\n      }\n      \n      compileProgram();\n      return COMPILATION_SUCCESSFUL;\n    } catch(Exception e){\n      System.out.println(\"Error occurred while processing command-line flags.\\n\");\n      e.printStackTrace();\n      exit(-1);\n    }\n  }\n  \n  private void usage(){\n    Properties props = new Properties();\n    try{\n      props.load(new FileInputStream(\"/home/alexander/Documents/closureCompilerProperties\"));\n    }catch(FileNotFoundException e){\n      System.err.println(\"Cannot find properties file.\");\n    }catch(IOException e){\n      System.err.println(\"Problem reading property file.\");\n    }\n    \n    System.out.println(props.getProperty(\"usageHeader\")+\"\\n\");\n    System.out.println(props.getProperty(\"globalOptions\"));\n    System.out.println(\"\\t--verbose\");\n    System.exit(0);\n  }\n  \n  private boolean parseArgument(String argument) {\n    String temp;\n    boolean optionSet = false;\n    try {\n      if (argument.startsWith(\"--\")) { // Process flag\n        temp = argument.substring(2);\n        if (\"version\".equalsIgnoreCase(temp)) {\n          \n          showVersionInfo();\n        }else if (\"help\".equalsIgnoreCase(temp)) {\n          \n          usage();\n        }else if (\"verbose\".equalsIgnoreCase(temp)) {\n          \n          verboseFlag = true;\n          optionSet = true;\n        }\n        \n      } else if (argument.startsWith(\"-\")) { // Short form\n        char[] chars = argument.toCharArray();\n        Arrays.sort(chars);\n        if (Arrays.toString(chars).equals(\"-v\")) {\n          \n          verboseFlag = true;\n          optionSet = true;\n        }\n      } else {\n        addInputFilename(argument);\n      }\n      return optionSet;\n    } catch (CmdLineException e) {\n      \n      System.err.println(e + \"\\n\");\n      usage();\n    }\n    return false;\n  }\n}",
