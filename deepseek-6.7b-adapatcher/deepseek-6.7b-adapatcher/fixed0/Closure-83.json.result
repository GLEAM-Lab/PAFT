    "patch_code": "import java.util.*;\npublic int parseArguments(List<String> args) throws CmdLineException {\n  ArrayList<String> argArray=new ArrayList<>(args);\n  for(Iterator<String> iterator=argArray.iterator(); iterator.hasNext();){\n    String arg=iterator.next();\n   // System.out.println(\"parameter:\"+parameter);\n    if(Objects.equals(arg,\"--version\")){\n        setter.addValue(true);\n        PrintVersionInformation();\n        \n       break ;\n        \n    }else if (!arg.startsWith(\"-\")){\n        continue;\n    }\n     String parameter=arg.substring(2);\n     if (\"verbose\".equalsIgnoreCase(parameter)){\n       \n         verbosityLevel++;\n         continue;\n         \n     }if (\"quiet\".equalsIgnoreCase(parameter)){\n         \n         verbosityLevel=0;\n         \n         \n     }else if(\"help\".equalsIgnoreCase(parameter)){\n         \n         printUsageAndExit(0);\n         \n     }else if(!parseFlagArgument(parameter))return -1;\n     iterator.remove();\n    \n  }\n  if(argArray.isEmpty())printUsageAndExit(-1);\n  return argArray.size();\n}\n\nstatic void PrintVersionInformation(){\n\n  System.out.println(\"\\nClosure Compiler\\nVersion: 698\\nBuilt on: 2011/01/17 12:16\");\n  \n  \n}\n\npublic static boolean checkJavaVersion() {\n    java.lang.String version = System.getProperty(\"java.version\");\n    if (Double.parseDouble(version.split(\"_\")[1]) < 1.5 ) {\n        System.err.println(\"Sorry, this program requires Java 1.5 or higher.\");\n        return false;\n    }\n    return true;\n}",
