    "patch_code": "import java.util.*;\n\npublic class CommandLineRunner extends com.google.javascript.jscomp.CommandLineRunnerBase {\n    \n  public static void main(String[] args) {\n        Parameters params = new Parameters(Arrays.asList(args), false);\n        System.exit((new CommandLineRunner()).run(params));\n    }\n  \n   private static final Set<String> TRUES =\n            new HashSet<>(Arrays.asList(\"\", \"true\"));\n\n    @Override\n    protected boolean run(final Parameters parameters) {\n        String param = parameters.getParameter(0);\n        \n        if (\"--help\".equalsIgnoreCase(param)) {\n            printUsageAndExit();\n            return true;\n        }\n\n        if (!parameters.allFlagsParsed()) {\n            throw new UsageException(\"Unknown flags\");\n        }\n        \n        if (\"--version\".equalsIgnoreCase(param)) {\n            System.out.println(getProductInfo() + \"\\n\\nOptions:\\n\"+ getOptions());\n            \n            return true;\n        }\n        return super.run(parameters);\n    }\n}",
