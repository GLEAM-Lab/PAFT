    "patch_code": "import org.apache.commons.math3.analysis.UnivariateRealFunction;\n\npublic class BisectionSolver extends UnivariateRealSolverImpl {\n    \n    public void setFunction(UnivariateRealFunction f) {\n        this.f = f;\n    }\n    \n    private UnivariateRealFunction f;\n\n    public double solve(double min, double max) throws MaxIterationsExceededException, FunctionEvaluationException {        \n        if (f == null){\n            throw new IllegalArgumentException(\"The given function cannot be null\");\n        }\n        final double valueMin = evaluate(min);\n        final double valueMax = evaluate(max);\n        if (!isBracketed(valueMin, valueMax)) {\n            throw new NoBracketFoundException();\n        }\n        for (int i = 0; i < maximumIterations; ++i) {\n            final double middlePoint = (min + max) / 2.0;\n            final double valueMiddlePoint = evaluate(middlePoint);\n            if (Math.abs(valueMiddlePoint) <= absoluteAccuracy) {\n                return middlePoint;\n            } else if ((i >= maximumIterations)) {\n                throw new MaxIterationsExceededException();\n            } else if (DoubleComparator.DEFAULT.compare(valueMiddlePoint, 0.0) > 0) {                \n                max = middlePoint;\n            }else{\n                min = middlePoint;\n            }\n        }\n        return min;\n    }\n}",
