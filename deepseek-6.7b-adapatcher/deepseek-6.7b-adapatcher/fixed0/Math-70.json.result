    "patch_code": "public double solve(final UnivariateRealFunction f, double min, double max)\n        throws MaxIterationsExceededException, FunctionEvaluationException {\n    this.function = f;\n    final int limit = getMaxEvaluations();\n    if (!validateInterval()) {\n        throw new IllegalStateException(\"The initial interval does not bracket a root.\");\n    }\n    for (int i = 0; i < limit; ++i) {\n        final double midPoint = (max + min) * 0.5;\n        final double evalAtMidpoint = f.value(midPoint);\n        if (DoubleUtil.isZero(evalAtMidpoint)) {\n            break;\n        } else if (DoubleComparator.COMPARATOR.compare(max - min, getAbsoluteAccuracy()) <= 0) {\n            ++i; // Do one more evaluation because it's almost there already.\n            break;\n        } else {\n            if ((DoubleComparator.COMPARATOR.compare(evalAtMidpoint, 0.0d) < 0 && DoubleComparator.COMPARATOR.compare(f.value(min), 0.0d) < 0) ||\n                    (DoubleComparator.COMPARATOR.compare(evalAtMidpoint, 0.0d) > 0 && DoubleComparator.COMPARATOR.compare(f.value(min), 0.0d) > 0)) {\n                min = midPoint;\n            } else {\n                max = midPoint;\n            }\n        }\n    }\n    return (max + min) * 0.5;\n}",
