    "patch_code": "public class BisectionSolver implements Solver{\n    private UnivariateRealFunction f;\n    \n    public void setF(UnivariateRealFunction func){\n        this.f = func;\n    }\n        \n    public double solve(double min, double max){\n        if(this.f == null){\n            throw new NullPointerException(\"The UnivariateRealFunction f is not initialized.\");\n        }\n        double middlePoint = 0.0;\n        while((max - min) > PRECISION ){\n            middlePoint = (min + max)/2;\n            \n            if(DoubleUtils.isPositive(this.f.valueAt(middlePoint))){\n                max = middlePoint;\n                \n            } else if(DoubleUtils.isNegative(this.f.valueAt(middlePoint))) {\n                min = middlePoint;\n                \n            } else {\n                break;\n            }\n        }\n       return middlePoint;\n    }\n     \n    @Override\n    public double solve(final UnivariateRealFunction f, double min, double max, double initial) throws MaxIterationsExceededException , FunctionEvaluationException{\n          setF(f);\n          return solve(min,max);\n    }\n}",
