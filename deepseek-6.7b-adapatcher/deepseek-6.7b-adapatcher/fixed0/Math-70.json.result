    "patch_code": "public double solve(final UnivariateRealFunction f, double min, double max, double initial)\n        throws MaxIterationsExceededException, FunctionEvaluationException {\n    if (initial < min || initial > max) {\n        throw new IllegalArgumentException(\"Initial guess must lie in [min,max]\");\n    }\n    this.function = f;\n    return solve(min, max);\n}",
