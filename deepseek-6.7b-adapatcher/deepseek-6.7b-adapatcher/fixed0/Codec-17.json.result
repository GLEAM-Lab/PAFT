    "patch_code": "import org.apache.commons.lang3.CharSet;\nimport java.io.*; \nimport java.util.*;\n\npublic class Main{\n     public static void main(String args[]){\n        System.out.println(\"Hello World\");\n        \n        try {\n            File file = new File(\"./src/text.txt\");\n            FileReader fr = new FileReader(file);\n            BufferedReader br = new BufferedReader(fr);\n            \n            String line;\n            while ((line=br.readLine()) != null){\n                String [] stringsArray = line.split(\" \");\n                    for (int i = 0; i < stringsArray.length; i++){\n                        if (stringToBinary(stringsArray[i]) == \"\") break;\n                        else System.out.print(stringToBinary(stringsArray[i]));\n                        \n                     }\n                System.out.print(\"\\r\\n\");  \n              }\n          \n          }catch(Exception e){\n            e.printStackTrace();\n        }\n      }\n      \n      private static String stringToBinary(String s){\n        String binary = \"\";\n        char[] chars = s.toCharArray();\n        for(char c : chars){\n            binary += Integer.toString((int) c,2).replace(' ', '0');\n        }\n      \n        return binary;\n      }\n  }",
