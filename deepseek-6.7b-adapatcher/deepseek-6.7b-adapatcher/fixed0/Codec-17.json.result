    "patch_code": "import org.apache.commons.lang3.CharSet;\n\npublic class Main{\n\n    public static void main(String []args){\n        System.out.println(StringUtils.newStringIso8859_1(null));  // Outputs: null\n    }\n\n}\nclass StringUtils {\n    \n    private static final Charset ISO_8859_1 = Charset.forName(\"ISO-8859-1\");\n\n    /**\n     * Create a new string using specified encoding, handling {@code null}.\n     *\n     * @param bytes The bytes to create a string from.\n     * @param charset The char set name to use when creating the string.\n     * @return A new string created from the specified bytes. This could be {@code null} if the provided bytes array is also {@code null}, or if the charset is unknown or null.\n     */\n    public static String newString(final byte[] bytes, final Charset charset) {\n        return bytes == null ? null : new String(bytes, charset);\n    }\n\n    public static String newStringIso8859_1(final byte[] bytes) {\n        return newString(bytes, ISO_8859_1);\n    }\n\n}",
