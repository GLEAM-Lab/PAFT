    "patch_code": "import org.apache.commons.lang3.CharSet;\nimport org.apache.commons.lang3.CharEncoding;\n\npublic class MainClass { \n    public static void main(String []args){ \n        System.out.println(newStringIso8859_1(null)); // Returns null\n    }\n    \n    public static String newStringIso8859_1(byte[] bytes) {\n        if(bytes == null || bytes.length == 0){\n            return null;\n        } else{\n          return new String(bytes, Charset.forName(CharEncoding.ISO_8859_1));  \n        }        \n    } \n}",
