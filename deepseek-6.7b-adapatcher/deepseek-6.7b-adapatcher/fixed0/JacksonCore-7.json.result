    "patch_code": "public int writeValue() throws IOException {\n    switch(_next.getType()) {\n    case ID_START_OBJECT: {\n        startObject();\n        break;\n    }\n\n    case ID_END_OBJECT: {\n        endObject();\n        break;\n    }\n\n    case ID_START_ARRAY: {\n        startArray();\n        break;\n    }\n\n    case ID_END_ARRAY: {\n        endArray();\n        break;\n    }\n\n    default: \n        throw new IOException(\"Unhandled data type \" + _next);\n    }\n\n    if (!hasMoreTokens()) {\n        _status = STATUS_DONE;\n    } else {\n        _status = STATUS_BEFORE;\n    }\n    return _status;\n}",
