    "patch_code": "public boolean writeValue(int statusAfterValue, String fieldNameToUse) throws IOException {\n \n    if (!isOk()) {\n        throw new IllegalStateException(\"No current value to start writing\");\n    }\n \n    /* We got name or index - can only be name */\n    if (fieldNameToUse != null && _currentName != null ){\n        throw new IllegalArgumentException(\"JsonWriteContext.writeValue(): Can only call with null OR without 'fieldName', but found both.\");\n    }else if ((statusAfterValue & JsonStreamConstants.STATUS_HAS_NEXT_FIELD) == 0){\n         setCurrentName(null); // clear cache for later lookups.\n    } else {\n        if( fieldNameToUse != null) { \n            setCurrentName(fieldNameToUse);\n            _jg.serialize(new MinimalArraySerializer._1()); \n            _jg._setCurrentValue(_values[_valueIndex], _types[_valueIndex]);  \n            resetValueBuffer();\n            ++_idxOfValuesList;\n        } else {\n            --_index;\n        }\n    }\n \n    /* Now what we have depends on next:\n    /  array starts (or array element after colon):\n     */\n    if ((statusAfterValue & JsonStreamConstants.STATUS_START_ARRAY) > 0) {\n        _type = TYPE_ARRAY;\n        _valuesStart = _index;\n        ++_index;\n        return true;\n    }\n    ++_index;\n    return false;\n}",
