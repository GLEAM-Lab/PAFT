    "patch_code": "public abstract class TokenStream implements Resettable {\n  private static final long serialVersionUID = 485192630067663002L;\n  \n  protected char[] buf = new char[256];\n  protected int next = 0;\n  protected transient AttributeSourceImpl attribs;\n  \n  public void reset(char[] text, int offset, int length){\n      synchronized (this){\n          System.arraycopy(text, offset, this.buf, 0, length);\n          this.next = length;\n          this.attribs = null;\n      }\n  }\n  \n  public boolean incrementToken() throws ParseException{\n       throw new UnsupportedOperationException();\n  }\n  \n  public final String getAttribute(String name){\n      if(name==null || !MultiThreaded.isMultithreaded()){\n          throw new IllegalArgumentException(\"Not support\");\n      }\n      if(attribs == null){\n          return null;\n      }\n      synchronized(attribs){\n          Object value = attribs.getFeature(name);\n          return (value instanceof String)? (String)value : null;\n      }\n  }\n  public void setAttribute(String name,Object value){\n      if(name==null||value==null||!MultiThreaded.isMultithreaded()){\n           throw new IllegalArgumentException(\"null input\");\n      }\n      if(attribs == null){\n          attribs = new AttributeSourceImpl();\n      }\n      synchronized(attribs){\n          attribs.setFeature(name,value);\n      }\n  }\n  public CharTermAttribute termAtt(){\n      return (CharTermAttribute)getAttribute(CoreAttributes.TermAtt);\n  }\n  public OffsetAttribute offsetAtt(){\n      return (OffsetAttribute)getAttribute(CoreAttributes.OffsetAtt);\n  }\n  public TypeAttribute typeAtt(){\n      return (TypeAttribute)getAttribute(CoreAttributes.TypeAtt);\n  }\n}",
