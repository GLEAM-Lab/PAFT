    "patch_code": "public int writeValue(int statusAfterValue, boolean allowNoContent) throws IOException {\n    // Most likely, object:\n    if (_type == TYPE_OBJECT) {\n        _gotName = false;\n        ++_index;\n        return STATUS_OK_AFTER_COLON + statusAfterValue;\n    }\n\n    // Ok, array?\n    if (_type == TYPE_ARRAY) {\n        int ix = _index;\n        ++_index;\n        if ((statusAfterValue & VALUE_IS_NULLISH) != 0) {\n            allowNoContent = true;  // can skip on empty values\n        }\n        return (ix < 0) ? STATUS_OK_AS_IS | statusAfterValue : STATUS_OK_AFTER_COMMA | statusAfterValue;\n    }\n    \n    // Nope, root context\n    // No commas within root context, but need space\n    ++_index;\n    if (!allowNoContent && ((statusAfterValue & VALUE_HAS_CONTENT) == 0)) {\n        throw new IllegalStateException(\"Cannot write content after top-level value\");\n    }\n    return STATUS_OK_AS_IS | statusAfterValue;\n}",
