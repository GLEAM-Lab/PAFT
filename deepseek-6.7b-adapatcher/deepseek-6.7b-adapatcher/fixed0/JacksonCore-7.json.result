    "patch_code": "public int writeValue(boolean allowScalarAsArrayItem) throws IOException {\n    switch(_next(true)) {\n    case 'n': \n        return _handleNull();\n    case ',': \n        throw new MalformedMessageException(\"Can not generate string value after comma\");\n    default: \n        String s = TextUtil._valueToEscapedUTF8(_current());\n        final boolean isEmptyStr = (TextUtil.noHexInJSON(s)) && (_tmpBuffer == null);\n        if (!allowScalarAsArrayItem && ((isEmptyStr && (_type != '{')) || \"\".equals(s))) {\n            throw new IllegalStateException(\"Scalar (number or boolean) as an array item cannot be written using scalar serialization.\");\n        }\n\n        _current('\"');\n        _append(s);\n        _current('\"');\n        if ((allowScalarAsArrayItem) && (_type == '[')) {\n            ++_arrayParamsCount;\n        } else if ((allowScalarAsArrayItem) && (_type != '{')) {\n            ++_fieldNamesCount;\n        }\n        return STATUS_OK_AFTER_VALUE;\n    }\n}",
