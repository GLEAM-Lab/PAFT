  {
    "patch_code": "private void visitCall(NodeTraversal t, CallNode cn, Node parent) {\n  JSType calleeType = getJSType(cn.getFunction());\n  JSType resultType;\n\n  switch (calleeType.types.size()) {\n    case 1: {\n      JSExpression e = cn.getObject();\n      if ((e == null || !hasProperties(e)) && cn.isMethodInvocation()) {\n        reportNoSuchMethod(t, cn);\n        return;\n      }\n      break;\n    }\n\n    default:\n      break;\n  }\n\n  Object[] args = cn.getArguments().toArray();\n  if (!cn.isConstructorCall()) {\n    resultType = validator.findCommonSupertype(args, t, cn);\n    if (resultType == null) {\n      throw new RuntimeException(\"couldn't find common supertype\" + Arrays.toString(args));\n    }\n    if (parent instanceof ReturnNode && resultType != UNDEFINED && resultType != NULL) {\n      resultType = UNDEFINED;\n    }\n  }\n  else {\n    assert args.length > 0;\n    resultType = new NamedType((String) args[args.length - 1]);\n  }\n\n  cn.setType(resultType);\n\n  Env env = validator.envAtCalleeOf(t, cn);\n  env.putNames(new NamesFromList(t, cn.getFunction()), cn.getFunction());\n\n  try {\n    handlePossibleExceptions(t, cn);\n  } finally {\n    validator.popEnvironments();\n  }\n  t.visitChildren(cn);\n}",
