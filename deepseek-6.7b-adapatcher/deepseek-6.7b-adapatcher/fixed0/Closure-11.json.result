    "patch_code": "private void visitGetprop(Node traverse,Node node,Node parent){\n  // obj.prop or obj. method()\n  // lot of types can appear on left side, call to void function can never be on leftside. getPropertyType will decides what is possible and what is not possible.\n Node property=node.getlastchild();\nNode objNode=node.getfirstchild();\nJSType childType=getJSType( objNode);\nif(childType.is Dict()) {\n  report(traverse,property,TypeValidator.ILlegalsproperty access,\"'.'\", \" Dict\");\n}else if(node.getJSType() != null && parent.is Assign()) {\nreturn ;\n} else if(validator. expectnotnullordefined(traverse,node, childType, \" No properties on this expression\", get NativeType(Object_type))){\ncheckProperty access(childType, property.getString(), traverse, node);\n}\nensureTyped(traverse, node);\n}",
