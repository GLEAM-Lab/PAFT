  {
    "patch_code": "private void visitGetProp(NodeTraversal t, Node n, Node parent) {\n  // obj.prop or obj.method()\n  // Lots of types can appear on the left, a call to a void function can\n  // never be on the left. getPropertyType will decide what is acceptable\n  // and what isn't.\n  Node property = n.getLastChild();\n  Node objNode = n.getFirstChild();\n  String childName = property.getString();\n  JSType childType = getJSType(objNode);\n  if (childType == null || childType == OBJECT_TYPE) {\n     if (!((scopeStack.peek().hasOwnBinding(childName)) || \n           (scopeStack.peek().parentScope.hasOwnBinding(childName)))){\n        scopeStack.push(new VariableSet());\n      \n     }\n     return;\n  }\n  else{\n      childType = getNonFunctionJsType(childType);\n  }\n  if (childType instanceof DictionaryType) {\n    report(t, property, TypeValidator.ILLEGAL_PROPERTY_ACCESS, \"'.'\", \"dict\");\n  } else if (n.getJSType() != null && parent.isAssign()) {\n    return;\n  } else if (validator.expectNotNullOrUndefined(t, n, childType,\n      \"No properties on this expression\", getNativeType(OBJECT_TYPE))) {\n    checkPropertyAccess(childType, childName, t, n);\n  }\n  ensureTyped(t, n);\n}",
