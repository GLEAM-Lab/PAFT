    "patch_code": "private boolean validThisAnnotation = true;\n\nprivate void ensureTyped(NodeTraversal t, Node n) {\n    Env env = t.getEnv();\n    if (!env.hasClosure()) {\n        return;\n    }\n    FunctionContext context = env.getFunctionContext();\n    if ((context == null) || (validThisAnnotation)) {\n        return;\n    }\n\n    Variable propVar = new Variable(\"property\");\n    Closure closure = env.getClosure(new FrameIndex());\n    context.addLocalVariable(propVar, true);\n    closure.setIncidentalsSize(closure.incidentalsSize() + 1);\n    Variable variableToAdd  = new Variable(\"toAdd\");\n    context.addLocalVariable(variableToAdd , false);\n}\n\nprivate boolean verifyPropType(NodeTraversal t, Variable variableToVerify ){\n    if (getDeclaredProperties().containsKey(variableToVerify.getOriginalName())){\n        Set<String> declaredProps =  getDeclaredProperties().get(variableToVerify.getOriginalName());\n        String errMsg = String.format(ERR_MESSAGE_INVALID_PROPERTY,\"@this\",variableToVerify );\n        reportErrorIfInvalidProp(errMsg,t,declaredProps);\n        validThisAnnotation = declaredProps.contains(variableToVerify .getName());\n        return declaredProps.contains(variableToVerify .getName());\n    }\n     validThisAnnotation = false;\n    return false;\n}\n\n\nprivate void visitGetProp(NodeTraversal t, Node n, Node parent) {\n  ...\n  if(!verifyPropType(t,n.getLastChild())){\n     reportInvalidProprty(n,t);\n   }\n  ...\n}\n\npublic static final ErrorBundle ERR_MESSAGE_INVALID_PROPERTY =\n        new DefaultErrorBundle(\"ERROR_INVALID_%s_ANNOTATED_PROPERTY_%s\",\"\");",
