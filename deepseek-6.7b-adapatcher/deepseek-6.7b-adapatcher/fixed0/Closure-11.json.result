  {
    "patch_code": "private void visitGetProp(NodeTraversal t, Node n, Node parent) {\n  Node property = n.getLastChild();\n  Node objNode = n.getFirstChild();\n  if (!property.getString().equals(\"this\")){\n    reportMissingPropertiesForFunctionOrObject(t, n,parent,objNode,property);\n    return;\n  }\n  JSType childType = getJSType(objNode);\n  boolean isObjOrCallResult = false;\n  if (childType instanceof AstObject || (objNode instanceof AstCall)) {\n    isObjOrCallResult = true;\n  }else {\n    reportError(\"Cannot access 'this' outside a method.\", childType.getSourceNameRange());\n    return ;\n  }\n  PropertyMap propMap  = validator.contexts.peekPropertyMaps().peek();\n  String propertyName =  ((AstIdent)property).name_;\n  int numOfErrorsBefore = errors_.size();\n  if(!propMap.hasPropertyWithName(propertyName)){\n    reportError(\"Property '\"+propertyName+\"' does not exist on this object.\",((AstIdent)property).nameRange_);\n    return;\n  }\n  Property prop = propMap.getPropertyByName(propertyName);\n  if(!prop.checkPublic() ){\n    reportError(\"Private members cannot be accessed from inside classes\",\"\");\n    return;\n  }\n  if(!isInAnnotatedContext(Annotation.ANNOTATEDCONTEXT.THIS)){\n    reportError(\"Only objects or methods can have the @this annotation.\",\"\");\n    return;\n  }\n  if(errors_.size() == numOfErrorsBefore){\n    ensureTyped(t,n,objNode , propMap);\n  }\n\n}",
