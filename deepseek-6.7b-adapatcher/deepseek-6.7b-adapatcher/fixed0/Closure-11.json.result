    "patch_code": "private void visitGetprop(Node traversal, node n, node parent) {\n  node property = n.getLast child();\n  node objnode = n.getfirstchild();\n  JSType childtype = getJSType( objnode );\n\n  if (childtype.is Dict()) {\n    report(traversal, property, TypeValidator.ILlegalsproperty access, '\".' + n.getstring());\n  } else if (n.getJSType() ! null && parent.iss Assign()) {\n    return;\n  } else if (validator. expect not null or undefined(traversal, n, childtype, \"no properties on this expression\", get Native type(object type)) {\n    checkproperty access(childtype, property.getString(), traversal, n);\n  }\n  ensureTyped(traversal, n);\n}",
