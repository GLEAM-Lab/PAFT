    "patch_code": "private void visitCall(NodeTraversal t, Node n, Node parent) {\n  Node receiver = n.getFirstChild();\n  JSType recvType = getJSType(receiver);\n  String methodName = n.getLastChild().getString();\n  boolean staticCall = false;\n  boolean hasValidReceiverType = true;\n  if (recvType == JSType.VOID || (!validator.canHaveSideEffects(receiver)) ){\n    reportErrorOnNullaryMethodCallWithVoidResult(receiver,methodName );\n  }else if (!hasStaticMemberOrInitializer(n)){\n    if (recvType == null || recvType == JSType.NULL ||\n        (recvType != JSType.NATIVE && recvType != JSType.PLAIN_OBJECT)) {\n      reportInvalidNonObjectInFunctionCall(receiver, methodName, \"non-object\", \"function\");\n      hasValidReceiverType = false;\n    }\n  } else if(!hasStaticMemberOrInitializer(n)){\n    if (recvType.isInterface()|| recvType.isDict()){\n      reportInvalidNonObjectInFunctionCall(receiver, methodName,\n            recvType.toString(),\"function\");\n      hasValidReceiverType = false;\n    \n    }\n  } else if(!hasValidReceiverType){\n    return;\n  }\n  if (staticCall || hasValidReceiverType){\n    checkCallArguments(receiver , methodName ,parent.getChildren());\n  }\n  \n}",
