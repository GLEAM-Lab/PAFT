    "patch_code": "private void visitGetPropertyCall(Node traversal,Node node) {\n  String propertyName=node.getFirst().getString();\n  JSType type=getJSType(node.getLast());\n  if (!type.isNull()) {\n    checkProperty accessor=getProperty accessor(type);\n    if (!checkProperty accessor.getProperty accessor.getpropertyName().isEmpty()) {\n      if (!checkProperty accessor.getProperty accessor.getProperty accessor.getpropertyName(). contains(propertyName)) {\n        report(traversal, node, TypeValidator.ILlegAL_PROPERTy_ACcessor, \" propertyName=\"+propertyName+\" type=\"+type);\n      }\n    }\n  } else if (!type.isDict()) {\n    report(traversal, node, TypeValidator.ILlegAL_PROPERTy_ACcessor, \" propertyName=\"+propertyName);\n  }\n}",
