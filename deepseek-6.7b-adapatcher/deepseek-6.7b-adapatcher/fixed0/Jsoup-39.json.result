  {
    "patch_code": "static Document parseByteData(ByteBuffer byteData, String charsetName, String baseUri, Parser parser) {\n    \n    Document doc = null;\n    if (charsetName == null) { // determine from meta. safe parse as UTF-8\n        \n        doc = parser.parse(new InputStreamReader(new ByteArrayInputStream(new ByteBuffer[]{byteData})));  \n        \n        Elements metas =  doc.select(\"meta[http-equiv=content-type], meta[charset]\");\n      \n        boolean movedToBody = false;\n        for (Element element : metas){\n          \n          if (element.attributes().get(\"http-equiv\") != null && element.attributes().get(\"http-equiv\").containsIgnoreCase(\"Content-Type\")){\n            \n              if (element.attributes().get(\"content\").contains(\"text/html\")){\n                  if (!element.parentNode().tagName().equals(\"head\")){\n                      ((HtmlTreeBuilder.Tag){element.parent()}.moveTo(doc.body());\n                      movedToBody = true;\n                  }\n              }\n              \n          }else if (element.attributes().get(\"charset\") != null){\n              \n              if (!element.parentNode().tagName().equals(\"head\")){\n                   ((HtmlTreeBuilder.Tag){element.parent()}.moveTo(doc.body());\n                     movedToBody = true;\n                 }\n              }\n          }\n      }\n      \n      \n        \n        if(!movedToBody){\n            Element headOrFirstChildOfHead = doc.select(\"head\").isEmpty() ? doc.body().childNodes().get(0) : doc.select(\"head\").first();\n            ListIterator<Node> iterator = new ArrayList<>(new NodeList(){doc.body().childNodes()}).listIterator();\n            while(iterator.hasNext()){\n                Node node = iterator.next();\n                if((node instanceof org.jsoup.nodes.Document.Element) && ((org.jsoup.nodes.Document.Element) node).tagName().equalsIgnoreCase(\"script\")){\n                    continue;\n                }\n                iterator.previous();\n                iterator.add(headOrFirstChildOfHead);\n                break;\n            }\n        }\n      \n       \n    } else { // specified by content type header (or by user on file load)\n        \n        InputStream inputStream = new ByteArrayInputStream(new ByteBuffer[]{byteData});\n        doc = Jsoup.parse(inputStream, charsetName ,baseUri);\n        \n    }\n    return doc;\n}",
