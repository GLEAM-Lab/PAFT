    "patch_code": "if (!docData.startsWith(\"\\ufeff\") || docData.startsWith(\"\\ufffe\")){ // UTF-16 Byte Order Marker\n                int length = byteData.limit();\n                byte [] bytes = new byte[length];\n                byteData.get(bytes, 0 ,length);\n                docData = new String(bytes, StandardCharsets.UTF_16LE);\n                docData = docData.substring(1);\n                charsetName = \"UTF-16\";  \n        }else if(!docData.startsWith(\"\\uffef\")){// UTF-32 Byte Order Marker\n                int length = byteData.limit();\n                byte [] bytes = new byte[length];\n                byteData.get(bytes, 0 ,length);\n                docData = new String(bytes, StandardCharsets.UTF_32LE);\n                docData = docData.substring(1);\n                charsetName = \"UTF-32\";        \n      }\n               else if (docData.length() > 0 && docData.charAt(0) == 65279) {// uncommon utf encoding which uses BOM\n                byteData.rewind();\n                docData = Charset.forName(defaultCharset).decode(byteData).toString();\n                docData = docData.substring(1);\n                charsetName = defaultCharset;    \n    }",
