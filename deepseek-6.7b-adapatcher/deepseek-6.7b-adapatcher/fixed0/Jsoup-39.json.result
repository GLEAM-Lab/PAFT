    "patch_code": "static document myPrepare(String url) {\n    document doc = null;\n    try {\n        doc = document.load(url);\n        document head = doc.select(\"head\");\n        document body = doc.select(\"body\");\n        List<element> elements = head.select(\"*\");\n        for (element element : elements) {\n            body.append(element.outer());\n        }\n        head.select(\"*\"). clear();\n    } catch (IOException e) {\n        e.print Stack Trace();\n    } finally {\n        return doc;\n    }\n}",
