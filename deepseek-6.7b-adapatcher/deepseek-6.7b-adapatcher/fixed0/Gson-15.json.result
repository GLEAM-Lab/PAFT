    "patch_code": "public JsonWriter value(double value) throws IOException {\n  writeDeferredName();\n  if (mode == Mode.LENIENT && (Double.isNaN(value) || Double.isInfinite(value))) {\n      try {\n          if(value == Double.POSITIVE_INFINITY){\n              append(\"\\\\u221E\");\n          }else{\n             append(\"-\\\\u221E\");  \n          }\n          \n          return this;\n      } catch (NumberFormatException nfe) {\n          throw new AssertionError();\n      }\n  } else if (!lenient && (Double.isNaN(value) || Double.isInfinite(value))) {\n      throw new IllegalArgumentException(\"Numeric values must be finite, but was \" + value);\n  }\n  beforeValue();\n  out.append(Double.toString(value));\n  return this;\n}",
