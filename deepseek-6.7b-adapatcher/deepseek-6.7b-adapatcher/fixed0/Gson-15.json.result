    "patch_code": "public JsonWriter value(double value) throws IOException {\n  writeDeferredName();\n  if (mode == Mode.LENIENT) {\n    if ((Double.isNaN(value) || Double.isInfinite(value))) {\n       switch ((int)value) {\n         case 0x7ff8 :\n           afterValue('\"', 'N');\n           break;\n         case 0xFFF8 :\n           afterValue('\"', '-');\n           afterValue('i', 'n');\n           afterValue('f', 'i');\n           afterValue('i', 't');\n           afterValue('y','\"');\n           break;\n        default:\n          throw new IllegalArgumentException(\"Numeric values must be finite, but was \" + value);\n     }\n   } else {\n     if (Double.isNaN(value)||Double.isInfinite(value)) {\n       throw new IllegalArgumentException(\"Numeric values must be finite, but was \" + value);\n     }\n     beforeValue();\n     out.append(Double.toString(value));\n   }\n  return this;\n}",
