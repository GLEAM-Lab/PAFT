    "patch_code": "import org.joda.time.*;\npublic class TimeSeriesTest{\n\tpublic static void main(String[] args)throws Exception {\n\t\tDateTime dt1=new DateTime(2005,4,19,0,0);\n\t\tDateTime dt2=new DateTime(2005,5,25,0,0);\n\t\tDateTime dt3=new DateTime(2005,5,28,0,0);\n\t\tDateTime dt4=new DateTime(2005,5,30,0,0);\n\t\tDateTime dt5=new DateTime(2005,6,1,0,0);\n\t\tDateTime dt6=new DateTime(2005,6,3,0,0);\n\t\tDateTime dt7=new DateTime(2005,8,19,0,0);\n\t\tDateTime dt8=new DateTime(2006,1,31,0,0);\n\t\tXYDataset ds = DatasetUtilities.sample_xy(dt1,dt2,dt3,dt4,dt5,dt6,dt7,dt8);\n\t\tTimeSeries series = (TimeSeries)ds.getSeries(0);\n\t\tint cnt =series.getItemCount();\n\t\tfor (int i = 0 ;i <cnt ;i ++){\n\t\t\tSystem.out.println(series.getX(i) +\"=> \"+ series.getY(i));\n\t\t}\n\t\tDateTime beginDate = new DateTime(2005,12,1).withTimeAtStartOfDay(),endDate= new DateTime(2006,1,18).withTimeAtStartOfDay();\n\t\tInterval interval = new Interval(beginDate , endDate);\n\t\tseries = series.subseriesBy(interval);\n\t\tcnt = series.getItemCount();\n\t\tfor (int i = 0 ;i <cnt ;i ++){\n\t\t\tSystem.out.println(series.getX(i) +\"=> \"+ series.getY(i));\n\t\t}\n\t\t\n\t}\n}",
