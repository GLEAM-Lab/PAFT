    "patch_code": "import org.jfree.data.time.*;\nimport org.jfree.data.general.*;\nimport java.text.*;\n\npublic class TimeSeriesExample{\n   static public void main(String args[]){\n      TimeSeries dataset = new TimeSeries(\"BDT\");\n      SimpleDateFormat formatter = new SimpleDateFormat(\"dd/MM/yyyy\");\n      \n      Date date=null;\n      double value= 0d;\n\t  \n\t  try{\n         date=formatter.parse(\"21/10/2015\");\n         value= 52.6;\n      }catch(ParseException e1){\n         System.out.println(\"Erreur dans l'analyse de la date !\");\n         \n\t\t \n         return;\n      }\n      \n      \n      dataset.addOrUpdate(new Millisecond(date.getTime()), new DefaultObservation(value));\n\ntry{\n         date=formatter.parse(\"25/10/2015\");\n         value= 52.7;\n      }catch(ParseException e1){\n         System.out.println(\"Erreur dans l'analyse de la date !\");\n         \n\t\t \n         return;\n      }\n\n      \n      dataset.addOrUpdate(new Millisecond(date.getTime()), new DefaultObservation(value));\n\n      try{\n         date=formatter.parse(\"28/10/2015\");\n         value= 52.4;\n      }catch(ParseException e1){\n         System.out.println(\"Erreur dans l'analyse de la date !\");\n         \n\t\t \n         return;\n      }\n\n      \n      dataset.addOrUpdate(new Millisecond(date.getTime()), new DefaultObservation(value));\n\n      \n      TimeSeries clone_ds  = null;\n      try{\n         date=formatter.parse(\"21/10/2015\");\n         Millisecond ms1 = new Millisecond(date.getTime());\n          \n         date=formatter.parse(\"25/10/2015\");\n         Millisecond ms2 = new Millisecond(date.getTime());\n        \n\n        \n         clone_ds = dataset.createCopy(ms1,ms2);\n\n      \n     for(int i = 0 ;i< clone_ds.getItemCount()-1;i++){\n           Object obsrvn = clone_ds.getDataItem(i).getValue();\n           System.out.println(((Number)obsrvn).doubleValue());\n\t}\n\n\n     }catch(Exception e ){\n      e.printStackTrace();\n    }\n   }\n}",
