    "patch_code": "public TimeSeries createCopy(Day start, Day end)\n    throws CloneNotSupportedException {\n    \n    if (!containsKey(start))\n        add(start, Double.NaN);\n    if (!containsKey(end))\n        add(end, Double.NaN);\n        \n    if (start.after(end)) {\n        throw new IllegalArgumentException(\n                \"Requires start on or before end.\");\n    }\n    boolean emptyRange = false;\n    int startIndex = getIndex(start);\n    if (startIndex < 0) {\n        startIndex = ~startIndex ;\n        if (startIndex >= size()) {\n            emptyRange = true;  // start is after last data item\n        }\n    }\n    int endIndex = getIndex(end);\n    if (endIndex < 0) {             // end period is not in original series\n        endIndex = ~endIndex ; // this is first item AFTER end period\n        endIndex--;    // so this is last item BEFORE end\n    }\n    if (endIndex < 0) {\n        emptyRange = true;\n    }\n    if (emptyRange) {\n        TimeSeries copy = (TimeSeries) super.clone();\n        copy.data = new ArrayList<DataItem>();\n        return copy;\n    }\n    else {\n        return createCopy(startIndex, endIndex);\n    }\n\n}",
