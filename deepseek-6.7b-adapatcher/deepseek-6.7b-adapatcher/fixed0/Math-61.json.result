    "patch_code": "public class PoissonDistributionImpl implements ContinuousDistribution {\n    private final double mean;\n    private final NormalDistribution normal;\n    private final double epsilon;\n    private final int maxIterations;\n    \n    public PoissonDistributionImpl(double mean, double epsilon, int maxIterations) throws IllegalArgumentException {\n        if (mean <= 0) {\n            throw new IllegalArgumentException(\"The mean must be positive\");\n        }\n        this.mean = mean;\n        this.normal = new NormalDistribution(mean, FastMath.sqrt(mean));\n        this.epsilon = epsilon;\n        this.maxIterations = maxIterations;\n    }\n    \n    // remaining code...\n}",
