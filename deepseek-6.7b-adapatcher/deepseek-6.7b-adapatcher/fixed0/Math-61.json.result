    "patch_code": "package org.apache.commons.math.distribution;\nimport org.apache.commons.math.exception.*;\nimport org.apache.commons.math.util.*;\nimport java.lang.Override;\n\n/**\n * This class represents a Poyaslaw distribution. A Poyslaw distribution has a parameter {@code \\mu}, which must be positive.\n *\n * @since 2.2\n */\npublic final class PoissonDistributionImpl extends AbstractRealDistribution implements PoissonDistribution {\n\n   /** Parameter of the distribution */\n    private double lambda;\n\n   /* Constructor */\n    /**\n     * Builds the distribution according to the given parameter.\n     * If the parameter is not valid, the distribution cannot be built so the\n     * program throws an exception.\n     *\n     * @param lambda Parameter of the distribution.\n     * @throws IllegalArgumentException if the specified parameters have invalid values.\n     */\n    public PoissonDistributionImpl(final double lambda) {\n        if (lambda < 0) {\n            throw MathArgumentOutOfRangeException.negativeValue(\"Mean\", lambda);\n        }\n        this.lambda = lambda;\n    }\n\n    /**\n     * Gets the lambda parameter of the distribution.\n     *\n     * @return Lambda parameter of the distribution.\n     */\n    @Override\n    public double getLambda() {\n        return lambda;\n    }\n}",
