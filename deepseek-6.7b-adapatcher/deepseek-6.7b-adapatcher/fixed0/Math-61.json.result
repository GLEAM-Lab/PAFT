    "patch_code": "package org.apache.commons.math.distribution;\n\nimport org.apache.commons.math.util.FastMath;\nimport java.io.Serializable;\n\n/**\n * Class implementing the Poisson distribution.\n */\npublic class PoissonDistribution implements RealDistribution, Serializable {\n\n    private static final long serialVersionUID = 7608654595518295074L;\n    \n    /** Parameter of the distribution. */\n    private double lambda;\n\n    /** Normal approximation of the Poisson distribution. */\n    private NormalDistribution normalApprox;\n\n    /**\n     * Create a new instance of the specified parameters.\n     * @param lambda parameter of the distribution\n     */\n    public PoissonDistribution(final double lambda) {\n        if (lambda < 0) {\n            throw new IllegalArgumentException(\"Parameter 'lambda' must be >= 0.\");\n        }\n        this.lambda = lambda;\n        normalApprox = new NormalDistribution((float) lambda, (float) FastMath.sqrt(lambda));\n    }\n\n    @Override\n    public Double getNumericalMean() {\n        return lambda;\n    }\n\n    @Override\n    public Double getNumericalVariance() {\n        return lambda;\n    }\n\n    @Override\n    public double density(final double x) {\n        validateArgument(x);\n        return normalApprox.density(x);\n    }\n\n    @Override\n    public double cumulativeProbability(final double x) {\n        validateArgument(x);\n        return normalApprox.cumulativeProbability(x);\n    }\n\n    @Override\n    public double inverseCumulativeProbability(final double p) {\n        validateProbability(p);\n        return normalApprox.inverseCumulativeProbability(p);\n    }\n\n    // Other unrelated parts of the implementation have been omitted for brevity...\n}",
