    "patch_code": "public final class PoissonDistribution implements RealDistribution {\n    \n    private final double lambda;\n    private final NormalDistribution normal;\n  \n    public PoissonDistribution(final double lambda) {\n        ArgCheck.greaterThan(lambda, 0.0, \"lambda\");\n        this.lambda = lambda;\n        normal = new NormalDistribution(lambda, FastMath.sqrt(lambda));\n    }\n\n    @Override\n    public double density(double x) {\n        ArgCheck.lessThan(x, Double.POSITIVE_INFINITY, \"x\");\n        return FastMath.exp(-lambda) * FastMath.pow(lambda, x) / factorial(x);\n    }\n\n    private long factorial(int n) {\n        long f = 1L;\n        for (int i = 1; i <= n; ++i) {\n            f *= i;\n        }\n        return f;\n    }\n\n    @Override\n    public double cumulativeProbability(double x) {\n        ArgCheck.lessThanOrEqualTo(x, Double.POSITIVE_INFINITY, \"x\");\n        return normal.cumulativeProbability(x);\n    }\n\n    @Override\n    public double getNumericalMean() {\n        return lambda;\n    }\n\n    @Override\n    public double getNumericalVariance() {\n        return lambda;\n    }\n\n    /**\n     * Generate a random number sampled from the distribution.\n     */\n    @Override\n    public int nextInt(Random rng) {\n        return normal.nextInt(rng);\n    }\n\n    @Override\n    public void reseedRandomGenerator(long seed) {\n        normal.reseedRandomGenerator(seed);\n    }\n\n    @Override\n    public long getSeed() {\n        return normal.getSeed();\n    }\n\n    @Override\n    public boolean isSupportConnected() {\n        return true;\n    }\n}",
