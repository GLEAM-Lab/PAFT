    "patch_code": "public final class PoissonDistributionImpl extends AbstractRealDistribution implements PoissonDistribution {\n    \nprivate static final long serialVersionUID = 20150719L;\n   private double lambda;\n   transient private NormalDistribution normal;\n   private double epsilon;\n   private int maxIterations;\n\n   \n\n    public PoissonDistributionImpl(double p, double epsilon, int maxIterations){\n        if (DoubleUtils.isNonNegative(p)){\n            \n            setParameters(p,epsilon,maxIterations);\n        }else{\n         \n           throw new IllegalArgumentException(\"mean must be positive or zero\");\n       }\n        \n        \n        \n        \n        \n    }\n      protected void setParameters(double lambda, double epsilon, int maxIteration) {\n        this.lambda = lambda;\n        this.normal = new NormalDistributionImpl(lambda,FastMath.sqrt(lambda));\n        this.epsilon = epsilon;\n        this.maxIterations = maxIterations;\n    }\n    @Override\n    public double probability(double x) {\n        checkBounds(x);\n        return getNumericalPrecision().computeProbability(this, x);\n    }\n\n    ...\n\n    /**\n     * {@inheritDoc}\n     */\n    @Override\n    public double cumulativeProbability(double x) {\n        checkBounds(x);\n        return getNumericalPrecision().cumulativeProbability(this, x);\n    }\n    \n    ....\n}",
