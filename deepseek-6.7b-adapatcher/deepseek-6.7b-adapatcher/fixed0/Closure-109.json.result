    "patch_code": "private Node parseContextTypeExpression(JsDocToken token) {\n    if (!isNewFunction()) throw new AssertionError();\n      TypeNode t = parseUnaryExpression();\n     JsDocComment comment;\n     boolean hasAsterisk = false;\n     while ((comment = peekJsDocComment()) != null) {\n       if (parseAnnotation()) continue;\n       String name = consumeIdentifierOrThrow(\"Illegal annotation target\");\n       List<String> identifiers = new ArrayList<>();\n       if (token == null || isTypeParameter(token)) {\n         hasAsterisk = true;\n       } else {\n         consumeAndCheckNextCharacterOrThrow(':');\n          do {\n            String nextName =\n                consumeRequiredNonKeywordIdentifierOrThrow(\"Expected parameter name in function context type\");\n            identifiers.add(nextName);\n            token = nextToken();\n           } while (!hasEol());\n       }\n       if (identifiers.size() == 0 && hasAsterisk){\n        t = TypeNodes.all();\n        continue;\n      } \n       if (identifiers.size() == 0 && isUnknownType(t)) {\n         t = TypeNodes.unknown();\n         continue;\n       } \n        t = makeCallableTypeNodeWithNamedArgs(t, identifiers);\n   }\n    return t;\n}",
