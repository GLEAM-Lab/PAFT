    "patch_code": "private Node parseContextTypeExpression(JsDocToken token) throws JsDocException {\n    if (isAny(token)) {\n      return createNode(ASTNodeType.ANY_TYPE); \n    } else if (isUnknown(token)) {\n       return createNode(ASTNodeType.UNKNOWN_TYPE);\n    } else {\n        return parseTypeName(token);\n    }\n}",
