    "patch_code": "private node getTypeNode(node node) {\n  if (!node.is node.NODE_CALL) {\n    return node;\n  }\n  if (!node.nodeType == node.NODE_CALL) {\n    return node;\n  }\n  if !node.nodeType == node.NODE_CALL {\n    return node;\n  }\n  return getTypeNode(node.nodeType);\n}",
