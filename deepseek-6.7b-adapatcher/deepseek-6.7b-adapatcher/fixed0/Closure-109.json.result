    "patch_code": "private static final String[] PARsing types = new String[] { \"function\", \"new\" };\n private node load ParseType expression(Js DocTokenToken) {\n    return load ParseType expression(null);\n}\nprivate node load ParseType expression(String types) {\n    if ( types == null || PARse types . contains( types)) {\n      return load ParseType expression(null);\n    }\n    return load ParseType expression( types);\n}\nprivate node load ParseType expression(String types) {\n    if ( types != null && types . length == 0) {\n      return null;\n    }\n    if ( types != null && types . length > 0) {\n      return new Js doc types expression( types);\n    }\n    return new Js doc types expression();\n}",
