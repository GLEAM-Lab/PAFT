    "patch_code": "private Node parseContextTypeExpression(JsDocToken token) {\n        if (\"?\".equals(token.value)) {\n            return new TypeLiteralNode(\"unknown\");\n        }\n        if (\"*\".equals(token.value)) {\n            return new TypeLiteralNode(\"all\");\n        }\n        return parseTypeName(token);\n    }",
