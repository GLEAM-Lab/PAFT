    "patch_code": "private Node parseContextTypeExpression(JsDocToken token) throws ParseException{\n    if (!isTypeIdentifier(token)) {\n      throw new ParseException(\"Expected type identifier\", token);\n    }\n  \n    String text = token.getValue();\n    if (\"?\".equals(text) || \"*\".equals(text)) {\n      return NodeBuilder.named('typeParameter', null, false, 0, token.getEnd(), false);\n    }\n    \n    int nameIndex;\n    if ((nameIndex = text.indexOf('#')) != -1 || (nameIndex = text.indexOf('.', 0)) != -1) {\n        String prefix = text.substring(0, nameIndex + 1);\n        String suffix = text.substring(nameIndex + 1);\n        return NodeBuilder.named('identifier', null, false, 0, token.getEnd(), false, true, true, false,\n                Arrays.asList(NodeBuilder.named('name', prefix)), Arrays.<Node> asList());\n    } else if (prefix != null && Object.prototype.hasOwnProperty(prefix)){\n      return NodeBuilder.named('resolvedTypeReference', prefix, false, 0, token.getEnd(), false, null);\n    }\n    return NodeBuilder.named('identifier', text, false, 0, token.getEnd(), false);\n}",
