    "patch_code": "public StringBuilder getGenericSignature(StringBuilder sb)\n{\n    _classSignature(_class, sb, false);\n    if (_parameters != null && _parameters.length > 0) {\n        sb.append(\"<\");\n        for (int i = 0 ; i < _parameters.length ; i++) {\n            Class<?> parameter = _parameters[i];\n            if (parameter == Void.TYPE) {\n                break;\n            }\n            _classSignature(parameter, sb, true);\n            if (i+1 < _parameters.length) {\n                sb.append(\", \");\n            } else {\n               sb.append(\">\"); \n            }\n        }\n     }\n    return sb;\n}",
