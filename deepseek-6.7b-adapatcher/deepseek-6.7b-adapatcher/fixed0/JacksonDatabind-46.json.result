    "patch_code": "public StringBuilder getFixedTightlyness() {\n    StringBuilder fixed = new StringBuilder();\n    int size = sb.length();\n    boolean found = false;\n    for (int i = 0; i < size; i++) {\n        char ch = sb.charAt(i);\n        if (ch == '>') {\n            fixed.append(';');\n            fixed.append('>');\n            found = true;\n        } else {\n            fixed.append(ch);\n        }\n    }\n    return fixed;\n}\n public StringBuilder getFixed() {\n    StringBuilder fixed = getFixedTightlyness();\n    int size = fixed.length();\n    boolean found = false;\n    for (int i = 0; i < size; i++) {\n        char ch = fixed.charAt(i);\n        if (! found && ch == '<') {\n            fixed.append('>');\n            found = true;\n        }\n    }\n    return fixed;\n}\npublic StringBuilder getFixed() {\n    StringBuilder fixed = getFixedTightlyness();\n    int size = fixed.length();\n    boolean found = false;\n    for (int i = 0; i < size; i++) {\n        char ch = fixed.charAt(i);\n        if (! found && ch == '<') {\n            fixed.append('>');\n            found = true;\n        }\n    }\n    return fixed;\n}\n public StringBuilder getFixedTightlyness() {\n    StringBuilder fixed = new StringBuilder();\n    int size = sb.length();\n    boolean found = false;\n    for (int i = 0; i < size; i++) {\n        char ch = sb.charAt(i);\n        if (ch == '>') {\n            fixed.append(';');\n            fixed.append('>');\n            found = true;\n        } else {\n            fixed.append(ch);\n        }\n    }\n    return fixed;\n}",
