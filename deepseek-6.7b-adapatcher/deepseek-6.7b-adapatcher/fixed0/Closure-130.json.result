    "patch_code": "private class GlobalName implements Name, Aliasable {\n  private boolean globalRead = false;\n  ...\n}\n\npublic static String findAliasedGetter(String globalVariableName) {\n  Namespace ns = currentThread().getContext().getUserCodeNamespace();\n  Name globalObjectName = ns.findOrNull(globalVariableName);\n  if (globalObjectName != null && globalObjectName instanceof GlobalName) {\n    GlobalName gn = (GlobalName) globalObjectName;\n    if (gn.globalRead) {\n      return gn.globalAliasee;\n    } else if (gn.type == Name.Type.PROPERTY) {\n      PropertyName pn = (PropertyName) globalObjectName;\n      List<Ref> refs = pn.refs;\n      for (int i = 0; i < refs.size(); i++) {\n        Ref r = refs.get(i);\n        if (r.type == Ref.Type.ALIASING_REF && r.target instanceof AliasedGetter){\n          AliasedGetter ag = (AliasedGetter) r.target;\n          return findAliasedGetter(ag.sourceName);\n        }\n      }\n    } else if (gn.type == Name.Type.FUNCTION) {\n      FunctionName fn = (FunctionName) globalObjectName;\n      Set<Binding> bindings = fn.bindings;\n      for (Binding b : bindings) {\n        Expr e = b.expr;\n        if (e instanceof GetField) {\n          GlobalName fldNm = (GlobalName)((GetField) e).field;\n          if (fldNm.globalRead) {\n            return fldNm.name;\n          }\n        }\n      }\n    }\n  }\n  return null;\n}",
