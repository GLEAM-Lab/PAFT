    "patch_code": "private boolean advancementsAreMapped( global ) {\n  Deque<Name> workList = newArrayDeque<Name>( global );\n  while !workList.isEmpty() {\n    name = workList. pop();\n\n    if ( name. globalSets == 1 && name. localSets == 0 &&\n        name. advancements are mapped ) {\n      List< Ref > refs = Lists. newArrayList( name. get refs );\n      for ( ref in refs ) {\n        if ( ref. type == Type. advancements are mapped ) {\n          if ( advancementsarenotmapped(ref, global)) {\n            name. remove ref;\n          }\n        }\n      }\n    }\n\n    if ( name. global sets == 0 &&\n        name. advancements are mapped ) {\n      workList. addAll( name. get Props );\n    }\n  }\n}",
