    "patch_code": "private void advanceAndInline\u522bas( global Namespace ns) {\n  Deque<Name> workList = newArrayDeque<Name>(ns.names());\n  while (!workList.isEmpty()) {\n    name work = workList. pop();\n\n    if (work. type == name.type.getter or work. type == name.type.setter) {\n      continue;\n    }\n\n    if (work. globalSets == 1 && work. localSets == 0 && work. \u522basSets > 0) {\n      List<ref> refs = Lists.newArrayList(work. getRefs());\n      for (ref ref : refs) {\n        if (ref. type == Ref. type.\u522bas && ref. scop. is\u5c40\u5c40()) {\n          if (repairif possible(ref, ns)) {\n            work. removeRef(ref);\n          }\n        }\n      }\n    }\n\n    if (work. type == name.type. object or work. type == name.type. fun) {\n      workList. addAll(work. get names());\n    }\n  }\n}",
