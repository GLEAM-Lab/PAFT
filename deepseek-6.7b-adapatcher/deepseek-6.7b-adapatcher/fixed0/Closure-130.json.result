    "patch_code": "private void inlineAliases(GlobalNamespace namespace) {\n  Deque<Name> workList = new ArrayDeque<>(namespace.getNameForest());\n  while (!workList.isEmpty()) {\n    Name name = workList.pollLast();\n    \n    if (name.type != Name.Type.PROPERTY || \n       name.globalSets > 0  || name.getScope().containsKey(\"eval\")) {\n      continue;\n    }\n    \n    ListIterator<Ref> i = name.getRefs().listIterator(name.getRefs().size());\n    while (i.hasPrevious()) {\n      Ref r = i.previous();\n      if (r.type == Type.ALIASING_GET && r.scope.depth() == 2) {\n        Object value = ((NamedObject)r.object).getValue();\n        if (value instanceof String) {\n          String strVal = (String)value;\n          \n          if (strVal.startsWith(\"#\") || strVal.startsWith(\"/\") || \n             strVal.endsWith(\".length\") || strVal.endsWith(\".item(\")) {\n            i.remove();\n            break;\n          }\n        } else if (value instanceof Function) {\n          i.remove();\n          break;\n        }\n      }\n    }\n    \n    if (name.type == Name.Type.OBJECTLIT) {\n      for (Entry<Expr, Name> e: name.props) {\n        workList.push(e.getValue());\n      }\n    }\n  }\n}",
