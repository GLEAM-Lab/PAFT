    "patch_code": "public class HelloWorld {\n     public static boolean isNotNil(Object x){\n          return x!=null;\n     }\n  \n     public static class Test{\n          \n       Object o1;\n    \n          \n       String b(){\n             final Object tmp=o1,tmp2=tmp==null?\"\":((CharSequence)tmp).toString(),tmp3=\" \";\n              System.out.println(\"\");\n           return \"\";\n       }\n     }\n \n     \n     \n     private static int findStringInParenthese(int startIndex, String str) {\n        if(str.charAt(startIndex)!='('||(startIndex+1>=str.length()))return -1;\n         char c;\n         do{\n           c=str.charAt(++startIndex);\n         }while(c!=')');\n        return startIndex;\n     }\n \n     private static int nextNonWhiteSpace(int pos, String s){\n         do{\n           ++pos;\n         }while(!Character.isWhitespace(s.charAt(pos)));\n         return pos;\n     }\n \n     public static void main(String[] args) {\n         String s=\",,,(346647\";\n      System.out.println(findStringInParenthese(1,s));\n     }\n}",
