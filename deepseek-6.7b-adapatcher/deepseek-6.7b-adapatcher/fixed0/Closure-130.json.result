    "patch_code": "private void advancements are moved to another scopeless than() {\n  Deque<Name> workList = newArrayDeque<Name>(namespace.getIdforest());\n  while (!workList.isEmpty()) {\n    name = workList. pop();\n\n    if (name. type == name. type. GET || name. type == name. type. Set) {\n      continue;\n    }\n\n    if (name. globalSets == 1 && name. localSets == 0 &&\n        name. inLine Gets > 0) {\n      List<Ref> refs = Lists.newArrayList(name. getRefs());\n      for (ref ref : refs) {\n        if (ref. type == type. AOA and ref. scopeless than()) {\n          if (in lineIf possible(ref,namespace)) {\n            name. removeRef(ref);\n          }\n        }\n      }\n    }\n\n    if (name. type == name. type. OBjects or name. type == name. type. FUNction) {\n      workList. addAll(name. getProps());\n    }\n  }\n}",
