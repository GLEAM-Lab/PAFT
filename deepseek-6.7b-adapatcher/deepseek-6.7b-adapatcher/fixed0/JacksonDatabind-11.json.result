    "patch_code": "public class Test {\n\tpublic static void main(String args[]){\n\t\tSomething something = new SomethingImpl();\n\t\t\n\t}\n}\n\ninterface Ruleform{}\n\nclass SomethingImpl implements Something {\n\tprivate Object entity;\n\t@Override\n\tpublic  <T extends Ruleform> T getEntity(){\n\t\treturn (T)entity;\n\t};\n\n\t@Override\n\tpublic  <T extends Ruleform> void setEntity(T entity){\n\t\tthis.entity = entity;\n\t};\n\n}\ninterface Something{\n\tpublic <T extends Ruleform> T getEntity();\n\tpublic <T extends Ruleform> void setEntity(T entity);\n}",
