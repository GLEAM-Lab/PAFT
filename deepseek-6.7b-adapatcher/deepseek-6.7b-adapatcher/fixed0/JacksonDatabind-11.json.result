    "patch_code": "private class PlaceHolderType extends SimpleType\n{\n    private static final long serialVersionUID = 1L;\n    protected PlaceHolderType(int id, Class<?> rawClass) { super(id, rawClass); };\n    @Override\n    public boolean isContainerType() { return true; }\n    @Override\n    public CollectionType withContentType(Type contentType)\n    {\n        return new ArrayType(getId(), contentType, rawClass());\n    }\n};\n\n@SuppressWarnings(\"unchecked\")\npublic JavaType resolveFully(JavaType t) throws JsonMappingException\n{\n    while (t instanceof ParameterizedType) {\n        ParameterizedType pt = (ParameterizedType) t;\n        if (!pt.isWrapperType()) {\n            break;\n        }\n        t = ((SimpleType)t).contentType();\n    }\n\n    /* Special treatment of place holders when found in generic argument:\n     *  if a placeholder points to itself, treat it as such: it must be circular reference.\n     */\n    if (_circularRefCounter != 0 && t instanceof TypeFactory.PlaceHolderType) {\n        return t;\n    }\n    ++_circularRefCounter;\n\n    TypeBindings bindings = t.getBindings();\n    assert bindings != null;\n    int size = bindings.size();\n    if (bindings.isEmpty()) {\n        --_circularRefCounter;\n        return t;\n    }\n    ArrayList<Binding<?>> list = new ArrayList<>(size);\n    for (Entry<String, JavaType> entry : bindings.entrySet()) {\n        String name = entry.getKey();\n        JavaType binding = entry.getValue();\n        assert name != null;\n        if (binding instanceof TypeFactory.PlaceHolderType) {\n            String refName = ((TypeFactory.PlaceHolderType) binding).getBoundName();\n            assert refName != null;\n            assert name.equals(refName);\n            // Now we have to resolve this placeholder. This could result into self-reference case above\n            binding = resolveFully(_recursionGuard ? UNRESOLVED : binding);\n            assert binding != UNRESOLVED;\n        }\n        list.add(new Binding<>(name, binding));\n    }\n    bindings = new TypeBindings(list, t.getTypeParameters());\n    t = new TypeFactory.GenericType(t.getRawClass(), (Type[]) t.getActualTypeArguments(), bindings, (JavaType[]) t.getTypeParameters());\n    --_circularRefCounter;\n    return t;\n}",
