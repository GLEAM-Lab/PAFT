    "patch_code": "void encode(int[] in, int inPos, int in ava) {\n    if (ava <0) {\n        eof = true;\n        if (ava == 0) {\n            return;\n        }\n    }\n    \n    if (eof) {\n        if (ava == 0) {\n            switch ( mod ) {\ncase 1:\n    b64encode() ;\n    break;\ncase 2:\n    b64encode() ;\n    b64encode() ;\n    break;\ncase 0:\n    break;\n            }\n        }\n        else {\n            while ( ava-- > 0 ) {\n                b64decode() ;\n            }\n            b64decode() ;\n            while ( ava-- > 0 ) {\n                b64decode() ;\n            }\n            while ( ava-- > 0 ) {\n                b64decode() ;\n            }\n        }\n    }\n    else {\n        while ( ava-- > 0 ) {\n            b64decode() ;\n        }\n    }\n}",
