    "patch_code": "import org.apache.commons.codec.binary.Base64OutputStream;\nimport java.io.*;\npublic class Main{\n    public static void main(String [] args){\n          try {  \n               File file= new File(\"filename\");\n\t           OutputStream out = new FileOutputStream(file);\n               BufferedOutputStream buffout = new BufferedOutputStream(out);\n               Base64OutputStream b64out = new Base64OutputStream(buffout);             \n               byte abyte[] = new byte[0];\n               b64out.write(abyte,0,abyte.length);      \n               b64out.flush();        \n               b64out.close();\n             \n            \n\t} catch (Exception ex) {  \n\t        ex.printStackTrace();  \n\t    }  \n    }\n}",
