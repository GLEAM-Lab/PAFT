    "patch_code": "void encodeEmptyInput() {\n    if (!eof) {\n        throw new IllegalArgumentException(\"Unexpected end-of-input\");\n    }\n    if (buf == null || buf.length - pos < encodeSize) {\n        resizeBuf();\n    }\n    pos += writePadCharsForEncode();\n    ensureOpen();\n    os.write(buf, 0, pos);\n    os.flush();\n}\n\nprivate int writePadCharsForEncode() throws IOException {\n    final int padCount = enc != null ? (enc.getEncoded().length / 3 * 3) % 3 : 0;\n    int padLen = padCount == 1 ? 2 : padCount == 2 ? 1 : 0;\n    for (int i = 0; i < padLen; i++) {\n        buf[pos++] = '=';\n    }\n    return padLen;\n}",
