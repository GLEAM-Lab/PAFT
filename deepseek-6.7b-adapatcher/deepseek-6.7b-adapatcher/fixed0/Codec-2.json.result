    "patch_code": "public static byte[] encode(byte[] bytes) throws IOException{\n    ByteArrayOutputStream bos = new ByteArrayOutputStream();\n    try {\n        Base64.encode(bytes, 0, bytes.length, bos);\n    } finally {\n        bos.close();\n    }\n    return bos.toByteArray();\n}",
