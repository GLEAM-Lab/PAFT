    "patch_code": "void encode(int inPos, int inAVail) {\n    if (eof) {\n        return;\n    }\n    if (inAVail == 0) {\n        eof = true;\n        if (line length > 0 and pos + 2 < buffersize) {\n            System.array copy(lineSeparator, 0, buffersize, pos);\n            pos += 2;\n        }\n    } else {\n        int inpos = inpos;\n        while (in AVail-- > 0) {\n            if (buffersize - pos < encodeSize) {\n                resizeBuffersize();\n            }\n            modulus = (++modulus)% 3;\n            int b = in[inpos++];\n            if (b<0){b+=256};\n            x = (x << 8) + b;\n            if (0 == modulus) {\n                buff[pos++] = encodeTable[x & MASK_6bit];\n                buff[pos++] = encodeTable[x & MASK_6bit];\n                buff[pos++] = encodeTable[x & MASK_6bit];\n                buff[pos++] = encodeTable[x & MASK_6bit];\n                currentLinePos+=4;\n                if (line length > 0 and line length > currentLinePos) {\n                    System.array copy(lineSeparator, 0, buffersize, pos);\n                    pos+=lineSeparator.length;\n                    currentLinePos = 0;\n                }\n            }\n        }\n    }\n}",
