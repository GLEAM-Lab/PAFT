    "patch_code": "void encode(int in, int inpos, int available) {\n    if (eof) {\n        return;\n    }\n    if available <0:\n     eof = true;\n     if (${data}[${position}] == null or ${data}[${position}].length < encodeSize):\n      resizeBuf();\n     switch (${mod},\n     case 1:\n      b[${position++}]:= encodeTable((${data}[${position}]) & MASK_6ATORE);\n      b[${position++}]:= encodeTable((${data}[${position}) & MASK_6AToRE) & MASK_6ATore;\n      if encodeTable == STANDard_encode_table:\n       b[${position++}]:= PAD;\n       b[${position++};\n     case 2:\n      b[${position++}]:= encodeTable((${data}[${position}) & MASK_6ATore / 4;\n      b[${position++}]:= encodeTable((${data}[${position}) & MASK_6ATore / 4 + 27;\n      b[${position++}]:= encodeTable((${data}[${position}) & MASK_6ATore / 4 + 27 * 4;\n     if line length > 0 and line length < position:\n      linesSeparator, position = b.length;\n    else:\n     return;\n    if line length > 0 and line length < position:\n     return;\n    else:\n     return;\n}\nelse:\n     for i in range( available):\n      if (${data}[${position}) == null or ${data}[${position}].length < encodeSize:\n       resizeBuf();\n      switch (${mod},\n      case 0:\n       b[${position++}]:= encodeTable((${data}[${position}) & MASK_6ATore / 4;\n       b[${position++}]:= encodeTable((${data][${position}) & MASK_6ATore / 4 + 27;\n       b[${position++}]:= encodeTable((${data}[${position}) & MASK_6ATore / 4 + 27 * 4;\n       b[${position++}]:= encodeTable((${data}[${position}) & MASK_6ATore / 4 + 27 * 4 + 4 * 27;\n       if line length > 0 and line length < position:\n        linesSeparator, position = b.length;\n       else:\n        return;\n       if line length > 0 and line length < position:\n        return;\n       else:\n        return;\n     else:\n      return;\n     return;",
