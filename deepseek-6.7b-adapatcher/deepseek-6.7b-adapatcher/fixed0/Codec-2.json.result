    "patch_code": "public final class Base64{\n    public static byte[] encode(byte [] in){\n        if(in == null || in.length == 0){\n            return new byte[0];\n        }\n        \n        int lengthOfIn = in.length;  \n        int sizeOfOut = (lengthOfIn / 3 * 4 + 3) & ~3;\n        \n        char[] outC = new char[sizeOfOut];\n    \n        int i = 0;\n        int j = 0;\n        while (i < lengthOfIn) {\n            int val = in[i] & 0xff;\n            \n            outC[j++] = CODES[val >> 2];  \n            \n            if ((++i < lengthOfIn)) {\n                val <<= 8;\n                \n                outC[j++] = CODES[((in[i] & 0xff) | val) >> 2];  \n            }\n            \n            if ((++i < lengthOfIn)) {\n                val <<= 8;\n                \n                outC[j++] = CODES[((in[i] & 0xff) | val) >> 2];  \n            }\n            \n            if (++i >= lengthOfIn) {\n                val <<= 8;\n                 \n                outC[j++] = CODES[(val >> 2) & 0x3f];\n                  \n                break;\n            }\n             \n            if ((j + 1) % 74 == 0 ) {\n                appendEOL(outC, j);\n            }\n        }\n         \n        byte [] base64Bytes = new byte [outC.length];\n        for(i=0 ; i<base64Bytes.length ; ++i) {\n           base64Bytes[i] = (byte)outC[i];\n        }\n       return base64Bytes;\n    }\n}",
