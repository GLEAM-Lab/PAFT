    "patch_code": "public void close() throws IOException {\n    if (!this.closed) {\n        if (this.out.checkError()) {\n            throw new IOException(\"Use of closed output stream\");\n        } else if (this.verbose && this.entriesWritten == 0L) {\n            System.err.println(\"No files processed.\");\n        }\n\n        super.close();\n        this.closed = true;\n    }\n}",
