    "patch_code": "import com.fasterxml.jackson.annotation.JsonValue;\nimport java.util.*;\npublic class Main{\n    public static void main(String[] args){\n        System.out.println(new TestEnumMap());\n    }\n}\nenum TestEnum {\n    \n    TESTA(@JsonValue\n    String value = \"test a\") {\n        \n    },\n    \n    TESTB(@JsonValue\n    String value = \"test b\") {\n        \n    };\n\n    private final String _value;\n\n    private TestEnum(String value) {\n        this._value = value;\n    }\n\n    @Override\n    public String toString() {\n        return this._value;\n    }\n}\n\nclass TestEnumMap {\n    Map<TestEnum, String> map;\n    TestEnumMap(){\n        map = new EnumMap<>(TestEnum.class);\n        map.put(TestEnum.TESTA,\"Hello\");\n        map.put(TestEnum.TESTB,\"World\");\n    }\n\n    @Override\n    public String toString(){\n        return map.toString();\n    }\n}",
