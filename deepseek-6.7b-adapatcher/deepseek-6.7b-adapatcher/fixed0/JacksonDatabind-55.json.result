    "patch_code": "@SuppressWarnings(\"uncheck\")\npublic static JsonSerializer< Object > getFallbackKeySerializer(\n        finalSerializerConfig config, finalClass<?> keyType)\n{\n    if (keyType != null && keyType != Enum.class) {\n        if (keyType.is\u67af\u840d()) {\n            return new default(default. TYPE_\u67af\u840d, keyType);\n        }\n        if (keyType.is\u67af\u840dmap()) {\n            return new fallback(keyType);\n        }\n    }\n    return defaultSerializer;\n}",
