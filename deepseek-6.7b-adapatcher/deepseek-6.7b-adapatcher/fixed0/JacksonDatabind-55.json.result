  {
    "patch_code": "public class EnumMapKeyMixIn {\n    private EnumMapKeyMixIn() {}\n}\n\npublic abstract class StdKeySerializers extends com.fasterxml.jackson.databind.ser.std.StdKeySerializers {\n    @Override\n    @SuppressWarnings(\"unchecked\")\n    public static JsonSerializer<Object> getFallbackKeySerializer(SerializationConfig config,\n            Class<?> rawKeyType)\n    {\n        if (rawKeyType != null && rawKeyType instanceof EnumMapKeyMixIn) {\n            Class<? extends Enum<?>> enumClass = (Class<? extends Enum<?>>) ((ParameterizedType) rawKeyType.getGenericSuperclass()).getActualTypeArguments()[0];\n            if (enumClass.isEnum()) {\n                return new Default(Default.TYPE_ENUM, enumClass);\n            }\n        } else if (rawKeyType != null && rawKeyType.isEnum()) {\n            return new Default(Default.TYPE_ENUM, rawKeyType);\n        }\n        return DEFAULT_KEY_SERIALIZER;\n    }\n}",
