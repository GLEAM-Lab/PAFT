    "patch_code": "@SuppressW warnings(\"uncheck\")\n    public static JsonSerializer< Object> getFallbackKeySerializer(\n            final SerializationConfig config, final Class<?>rawKeyType)\n    {\n        if (rawKeyType != null) {\n            final Class<?> cl =rawKeyType;\n            if (cl == Enum.class) {\n                return new Delta();\n            }\n            if (cl.is Enum()) {\n                return new default(default. TYPE_\u679a\u4e3e, cl);\n            }\n        }\n        return default keySerializer;\n    }",
