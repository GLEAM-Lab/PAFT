    "patch_code": "import com.fasterxml.jackson.annotation.JsonFormat;\nimport java.lang.reflect.Method;\nimport java.util.Arrays;\n\npublic class TestClass extends StdKeySerializers{\n    \n    private static <T> JsonSerializer<Object> _getFallbackKeySerializer(SerializationConfig config,\n            Class<?> rawKeyType) throws Exception\n    {\n        if (rawKeyType != null) {\n            \n            if (_shouldUseJsonFormatForKeysIfAvailable(config, rawKeyType)) {\n                return new EnumKeySerializer((Class<T>) rawKeyType,\n                        _findScalarAsTokenType(_toClass(config, rawKeyType), false));\n            }\n            Method[] methods = rawKeyType.getMethods();\n            boolean hasNonPublicGetName = Arrays.stream(methods)\n                    .anyMatch(m -> m.getName().equals(\"name\"));\n            if ((rawKeyType == Enum.class && !hasNonPublicGetName) ||\n                    (!rawKeyType.isEnum() && !hasNonPublicGetName)) {\n                \n                return new Default(Default.TYPE_ANY_ID, rawKeyType);\n            } else if (EnumMap.class.isAssignableFrom(rawKeyType)) {\n                final Class<?> elementType = (Class<?>) ((ParameterizedType) rawKeyType.getGenericSuperclass()).getActualTypeArguments()[0];\n                final JsonSerializer<Object> ser = getFallbackKeySerializer(config, elementType);\n                return new EnumMapKeySerializer(elementType, ser);\n            }else if(rawKeyType.isEnum()){\n              return new Default(Default.TYPE_ENUM, rawKeyType);\n           }\n        \n        }\n        return DEFAULT_KEY_SERIALIZER;\n    }\n}",
