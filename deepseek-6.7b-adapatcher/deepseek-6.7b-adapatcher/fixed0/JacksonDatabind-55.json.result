    "patch_code": "public class CustomMapSerializer extends StdSerializer<EnumMap<?, ?>> {\n\n    private static final long serialVersionUID = 1L;\n    \n    public CustomMapSerializer() {\n        super(EnumMap.class);\n    }\n    \n    @Override\n    public void serialize(EnumMap<?, ?> map, JsonGenerator gen, SerializerProvider provider) throws IOException {\n        \n        gen.writeStartObject();\n        Set<Entry<?, ?>> set = map.entrySet();\n        Iterator<Entry<?, ?>> iter = set.iterator();\n        \n        while (iter.hasNext()) {\n            \n            Entry<?, ?> entry = iter.next();\n            Object key = entry.getKey();\n            if (!key.getClass().isEnum()) {\n                continue;\n            }\n            \n            Enum<?> e = (Enum<?>) key;\n            String jsonName = e.getDeclaringClass().getAnnotation(JsonProperty.class) != null ?\n                    e.getDeclaringClass().getAnnotation(JsonProperty.class).value() :\n                    e.name();\n                \n            provider.defaultSerializeField(jsonName, entry.getValue(), gen);\n        }\n        gen.writeEndObject();\n    }\n}",
