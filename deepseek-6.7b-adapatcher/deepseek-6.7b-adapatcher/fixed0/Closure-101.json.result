    "patch_code": "public class com.google.javascript.jscomp.CommandLineRunner extends javax.lang.model.util.SimpleElementVisitor8<Boolean> implements java.io.Closeable {\n  protected void exitWithError(String errorMessage) throws Exception {\n     System.err.println(\"error: \" + errorMessage);\n     close();\n     System.exit(-1);\n   }\n  public Boolean visitPackageDeclaration(javax.lang.model.element.PackageElement e, Object o) {\n    this.packageName = e.getName().toString();\n    return super.visitPackageDeclaration(e, o);\n  }\n  private int processSingleInputFile(final File inputFile, final File outputFile) throws IOException, ParserException {\n    try (Reader reader = Files.asCharSource(inputFile, Charsets.UTF_8).openBufferedStream()) {\n      Tokenizer tokenizer = new Tokenizer(reader);\n      Ast ast = new Ast(tokenizer.parseProgram(), null);\n      compiler.init(ast, options);\n      List<ClosureInfo> closureInfos = ClosureCompiler.analyzeAst(compiler, ast);\n      compiler.compileUnit(closureInfos);\n      \n      writeOutputFilesAndReturnExitCode(outputFile, null, ast.getPreNormalizedJavaScript(), compiler.hasErrorsOrWarnings());\n      return compiler.hasErrorsOrWarnings() ? 1 : 0;\n    } catch (ParserException e) {\n      throw new RuntimeException(\"Parsing failed: \" + e.getMessage(), e);\n    } finally {\n      Utils.closeQuietly(reader);\n      lastCompileStats.reset();\n    }\n  }\n@Override \n  public void close() throws IOException {\n      try {\n        compiler.end();\n      } finally {\n        IOUtils.closeQuietly(writer);\n        writer = null;\n      }\n    }\n\n  public static void main(String[] args) throws Exception {\n    new com.google.javascript.jscomp.CommandLineRunner().run(args);\n  }\n}",
