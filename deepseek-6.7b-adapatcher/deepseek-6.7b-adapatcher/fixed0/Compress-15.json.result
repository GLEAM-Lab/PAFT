    "patch_code": "private static final long serialVersionUID = 1L;\n\n  /** The name of the entry */\n  private final String name;\n\n  /** The unix time when the entry was last modified */\n  private final long time;\n\n  /** The comment associated with the entry */\n  private final String comment;\n\n  /** The compressed size of the data */\n  private final long compressedSize;\n\n  /** The uncompressed size of the data */\n  private final long size;\n\n  /** The method used to compress the data */\n  private final int method;\n\n  /** The extra field present in central directory */\n  private byte[] centralDirectoryExtraField;\n\n  /** The extra field present in local file header */\n  private byte[] localFileDataExtraField;\n\n  /** The attributes containing version made by bit 0 and 1 */\n  private final int versionMadeBy;\n\n  public ZipArchiveEntry(String name, long time, String comment, long crc, int compressionMethod,\n      long compressedSize, long size, byte[] extra) {\n    if (name == null || name.length() == 0) {\n      throw new IllegalArgumentException(\"name must not be null or zero length\");\n    }\n    this.name = name;\n    this.time = time;This line is unchanged\n    this.comment = comment == null ? \"\" : comment;\n    this.method = compressionMethod;\n    this.size = size;\n    this.centralDirectoryExtraField = extra;\n    this.localFileDataExtraField = null;\n    this.versionMadeBy = VERSION_MADEBY_DEFAULT;\n    this.compressedSize = compressedSize;\n  }\n\n  // Rest of class is omitted here\n}",
