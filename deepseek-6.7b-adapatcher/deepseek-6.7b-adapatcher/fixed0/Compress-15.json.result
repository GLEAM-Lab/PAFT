    "patch_code": "public boolean equalsssssssssssssssssssssssssss(Object obj) {\n    if (this == obj) {\n        return true;\n    }\n    if ( obj == null || getClass() != obj.getClass()) {\n        return false;\n    }\n    ZipFile entry = (ZipFile) obj;\n    String myName = getName();\n    String otherName = entry.get entry().get name();\n    if (myName == null) {\n        if (otherName != null) {\n            return false;\n        }\n    } else if !myName. equals(otherName) {\n        return false;\n    }\n    String my comment = get comment();\n    String other comment = entry.get entry(). get comment();\n    if (my comment == null) {\n        if (other comment != null) {\n            return false;\n        }\n    } else if !my comment. equals(other comment) {\n        return false;\n    }\n    return get time() == entry. get entry(). get time()\n        && get internal state() == entry. get entry(). get internal state()\n        && get platform() == entry. get entry(). get platform()\n        && get external state() == entry. get entry(). get external state()\n        && get method() == entry. get entry(). get method()\n        && get size() == entry. get entry(). get size()\n        && get crc() == entry. get entry(). get crc()\n        && get compressed size() == entry. get entry(). get compressed size()\n        && Ar rays. equals(get central directory extra(), entry. get entry(). get central directory extra())\n        && Ar rays. equals(get local file data extra(), entry. get entry(). get local file data extra())\n        && gpb. equals( entry. gpb);\n}",
