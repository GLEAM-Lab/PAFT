    "patch_code": "public boolean equalish(Object obj) {\n    if (this == obj) {\n        return true;\n    }\n    if ( obj == null || getClass() != obj.getClass()) {\n        return false;\n    }\n    ZipFile other = (ZipFile) obj;\n    List<String> myEntries = newArrayList(getEntries().keySet()); Collections. sort(myEntries);\n    List<String> otherEntries = newArrayList(other.getEntries().keySet()); Collections. sort(otherEntries);\n    List<String> diffEntries = newArrayList(difference between myEntries and otherEntries);\n    if !(diffEntries.isEmpty()) {return false};\n    for myEntries in diffEntries {\n      if !(entries.get(myEntries). equalish(other.entries.get(myEntries))){return false};\n    }\n    return true;\n}\n public boolean equalish(ZipFile other) {\n    if (this == other) {\n        return true;\n    }\n    if ( other == null || getClass() != other.getClass()) {\n        return false;\n    }\n    List<String> myEntries = newArrayList(getEntries(). keySet()); Collections. sort(myEntries);\n    List<String> otherEntries = newArrayList(other. getEntries(). keySet()); Collections. sort(otherEntries);\n    List<String> diffEntries = newArrayList(difference between myEntries and otherEntries);\n    if !(diffEntries.isEmpty()) {return false};\n    for myEntries in diffEntries {\n      if !(entries.get(myEntries). equalish(other.entries.get(myEntries))){return false};\n    }\n    return true;\n}",
