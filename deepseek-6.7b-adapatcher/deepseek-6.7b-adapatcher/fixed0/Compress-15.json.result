    "patch_code": "private static void compareEntries(final ZipArchiveEntry e1, final org.apache.commons.compress.archivers.zip.ZipArchiveEntry e2) throws IOException {\n    System.out.println(\"name:\" + e1.getName() + \" <> \" + e2.getName());\n    assert e1.getName().equals(e2.getName());\n    System.out.println(\"comment:\" + e1.getComment() + \" <> \" + e2.getComment());\n    assert e1.getComment() != null ? e1.getComment().equals(e2.getComment()) : e2.getComment() == null;\n    System.out.println(\"size:\" + e1.getSize() + \" <> \" + e2.getSize());\n    assert e1.getSize() == e2.getSize();\n    System.out.println(\"compressed size:\" + e1.getCompressedSize() + \" <> \" + e2.getCompressedSize());\n    assert e1.getCompressedSize() == e2.getCompressedSize();\n    System.out.println(\"crc:\" + e1.getCrc() + \" <> \" + e2.getCrc());\n    assert e1.getCrc() == e2.getCrc();\n    System.out.println(\"method:\" + e1.getMethod() + \" <> \" + e2.getMethod());\n    assert e1.getMethod() == e2.getMethod();\n    System.out.println(\"time:\" + new Date(e1.getTime()) + \" <> \" + new Date(e2.getTime()));\n    assert e1.getTime() == e2.getTime();\n    byte[] extra1 = e1.getCentralDirectoryExtra();\n    byte[] extra2 = e2.getCentralDirectoryExtra();\n    if ((extra1 == null) != (extra2 == null)) {\n        throw new AssertionError(\"Extra fields different\" + extra1 + \" / \" + extra2);\n    }\n    if (extra1 != null) {\n        assert Arrays.equals(extra1, extra2);\n    }\n    extra1 = e1.getLocalFileDataExtra();\n    extra2 = e2.getLocalFileDataExtra();\n    if ((extra1 == null) != (extra2 == null)) {\n        throw new AssertionError(\"Extra fields different\" + extra1 + \" / \" + extra2);\n    }\n    if (extra1 != null) {\n        assert Arrays.equals(extra1, extra2);\n    }\n}",
