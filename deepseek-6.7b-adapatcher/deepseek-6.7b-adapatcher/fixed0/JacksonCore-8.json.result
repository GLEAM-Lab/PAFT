            String str = new String(_block, _start, _limit - _start);\n            ++_references;\n            _start = _limit;\n            return EMPTY_CHAR_ARRAY;\n        }\n        if (_text == null) {// none yet, but not with recycling\n            _text = new char[(_limit - _start) + 16];\n            System.arraycopy(_block, _start, _text, 0, _limit - _start);\n            _limits[0] = _limit;\n            _limits[1] = _limits[0];\n            assertValidLimit(1);\n            assertContentValid(false, false, true, ' ', \"\\n\");\n            return _text;\n        }\n        final int len = (_limit - _start);\n        if (len == 0) {\n            _limits[0] = _limit;\n            _limits[1] = _limits[0];\n            assertValidLimit(1);\n            assertContentValid(false, false, true, ' ', \"\\n\");\n            return EMPTY_CHAR_ARRAY;\n        }\n        char[] oldBuf = _text;\n        if (oldBuf.length < len) {\n            _text = new char[len];\n        }\n        System.arraycopy(_block, _start, _text, 0, len);\n        _limits[0] = _limit;\n        _limits[1] = _limits[0];\n        assertValidLimit(1);\n        assertContentValid(true, true, false, '\\t', '\\n');\n        return _text;\n    }",
