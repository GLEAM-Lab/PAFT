    "patch_code": "import java.lang.Double;\npublic class Main {\n    public static void main(String[] args){\n        System.out.println(\"NaN==NaN is:\" + equals(Double.NaN ,Double.NaN));\n        System.out.println(\"0.1234567890123456E10==0.1234567890123456E10 is:\"+ equals(0.1234567890123456E10L, 0.1234567890123456E10L));        \n        System.out.println(\"1.0==NaN is:\" +equals(1.0 ,Double.NaN));\n        System.out.println(\"NaN==1.2223334444555667e-5 is:\"+ equals(Double.NaN ,1.2223334444555667e-5));      \n        }\n\n   public static boolean equals(double x, double y) {\n      long p = Double.doubleToLongBits(x);\n      long q = Double.doubleToLongBits(y);\n    \n      //The two values are identical\n      if (p == q) {\n          return true;\n      }\n    \n      //Either value is NaN (including negative NaN), but they are not identical.\n      if ((q | p) < 0) {\n          return false;\n      }\n          \n      //Both values are finite, but they have different magnitudes or exponents.\n      if((q >> 52 & 0x7ff) != (p >> 52 & 0x7ff)){\n         return false;\n      } \n      \n      //At this point, all NaNs must be identical because of the checks above. We can consider that both arguments are finite numbers now.\n      return Math.abs(x - y) < Double.MIN_VALUE;\n   }\n}",
