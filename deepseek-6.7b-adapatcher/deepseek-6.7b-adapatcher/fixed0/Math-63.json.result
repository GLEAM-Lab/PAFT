    "patch_code": "import java.lang.Float;\nimport org.apache.commons.math.util.MathUtils;\npublic class Main{\nstatic int compareValues = 0;\npublic static void main(String[] args){\n        System.out.println(\"Hello World!\");\n        System.out.println(MathUtils.equals(15.238764090407414D, 0));\n       }\n    \n         public static boolean equals(double x, double y) {\n             final double tmpX = x + DBL_EPSILON;\n             final double tmpY = y + DBL_EPSILON;\n            compareValues++;\n              if ((Float.isNaN(tmpX) && Float.isNaN(tmpY))) {\n                 return true;\n               } else if (!(Float.isNaN(tmpX)) && !(Float.isNaN(tmpY))){\n                return Math.abs((tmpX - tmpY)) < MIN_NORMAL;\n              }\n              \n              return false;\n           }  \n      }",
