    "patch_code": "import java.lang.Math;\n\npublic class MathUtils{\n\n   public static final double EPSILON = 0.00001f;\n\n   /** \n    * Determines whether two doubles are equal within tolerance limits.\n    * Tests for equality of two Doubles including checking against the NaN case.\n    * @param x The first Double.\n    * @param y The second Double.\n    * @return a boolean value indicating whether they are equal or not.\n    */    \n   public static boolean equals(double x, double y){\n       //Checking if both are NaN\n       if(Double.isNaN(x)&&Double.isNaN(y)){\n           return true;\n       }\n       else if((Double.isNaN(x)&&!Double.isNaN(y))||(!Double.isNaN(x)&&Double.isNaN(y))) {\n       \t\treturn false;\n       }else {\n            return Math.abs(x - y) < EPSILON;\n        }\n   }\n\n}",
