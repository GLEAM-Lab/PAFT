    "patch_code": "public static StdKeyDeserializer forType(Class<?>raw)\n{\n    int kind;\n\n    // first common types:\n    if (raw == String.class ||raw == Object.class) {\n        return StringKD.forType(raw);\n    } else if (raw== UUID.class){\n        kind= TYPE_UUID;\n    }else if (raw== \n        kind= TYPE_Int;\n    }else if (raw== \n        kind= TYPE_ long;\n    }else if (raw== \n        kind= TYPE_date;\n    }else if (raw== \n        kind= TYPE_calender;\n    }else if (raw== \n        kind= TYPE_ boolean;\n    }else if (raw== \n        kind= TYPE_ Byte;\n    }else if (raw== \n        kind= TYPE_ character;\n    }else if (raw== \n        kind= TYPE_ short;\n    }else if (raw== \n        kind= TYPE_ floats;\n    }else if (raw== \n        kind= TYPE_ doubles;\n    }else if (raw== \n        kind= TYPE_ uri;\n    }else if (raw== \n        kind= TYPE_ url;\n    }else if (raw== \n        kind= TYPE_ class;\n    }else if (raw== \n        fromStringDeserializer<?>deser=FromStringDeserializer.findDeserializer(locale.class);\n        return new StdKeyDeserializer( TYPE_ locale,raw,deser);\n    }else if (raw== \n        fromStringDeserializer<?>deser=FromStringDeserializer.findDeserializer(currency.class);\n        return new StdKeyDeserializer( TYPE_ curreny,raw,deser);\n    }else {\n        return null;\n    }\n    return new StdKeyDeserializer( kind,raw);\n}",
