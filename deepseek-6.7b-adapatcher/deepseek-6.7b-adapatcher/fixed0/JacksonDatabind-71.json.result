    "patch_code": "public static JsonDeserializer<?> findKeyDeserializer(DeserializationConfig config, AnnotatedMember amember, JavaType jacksonTypeArg, Class<?> propertyType, CollectionType collectionType) throws JsonMappingException\n{\n    // First try to get it from context annotations (like @JsonAnySetter annotation)\n    if (_findFromContextAnnotations(config, amember, jacksonTypeArg, propertyType, collectionType) != null) {\n        return null;\n    }\n    // Handle case where we have a Map and no special handling required for keys\n    if (JacksonUtil.isMapLikeType(propertyType)) {\n        if (collectionType == null) {\n            // We need separate handling, so let's use basic deserialization\n            return config.getDefaultKeyDeserializer();\n        }\n    }\n    final Class<?> baseType = JacksonAnnotationIntrospector._findBaseType(amember, jacksonTypeArg, collectionType, true);\n    if (baseType != null && _findFromAnnotations(config, amember, jacksonTypeArg, baseType, collectionType) != null) {\n        return null;\n    }\n    \n    // Finally check built-in list handlers (Arrays etc.)\n    if ((jacksonTypeArg instanceof ArrayType)) {\n        if (jacksonTypeArg.getRawClass() == CharSequence.class) {\n            return new StdKeyDeserializer(CharSequence.class);\n        }\n    }\n    /* Special handling for common class types */\n  \n    return null;\n}",
