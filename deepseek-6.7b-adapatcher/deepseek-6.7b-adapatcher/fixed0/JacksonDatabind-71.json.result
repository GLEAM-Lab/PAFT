    "patch_code": "@Override\npublic Object findObjectReference(Object id) {\n    try {\n        return super.findObjectReference(id);\n    } catch (IllegalArgumentException e) {\n        return _referenced + \":\" + id;\n    }\n}\n\nprivate class CharSequenceDeserializer extends JsonDeserializer<CharSequence> {\n    @Override\n    public CharSequence deserialize(JsonParser jsonParser, DeserializationContext deserializationContext) throws IOException, JsonProcessingException {\n        return jsonParser.getValueAsString();\n    }\n}",
