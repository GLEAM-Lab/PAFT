    "patch_code": "@Override\nprotected K _keyFromNode(JsonParser p, JsonDeserializer<?> valueDeser) throws IOException {\n    final JsonToken t = p.getCurrentToken();\n    switch (t) {\n    case VALUE_EMBEDDED_OBJECT :\n        if (_objectIdWriter != null && ((JsonObjectNode)p.getParsingContext()).id() != null){\n            try {\n                synchronized (this){\n                    String id = p.getText();\n                    Object obj = this._oidResolver.resolveId(id);\n                    if (obj != null) {\n                        return (K)_valueToKey(obj);\n                    }\n                }\n            } catch (Exception e) {}\n        }\n        break;\n    default :\n        if (t == JsonToken.VALUE_STRING){\n            try {\n                return (K)(CharSequence)p.getText();\n            } catch (IOException ex) {\n                throw ex ;\n            } catch (RuntimeException ex) {\n                throw ex ;\n            } catch (Error ex) {\n                throw ex ;\n            }\n        }\n        break;\n    }\n    throw ctxt.mappingException(_contextualType(), \"Expected string value\");\n}",
