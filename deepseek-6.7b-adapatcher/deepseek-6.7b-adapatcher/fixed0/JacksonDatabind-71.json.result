    "patch_code": "public static StdKeyDeserializer forType(Class<?>raw)\n{\n    int kind;\n\n    // first common types:\n    if (raw==String.class||raw==Object.class){return StringKD.forType(raw);}\n    else if (raw== UUID.class) { kind= TYPE_UUID; }\n    else if (raw== int.class) { kind= TYPE_Int; }\n    else if (raw== long.class) { kind= TYPE_long; }\n    else if (raw== date.class) { kind= TYPE_date; }\n    else if (raw== Calendar.class) { kind= TYPE_Calendar; }\n    else if (raw== boolean.class) { kind= TYPE_ boolean; }\n    else if (raw== char.class) { kind= TYPE_ char; }\n    else if (raw== short.class) { kind= TYPE_ short; }\n    else if (raw== floats.class) { kind= TYPE floats; }\n    else if (raw== double.class) { kind= TYPE_ double; }\n    else if (raw== URI.class) { kind= TYPE_ URI; }\n    else if (raw== url.class) { kind= TYPE_ url; }\n    else if (raw== class.class) { kind= TYPE_ class; }\n    else if (raw== locale.class) { kind= TYPE locale; }\n    else if (raw==currency.class) { kind= TYPE_currency; }\n    else { return null; }\n    return new StdKeyDeserializer( kind,raw);\n}",
