    "patch_code": "private final DeserializationConfig _config;\n    \n/**\n * Constructor to use when we have actual configuration object (and no static defaults).\n */\nprotected JsonObjectIdReader(final DeserializationConfig config)\n{\n    super();\n    this._config=config;\n}\n\n@Override\npublic ObjectId readId(JsonParser jp, DeserializationContext ctxt) throws IOException, JsonProcessingException {\n   SimpleDateFormat dateFormat = new SimpleDateFormat(\"yyyy-MM-dd\");\n        dateFormat.setLenient(false);\n         try {\n             return new ObjectId((dateFormat.parse(jp.getText()).getTime() / 1000));\n         } catch (ParseException e) {\n             throw new RuntimeException(e);\n         }\n}",
