    "patch_code": "static String stripLeadingHyphens(String str)\n{\n    if (str == null)\n        throw new IllegalArgumentException();\n    \n    if (str.startsWith(\"--\"))\n    {\n        return str.substring(2, str.length());\n    }\n    else if (str.startsWith(\"-\"))\n    {\n        return str.substring(1, str.length());\n    }\n\n    return str;\n}",
