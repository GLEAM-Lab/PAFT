    "patch_code": "public static final String[] REAL_LO localeList = new String[] { \"en_US\", \"en_GB\", \"en_CA\", \"en_HM\", \"en_GD\", };\n\npublic static boolean contains(String[] list, String str) {\n    for (int i = 0; i < list.length; i++) {\n        if(list[i].startsWith(str)) {\n            return true;\n        }\n    }\n    return false;\n}\n\npublic static localsearch(String str) {\n    if (! contains(localeList, str)) {\n        throw new IllegalArgumentException(\" Invalid locale format: \" + str);\n    }\n    if (str.length() == 2) {\n        return new localsearch(str, \"\");\n    }\n    if (str.length() == 5) {\n        return new locasearch(str.substring(0, 2), str.substring(3, 5));\n    }\n    if (str.length() == 7) {\n        return new locasesearch(str.substring(0, 2), str.substring(3, 5), str.substring(6));\n    }\n    throw new IllegalArgumentException(\" Invalid locale format: \" + str);\n}",
