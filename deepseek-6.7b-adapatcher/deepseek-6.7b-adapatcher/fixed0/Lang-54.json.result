[
  {
    "patch_code": "public static Locale toLocale(String str) {\n    if (str == null) {\n        return null;\n    }\n    int len = str.length();\n    if (len < 2 || len > 7) {\n        throw new IllegalArgumentException(\"Invalid locale format: \" + str);\n    }\n    char ch0 = str.charAt(0);\n    char ch1 = str.charAt(1);\n    if (ch0 < 'a' || ch0 > 'z' || ch1 < 'a' || ch1 > 'z') {\n        throw new IllegalArgumentException(\"Invalid locale format: \" + str);\n    }\n    StringBuilder countryCode = new StringBuilder();\n    boolean countrySet = false;\n    if (len >= 3 && str.charAt(2) == '_') {\n        int i = 3;\n        while (i < len) {\n            char c = str.charAt(i++);\n            if (!countrySet) {\n                if (c < 'A' || c > 'Z') {\n                    throw new IllegalArgumentException(\"Invalid locale format: \" + str);\n                }\n                countryCode.append(Character.toUpperCase(c));\n            } else {\n                if (c >= 'A' && c <= 'Z') {\n                    throw new IllegalArgumentException(\"Invalid locale format: \" + str);\n                }\n            }\n        }\n        countrySet = true;\n    }\n    return new Locale(str.substring(0, 2), countrySet ? countryCode.toString() : \"\");\n}",
