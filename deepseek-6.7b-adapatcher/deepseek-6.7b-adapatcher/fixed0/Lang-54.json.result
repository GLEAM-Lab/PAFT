  {
    "patch_code": "public static Locale toLocale(String str) {\n    if (str == null) {\n        return null;\n    }\n    String[] parts = str.split(\"_|-\");\n    int numParts = parts.length;\n    switch (numParts) {\n        case 1: // Language only\n            return new Locale(parts[0], \"\");\n        case 2: // Language and country only\n            return new Locale(parts[0], parts[1]);\n        default: // Language, country, and variants\n            StringBuilder variante = new StringBuilder();\n            boolean hasVariante = false;\n            for (int i = 2; i < numParts; ++i) {\n                variante.append('.').append(parts[i].replaceAll(\"\\\\.\", \"_\"));\n                hasVariante = true;\n            }\n            if (hasVariante){\n                return new Locale(parts[0], parts[1] , variante.toString());\n            } else {\n                return new Locale(parts[0], parts[1]);\n            }\n    }\n}",
