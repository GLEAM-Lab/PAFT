    "patch_code": "public static Locale toLocale(String str) {\n    if (str == null) {\n        return null;\n    }\n    int len = str.length();\n    if (len > 8) {\n        throw new IllegalArgumentException(\"Invalid locale format: \" + str);\n    }\n    char ch0 = str.charAt(0);\n    char ch1 = str.charAt(1);\n    if (ch0 < 'a' || ch0 > 'z' || ch1 < 'a' || ch1 > 'z') {\n        throw new IllegalArgumentException(\"Invalid locale format: \" + str);\n    }\n    if (len == 2) {\n        return new Locale(str, \"\");\n    } else {\n        if (!str.contains(\"_\")) {\n            throw new IllegalArgumentException(\"Invalid locale format: \" + str);\n        }\n        String[] splitStr = str.split(\"_\");\n        if (splitStr[0].length() != 2) {\n            throw new IllegalArgumentException(\"Invalid locale format: \" + str);\n        }\n        if (\"\".equalsIgnoreCase(splitStr[splitStr.length - 1])) {\n            throw new IllegalArgumentException(\"Invalid locale format: \" + str);\n        }\n        return new Locale(splitStr[0], splitStr[1]);\n    }\n}",
