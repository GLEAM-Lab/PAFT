  {
    "patch_code": "private void handleObjectLit(NodeTraversal t, Node n) {\n  Node grandchild = null;\n  for (Node child = n.getFirstChild();\n       child != null;\n       child = child.getNext()) {\n    // Maybe STRING, GET, SET\n    \n    // We should never see a mix of numbers and strings.\n    String name = child.getString();\n    T type = typeSystem.getType(getScope(), n, name);\n    \n    if(grandchild!=null && grandchild.isMethod()){\n      ObjectLiteral ol = (ObjectLiteral)grandchild.parent;\n      Method m = new Method((Expression)ol.object,\n                              (Function)grandchild.toStatement());\n      ol.setProperty(m.name, Expression.THIS, m.funcExpr);\n    }\n    \n    Property prop = getProperty(name);\n    if (!prop.scheduleRenaming(child,\n                               processProperty(t, prop, type, grandchild))) {\n      // TODO(user): It doesn't look like the user can do much in this\n      // case right now.\n      if (propertiesToErrorFor.containsKey(name)) {\n        compiler.report(JSError.make(\n            t.getSourceName(), child, propertiesToErrorFor.get(name),\n            Warnings.INVALIDATION, name,\n            (type == null ? \"null\" : type.toString()), n.toString(), \"\"));\n      }\n    }\n  }\n  \n  for (grandchild = n.getFirstChild();\n       grandchild != null;\n       grandchild = grandchild.getNext().getFirstChild()) {\n    while (true) {\n      if (grandchild.next() == null) break;\n      grandchild = grandchild.getNext();\n    }\n  }\n}",
