  {
    "patch_code": "protected void handleObjectLit(NodeTraversal t, Node n) {\n  Object lit = ((LiteralNode)n).getValue();\n  int kind = ((LiteralNode)n).getKind();\n  \n  if(!(lit instanceof Map)){\n    return;\n  }\n  \n  @SuppressWarnings(\"unchecked\")\n  Iterator<Map.Entry<String,Object>> ite =  ((Map<String,Object>)lit).entrySet().iterator();\n  while (ite.hasNext()) {\n    \n    Map.Entry<String,Object> me = (Map.Entry<String,Object>) ite.next();\n    String name  = me.getKey();\n    Node value = (Node)me.getValue();\n    \n    if((kind & Syntax.Literals.STRING) != 0){\n      \n      continue;\n    }\n    \n    // Maybe STRING, GET, SET\n\n    // We should never see a mix of numbers and strings.\n    String nameStr = name;\n    T type = typeSystem.getType(getScope(), n, nameStr);\n\n    Property prop = getProperty(nameStr);\n    if (!prop.scheduleRenaming(value,\n                               processProperty(t, prop, type, null))) {\n      // TODO(user): It doesn't look like the user can do much in this\n      // case right now.\n      if (propertiesToErrorFor.containsKey(nameStr)) {\n        compiler.report(JSError.make(\n            t.getSourceName(), value, propertiesToErrorFor.get(nameStr),\n            Warnings.INVALIDATION, nameStr,\n            (type == null ? \"null\" : type.toString()), n.toString(), \"\"));\n      }\n    }\n  }\n}",
