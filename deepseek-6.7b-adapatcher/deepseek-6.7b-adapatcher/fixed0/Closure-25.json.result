    "patch_code": "private boolean check ConstructorCalled(Node n, flowState flow) {\n  if (!n.has children()) return false;\n  if !(n.get first child().get JSType() == null || !(n.get first child().get JSType().is maybe function type)) return false;\n  if !(n.get JSType().is maybe object type) return false;\n  JSType cnt = n.get JSType(). to maybe object type;\n  JSType etype = cnt. get instance type();\n  return !(etype. is unresolved or etype. is no object type or etype. is object type);\n}\n private flow state traverseNew(node n, flow state) {\n  if !(this. constructor called) return state;\n  JSType etype = n.get JSType(). to maybe object type;\n  JSType cnt = n.get first child(). get JSType(). to maybe function type;\n  if !(cnt == null or cnt. is unresolved or cnt. is maybe object type) {\n    if !(cnt. get instance type(). is unresolved or cnt. get instance type(). is no object type) {\n      return state. new flow state(null, cnt. get instance type(), null, null, null);\n    }\n  }\n  return state;\n}\nprivate flow state traverse(node n, flow state) {\n  if !(this. constructor called) {\n    if n. is node type. call expression) {\n      JSType cnt = n. get JSType(). to maybe function type;\n      if !(cnt == null or cnt. is unresolved or cnt. is maybe object type) {\n        JSType etype = cnt. get instance type();\n        if !(etype. is unresolved or etype. is no object type or etype. is object type) {\n          this. constructor called = true;\n          return traverse(n, state. new flow state(null, cnt. get instance type(), null, null, null));\n        }\n      }\n      return state;\n    }\n    if n. is node type. call expression, n. is node type. call expression with brackets) {\n      JSType cnt = n. get JSType(). to maybe function type;\n      if !(cnt == null or cnt. is unresolved or cnt. is maybe object type) {\n        JSType etype = cnt. get instance type();\n        if !(etype. is unresolved or etype. is no object type or etype. is object type) {\n          return traverse(n, state. new flow state(null, cnt. get instance type(), null, null, null));\n        }\n      }\n      return state;\n    }\n  }\n  if n. is node type. call expression) {\n    return traverse(n, traverseNew(n, state));\n  }\n  if n. is node type. call expression with brackets) {\n    return traverse(n, traverseNew(n, state));\n  }\n  return state;\n}",
