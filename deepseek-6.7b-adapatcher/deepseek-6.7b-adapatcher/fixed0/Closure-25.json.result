    "patch_code": "public class TypeInferenceTest extends TestCase {\n\n  public void testIssue394() throws Exception {\n    String source = \"var x;\\n\" +\n        \"try {\\n\" +\n        \"  var y = 7;\\n\" +\n        \"  eval('x = new Array(y).join(\\'\\')');\\n\" +\n        \"}\\n\" +\n        \"catch (e) {\\n\" +\n        \"}\\n\";\n    SourceFile sourceFile = new SourceFile(\"test.js\", source);\n    Compiler compiler = Compiler.createJavaScriptCompiler();\n    compiler.addSourceFile(sourceFile);\n    assertTrue(compiler.compile());\n    \n    AssertionError assertionError = ExpectUtil.expect(() -> {\n      compiler.getProgram().toString();\n    });\n    assertEquals(assertionError.getMessage(), \"Failed to compile.\");\n    \n    List<DiagnosticMessage> diagnosticMessages = compiler.getDiagnostics();\n    DiagnosticMessage diagnosticMessage = diagnosticMessages.get(diagnosticMessages.size() - 1);\n    int lineNumber = diagnosticMessage.lineNumber;\n    assertEquals(lineNumber, 6);\n  }\n\n  /**\n   * Tests that the inferred types for variables inside try blocks are updated correctly when their respective catch\n   * handlers are invoked.\n   */\n  public void testTryVariableScoping() throws Exception {\n    String source = \"function f(){\\n\" +\n            \"  try {\\n\" +\n            \"    var caught = 'not thrown';\\n\" +\n            \"    throw null;\\n\" +\n            \"  } catch (c) {\\n\" +\n            \"  }\\n\" +\n            \"\\n\" +\n            \"  console.log(caught);\\n\" +\n            \"}\\n\" +\n            \"f();\\n\";\n            \n    SourceFile sourceFile = new SourceFile(\"test.js\", source);\n    Compiler compiler = Compiler.createJavaScriptCompiler();\n    compiler.addSourceFile(sourceFile);\n    assertTrue(compiler.compile());\n    System.out.println(compiler.getProgram().toString());\n  }\n\n}",
