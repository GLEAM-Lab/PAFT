    "patch_code": "public void removeUnreferencedFunctionArgs(Scope fnScope) {\n  Node function = fnScope.getRootNode();\n  Preconditions.checkState(function.isFunction(), \"Only functions may have arguments.\");\n  \n  if(!fnScope.hasProperty(\"param\") && NodeUtil.isGetOrSetKey(function.getParent())){\n    return;\n  }\n  \n  List<String> referencedArgs = fnScope.getReferencedNamesInThisScope();\n  int numArgs = 0;\n  for (Node each : function.getChildrenByType(JSSymbol.KEYWORD_PARAMETERS)){\n    if (each == null){\n      continue;\n    }\n    numArgs += each.getChildCount();\n  }\n  \n  boolean modifyCallers = modifyCallSites \n      && callSiteOptimizer.canModifyCallers(function);\n  if (!modifyCallers) {\n    Node lastArg;\n    \n    while((lastArg = NodeUtil.getLastKeywordArgument(function))!=null){\n      String name = lastArg.getString();\n      \n      if(!referencedArgs.contains(name)){\n        \n        Compiler.log(\"%s is never used\", name);\n        \n        Util.deleteFromParent(lastArg);\n        \n      }else{\n        break;\n      }\n    }\n    \n    if(!function.hasProperty(\"length\")){\n      \n      JSDoc letDefn = function.addJSdocComment(new JSToken('/**'), false);\n      \n      letDefn.appendKeyValue(new JSStrictKeywordToken(\"@const\"),\n          new JSNumericLiteralToken(numArgs));\n    }\n  }\n  \n}",
