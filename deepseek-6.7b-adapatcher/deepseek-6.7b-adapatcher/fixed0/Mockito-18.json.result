  {
    "patch_code": "public class ReturnsEmptyIterables implements Answer<Object> {\n    public static final ReturnsEmptyIterables INSTANCE = new ReturnsEmptyIterables();\n    \n    @Override\n    public Object answer(InvocationOnMock invocation) throws Throwable {\n        Class<?> type = invocation.getMethod().getReturnType();\n        \n        if (!Collection.class.isAssignableFrom(type)){\n            throw new IllegalArgumentException(\"@ReturnsEmpty doesn't support \"+ type +\" because it's not a subtype of Iterable or similar\");\n        }\n        \n        if (invocation.getMethod().getName().startsWith(\"iterator\")){\n             return invocation.callRealMethod();  \n        }\n        return returnValueFor(type);\n    }\n\n    private static Object returnValueFor(Class<?> type){\n        if (type==Iterable.class || type==ArrayList.class ||  type==LinkedList.class  || type==HashSet.class  || type==TreeSet.class\n                || type==SortedSet.class || type==Collection.class ){\n            return new ArrayList<>();\n        }else if (type==Iterator.class){\n            return new ArrayList<>().iterator();\n        }\n        return new LinkedList<>();\n    }\n}",
