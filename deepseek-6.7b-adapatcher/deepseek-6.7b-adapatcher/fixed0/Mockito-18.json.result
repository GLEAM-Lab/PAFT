    "patch_code": "Object returnValueFor(Class<?> type) {\n    if ( primitiveOr wrapper types here ) {return null; }\n    if ( type == Iterable.class ) {return Collections. emptyList(); }\n    if ( type == Iterator.class ) {return Collections. emptySet(); }\n    if ( primitive types here ) {return null; }\n    if ( type == Set.class ) {return Collections. emptySet(); }\n    if ( type == List.class ) {return Collections. emptyList(); }\n    if ( type == Iterator<?>.class ) {return Collections. emptySet(); }\n    if ( type == Iterable<?>.class ) {return Collections. emptyList(); }\n    if ( type == Iterator<?>.class ) {return Collections. emptySet(); }\n    if ( type == Iterable<?>.class ) {return Collections. emptyList(); }\n    return null;\n}",
