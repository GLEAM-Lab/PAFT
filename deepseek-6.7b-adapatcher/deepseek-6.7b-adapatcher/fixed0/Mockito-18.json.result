    "patch_code": "import java.util.*;\n\npublic class EmptyIterable implements Iterable<Object> {\n    private static final Iterable<Object> INSTANCE = new EmptyIterable();\n    \n    @Override\n    public Iterator<Object> iterator() {\n        return Collections.emptyIterator();\n    }\n    \n    @SuppressWarnings(\"unchecked\")\n    public static <T> T ofType(Class<T> type) {\n        if (Collection.class.isAssignableFrom(type) || Iterable.class.isAssignableFrom(type)) {\n            return (T)INSTANCE;\n        }\n        throw new IllegalArgumentException(String.format(\"%s is no Iterable\", type));\n    }\n}",
