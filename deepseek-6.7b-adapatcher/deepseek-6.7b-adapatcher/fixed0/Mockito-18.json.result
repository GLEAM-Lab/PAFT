    "patch_code": "Object returnValueFor(Class<?> type) {\n    if (Primitives.isPrimitiveOrWrapper(type)) {\n        return Primitives.defaultValueForPrimitiveOrWrapper(type);\n    } else if (Iterable.class.isAssignableFrom(type)) {\n        try{\n            Constructor constructor = type.getConstructor();\n            return (Object)constructor.newInstance();\n        }catch(Exception e){\n          throw new RuntimeException(\"Cannot instantiate iterable\");\n       } \n    } else if (type == Collection.class || Collection.class.isAssignableFrom(type)) {\n        return new ArrayList<>();\n    } else if (type == Set.class || Set.class.isAssignableFrom(type)) {\n        return new HashSet<>();\n    } else if (type == List.class || List.class.isAssignableFrom(type)) {\n        return new ArrayList<>();\n    } else if (type == Map.class || Map.class.isAssignableFrom(type)) {\n        return new HashMap<>();\n    }  \n    return null;\n}",
