    "patch_code": "public static final class ReturnsEmptyValues implements Answer<Object> {\n\n  public static final ReturnsEmptyValues INSTANCE = new ReturnsEmptyValues();\n  \n  private ReturnsEmptyValues() {}\n  \n  @Override\n  public Object answer(InvocationOnMock invocation) throws Throwable {\n     Class<?> realType = TypeUtil.getRealClassIfProxy(invocation.getMock().getClassLoader(), invocation.getMethod().getReturnType());\n    if (!realType.isInterface()) {\n      return createCollectionOfSameTypeAs(invocation);\n    }\n    if (\"[]\".equals(realType.getName())) {\n      return new Object[0];\n    }\n    if (Iterable.class.isAssignableFrom(realType)) {\n      return new ArrayList<>();\n    }\n    if (Iterator.class.isAssignableFrom(realType)) {\n      return Collections.emptyIterator();\n    }\n    if (Collection.class.isAssignableFrom(realType)) {\n      return new ArrayList<>();\n    }\n    if (Map.class.isAssignableFrom(realType)) {\n      return new HashMap<>();\n    }\n    if (Set.class.isAssignableFrom(realType)) {\n      return new HashSet<>();\n    }\n    throw new IllegalArgumentException(\"can't stub \" + invocation.getMethod());\n  }\n  \n  private Object createCollectionOfSameTypeAs(InvocationOnMock invocation){\n      try{\n          return ((Class)invocation.getArgument(0)).newInstance();\n      }catch(InstantiationException e){\n          throw new RuntimeException(e);\n      }catch(IllegalAccessException e){\n          throw new RuntimeException(e);\n      }\n  }\n}",
