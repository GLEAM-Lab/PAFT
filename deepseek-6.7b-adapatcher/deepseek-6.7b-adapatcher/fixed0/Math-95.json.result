    "patch_code": "protected double getInitialDomain(double p) {\n    double ret;\n    double d = getDenominatorDegreesOfFreedom();\n    if (d > 2.0){\n       // use mean\n       ret = d / (d - 2.0);\n     } else if (d < 0) {\n      throw new MathIllegalArgumentException(\" Degrees of freedom cannot be negative \" + d);\n   }else{\n       // This may lead to some problems, but better than dividing by zero\n       ret = 1.0;\n   }\n  \n    return ret;\n}",
