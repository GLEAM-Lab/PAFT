    "patch_code": "protected double getInitialDomain(double p) {\n    double ret = 0.0;\n    double d = getDenominatorDegreesOfFreedom();\n    // check for denominator degree of freedom being 2\n    if (Math.abs(d - 2.0) < EPSILON){\n        return Double.MAX_VALUE;\n    }else{\n        // otherwise proceed with regular calculation\n        ret = d / (d - 2.0);\n    }\n    return ret;\n}",
