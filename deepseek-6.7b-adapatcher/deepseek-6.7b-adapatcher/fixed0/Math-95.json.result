    "patch_code": "protected double getInitialDomain(double p) {\n    double ret;\n    double d = getDenominatorDegreesOfFreedom();\n        // check for zero degrees of freedom\n        if ((int)d == 2){\n            // avoids division by zero\n            ret = 0.1;\n        }else{\n             // use mean\n            ret = d / (d - 2.0);\n        }\n    \n    return ret;\n}",
