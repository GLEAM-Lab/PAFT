    "patch_code": "private static Predicate<Node> MAY_BE_STRING_PREDICATE = new Predicate<Node>() {\n  public boolean apply(Node input) {\n    return input instanceof StringLiteral || (input instanceof BinaryExpression && mayBeString((BinaryExpression)input, true));\n  }\n};",
