    "patch_code": "public boolean setPosition(int position) {\n        if (!prepared) {\n            prepared = true;\n            BasicNodeSet nodeSet = (BasicNodeSet) getNodeSet();\n            TreeMap pointers = new TreeMap(); //using tree map instead of array list\n            Comparator comp = new DefaultComparator();\n            \n            for (int i = 0; i < contexts.length; i++) {\n                EvalContext ctx = (EvalContext) contexts[i];\n                int index=0;\n                while (ctx.nextSet()) {\n                    while (ctx.nextNode()) {\n                        NodePointer ptr = ctx.getCurrentNodePointer();\n                        \n                       if (!pointers.containsKey(ptr)) {\n                            nodeSet.add(index, ptr);\n                           pointers.put(ptr, index);\n                            index++;\n                            \n                        }\n                        \n                        \n                    }\n                }\n            }\n        }\n        return super.setPosition(position);\n    }",
