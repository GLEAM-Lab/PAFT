    "patch_code": "import java.util.*;\npublic class UnionContext extends org.apache.commons.jxpath.ri.axes.UnionContext implements Iterator {\n    Vector pointersList;\n    \n    public UnionContext(){\n       pointersList = new Vector(); \n    }\n    @Override\n    public boolean setPosition(int position) {\n        if (!prepared) {\n            prepared = true;\n            org.apache.commons.jxpath.nodeset.BasicNodeSet nodeSet = (org.apache.commons.jxpath.nodeset.BasicNodeSet) getNodeSet();\n            \n            for (int i = 0; i < contexts.length; i++) {\n                EvalContext ctx = (EvalContext) contexts[i];\n                \n                while (ctx.nextSet()) {\n                    \n                    while (ctx.nextNode()) {\n                        \n                        Object ptr = ctx.getCurrentNodePointer().getObject();\n                       \n                        if (!pointersList.contains(ptr)) {\n                            \n                            nodeSet.add((Node) ptr);\n                           \n                            pointersList.add(ptr);\n                        }\n                    }\n                }\n            }\n            \n            Collections.sort(pointersList, new Comparator() {\n               public int compare(Object o1, Object o2) {\n                  int index1 = ((DocumentNavigator)o1).getCursor(),\n                      index2 = ((DocumentNavigator)o2).getCursor();\n                  \n                   return Integer.compare(index1,index2);\n                }\n            });\n             \n            Iterator itr = this.iterator(); \n            \n            while (itr.hasNext()) {\n                \n                DocumentNavigator dn = (DocumentNavigator) itr.next();\n                \n                dn.setPosition(pointersList.indexOf(dn.getCurrentNodePointer().getObject()));\n            }\n            \n            \n        }\n        \n        \n        \n        return super.setPosition(position);\n    }\n  \n}",
