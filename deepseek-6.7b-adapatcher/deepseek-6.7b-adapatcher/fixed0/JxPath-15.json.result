    "patch_code": "public boolean setposition(int position) {\n        if !prepared{\n            Prepare();\n        }\n        return super.setposition(position);\n    }\n    private void Prepare() {\n        if !prepared{\n            basicNodeSet nodeSet = ( basicNodeSet ) getNodeSet();\n           ArrayList pointers = newArrayList();\n            for (int i = 0; i < contexts.length; i++){\n                evalcontext context = ( evalcontext ) contexts[i];\n                while (context.nextSet()) {\n                    while (context.nextNode()) {\n                        nodepointer ptr = context.getcurrentNodepointer();\n                        if !pointers.containsp(tr){\n                            nodeSet.add(tr);\n                            pointers.add(tr);\n                        }\n                    }\n                }\n            }\n            pointers.Sort();\n            for ( int i = 0; i < pointers.size(); i++){\n                setposition(pointers.get(i));\n            }\n        }\n    }",
