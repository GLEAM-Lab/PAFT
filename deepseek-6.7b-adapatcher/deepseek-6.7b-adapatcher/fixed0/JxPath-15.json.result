    "patch_code": "public boolean setPosition(int position) {\n        if (!prepared) {\n            prepared = true;\n            BasicNodeSet nodeSet = (BasicNodeSet) getNodeSet();\n            ArrayList pointers = new ArrayList();\n            \n            List tempList = new LinkedList<>();\n            \n            for (int i = 0; i < contexts.length; i++) {\n                EvalContext ctx = (EvalContext) contexts[i];\n                while (ctx.nextSet()) {\n                    while (ctx.nextNode()) {\n                        \n                        NodePointer ptr = ctx.getCurrentNodePointer();\n                        if (!pointers.contains(ptr)) {\n                            \n                            int lastIndexOfChildInParent = ((Element) ptr.getNode()).getOwnerDocument().getElementsByTagName(\"MAIN\").item(0).getChildNodes().getLength()-1; \n                            int indexOfChild = ((Element) ptr.getNode()).getOwnerDocument().getElementsByTagName(\"MAIN\").item(0).getChildNodes().indexOf(((Element) ptr.getNode()));\n                            \n                            if (lastIndexOfChildInParent == indexOfChild){\n                                nodeSet.add(ptr);\n                                pointers.add(ptr);\n                            } else {\n                                \n                                tempList.add(ptr);\n                                \n                            }\n                        }\n                    }\n                }\n            }\n            \n            Iterator itr2 = tempList.iterator();  \n              \n            while(itr2.hasNext()) {  \n                \n                nodeSet.add((NodePointer) itr2.next());\n                pointers.add(itr2.next());\n            }\n            \n        }\n        \n        return super.setPosition(position);\n}",
