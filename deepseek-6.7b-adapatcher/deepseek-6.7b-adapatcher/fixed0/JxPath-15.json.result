    "patch_code": "public boolean setPosition(int position) {\n        if (!prepared) {\n            prepared = true;\n            BasicNodeSet nodeSet = (BasicNodeSet) getNodeSet();\n            ArrayList<Integer> pointers = new ArrayList<>();\n            for (int i = 0; i < contexts.length; i++) {\n                EvalContext ctx = (EvalContext) contexts[i];\n                int j = 0;\n                while (ctx.nextSet()) {\n                    while (ctx.nextNode()) {\n                        NodePointer ptr = ctx.getCurrentNodePointer();\n                        int indexOfPtr = nodeSet.indexOf(ptr);\n                        if (indexOfPtr == -1 && !pointers.contains(j)) {\n                            nodeSet.add(ptr);\n                            pointers.add(j);\n                        }\n                        j += 1;\n                    }\n                }\n            }\n            \n            Collections.sort(pointers, new Comparator<Integer>(){\n    \t\t\tpublic int compare(Integer o1, Integer o2){\n    \t\t\t\tObject obj1 = nodeSet.get(o1);\n    \t\t\t\tObject obj2 = nodeSet.get(o2);\n    \t\t\t\t\n    \t\t\t\tint docOrder1 = ((BasicNodePointer)obj1).getNode().getNodeNumber(); \n    \t\t\t\tint docOrder2 = ((BasicNodePointer)obj2).getNode().getNodeNumber();\n    \t\t\t\treturn docOrder1 - docOrder2;\n    \t\t\t}\n    \t\t});\n            \n            ArrayList<NodePointer> reSortedList = new ArrayList<>();\n            for (Integer pointer : pointers) {\n                reSortedList.add(nodeSet.get(pointer));\n            }\n            \n            nodeSet.clear();\n            for (NodePointer np : reSortedList) {\n                nodeSet.add(np);\n            }\n        }\n        return super.setPosition(position);\n    }",
