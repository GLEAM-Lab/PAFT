    "patch_code": "public boolean setPosition(int position) {\n        if (!prepared) {\n            prepared = true;\n            BasicNodeSet nodeSet = (BasicNodeSet) getNodeSet();\n            \n            Vector<NodePointer> pointers = new Vector<>();\n            for (int i = 0; i < contexts.length; i++) {\n                EvalContext ctx = (EvalContext) contexts[i];\n                while (ctx.nextSet()) {\n                    while (ctx.nextNode()) {\n                        NodePointer ptr = ctx.getCurrentNodePointer();\n                        \n                        // Check whether it exists\n                        int idx = pointers.indexOf(ptr);\n                        if (idx == -1){\n                            nodeSet.add(ptr);\n                            pointers.add(ptr);\n                        } else if(idx > -1 && idx != nodeSet.size()-1){ \n                            // Existing but not at end position, then exchange positions\n                            nodeSet.remove(idx);\n                            nodeSet.add(nodeSet.size(), ptr);\n                            \n                        }\n                    }\n                }\n            }\n        }\n        return super.setPosition(position);\n    }",
