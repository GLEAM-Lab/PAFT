    "patch_code": "public class JDK8Hack extends DefaultParser {\n     protected void burstToken(String token, boolean stopAtNonOption) throws ParseException {\n         boolean hitEquals = false;\n         for (Iterator<Character> iterator = token.iterator(); iterator.hasNext(); ) {\n             Character ch = iterator.next();\n             boolean isEqualsSign = (ch == '=');\n             if (!isEqualsSign && ch == '-' && !hitEquals){\n                 while (iterator.hasNext()) {\n                     char nextChar = iterator.next();\n                     if (nextChar == '='){\n                         tokens.addLast(new Token(-1,\"\"));\n                         iterator.remove();\n                         hitEquals = true;\n                     }else{\n                         break;\n                     }\n                 }\n                 continue;\n             }\n             if (hitEquals) {\n                 StringBuilder argSb = new StringBuilder();\n                 while (iterator.hasNext()) {\n                     argSb.append(iterator.next());\n                 }\n                 tokens.addLast(new Token(-1,argSb.toString()));\n                 return;\n             }\n             if(!hitEquals){\n                 super.burstToken(String.valueOf(ch), stopAtNonOption);\n             }\n         }\n     }\n }\n\n public static CommandLine parseArgs(String[] args, Options options) throws ParseException {\n     return new JDK8Hack().parse(options,args);\n }",
