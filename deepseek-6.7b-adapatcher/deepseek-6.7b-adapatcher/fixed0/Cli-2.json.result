    "patch_code": "protected void burstToken(String token, boolean stopAtNonOption)\n    {\n        int tokenLength = token.length();\n        \n        // Add space before and after token to handle cases like -t\"-something\"\n        String[] tokensIncludingSpace = {\" \", token, \" \"};\n\n        for (int i = 0; i < tokensIncludingSpace.length; i++)\n        {\n            String currToken = tokensIncludingSpace[i];\n            \n            int currTokenLen = currToken.length();\n    \n            for (int j = 1; j < currTokenLen; j++)\n            {\n                String ch = String.valueOf(currToken.charAt(j));\n                boolean hasOption = options.hasOption(ch);\n\n                if (hasOption)\n                {\n                    tokens.add(\"-\" + ch);\n                    currentOption = options.getOption(ch);\n\n                    if (currentOption.hasArg() && (currToken.length() != (j + 1)))\n                    {\n                        tokens.add(currToken.substring(j + 1));\n\n                        return;\n                    }\n                }\n                else if (stopAtNonOption)\n                {\n                    process(currToken.substring(j));\n                    \n                    return;\n                }\n                else\n                {\n                    tokens.add(\"-\" + ch);\n                }\n            }\n        }\n    }",
