    "patch_code": "@Override\npublic int read(byte[] b, int off, int len) throws IOException {\n     if (b == null) {\n         throw new NullPointerException();\n     } else if (off < 0 || len < 0 || off + len > b.length) {\n         throw new IndexOutOfBoundsException();\n     }\n     int total = 0, n;\n     do {\n          final boolean bufferEnd = base64.getCursor() >= base64.getLimit();\n          if (!bufferEnd){\n              break;\n          }\n          if (in.available() <= 0) {\n             break;\n         }\n         byte[] buf = new byte[doEncode ? 4096 : 8192];\n         int c = in.read(buf);\n         if (doEncode) {\n             base64.encode(buf, 0, c);\n         } else {\n             base64.decode(buf, 0, c);\n         }\n     }while(true);\n     n = Math.min(Math.max(base64.getLimit()-base64.getCursor(), 0), len - off);\n     base64.readFully(b, off, off+n, n);\n     total += n;\n     if(total < len && in.available()>0 ){\n         base64.skipBytes((len-total));\n     }\n     return total;\n   }\n}",
