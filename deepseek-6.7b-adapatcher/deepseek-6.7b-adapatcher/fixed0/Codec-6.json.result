  {
    "patch_code": "private static class Base64InputStream extends FilterInputStream implements Closeable {\n\n    ~\n    @Override\n    public int read(byte[] b, int off, int len) throws IOException {\n        if (b == null) {\n            throw new NullPointerException();\n        } else if ((off | len | b.length - off - len) < 0) {\n            throw new IndexOutOfBoundsException(\"read arguments out of range\");\n        } else if (closed){\n             throw new IOException(\"stream closed\");\n        } else if (len == 0) {\n           // When no input buffered but not yet EOF'd, may still need more\n           // space in output buffer. So don't treat as 'end of file'\n           if(!base64.hasData()) {\n              byte []buffer = new byte[8192];\n              int rd =  in.read(buffer);\n              if(rd<=0){\n                  return rd;\n              }\n              if(buffer.length==len&&rd>0){\n                 base64.setInitialBuffer(b, off, len);\n              }\n               if(doEncode){\n                   base64.encode(buffer,0,rd);\n               }else{\n                 base64.decode(buffer,0,rd);  \n               }\n           }\n          return base64.readResults(b, off, len);\n        } else if (countBytesRead >= length && !isEofOnClose){\n            // If no more data coming after this, can tolerate returning 0\n            // now without forcing underlying stream to supply more data first\n            if(base64.getOutputCount() <= 0 ){\n                return -1;\n            }\n        } else if (!in.ready()) {\n            try {\n                Thread.sleep(100L);\n            } catch (InterruptedException ignore) {\n            }\n            if (!in.ready()) {\n                return -1;\n            }\n        }\n        byte []buffer = new byte[8192];\n        int cnt = in.read(buffer);\n        int len1 = cnt;\n        boolean done = false;\n        if(cnt <=0){\n            done=true;\n        }\n       int total  = off+len;\n      if(total==len&&cnt>0){\n          base64.setInitialBuffer(b,off,len);\n      }\n        if(doEncode){\n            base64.encode(buffer,0,cnt);\n        }else{\n            base64.decode(buffer,0,cnt);\n        }\n        countBytesRead += cnt;\n        if(done){\n            return -1;\n        }\n        int nr = base64.readResults(b, off, len);\n        return nr;\n    }\n\n}",
