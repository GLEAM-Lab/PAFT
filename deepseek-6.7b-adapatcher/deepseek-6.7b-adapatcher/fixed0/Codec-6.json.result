    "patch_code": "public int read(java.lang.String s){return super.read(s.to char[]);}\npublic int read( java.lang.String s, int off, int length){return super.read(s.to char[],off,length);}\npublic int read( java.lang.String s, int off, java.lang. String characterEncoding){return super.read(s.to char[],off, characterEncoding.length());}\npublic int read( java.lang.String s, int off, int length, java.lang. String characterEncoding){return super.read(s.to char[],off, length, characterEncoding);}\n public int read(java.lang. String s, int off, int length, java.lang. String characterEncoding) {return super.read(s.to char[], off, length, characterEncoding);}\n public int read(java.lang. String s, int off, int length, java.lang. String characterEncoding, boolean doEncoding) {return super.read(s.to char[], off, length, doEncoding ? characterEncoding : null);}",
