    "patch_code": "public int read(byte b[], int off, int len) throws IOException {\n    if (b == null) {\n        throw new NullPointerException();\n    } else if ((off < 0) || (len < 0) || (off + len) > b.length) {\n        throw new IndexOutOfBoundsException();\n    } else if (len == 0) {\n        return 0;\n    } else {\n        ByteArrayOutputStream buf = new ByteArrayOutputStream();\n        int sum = 0;\n        do {\n            int length = in.read(buf);\n            if (length < 0) {\n                break;\n            }\n            sum += length;\n        } while (sum % 3 != 0 || !base64.hasData());\n        \n        byte[] input = buf.toByteArray();\n        \n        final boolean useOptimization = base64.hasData() && \n                                        base64.getInputLength() <= len - sum;\n        \n        final int initialOffset;\n        if (useOptimization) {\n            initialOffset = off + sum;\n            base64.initialize(initialOffset, len);\n        } else {\n            initialOffset = off;\n        }\n        \n        if (doEncode) {\n            base64.encodeTripletBytes(input, 0, input.length / 3 * 3, initialOffset, len);\n        } else {\n            base64.decodeQuadrupleBytes(input, 0, input.length / 4 * 4, initialOffset, len);\n        }\n        \n        int result = base64.readResults(b, off, len);\n        if (result <= 0 && sum > 0) {\n            base64.reset();\n            if (buf instanceof FileCacheBase) {\n                ((FileCacheBase) buf).dispose();\n            }\n        }\n        return result;\n    }\n}",
