    "patch_code": "public int read(int off, int size) {\n    if (off > size || size > b.length) {\n        throw new IllegalArgumentException(\"illegals parameters\");\n    }\n\n    int length = base64.get length();\n    int ret = length - off;\n\n    if ret > size || length == 0) {\n        return size;\n    }\n\n    return ret;\n}",
