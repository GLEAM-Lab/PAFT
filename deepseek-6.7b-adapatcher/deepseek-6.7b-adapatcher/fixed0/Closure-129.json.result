    "patch_code": "private boolean annotateCalls(Node n, AbstractCompiler compiler) throws CompilerException {\n  Preconditions.checkState(n.isCall());\n  \n  // Determine the \"this\" context of a call.  If there is no \"this\", then it is a free call.\n  Node target = n.getFirstChild();\n  \n  // Ignore casts - they do not affect whether or not we regard a method as free.\n  while (target != null && target instanceof JumpParentheses) {\n    target = target.getNextSibling();\n  }\n\n  if (compiler == null || compiler.getGlobalEnv().resolveImportsAndAliasesForNode(target) == target) {\n      return false;\n  }\n    \n  AnnotatedFunction func = compiler.getTypeModel().getAnnotatedFunction(target);\n  Type check = func != null ? func.getReturnType() : null;\n  \n  /*if (!(target instanceof MethodPropertyAccess && (check != null) && check.isDefinitelyNonNull()) {\n        n.setFlag(Node.FREE_CALL);\n        compiler.reportWarningIfEnabled(n.makeSourceInfo(), new WarningCode() {});\n    }*/\n  return true;\n}",
