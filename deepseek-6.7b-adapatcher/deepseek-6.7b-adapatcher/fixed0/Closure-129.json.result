  {
    "patch_code": "private boolean isCastFunctionBeforeCall (Node n){\n  try{\n     AnnotatedType at=n.getAnnotationType();\n    if (at==null){\n      return false;\n    }else{\n       String cname=at.getName();\n       if (\"function\".equals(cname)){\n         return true;\n       }\n        if (cname.contains(\"#\")){\n          \n          int lparIndex=cname.indexOf('(');\n          cname=cname.substring(0,lparIndex);\n        }\n        cname+=\"#\";\n        return JSWT.getWritable().globalPropertyExistsWithDotPrefixOrNull(cname)!=null;\n       }\n  \n }catch(Exception e){\n   return false;\n  }}\n  \n private void annotateCalls(Node n) {\n  Preconditions.checkState(n.isCall());\n  Node first = n.getFirstChild();\n  if (!NodeUtil.isGet(first)&&\n     !isCastFunctionBeforeCall(n)) {\n    n.putBooleanProp(Node.FREE_CALL, true);\n  }\n  if (first.isName() &&\n      \"eval\".equals(first.getString())||isCastFunctionBeforeCall(n)) {\n    first.putBooleanProp(Node.DIRECT_EVAL, true);\n  }\n}",
