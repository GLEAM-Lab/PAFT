    "patch_code": "public static long skip(InputStream input, long numToSkip) throws IOException {\n    long totalSkipped = 0L;\n    boolean eofReached = false;\n    byte[] singleByteArray = new byte[1];\n    while (!eofReached && numToSkip > 0) {\n        int remainingBytesToReadFromInput = (int) Math.min((long) singleByteArray.length, numToSkip);\n        int numRead = input.read(singleByteArray, 0, remainingBytesToReadFromInput);\n        if (numRead == -1) {\n            eofReached = true;\n        } else {\n            totalSkipped += numRead;\n            numToSkip -= numRead;\n        }\n    }\n        \n    return totalSkipped;\n}",
