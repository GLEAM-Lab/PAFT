    "patch_code": "public static long skip(InputStream input, long numToSkip) throws IOException {\n    long available = 0;\n    try {\n        // Try to get the available data in the input stream without reading anything\n        CompressedStreamCommons.checkNotNullParameter(input, \"input\");\n        if (!input.markSupported()) {\n            throw new UnsupportedOperationException(\"Mark is not supported\");\n        }\n        input.mark(Integer.MAX_VALUE);\n        byte[] peekByteBuffer = new byte[1];\n        for (; ; ) {\n            int r = input.read(peekByteBuffer, 0, 1);\n            if (r != 1) {\n                break; // EOF Reached\n            }\n            available++;\n        }\n        input.reset();\n    } catch (IOException ex) {\n        throw ex;\n    } finally {\n        try {\n            input.close();\n        } catch (IOException ex2) {\n            // Ignore\n        }\n    }\n    if (available <= numToSkip) {\n        return available;\n    } else {\n        for (long i = numToSkip; i >= 0; i--) {\n            byte[] b = new byte[1];\n            try {\n                input.read(b);\n            } catch (IOException e) {\n                throw new UncheckedIOException(e);\n            }\n        }\n        return numToSkip;\n    }\n}",
