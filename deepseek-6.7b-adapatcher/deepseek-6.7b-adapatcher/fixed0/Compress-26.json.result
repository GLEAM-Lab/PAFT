    "patch_code": "public static long skip(InputStream input, long numToSkip) throws IOException {\n    long available = numToSkip;\n    while (numToSkip > 0) {\n        long sz = 4096; // size of the internal buffer for reading data from InputStream\n        byte[] buf = new byte[sz];\n        int nr = input.read(buf);\n        if (nr == -1) { // EOF reached before we could read all requested number of bytes\n           break;\n        }\n        if (nr > numToSkip) {\n           nr = (int) numToSkip;\n        }\n        numToSkip -= nr;\n    }\n    return available - numToSkip;\n}",
