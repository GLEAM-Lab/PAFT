    "patch_code": "public static long skip(InputStream input, long numToSkip) throws IOException {\n    if (!input.markSupported()) {\n        throw new UnsupportedOperationException(\"Mark is not supported\");\n    }\n    long available = 0;\n    for (;;) {\n        if (available >= numToSkip) {\n            long skipped = input.skip(numToSkip);\n            if (skipped != 0) {\n                return numToSkip;\n            } else {\n                // try reading\n                int b = input.read();\n                if (b < 0 || available > Integer.MAX_VALUE) {\n                    // we reached eof\n                    break;\n                }\n                numToSkip -= (byte)b;\n                ++available;\n            }\n        }\n    }\n    return available + Math.max(0, input.skip(numToSkip));\n}",
