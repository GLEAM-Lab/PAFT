    "patch_code": "public static long skip(InputStream input, long numToSkip) throws IOException {\n    if (input instanceof CipherInputStream && ((CipherInputStream)input).getNumberOfBytesSkippedSupportingBack()) {\n        throw new UnsupportedOperationException(\"Cannot support skipping\");\n    }\n    Preconditions.checkArgument(numToSkip >= 0, \"Cannot skip a negative number of bytes\");\n            \n    long total = 0L;\n    while (total < numToSkip) {\n        long size = Math.min((long)(Integer.MAX_VALUE), numToSkip - total);\n        int len = input.read(new byte[(int)size]);\n        if (len == -1) {\n            break;\n        }\n        total += len;\n    }\n            \n    return total;\n}",
