    "patch_code": "public static long skip(InputStream input, long numToSkip) throws IOException {\n    // If the input is already a SkipCapableInputStream, reuse its skip implementation\n    if (input instanceof SkipCapableInputStream) {\n        return ((SkipCapableInputStream) input).skipBytes((int) Math.min(Integer.MAX_VALUE, numToSkip));\n    } else if (input instanceof java.util.zip.GZIPInputStream && !(((java.util.zip.GZIPInputStream) input).getHeader().compressedSize > numToSkip)) {\n        // The GZIP header contains a compressed size which must be greater than the original size when uncompressed. So if the user requests to skip more data than there actually is in the file, we can just return immediately instead of attempting to skip all remaining data.\n        return 0L;\n    }\n    long totalSkipped = 0L;\n    while (totalSkipped < numToSkip) {\n        long count = input.skip(Math.min(Long.MAX_VALUE, numToSkip - totalSkipped));\n        if (count <= 0) {\n            break;\n        }\n        totalSkipped += count;\n    }\n    return totalSkipped;\n}",
