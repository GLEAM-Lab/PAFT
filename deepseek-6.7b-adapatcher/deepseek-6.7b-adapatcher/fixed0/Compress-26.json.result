    "patch_code": "public static longskip(InputStreaminput,longnumToSkip) throwIOException {\n    long available = numToSkip;\n    while (numToSkip > 0 && !input. closed()) {\n        longskipped = input.skip(numToSkip);\n        if (skipped == 0) {\n            int skips = 0xFF & input.read();\n            skip((int skips), input);\n            if (skipped == skips) {\n                break;\n            }\n            numToSkip -= skips;\n            skips -= skips;\n            continue;\n        }\n        numToSkip -= skips;\n    }\n    \n    return available - numToSkip;\n}",
