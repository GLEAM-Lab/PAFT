    "patch_code": "private byte[] getBinaryContentFromTextNodeOrEmbeddedNodes(JsonNode rootNode, Set<Object> seenNodes) {\n    if (rootNode == null || seenNodes == null) {\n        return null;\n    }\n    if (!rootNode.isContainerNode()) {\n        if (rootNode instanceof TextNode) {\n            final String text = rootNode.asText();\n            if (text != null && !text.isEmpty()) {\n                final int commaIndex = text.indexOf(',');\n                if (commaIndex > 0 &&\n                        (commaIndex + 1 < text.length()) &&\n                        (text.charAt(commaIndex + 1) == ' ')) {\n                    // special handling for base64 images - these usually start with \"data:...\" headers before the actual content\n                    final String dataHeader = text.substring(0, commaIndex);\n                    if (\"data\".equalsIgnoreCase(dataHeader.split(\"\\\\W+\")[0])) {\n                        try {\n                            return DatatypeConverter.parseBase64Binary(text.substring(commaIndex + 1));\n                        } catch (IllegalArgumentException e) {\n                            /* invalid image data - ignore */\n                        }\n                    }\n                }\n            }\n        } else if (rootNode instanceof POJONode) {\n            Object ob = ((POJONode) rootNode).getPojo();\n            if (ob instanceof byte[]) {\n                return (byte[]) ob;\n            }\n        }\n    } else {\n        if (seenNodes.contains(rootNode)) {\n            return null;\n        }\n        seenNodes.add(rootNode);\n        \n        Iterator<JsonNode> elements = rootNode.elements();\n        while (elements.hasNext()) {\n            byte[] result = getBinaryContentFromTextNodeOrEmbeddedNodes(elements.next(), seenNodes);\n            if (result != null) {\n                return result;\n            }\n        }\n    }\n    return null;\n}\n\npublic byte[] getBinaryValue(Base64Variant b64variant)\nthrows IOException, JsonParseException\n{\n    ByteArrayOutputStream out = new ByteArrayOutputStream();\n    \n    InputStream in = new BufferedInputStream(_inputStream);\n    StreamDecoder decoder = _decoderProvider.createStreamDecoderForUTF8(_parser, in, false, true);\n    boolean sawClose = decoder.decodeRootNodeInto(this);\n    if (_settings.isEnabled(Feature.IGNORE_TRAILING_UNEXPECTED) && (sawClose ^ _parser.finished())) {\n        throw _parser.nonConsumedCharError(null, \"Unexpected characters\");\n    }\n    return getBinaryContentFromTextNodeOrEmbeddedNodes(currentNode(), new HashSet<>());\n}",
