    "patch_code": "public byte[] getBinaryValue(Base64Variant b64variant)\n    throws IOException, JsonParseException\n{\n    // Multiple possibilities...\n    JsonNode n = currentNode();\n    if (n != null) {\n         if (b64variant == Base64Variants.MIME) {\n           if (n.isTextual() && n instanceof TextNode) {\n               String txt = ((TextNode) n).textValue();\n               try {\n                   return Base64.getMimeDecoder().decode(txt);\n               } catch (IllegalArgumentException ex) {\n                    throw new JsonMappingException(\"Can't handle Base64 MIME variant in binary value\", ex);\n               }\n           }\n       } else if (b64variant == Base64Variants.URL) {\n           if (n.isTextual() && n instanceof TextNode) {\n               String txt = ((TextNode) n).textValue();\n               try {\n                   return Base64.getUrlDecoder().decode(txt);\n               } catch (IllegalArgumentException ex) {\n                    throw new JsonMappingException(\"Can't handle Base64 URL variant in binary value\", ex);\n               }\n           }\n       }\n    }\n    \n     \n        // [databind#2096]: although `binaryValue()` works for real binary node\n        // and embedded \"POJO\" node, coercion from TextNode may require variant, so:\n        byte[] data = n.binaryValue();\n        if (data != null) {\n            return data;\n        }\n        if (n.isPojo()) {\n            Object ob = ((POJONode) n).getPojo();\n            if (ob instanceof byte[]) {\n                return (byte[]) ob;\n            }\n        }\n    \n    // otherwise return null to mark we have no binary content\n    return null;\n}",
