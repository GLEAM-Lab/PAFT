    "patch_code": "import org.junit.jupiter.api.extension.*;\nimport org.mockito.Mockito;\nimport org.mockito.stubbing.Answer;\n\nimport java.lang.reflect.Field;\nimport java.lang.reflect.ParameterizedType;\nimport java.util.Optional;\n\npublic class InjectExtension implements BeforeEachCallback, AfterEachCallback{\n\n    private static final String FIELD_NAME = \"target\";\n\n    @Override\n    public void beforeEach(ExtensionContext context){\n        injectFields(context.getRequiredTestInstance(), context);\n    }\n\n    @Override\n    public void afterEach(ExtensionContext context){\n        resetMocks(context.getRequiredTestInstance());\n    }\n\n    private void injectFields(Object testInstance, ExtensionContext context){\n        Class<?> testClass = testInstance.getClass();\n        while(testClass != Object.class){\n            try{\n                Field declaredField = testClass.getDeclaredField(FIELD_NAME);\n                if(declaredField != null){\n                    declaredField.setAccessible(true);\n                    Object fieldValue = declaredField.get(testInstance);\n                    if(fieldValue instanceof Mock){\n                        Mock mock = (Mock) fieldValue;\n                        ParameterizedType genericSuperclass = (ParameterizedType) mock.getClass().getGenericSuperclass();\n                        Class<?> actualTypeArgument = (Class<?>) genericSuperclass.getActualTypeArguments()[0];\n                        Optional.ofNullable((Injectable) mock)\n                                .ifPresent(injectable -> injectable.inject(actualTypeArgument));\n                    }\n                }\n            }catch (NoSuchFieldException e){\n            } catch (IllegalAccessException e){\n            }\n            testClass = testClass.getSuperclass();\n        }\n    }\n\n    private void resetMocks(Object testInstance){\n        Class<?> testClass = testInstance.getClass();\n        while(testClass != Object.class){\n            try{\n                Field declaredField = testClass.getDeclaredField(FIELD_NAME);\n                if(declaredField != null){\n                    declaredField.setAccessible(true);\n                    Object fieldValue = declaredField.get(testInstance);\n                    if(fieldValue instanceof Mock){\n                        Mockito.reset((Mock) fieldValue);\n                    }\n                }\n            }catch (NoSuchFieldException e){\n            } catch (IllegalAccessException e){\n            }\n            testClass = testClass.getSuperclass();\n        }\n    }\n}",
