    "patch_code": "import java.util.Arrays;\nimport java.util.stream.Collectors;\n\npublic class TestClass {\n  public static void main(String[] args) throws Exception {\n    System.out.println(cacheString(new char[]{'h', 't', 'm', 'l'}, new String[4], 1, 3));\n  }\n  \n  private static String cacheString(final char[] charBuf, final String[] stringCache, final int start, final int count) {\n      if (stringCache == null || stringCache.length == 0){\n          throw new ArrayIndexOutOfBoundsException();\n      }\n      \n    // limit (no cache):\n    if (count > maxStringCacheLen())\n        return Arrays.copyOfRange(charBuf, start, count);\n\n    // calculate hash:\n    int hash = 0;\n    int offset = start;\n    for (int i = 0; i < count; i++) {\n        hash = 31 * hash + charBuf[offset++];\n    }\n\n    // get from cache\n    final int index = hash % stringCache.length ;\n    String cached = stringCache[index];\n\n    if (cached == null) { // miss, add\n        cached = Arrays.copyOfRange(charBuf, start, count);\n        stringCache[index] = cached;\n    } else { // hashcode hit, check equality\n        if (rangeEquals(charBuf, start, count, cached)) { // hit\n            return cached;\n        } else { // hashcode conflict\n            cached = Arrays.copyOfRange(charBuf, start, count);\n            stringCache[index] = cached; // update the cache, as recently used strings are more likely to show up again\n        }\n    }\n    return cached;\n}\n  \n  private static boolean rangeEquals(final char[] array1, final int start1, final int end1, final String s2) {\n     if ((end1 - start1) != s2.length()){\n         return false;\n     }\n        for (int i = 0; i < end1 - start1; i++) {\n           if (array1[start1+i]!=s2.charAt(i)){\n               return false;\n           }\n        }\n        return true;\n    }\n  \n  private static int maxStringCacheLen(){\n      return Integer.MAX_VALUE / (sizeof(int) * 8 + 31);\n  }\n}",
