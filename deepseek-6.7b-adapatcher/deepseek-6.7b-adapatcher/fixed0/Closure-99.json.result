    "patch_code": "public boolean shouldTraverse(NodeTraversal t, Node n, Node parent) {\n  if (n.getType() == Token.FUNCTION) {\n    JSDocInfo jsDoc = getFunctionJsDocInfo(n);\n    if (jsDoc != null &&\n        (jsDoc.isConstructor() ||\n         jsDoc.hasThisType() ||\n         jsDoc.isOverride())) {\n      return false;\n    }\n  } else if (n.getType() == Token.VAR) {\n    Node init = n.getFirstChild().getNext();\n    if ((init.getType() == Token.CALLEXPR &&\n        init.getFirstChild().getType() == Token.NAME &&\n        ((String)init.getFirstChild().getValue()).equals(\"Object\"))){\n      String name = ((String)n.getName());\n      \tif(!name.equals(\"undefined\")&&!name.equals(\"null\")&&name.charAt(0)!='_'){\n\t\t\t\tt.traverse(init);\n\t\t\t}\n\t\t}else if (init.getType() == Token.NEWEXPR){\n      String name = ((String)n.getName());\n      \tif(!name.equals(\"undefined\")&&!name.equals(\"null\")&&name.charAt(0)!='_'){\n\t\t\t\tt.traverse(init);\n\t\t\t}\n\t\t}else {\n\t\t\tString name1 = ((String)n.getName()),name2 = \"\";\n      \tif((n.getLastChild().getToken()==Token.ASSIGN)&&(n.getLastChild().getNext()==null)){\n\t\t\t\t\tinit = n.getLastChild();\n\t\t\t\t\tif(init.getPrev().getType()!=Token.OBJECTLITERAL){\n\t\t\t\t\t\tfor (int i = 0; i < name1.length(); i++) {\n\t\t\t\t\t\t\tif(name1.charAt(i)=='.'){\n\t\t\t\t\t\t\t\tbreak;\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\tname2 += Character.toString(name1.charAt(i));\n\t\t\t\t\t\t}if(name2.indexOf('[')>-1||name2.indexOf('<')>-1||name2.indexOf('#')>-1){\n\t\t\t\t\t\t\treturn false;\n\t\t\t\t\t\t}else if(!name2.isEmpty())\n\t            \tif (init.getNext().getPrev().getNext().getType() == Token.ARGUMENTS &&\n\t                 init.getPrev().getPrev().getType() == Token.ASSIGN) {\n\t               t.traverse(n);\n\t               return false;\n\t           }\n  \t\t\t\t}\n\t\t}return true;}\n\t}\n   else if (n.getType() == Token.NAME) {\n\t\tString name = ((String)n.getValue());\n    if(name.charAt(0)=='_'){\n\t\t\treturn false;\n\t\t}\n\t}\n   \n  int pType = parent.getType();\n  if (pType == Token.SCRIPT || \n      pType == Token.STATEMENTS || \n      pType == Token.RETURNSTMT ||\n      pType == Token.IFCONSTRUCTOR ||\n      pType == Token.WHILELOOPHEAD ||\n      pType == Token.FORLOOPHEAD ||\n      pType == Token.WITH ||\n      pType == Token.TRYHEAD ||\n      pType == Token.CATCHPARAMETERS ) {\n    return true;\n  } \n  return false;\n}",
