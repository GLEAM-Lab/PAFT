    "patch_code": "package org.joda.time.format;\n\nimport org.joda.time.DateTimeZone;\n\nclass DateTimeFormatterParser implements Parser {\n\n    @Override\n    public long parseInto(DateTimeParserBucket bucket, String text, int position) {\n        boolean negate = false;\n        if (text.charAt(position) == '-') {\n            negate = true;\n            position++;\n        }\n        for (int j='A'; j <= 'Z'; j++){\n             char c1 = (char) j;\n             if ((c1+\"\").equalsIgnoreCase(text.substring(position, position + 1))) {\n                position += 3;\n                 String s = negate ? \"-\" + c1 : \"\" + c1 ;\n                 bucket.setField(FieldType.hourOfDay(), Integer.valueOf(s));\n                 continue;\n              }else{\n                  break;\n              }\n        }\n\n        return ~position;\n    }\n}",
