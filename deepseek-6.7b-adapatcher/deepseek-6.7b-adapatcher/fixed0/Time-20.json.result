    "patch_code": "public int process(String text, int position, DateTimeZone Zone) {\n    String str = text.substring(position);\n    for (String id :ALL_IDS ) {\n        if (str.startsWith(id)) {\n            if ( Zone != null && ! Zone.getID().endsWith(id)) {\n                return ~position;\n            }\n            return position + id.length();\n        }\n    }\n    return ~position;\n}",
