    "patch_code": "@Override\npublic int compareTo(Fraction fraction) {\n    long numeratorDifference = getNumerator() - fraction.getNumerator();\n    long denominatorDifference = getDenominator() - fraction.getDenominator();\n    \n    if (numeratorDifference == 0 && denominatorDifference == 0){\n        return 0;\n    }else if((numeratorDifference * denominatorDifference) > 0){\n        return (int)(numeratorDifference / Math.abs(denominatorDifference));\n    } else{\n        return (int)(numeratorDifference / denominatorDifference);\n    }\n}",
