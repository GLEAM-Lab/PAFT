    "patch_code": "import java.math.BigDecimal;\nimport java.math.RoundingMode;\n\npublic int compareTo(Fraction that) {\n    BigDecimal v1 = BigDecimal.valueOf(this.getNumerator()).divide(BigDecimal.valueOf(this.getDenominator()), 20, RoundingMode.HALF_UP);\n    BigDecimal v2 = BigDecimal.valueOf(that.getNumerator()).divide(BigDecimal.valueOf(that.getDenominator()), 20, RoundingMode.HALF_UP);\n    \n    return v1.compareTo(v2);\n}",
