    "patch_code": "public int compareTo(Fraction object) {\n    long num1 = numerator;\n    long denom1 = denominator;\n    \n    long num2 = object.numerator;\n    long denom2 = object.denominator;\n\n    double diff = (num1 * denom2) - (num2 * denom1);\n    \n    if (Math.abs(diff) <= 1e-12){\n        return 0;\n    }else{\n        return (diff > 0) ? +1 : -1;\n    }  \n}",
