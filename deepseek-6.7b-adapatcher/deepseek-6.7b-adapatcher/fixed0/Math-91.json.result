    "patch_code": "public int compareTo(Fraction object) {\n    long nominatorDifference = getNumerator() * object.getDenominator() - getDenominator() * object.getNumerator();\n    long denominatorCommonProduct = getDenominator() * object.getDenominator();\n    \n    boolean equals = Math.abs(nominatorDifference) < 0.0000001 && denominatorCommonProduct != 0;\n    return equals ? 0 : (int)Math.signum(nominatorDifference);\n}",
