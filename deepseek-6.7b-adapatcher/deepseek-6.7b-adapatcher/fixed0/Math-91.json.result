  {
    "patch_code": "import java.lang.*;\n\nclass Solution{\n    \n    public static void main(String[] args){\n        String frac1 = \"2987654321/123456789\";\n        String frac2 = \"123456789/2987654321\";\n        \n        Fraction pi1 = new Fraction(frac1);\n        Fraction pi2 = new Fraction(frac2);\n        \n        System.out.println(pi1.compareTo(pi2));\n    }\n    \n}\n\nclass Fraction implements Comparable<Fraction> {\n\n    private final long numerator;   // Z\u00e4hler\n    private final long denominator; // Nenner\n\n    // erzeugt eine Bruch-Zahl mit den angegebenen Werten f\ufffdr Nenner und Z\u00e4hler\n    public Fraction(long numerator, long denominator) {\n        this.numerator = numerator;\n        this.denominator = denominator;\n    }\n    \n    @Override\n    public boolean equals(Object x) {\n        if (x == null) {\n            throw new NullPointerException(\"Bruch ist nicht zulaessig\");\n        }\n        if (this == x) {\n            return true;\n        }\n        if (!(x instanceof Fraction)) {\n            return false;\n        }\n        Fraction that = (Fraction) x;\n        return this.numerator * that.denominator == that.numerator * this.denominator;\n    }\n\n    // gibt den Nenner des Bruchs zurueck\n    public long getDenominator() {\n        return denominator;\n    }\n\n    // gibt die Zaehler des Bruchs zurueck\n    public long getNumerator() {\n        return numerator;\n    }\n\n    public double doubleValue() {\n        return ((double) numerator) / denominator;\n    }\n\n    @Override\n    public String toString() {\n        return numerator + \"/\" + denominator;\n    }\n\n    public int hashCode(){\n        int prime = 31;\n        int result = 1;\n        result = prime * result + (int)(numerator ^ (numerator >>> 32));\n        result = prime * result + (int)(denominator ^ (denominator >>> 32));\n        return result;\n    }\n    \n    @Override\n    public int compareTo(Fraction q) {\n        if (this.equals(q)){\n            return 0;\n        }\n        else if (this.doubleValue() < q.doubleValue()) {\n            return -1;\n        }\n        else return 1;\n    }\n}",
