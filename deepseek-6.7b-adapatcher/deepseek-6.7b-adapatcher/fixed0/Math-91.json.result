    "patch_code": "public int compareTo(Fraction object) {\n    long nOd = getNumerator(), dOn = object.getNumerator();\n    long od = getDenominator(), don = object.getDenominator();\n    double diff  = Math.abs((double)(nOd*don - dOn * od) / (od*don));\n    if (diff < 1E-12){\n        return 0;    \n    } else if((nOd*don - dOn * od) > 0 ){\n            return -1;      \n         }else{\n             return +1;     \n         }\n}",
