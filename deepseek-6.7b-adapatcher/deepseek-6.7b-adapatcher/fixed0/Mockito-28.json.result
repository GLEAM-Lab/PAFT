    "patch_code": "import java.lang.reflect.Field;\nimport java.util.*;\npublic class Main{\n    \n   static String someMethod(int arg1, int arg2){\n      return Integer.toString(arg1+arg2);\n    }\n\n   static void someOther(int arg1, String arg2){\n       System.out.println(\"arg1: \" + arg1 + \", arg2:\"+ arg2);\n    }\n\nstatic List<Field> orderedInstanceFieldsFrom(Class<?> clazz) throws SecurityException, NoSuchFieldException{\n        Class<?> superclass = clazz.getSuperclass();\n        if(superclass!=null && !superclass.equals(Main.class)){\n            try {\n                Field[] publicFields =  superclass.getDeclaredField() ;\n                 return Arrays.asList(new Field[0]);\n            } catch(NoSuchFieldException ex){\n                throw new NoSuchFieldException(clazz.getName());\n            }\n            \n        }else if(!clazz.isInterface()){\n              try {\n                Field[] publicFields = clazz.getDeclaredField();\n                  return Arrays.asList(new Field[0]);\n               }catch(NoSuchFieldException ex){\n                   throw new NoSuchFieldException(clazz.getName());\n               }\n         }\n        throw new NoSuchFieldException(clazz.getName());\n         \n        \n        \n    }\npublic static void main(String []args)throws Exception {\n  //current:\n    someOther(1, someMethod(1,2));\n  //repair:\n    \n    int i = 3;\n    someOther(1,(String)someMethod(i,4));\n}\n}",
