    "patch_code": "private void adjustArguments(Set<Object> mocks, List<Object[]>arguments) {\n    for(Object[] argument :arguments){\n        if( argument.length == 2 && !((Object[][]) argument).isEmpty()) {\n            Object[] argumentArray =((Object[][]) argument).get(0);\n            Object arg1 = argumentArray[0];\n            Object arg2 = argumentArray[1];\n            String strarg2 = arg2 == null ? null : arg2.getClass().getAnnotation( annotation ) == null ? arg2.toString() : null;\n            if(strarg2 !null){\n                argumentArray[1]= strarg2;\n            }\n        }\n    }\n}",
