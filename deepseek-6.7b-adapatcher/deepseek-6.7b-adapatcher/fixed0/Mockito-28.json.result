    "patch_code": "private void injectMockCandidate(Class<?> awaitingInjectionClazz, Set<Object> mocks, Object fieldInstance) throws IllegalAccessException {\n    for(Field field : orderedInstanceFieldsFrom(awaitingInjectionClazz)) {\n        if (isValidType(field)) {\n            InjectedValue injected = mockCandidateFilter.filterCandidate(mocks, field, fieldInstance);\n            injected.thenInject();\n        } else {\n            injectNonPrimitiveOrReferenceTypes(mocks, field, fieldInstance);\n        }\n        \n    }\n}\n\nprivate boolean isValidType(Field field){\n   Class<?> cls = field.getType();\n    return !cls.isPrimitive() && !cls.equals(String.class);\n}\n\nprivate void injectNonPrimitiveOrReferenceTypes(Set<Object> mocks, Field field, Object instance) throws IllegalArgumentException, IllegalAccessException{\n       String rawTypeName = field.toString().split(\" \")[1];\n       if(rawTypeName.contains(\"<\") ){\n           int endIndex = rawTypeName.indexOf('<');\n           rawTypeName = rawTypeName.substring(0,endIndex);\n       }\n       \n      Class <?> typeToCast= null;\n        try {\n             typeToCast = getUnmockedMatcherByTypeName(mocks ,rawTypeName);\n             \n        }catch(ClassNotFoundException e){\n            throw new RuntimeException(\"There was problem during casting process\",e);\n        } catch(NoSuchBeanDefinitionException e ){\n            throw new IllegalArgumentException(\"You can not create mock for primitive types or classes that do not have public empty constructor\", e);\n        }\n    \n          if(!Modifier.isPublic(typeToCast.getDeclaredConstructor().getModifiers())){\n               throw new IllegalArgumentException(\"You can not create mock for classes that does not have public no arguments constructor\"+typeToCast.getName());\n               \n           }\n           \n           Constructor<?>[] declaredConstructors = typeToCast.getDeclaredConstructors();\n           if (declaredConstructors.length > 0) {\n               // We find correct constructor\n                final ConstraintDesc desc = getApplicableConstructorDescriptor(new MethodDescription(typeToCast), mocks );\n                \n                Constructor<?> chosenConstructor = desc.constructor;\n               \n                    if (!chosenConstructor.isAccessible()) {\n                        chosenConstructor.setAccessible(true);\n                        \n                    }\n                    \n                  instance =  chosenConstructor.newInstance();\n                   \n                   setter(field ,instance ,typeToCast);\n\n               \n              \n           }else {\n               setter(field ,instance ,typeToCast);\n               \n           }\n           \n       \n    }\n\nprivate void setter(Field field , Object instance ,Class < ? > clazz ) throws IllegalAccessException{\n    \n    field.setAccessible(true);\n   \n        field.set(clazz.cast(instance));\n}\n\nprivate  Class<?> getUnmockedMatcherByTypeName(Set<Object> mocks , String className) throws ClassNotFoundException, NoSuchBeanDefinitionException {\n    String qualifiedName = convertNameToFullyQualifiedName(className);\n        Class<?> candidate = Class.forName(qualifiedName);\n        if(candidate.isInterface() || alreadyMocksAnyOfTheseClasses(mocks,candidate)){\n             throw new NoSuchBeanDefinitionException (\" There is already created mock for class\" + candidate.getName());\n        \n    }\n    return candidate;\n    \n    \n}\n private boolean alreadyMocksAnyOfTheseClasses(Set<Object> mocks, Class<?> candidate) {\n    for (Object mock : mocks) {\n        if (mock.getClass().isAssignableFrom(candidate)) {\n            return true;\n        }\n    }\n    return false;\n}\n\nprivate String convertNameToFullyQualifiedName(String simpleName) {\n    return Thread.currentThread().getContextClassLoader().getPackage().getName()  + '.' + simpleName;\n}",
