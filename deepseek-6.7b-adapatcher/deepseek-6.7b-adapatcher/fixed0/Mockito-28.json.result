    "patch_code": "public class Test_injectMockCandidate {\n    \n    public static String printTypeInfo(Class c){\n       if(c == Integer.class || c== int.class){\n           return \"int\";\n       } else if (c == Double.class || c == double.class){\n           return \"double\";\n       }else if (c == Float.class || c == float.class){\n           return \"float\";\n       }else if (c == Boolean.class || c == boolean.class){\n           return \"boolean\";\n       }else if (c == Character.class || c == char.class){\n           return \"char\";\n       }\n     \n       return null;\n   }\n    private static void injectMockCandidate(Class<?> awaitingInjectionClazz, Set<Object> mocks, Object fieldInstance) {\n         Field[] fields = ClassLayout.parseInstance(new Object()).toPrintable().fields();\n         \n        for(Field field : fields) {\n            String printType=null;\n            \n            System.out.println(field.getGenericSignature());\n            if (!field.getName().equals(\"this$0\")&& !field.getName().contains(\"$$\")){\n                \n                printType=printTypeInfo(field.getType());\n            }\n             \n            \n            \n               // if(mockCandidateFilter.filterCandidate(mocks, field, fieldInstance)!=null){\n                    \n                   \n                   \n                 \n                   \n                   \n                  \n                     \n                         if(printType!=null && !printType.equalsIgnoreCase(\"double\") && \n                            !printType.equalsIgnoreCase(\"float\")&& !printType.equalsIgnoreCase(\"long\") && \n                           !printType.equalsIgnoreCase(\"char\") ) {\n                         \n                       \n                       System.out.printf(\"someOther(1, %s %s)\",printType, field.getName());\n                       \n                      \n                    }\n                        else{\n                             System.out.printf(\"someOther(1, %s)\", field.getName());\n                        }\n                 \n                \n             \n        }\n    }\n\n\tpublic static void main(String [] args) {\n\t    \n\t    injectMockCandidate(Test_injectMockCandidate.class, new HashSet<Object>(), new Object() );\n\t}\n}",
