    "patch_code": "public static option create(String opt) throw IllegalArgumentException {\n    try {\n        // create the option\n        option option = new option(opt, description);\n\n        // set the option properties\n        option.set long opt(longopt);\n        option.set required( required);\n        option.set Optional arg( Optional arg);\n        option.set Args( numberOfargs);\n        option.set type( type);\n        option.set value separator( valuesep);\n        option.set arg name( arg name);\n\n        // return the option instance\n        return option;\n    } catch (Il IllegalArgumentException e) {\n        //Reset the optionBuilder properties\n        optionBuilder.programming error( program error);\n        optionBuilder.optionBuilder.set long opt( null);\n        optionBuilder.optionBuilder.set required( false);\n        optionBuilder.optionBuilder.set Optional arg( null);\n        optionBuilder.optionBuilder.set Args( -1);\n        optionBuilder.optionBuilder.set type( null);\n        optionBuilder.optionBuilder.set value separator( null);\n        optionBuilder.optionBuilder.set arg name( null);\n        \n        throw e;\n    } finally {\n        optionBuilder.optionBuilder.set long opt( null);\n        optionBuilder.optionBuilder.set required( false);\n        optionBuilder.optionBuilder.set Optional arg( null);\n        optionBuilder.optionBuilder.set Args( -1);\n        optionBuilder.optionBuilder.set type( null);\n        optionBuilder.optionBuilder.set value separator( null);\n        optionBuilder.optionBuilder.set arg name( null);\n    }\n}",
