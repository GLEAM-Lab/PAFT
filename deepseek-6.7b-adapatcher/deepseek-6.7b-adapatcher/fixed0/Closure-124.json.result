    "patch_code": "private boolean isSafeReplacement(Node node, Node replacement) {\n  // No checks are needed for simple names.\n  if (node.isName()) {\n    return true;\n  }\n  Preconditions.checkArgument(node.isGetProp());\n\n  node = node.getFirstChild();\n  \n  if (!isNameOrEmpty(node)){\n        String nameOrEmpty = node.getString();\n        \n        Preconditions.checkNotNull(nameOrEmpty);\n    \n            int end = nameOrEmpty.indexOf('.');\n          if (end >= 0) {\n              String variableName = nameOrEmpty.substring(0, end);\n            \n              if (variableMap.containsKey(variableName)) {\n                  VarType typeOfVariable = variableMap.get(variableName).getType();\n                if (typeOfVariable == null || typeOfVariable.isAnyFunction() ){\n                    // Ignore this assignment since we don't want to change global variables.\n                    return false;\n                } else {\n                    \n                    typeOfVariable = resolveIfUndefined(typeOfVariable);\n                \n                    Preconditions.checkState(typeOfVariable != null,\"Unresolved type\");\n                \n                        String remainingPropertiesPath = nameOrEmpty.substring(end + 1);\n                      \n                        if(!remainingPropertiesPath.isEmpty())\n                      {\n                        \n                          if (resolvePropertyAccessIncludingChainLinksCalls(replacement, remainingPropertiesPath)!= null)\n                            return false;\n                        }\n                \n                }\n              \n          }\n          \n       }\n      \n    return true;\n}",
