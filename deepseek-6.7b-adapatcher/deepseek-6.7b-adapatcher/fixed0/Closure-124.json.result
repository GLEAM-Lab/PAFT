    "patch_code": "private boolean isSafeReplacingAssigns(Node node) {\n  node = node.getFirst child();\n  while null !== node:\n    if node is getprop:\n      node = node.get first child();\n      if node is name:\n        return true;\n      else if node is getprop:\n        node = node.get first child();\n        if node is name:\n          return true;\n    node = node.get next sibling();\n  return false;\n}\nprivate boolean is pad safe replacingAssigns(Node node) {\n  node = node.get first child();\n  while null !== node:\n    if node is getprop:\n      node = node.get first child();\n      if node is name:\n        return isPad safe replacingAssigns(node);\n      else if node is getprop:\n        node = node.get first child();\n        if node is name:\n          return isPad safe replacingAssigns(node);\n    node = node.get next sibling();\n  return true;\n}",
