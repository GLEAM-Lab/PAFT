    "patch_code": "boolean isAssignedOnceInLifetime() {\n  Assignment assignment = (Assignment) getOneAndOnlyAssignment();\n  if (assignment == null || assignment.getDst().getType() != TypeKind.VARIABLE) {\n    return false;\n  }\n  Variable variable = (Variable) assignment.getDst();\n\n  BasicBlock basicBlockForDestination =\n    variableToDefinition.getValueFactory().getProgramBuilder().toBasicBlock(variable);\n\n  // Walk up parent blocks until we reach either a function or the root of the program.\n  boolean seenLoop = false;\n  while (!basicBlockForDestination.isMethod()) {\n    if (basicBlockForDestination.parent instanceof LoopInfo) {\n      seenLoop = true;\n      break;\n    }\n    basicBlockForDestination = basicBlockForDestination.parent;\n  }\n\n  return !seenLoop && assignment.useList.isEmpty();\n}",
