    "patch_code": "boolean isAssignedOnceInLifetime() {\n  Reference ref = getOneAndOnlyAssignment();\n  if (ref == null) {\n    return false;\n  }\n  \n  boolean visited = new HashSet<String>();\n  Stack<Statement> stack = new Stack<Statement>();\n  stack.push(ref.getBasicBlock().entry);\n  \n  while(!stack.isEmpty()) {\n    Statement statement = stack.pop();\n    \n    if (!visited.contains(statement.toString())) {\n      visited.add(statement.toString());\n      \n      if(statement instanceof IfStatement) {\n        IfStatement ifState = (IfStatement)statement;\n        \n        for (int i = 1; i < ifState.getSuccessors().length; ++i) {\n          BasicBlock successor = ifState.getSuccessors()[i];\n          \n          if(successor != null && !successor.isUnreachable()) {\n            stack.push(successor.entry);\n          }\n        }\n      } else if (statement instanceof ExpressionStatement) {\n        ExpressionStatement expStat = (ExpressionStatement)statement;\n        \n        if(expStat.expression instanceof Assign) {\n          Assign assign = (Assign)expStat.expression;\n          \n          if(assign.getTarget() instanceof Local || assign.getTarget() instanceof Parameter) {\n            \n            if(visited.contains(assign.getTarget().getName())){\n              continue;\n            }else{\n              \n              String targetName = ((Local|Parameter)assign.getTarget()).getName();\n              int indexOfVar = currentCompilationUnit.ast().findVariable(targetName).index;\n              \n              ArrayList assignments = currentCompilationUnit.findAllReferencesToVariable(indexOfVar);\n                              \n                if(assignments.size() > 1) {\n                  return false;\n                  \n                 } \n              }\n            }\n          }\n        } else if (statement instanceof ReturnStatement) {\n          break;\n        }\n      }\n    \n    }\n    \n    if(ref.getBasicBlock() == ((ReturnStatement)statement).getReturnedExpression().getEnclosingBlock()) {\n      return visited.size() == 1;\n      \n    } else if(ref.getBasicBlock().equals(((ReturnStatement)statement).getReturnedExpression().getEnclosingBlock().predecessors[0])) {\n      return visited.size() <= 2;\n    }\n  }\n  \n  throw new RuntimeException(\"Failed to detect variable lifespan.\");\n}",
