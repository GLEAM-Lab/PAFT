    "patch_code": "public boolean isAssignedOnceInLifetime() {\n  Reference ref = getOneAndOnlyAssignment();\n  if (ref == null) {\n    return false;\n  }\n\n  BasicBlock block = ref.getBasicBlock();\n  while ((block = block.getParent()) != null) {\n    if (block.isFunction || block.isLoop) {\n      break;\n    }\n  }\n\n  return block == null;\n}",
