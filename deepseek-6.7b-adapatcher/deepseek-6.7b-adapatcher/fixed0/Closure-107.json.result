    "patch_code": "private String getValueOrNull(String str) {\n        int end = str.indexOf(']');\n        if (end != -1) {\n            String value = str.substring(0, end).trim();\n            if (!\"\".equals(value)) {\n                return value;\n            }\n        }\n        return null;\n    }\n  \npublic void processArgsWithCallback(Runnable callback) throws IOException {\n    List<String> argsList = Lists.newArrayList();\n    Map<String, String> keyValueMap = Maps.newHashMap();\n    ProcessContext context = ProcessContext.getInstance();\n\n    while (context.hasMoreTokens()) {\n        String token = context.getNextToken();\n        switch (token) {\n        case \"--msg\":\n            context.setFlagMode(FLAG_MSG);\n            break;\n        case \"--dir\":\n            context.setFlagMode(FLAG_DIR);\n            break;\n        default:\n            if (context.isInFlagMode()) {\n                String value = getValueOrNull(token);\n                if (value != null) {\n                    keyValueMap.put(context.currentKey(), value);\n                }\n                break;\n            }\n            argsList.add(token);\n            break;\n        }\n    }\n    callback.run();\n}",
