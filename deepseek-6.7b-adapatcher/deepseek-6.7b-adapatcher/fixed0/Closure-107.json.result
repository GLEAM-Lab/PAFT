    "patch_code": "import com.google.javascript.jscomp.CompilerOptions;\nimport com.google.javascript.jscomp.Warnings;\n\npublic class CommandLineRunner extends com.google.javascript.jscomp.CommandLineRunner{\n   protected CompilerOptions createOptions() {\n       CompilerOptions options = new CompilerOptions();\n       if (flags.processJqueryPrimitives){\n           options.setCodingConvention(new JqueryCodingConvention());\n       }else{\n            options.setCodingConvention(new ClosureCodingConvention());\n        }\n        \n        options.setExtraAnnotationNames(flags.extraAnnotationName);\n        \n        options.setGenerateExports(flags.generateExports);\n        \n        WarningLevel warningLevel = flags.warningLevel;\n        int errorReporterId = warningLevel.errorReporterId;\n        warningLevel.setOptionsForWarningLevel(options);\n        \n        FormattingOption formattingOption = flags.formatting[0];\n        formattingOption.applyToOptions(options);\n        \n        String processClosurePrimitives = flags.processClosurePrimitives;\n        if (processClosurePrimitives != null){\n            processClosurePrimitives = processClosurePrimitives.replaceAll(\"\\\\bMSG_\\\\w+\", \"\");\n        }\n        \n        boolean jqueryPassFlag = flags.processJqueryPrimitives || flags.advancedOptimization;\n        if (flags.translateFileName != null){\n             try{\n                options.messageBundle = new XtbMessageBundle(\n                        new java.io.FileInputStream(flags.translateFileName),\n                        flags.translationProjectName);\n              }catch (IOException ex){\n                  throw new Error(\"Reading XTB file\", ex);\n              }\n         }else if (flags.advancedOptimization){\n            warningLevel.suppressWarning(Warnings.I18N_MESSAGES, \"goog.getMsg call not localized.\");\n            options.messageBundle = new EmptyMessageBundle();\n        }\n        \n        options.closurePass = processClosurePrimitives != null;\n        options.angularPass = flags.angulaPass;\n        options.jqueryPass = jqueryPassFlag;\n\n        return options;\n    }\n}",
