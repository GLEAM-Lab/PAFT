    "patch_code": "import java.lang.*;\nimport org.apache.commons.cli.*;\npublic class Main {\n    public static void main(String[] args){\n      \n       \n         \n     \n  \n    \tOptions options = new Options();\n    \t\n      try {\n\t\toptions.addOption(OptionBuilder.withLongOpt(\"hello\").hasArg().create());\n\t} catch (ParseException e1) {\n\t\t// TODO Auto-generated catch block\n\t\te1.printStackTrace();\n\t}\n\n\ttry {\n\t\toptions.addOption(OptionBuilder.withLongOpt(\"hi\").hasArgs().create());\n\t} catch (ParseException e1) {\n\t\t// TODO Auto-generated catch block\n\t\te1.printStackTrace();\n\t}\n\n\ttry {\n\t\toptions.addOption(OptionBuilder.withLongOpt(\"hey\").required().argName(\"name\").desc(\"bla bla\").build());\n\t} catch (Exception e1) {\n\t\t// TODO Auto-generated catch block\n\t\te1.printStackTrace();\n\t}\n\n\ttry {\n\t\toptions.addOption(OptionBuilder.withLongOpt(\"help\").noArg().desc(\"display help message.\").create());\n\t} catch (ParseException e1) {\n\t\t// TODO Auto-generated catch block\n\t\te1.printStackTrace();\n\t}\n        CommandLineParser parser = new DefaultParser();\n\n        HelpFormatter helpFormatter = new HelpFormatter();\n\n        CommandLine commandLine = null;\n        try {\n           commandLine= parser.parse(options,\"program --hey name  --hhh \");\n\n        }catch ( ParseException e) {\n            \n            System.err.println(e.getMessage());\n\n            helpFormatter.printHelp(\"utility [OPTION]...\", options );\n\n            System.exit(1);\n            \n            \n        }\n        if (commandLine.hasOption('h')) {\n            helpFormatter.printHelp(\"program \", options);\n        }\n\n    }\n    }",
