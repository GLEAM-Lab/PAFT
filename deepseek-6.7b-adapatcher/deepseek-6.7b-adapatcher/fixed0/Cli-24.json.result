    "patch_code": "protected StringBuffer renderWrappedText(StringBuffer sb, int width, \n                                         int nextLineTabStop, String text)\n{\n    int pos = findWrapPos(text, width, 0);\n    \n    try \n    {\n      if (pos == -1)\n      {\n          sb.append(rtrim(text));\n\n          return sb;\n      }\n      \n      sb.append(rtrim(text.substring(0, pos))).append(defaultNewLine);\n  \n      if (nextLineTabStop >= width)\n      {\n          throw new Exception (\"Total width is less than the width of the argument and indent \" + \n                              \"- no room for the description\");\n      }\n  \n      final String padding = createPadding(nextLineTabStop);\n  \n      while (true)\n      {\n          \n          text = padding + text.substring(pos).trim();\n          \n          pos = findWrapPos(text, width, 0);\n  \n          if (pos == -1)\n          {\n              sb.append(text);\n              \n              break;\n          }\n        \n          if ((text.length() > width) && (pos <= (width - padding.length()))) \n          {\n              pos = width - padding.length();\n          }\n  \n          sb.append(rtrim(text.substring(0, pos))).append(defaultNewLine);\n      }\n  \n      return sb;\n    }\n    \n    catch (Exception e) \n    {\n        System.err.println(e.getMessage());\n        \n        return null;\n    }\n}",
