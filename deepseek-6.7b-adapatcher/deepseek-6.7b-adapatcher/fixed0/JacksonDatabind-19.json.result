    "patch_code": "private static final class MapType extends SimpleType implements JavaType {\n     /*\n     /***********************************************\n     /* Life cycle\n     /***********************************************\n      */\n\n    public MapType(Class<?> rawType) {\n        super(rawType, JsonType.OBJECT_MAPPER_SCOPED);\n        addIfNotPresent(JsonTypeId.MAP, rawType);\n    }\n\n    @Override\n    public String toString() {\n        return \"[MapType]\"+_class.getName();\n    }\n}\n\npublic <T extends Annotated> JavaType constructMapType(Class<?> keyType, Class<?> contentType) {\n    Class<Map> mapClass = Map.class;\n    try {\n        mapClass = (Class<Map>) _findCachedSubType(mapClass, keyType, contentType);\n    } catch (Exception e) {\n        /* No exception - we'll just have to go on and create new one instead */\n    }\n    if (mapClass != null && keyType != String.class || contentType != String.class) {\n        // Needs substitution\n        return new MapType(mapClass).narrowByKeyAndContent(keyType, contentType);\n    }\n    return new MapType(mapClass);\n}",
