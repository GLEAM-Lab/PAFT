    "patch_code": "private static final class _MapTypeHolder {\n    private static final Type _MapType = mapper().getType Factory._mapType(Map.class);\n}\nprivate static final class _TypeHolder {\n    private static final Type _StringType = mapper().getType Factory._StringType;\n}\nprivate static Type _mapType(Class<?> cl)\n{\n    Type result = _MapTypeHolder._MapType;\n    List<Type> types = result.get types();\n    types.add(cl); types.add( _StringType);\nreturn result;\n}",
