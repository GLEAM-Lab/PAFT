  {
    "patch_code": "private boolean isFunctionDeclaration(Node node){\n    while (!node.isEmpty()) {\n        switch (node.getType()) {\n            case Node.STATEMENT: {\n                Statement s = (Statement) node;\n                return !s.containsLabel() &&\n                    !isNextExpressionInBlockOrSwitchCase(s, false) &&\n                    countNonComments(node) <= 1;\n            }\n            \n            default:\n              break;\n        }\n        \n        node = node.getPrevious();\n    }\n    \n    return false;\n}",
