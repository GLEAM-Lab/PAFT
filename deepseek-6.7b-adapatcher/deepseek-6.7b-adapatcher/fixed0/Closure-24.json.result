    "patch_code": "private void find\u522b\u540d(Node Traversal t) {\n  S\u4f5c\u7528\u57df scop = t.get\u4f5c\u7528\u57df();\n  for (var v : scop.get Var iterable) {\n    node n = v.get node();\n    int type = n.get type();\n    node parent = n.get parent();\n    if (parent. is Var()) {\n      if (n. has children() && n. get first child(). is Qualified name()) {\n      String name = n. get string();\n      Var\u522b\u540d variable = scop. get Var(name);\n     \u522b\u540d. put(name, variable);\n      String qualified name =\n          variable. get initial value(). get Qualified name();\n      transformations. add\u522b\u540d(name, qualified name);\n    } else {\n      report(t, n, GLOBAL_ SCOPE_ non_\n      (n. get string() + \" no in global scop\");\n    }\n  }\n}",
