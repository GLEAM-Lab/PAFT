  {
    "patch_code": "private boolean hasReturnStatement(Statement s){\n        if(s instanceof ReturnStatement){\n            return true;\n        }\n        \n        if(!(s instanceof Block)){\n            return false;\n        }\n        \n        Statement[] statements = ((Block)s).getStatements();\n        for(int i=0;i<statements.length;++i){\n            if(hasReturnStatement(statements[i])){\n                return true;\n            }\n        }\n        return false;\n    }\n    \nprivate void findAliases(NodeTraversal t) {\n        Scope scope = t.getScope();\n        for (Var v : scope.getVarIterable()) {\n            Node n = v.getNode();\n            \n            int type = n.getType();\n            Node parent = n.getParent();\n            \n            if (!parent.isFunction()) {\n                 continue;\n                 \n             }else if(parent.isVar()){\n                if (n.hasChildren() && n.getFirstChild().isQualifiedName()) {\n                    String name = n.getString();\n                    \n                    Var aliasVar = scope.getVar(name);\n                    aliases.put(name, aliasVar);\n                    \n                    \n                    if(!hasReturnStatement((Statement)aliasVar.getInitialValue())){\n                        \n                        String qualifiedName =\n                            aliasVar.getInitialValue().getQualifiedName();\n                        transformation.addAlias(name, qualifiedName);\n                        \n                    }else {\n                         \n                       report(t, n, GOOG_SCOPE_BAD_RETURNED, n.getString());  \n                    }\n                     \n                  \n               } else {\n                    \n                    report(t, n, GOOG_SCOPE_NON_ALIAS_LOCAL, n.getString());\n                }\n             \n                \n            }\n        }\n    }",
