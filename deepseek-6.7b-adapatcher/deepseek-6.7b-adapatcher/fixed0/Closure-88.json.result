    "patch_code": "private boolean is variable living(Node n) {\n  if (!NodeUtil.is name(n)) {\n    return true;\n  }\n  String variable = n.getString();\n  boolean live = false;\n  for (Node child = n.getFirst child(); child ! null; child = child. get next()) {\n    if (!control flow graph.is enter new cfga node(child)) {\n      variabledlivens state = variabledlivens.is variable read before kill(child, variable);\n      if (state ==variabledlivens. kill) {\n        return false;\n      }\n      live |= state !=variabledlivens.maybe live;\n    }\n  }\n  return live;\n}\nprivate variabledlivens is variable read before kill(Node n, String variable) {\n  if (node util. is name(n)) {\n    if (n.getString(). matches(\"^[abcd][^.][^.]*$\") && n.getString().startsWith(\"&\" + variable)) {\n      return variabledlivens. kill;\n    }\n  }\n  for (Node child = n. get first child(); child ! null; child = child. get next()) {\n    variabledlivens state = is variabledlivens.is variable read before kill(child, variable);\n    if (state != variabledlivens. maybe live) {\n      return state;\n    }\n  }\n  return variabledlivens. maybe live;\n}",
