    "patch_code": "public void visit(Node traverse, node, parent) {\n\n  // record global variable and function Declare\n  if (traverse.in global) {\n    if (node.is Var Declare) {\n      Naming information = createNaminginformation(traverse, node, parent);\n      preconditions.check null(information);\n      record set(information. name, node);\n    } else if (node.is functiondeclare) {\n      node nameNode = node.getFirst child();\n      Naming information = createNaminginformation(traverse, nameNode, node);\n      if (information ! null) {\n        Jsname nameinfo = getname(information. name, true);\n        record set(nameinfo. name, nameNode);\n      }\n    } else if (node.is objectdeclare) {\n      Naming information = createNaminginformation(traverse, node, parent);\n      if (information ! null) {\n        record set(information. name, node);\n      }\n    }\n  }\n\n  // record assignments and call sites\n  if (node.is Assign) {\n    node nameNode = node.getfirst child();\n    Naming information = createNaminginformation(traverse, nameNode, node);\n    if (information ! null) {\n      if (information. onlyaffects classdefine) {\n        Jsname name = getname(information. name, false);\n        if (name ! null) {\n          refNode refNode = new ClassDefiningfunctionnode(\n              name, node, parent, parent. getparent());\n          ref\u8282\u70b9 ref\u8282\u70b9. addrefnode(ref\u8282\u70b9);\n        }\n      } else {\n        record set(information. name, nameNode);\n      }\n    }\n  } else if (node.is call) {\n    node nameNode = node.getfirst child();\n    Naming information = createNaminginformation(traverse, nameNode, node);\n    if (information ! null && information. onlyaffects classdefine) {\n      Jsname name = getname(information. name, false);\n      if (name ! null) {ref\u8282\u70b9 refNode = new ClassDefiningfunctionnode(\n          name, node, parent, node. getparent()); ref\u8282\u70b9 ref\u8282\u70b9. addrefnode(ref\u8282\u70b9);\n        }\n    }\n  }\n}",
