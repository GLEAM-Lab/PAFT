    "patch_code": "public void visit(Node Traversal t,Node n,Node parent) {\n  \n  if (!(n.getNodeType().getMask() & nodeTypeMask)) { return; }\n  \n  if (t.in globalScopp){\n    if ( n.getNodeType().getMask() & nodeTypeMask == nodeTypeMast.NODE_ VarDeclaration){\n      recordSet(createNameinformation(n));\n    }elseif ( n.getNodeType().getMask() & nodeTypeMask == nodeTypeMast.NODE_ functionDeclaration){\n      recordSet(createNameinformation(n.getFirst child());\n    }elseif ( n.getNodeType().getMask() & nodeTypeMask == nodeTypeMast.NODE_ object literals){\n      recordSet(createNameinformation(n));\n    }\n  }elseif ( n.is Assign()) {\n    recordSet(createNameinformation(n.getFirst child());\n  }elseif ( n.is call()) {\n    recordSet(createNameinformation(n.getFirst child());\n  }elseif ( n.is functionCall()) {\n    recordSet(createNameinformation(n.getFirst child());\n  }elseif ( n.is expression()) {\n    recordSet(createNameinformation(n.getFirst child());\n  }\n}",
