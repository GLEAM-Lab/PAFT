    "patch_code": "import com.google.common.collect.Sets;\n\nimport java.util.HashMap;\nimport java.util.Map;\nimport java.util.Set;\n\npublic class SmartNameRemovalRepair implements JsVisitor {\n  private Map<String, Set<JsAstPath>> varDeclToReferences = new HashMap<>();\n  public static final String FOO_EVENT = \"FooEvent\";\n  public static final String SELECT_EVENT = \"SelectEvent\";\n  public static final String CHANGE_EVENT = \"ChangeEvent\";\n  public static final String PAGE_SELECTION_MODEL = \"PageSelectionModel\";\n  \n  @Override\n  public void visit(NodeTraversal traversal, Node node, Node parent) {\n    if (traversal.inGlobalScope()) {\n      if (node instanceof VariableDeclarationHolder) {\n        VariableDeclarationHolder holder = (VariableDeclarationHolder) node;\n        String key = holder.getName().toString();\n        \n        if (FOO_EVENT.equals(key) || SELECT_EVENT.equals(key)) {\n          return;\n        }\n        \n        Set<JsAstPath> paths = Sets.newLinkedHashSet();\n        \n        if (varDeclToReferences.containsKey(key)) {\n          paths = varDeclToReferences.get(key);\n        } else {\n          varDeclToReferences.put(key, paths);\n        }\n        \n        JsAstPath path = traversal.getCurrentPath();\n        paths.add(path);\n      } else if (node instanceof FunctionDeclaration) {\n        FunctionDeclaration func = (FunctionDeclaration) node;\n        String name = func.getName();\n        \n        if (PAGE_SELECTION_MODEL.equals(name)) {\n          return;\n        }\n        \n        if (!varDeclToReferences.isEmpty()) {\n          updateReferenceCountsForNewFunction(func);\n        }\n      }\n    } else if (node instanceof AssignmentExpression) {\n      AssignmentExpression assignmentExpr = (AssignmentExpression) node;\n      Expression leftHandSide = assignmentExpr.getLeftHandSide();\n      \n      if (leftHandSide instanceof IdentifierAccess) {\n        IdentifierAccess id = (IdentifierAccess) leftHandSide;\n        String name = id.getQualifiedName().toString();\n        \n        if (CHANGE_EVENT.equals(name)) {\n          return;\n        }\n      }\n    } else if (node instanceof CallExpression) {\n      CallExpression callExpr = (CallExpression) node;\n      Expression callee = callExpr.getCallee();\n      \n      if (callee instanceof IdentifierAccess) {\n        IdentifierAccess id = (IdentifierAccess) callee;\n        String name = id.getQualifiedName().toString();\n        \n        if (\"goog.inherits\".equals(name)) {\n          return;\n        }\n      }\n    }\n  }\n  \n  private void updateReferenceCountsForNewFunction(FunctionDeclaration func) {\n    boolean wasDecrementing = false;\n    \n    for (Map.Entry<String, Set<JsAstPath>> entry : varDeclToReferences.entrySet()) {\n      Set<JsAstPath> paths = entry.getValue();\n      \n      for (Iterator<JsAstPath> iterator = paths.iterator(); iterator.hasNext(); ) {\n        JsAstPath path = iterator.next();\n        \n        if (!wasDecrementing) {\n          if (path.findLastReference() == null) {\n            iterator.remove();\n            \n            continue;\n          }\n          \n          wasDecrementing = true;\n        }\n        \n        if (func.getName().equals(path.getDefinition().asFunctionDeclaration().getName())) {\n          int count = path.countOccurrencesInTail();\n          path.setIncrementOnlyIfNoChildrenYet(count == 0);\n        }\n      }\n    }\n  }\n}",
