    "patch_code": "public void reparseCentralDirectoryData(boolean hasUncompressedSize,\n                                        boolean hasCompressedSize,\n                                        boolean hasRelativeHeaderOffset,\n                                        boolean hasDiskStart)\n    throws ZipException {\n    if (rawCentralDirectoryData != null) {\n        int expectedLength = (hasUncompressedSize ? 8 : 0)\n            + (hasCompressedSize ? 8 : 0)\n            + (hasRelativeHeaderOffset ? 8 : 0)\n            + (hasDiskStart ? 2 : 0);\n        if (rawCentralDirectoryData.length != expectedLength) {\n            throw new ZipException(\"central directory zip64 extended\"\n                                   + \" information extra field's length\"\n                                   + \" doesn't match central directory\"\n                                   + \" data.  Expected length \"\n                                   + expectedLength + \" but is \"\n                                   + rawCentralDirectoryData.length);\n        }\n        int offset = 0;\n        if (hasUncompressedSize) {\n            byte[] uncompressedBytes = Arrays.copyOfRange(rawCentralDirectoryData, offset, offset + 8);\n            size = new BigInteger(uncompressedBytes).longValue();\n            offset += 8;\n        }\n        if (hasCompressedSize) {\n            byte[] compressedBytes = Arrays.copyOfRange(rawCentralDirectoryData, offset, offset + 8);\n            compressedSize = new BigInteger(compressedBytes).longValue();\n            offset += 8;\n        }\n        if (hasRelativeHeaderOffset) {\n            byte[] headerOffsetBytes = Arrays.copyOfRange(rawCentralDirectoryData, offset, offset + 8);\n            relativeHeaderOffset = new BigInteger(headerOffsetBytes).longValue();\n            offset += 8;\n        }\n        if (hasDiskStart) {\n            diskStart = ByteBuffer.wrap(Arrays.copyOfRange(rawCentralDirectoryData, offset, offset + 2)).getShort() & 0xFFFF;\n            offset += 2;\n        }\n    }\n}",
