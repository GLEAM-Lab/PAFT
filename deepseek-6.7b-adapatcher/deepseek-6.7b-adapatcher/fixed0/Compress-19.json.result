    "patch_code": "private static final int LONG_LEN = 4;\nprivate static final int INT_LEN = 2;\npublic void reparseCentralDirectoryData(boolean hasUncompressedSize,\n                                        boolean hasCompressedSize,\n                                        boolean hasRelativeHeaderOffset,\n                                        boolean hasDiskStart)\n    throws ZipException {\n    if (rawCentralDirectoryData != null && rawCentralDirectoryData.length > LONG_LEN * 3 + INT_LEN) {\n        int expectedLength = (hasUncompressedSize ? LONG_LEN : 0)\n            + (hasCompressedSize ? LONG_LEN : 0)\n            + (hasRelativeHeaderOffset ? LONG_LEN : 0)\n            + (hasDiskStart ? INT_LEN : 0);\n        if (expectedLength != rawCentralDirectoryData.length) {\n            throw new ZipException(\"central directory zip64 extended information extra field's length doesn't match central directory data.  Expected length \"\n                                   + expectedLength + \" but is \"\n                                   + rawCentralDirectoryData.length);\n        }\n        int offset = 0;\n        if (hasUncompressedSize) {\n            long[] ltmp = new long[LONG_LEN];\n            for (int i = 0 ; i < LONG_LEN; ++i){\n               ltmp[i] = ((long) rawCentralDirectoryData[offset]) & 0xff;\n              ++offset;  \n           }\n            size = java.util.Arrays.asList(ltmp).stream().mapToLong(Long::longValue).sum();\n        }\n        if (hasCompressedSize) {\n            long[] ltmp = new long[LONG_LEN];\n            for (int i = 0 ; i < LONG_LEN; ++i){\n               ltmp[i] = ((long) rawCentralDirectoryData[offset]) & 0xff;\n              ++offset;  \n           }\n            compressedSize = java.util.Arrays.asList(ltmp).stream().mapToLong(Long::longValue).sum();\n        }\n        if (hasRelativeHeaderOffset) {\n            long[] ltmp = new long[LONG_LEN];\n            for (int i = 0 ; i < LONG_LEN; ++i){\n               ltmp[i] = ((long) rawCentralDirectoryData[offset]) & 0xff;\n              ++offset;  \n           }\n            relativeHeaderOffset = java.util.Arrays.asList(ltmp).stream().mapToLong(Long::longValue).sum();\n        }\n        if (hasDiskStart) {\n            short sTmp = 0;\n            for (int i = 0; i < INT_LEN; ++i) {\n              sTmp |= rawCentralDirectoryData[offset];\n              if (i < INT_LEN - 1) {\n                 sTmp <<= 8;\n              }\n              ++offset;\n            }\n            diskStart = sTmp;\n        }\n    } else{\n      throw new ZipException (\"corrupted data in zip64 entry\");\n    }\n}",
