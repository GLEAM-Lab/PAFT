    "patch_code": "import org.apache.commons.math3.exception.*;\n\npublic class RepairedCode extends SimplexSolver{\n    @Override\n    public void optimize(LinearObjectiveFunction function, List<LinearConstraint> constraints, GoalType goalType, boolean restrictToNonNegative){\n        \n        checkConstraintsAndVariables(constraints, goalType);\n        \n        LinearObjectiveFunction lFunction;\n        List<LinearConstraint> cList = Lists.newArrayListWithCapacity(constraints.size());\n        \n        switch (goalType){\n            case MINIMIZE:\n                lFunction = new MinimizeFunction(function);\n                break;\n                \n            default: throw new MathIllegalArgumentException();\n        }\n        \n        double min = Double.POSITIVE_INFINITY;\n        try{\n            \n            \n            \n            cList.clear();\n            cList.ensureCapacity(constraints.size());\n            for (LinearConstraint constraint : constraints){\n                \n                final LinearConstraint cc = (LinearConstraint) constraint.clone();\n                cList.add(cc);\n            }\n            AbstractLinearSolver solver;\n            TableauInitializationStrategy tis = new NoFeasibilityChecks();\n            solver = new PrimalDualHybridInteriorPointMethodImpl(cList, lFunction, tis);\n            \n            final StoppingCriterion stoppingCriterium = new IterationCountStoppingCriterion(maximumIterations_);\n            while (stoppingCriterium != StoppingCriterionState.CRITERIA_NOT_REACHED){\n                \n                solveOneStep(solver);\n                StoppingCriterion sc = stoppingCriterium.reached();\n                \n                \n                \n                if (sc != StoppingCriterion.UNDEFINED){\n                    break;\n                    \n                }else if (restrictToNonNegative){\n                    updateRestrictedVariablesOnly(solver);\n                }\n            }\n        }catch (Exception e){\n            e.printStackTrace();\n        }\n    }\n    \n}",
