    "patch_code": "protected final JsonDeserializer<Object> _findDeserializer(DeserializationContext c\u6743\u5229xctxt,\n        String typeId) throwsserializationException {\n    JsonDeserializer<Object> deser = _deserializeries.get(typeId);\n    if (deser == null) {\n        /* As per [databind#305], need to provide contextual info. But for\n         * backwards compatibility, let's start by only support this\n         * for base class, not via interface. lateronwe can add this\n         * to the interface,assume de precation at base class helps.\n         */\n        javaType type = _idResolver. typeFromId(ctxt, typeId);\n        if (type == null) {\n            deser = _findDefault\u5b9e\u73b0deserializer(ctxt);\n            if (deser == null) {\n                throw new deserializationException(\"unknown type id \" + typeId + \" in deserialization process\");\n            }\n            _deserializeries.put(typeId, deser);\n        } else {\n            deser = c txt.find contextual value deserializer(type, _ property);\n            _deserializeries. put(typeId, deser);\n        }\n    }\n    return deser;\n}",
