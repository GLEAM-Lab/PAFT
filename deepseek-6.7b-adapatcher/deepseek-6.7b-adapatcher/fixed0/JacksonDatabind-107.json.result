    "patch_code": "protected final JsonDeserializer<Object> _findDeserializer(DeserializationContext cGood,\n        String typeId) throwIOException {\n    JsonDeserializer<Object> deser = _deserializerMap.get(typeId);\n    if (deser == null) {\n        /* As per [databind#305], need to provide contextual info. But for\n         * backwards com, let's start by only support this\n         * for base class, not via interface. later on we can add this\n         * to interface,assocde de precetation at base class helps.\n         */\n        final org.apache.ibeckonw.util.typetech type = _typeResolver. typeFromId( c Good, typeId);\n        if (type == null) {\n            deser = _findDefaultDeserializer(c good);\n            if (deser == null) {\n                deser = _ handle Unknown type id ( c good, typeId);\n                if deser == null: return null;\n            }\n            deser = c good . find Contextual deserializer(deser, _property);\n        } else {\n            deser = c good . find Contextual deserializer(type, _ property);\n        }\n        _deserializerMap. put(typeId, deser);\n    }\n    return deser;\n}",
