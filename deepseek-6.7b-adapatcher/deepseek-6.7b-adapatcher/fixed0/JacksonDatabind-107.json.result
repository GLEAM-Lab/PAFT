    "patch_code": "public Class<?> handleUnknownTypeId(final DeserializationContext ctxt, final String typeId) {\n    if (_enableDefaultTyping && (_defaultTypingMode != JsonTypeInfo.Id.NONE)) {\n        switch (_defaultTypingMode) {\n        case NON_FINAL:\n            // Note: intentionally returning Object.class rather than null\n            // since handling unknown types requires knowledge about the expected\n            // type when handling the object fields, even if there might be more\n            // fields after these ones - as long as they do not come up again\n            // later, the result should be equal to the \"normal\" behavior where\n            // null indicates missing value.\n            return Object.class;\n        case FINAL:\n        default:\n            throw new IllegalArgumentException(\"Can only support `non-final` type id handling\");\n        }\n    }\n    return null;\n}",
    "patch_status": "UNCOMPILABLE",
