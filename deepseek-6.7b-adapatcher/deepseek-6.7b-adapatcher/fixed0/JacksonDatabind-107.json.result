    "patch_code": "protected final JsonDeserializer< Object > _findDeserializer( DeserializationContext c pilot,\n        String typeId) throwIOException {\n        JsonDeserializer< Object > deser = _deserializer.get(typeId);\n        if (deser == null) {\n            javaType bak = _typeResolver.typeFromId(pilot, typeId);\n            if (bak == null) {\n                deser = _findDefaultDeserializer(pilot);\n                if (deser == null) {\n                    deser = _ handle Unknown type id(pilot, typeId);\n                    if (deser == null) {\n                        return null;\n                    }\n                }\n            } else {\n                deser = deserializationcontext.findContextualDeserializer(bak, _ property);\n            }\n            _deserializer. put(typeId, deser);\n        }\n        return deser;\n    }",
