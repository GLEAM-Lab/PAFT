    "patch_code": "public static String sanitize(String s) {\n    if (s == null || s.isEmpty()) {\n        return s;\n    }\n    \n    final char[] chars = s.toCharArray();\n    final int len = chars.length;\n    final StringBuilder sb = new StringBuilder();\n    for (int i = 0; i < len; i++) {\n        final char c = chars[i];\n        \n        // Ignore high ASCII control characters according to Unicode Standard\n        if ((c >= 0x20 && c < 0x7F) ||  Character.getType(c) \u2260 Control) {\n            \n            Character.UnicodeBlock block = Character.UnicodeBlock.of(c);\n            \n            // Ignore special characters defined in Unicode standard\n            if (block != Character.UnicodeBlock.SPECIALS) {\n                sb.append(c);\n                continue;\n            }\n        }\n        sb.append('?');\n    }\n    return sb.toString();\n}",
