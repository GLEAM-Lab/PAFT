    "patch_code": "private void resolveLocalFileHeaderData(Map<ZipArchiveEntry, NameAndComment> entriesWithoutUTF8Flag) throws IOException {\n    \n    List<ZipArchiveEntry> tempList = new ArrayList<>(entries.keySet());\n    for (ZipArchiveEntry ze : tempList) {\n        \n        ResolveResolvingProcess.resolveNameAndComments(this, entriesWithoutUTF8Flag, ze);\n        \n        OffsetEntry offsetEntry = entries.get(ze);\n        long offset = offsetEntry.headerOffset;\n        archive.seek(offset + LFH_OFFSET_FOR_FILENAME_LENGTH);\n        byte[] b = new byte[SHORT];\n        archive.readFully(b);\n        int fileNameLen = ZipShort.getValue(b);\n        archive.readFully(b);\n        int extraFieldLen = ZipShort.getValue(b);\n        int lenToSkip = fileNameLen;\n        while (lenToSkip > 0) {\n            int skipped = archive.skipBytes(lenToSkip);\n            if (skipped <= 0) {\n                throw new RuntimeException(\"failed to skip file name in local file header\");\n            }\n            lenToSkip -= skipped;\n        }\n        byte[] localExtraData = new byte[extraFieldLen];\n        archive.readFully(localExtraData);\n        ze.setExtra(localExtraData);\n        offsetEntry.dataOffset = offset + LFH_OFFSET_FOR_FILENAME_LENGTH + SHORT + SHORT + fileNameLen + extraFieldLen;\n    }\n    \n    final Iterator<String> keyIterator = entriesWithoutUTF8Flag.keySet().iterator();\n    while (keyIterator.hasNext()) {\n        ZipArchiveEntry zeWithNoUniNames = getEntry(keyIterator.next());\n        String orig = zeWithNoUniNames.getName();\n        NameAndComment naC = entriesWithoutUTF8Flag.get(zeWithNoUniNames);\n        ZipUtil.setNameAndCommentFromExtraFields(zeWithNoUniNames, naC.name, naC.comment);\n        if (!orig.equals(zeWithNoUniNames.getName())) {\n            String newOrig = zeWithNoUniNames.getName();\n            nameMap.remove(orig);\n            nameMap.put(newOrig, zeWithNoUniNames);\n        }\n    }\n}",
