  {
    "patch_code": "private void resolveLocalFileHeaderData(Map<ZipArchiveEntry, NameAndComment>\n                                        entriesWithoutUTF8Flag)\n    throws IOException {\n    \n    List<String> names = new ArrayList<>(entriesWithoutUTF8Flag.size());\n    List<byte[]> extraDatas = new ArrayList<>(entriesWithoutUTF8Flag.size());\n    \n    for (Iterator<ZipArchiveEntry> iterator = entries.keySet().iterator(); iterator.hasNext(); ) {\n        ZipArchiveEntry ze = iterator.next();\n        \n        if (entriesWithoutUTF8Flag.containsKey(ze)) {\n            NameAndComment nc = entriesWithoutUTF8Flag.get(ze);\n            if (nc != null && nc.name != null && !nc.name.isEmpty()) {\n                \n                iterator.remove();\n                names.add(nc.name);\n                extraDatas.add(ze.getExtra());\n                \n                continue;\n            }\n        }\n        \n        OffsetEntry offsetEntry = entries.get(ze);\n        long offset = offsetEntry.headerOffset;\n        archive.seek(offset + LFH_OFFSET_FOR_FILENAME_LENGTH);\n        byte[] b = new byte[SHORT];\n        archive.readFully(b);\n        int fileNameLen = ZipShort.getValue(b);\n        archive.readFully(b);\n        int extraFieldLen = ZipShort.getValue(b);\n        int lenToSkip = fileNameLen;\n        while (lenToSkip > 0) {\n            int skipped = archive.skipBytes(lenToSkip);\n            if (skipped <= 0) {\n                throw new RuntimeException(\"failed to skip file name in\"\n                                           + \" local file header\");\n            }\n            lenToSkip -= skipped;\n        }\n        byte[] localExtraData = new byte[extraFieldLen];\n        archive.readFully(localExtraData);\n        ze.setExtra(localExtraData);\n        offsetEntry.dataOffset = offset + LFH_OFFSET_FOR_FILENAME_LENGTH\n            + SHORT + SHORT + fileNameLen + extraFieldLen;\n        \n        nameMap.put(ze.getName(), ze);\n    }\n    \n    for (int i = 0; i < names.size(); i++) {\n        ZipArchiveEntry ze = new ZipArchiveEntry(nameMap.get(names.get(i)));\n        ze.setExtra(extraDatas.get(i));\n        entries.put(ze, new OffsetEntry(archive.getFilePointer()));\n    }\n}",
