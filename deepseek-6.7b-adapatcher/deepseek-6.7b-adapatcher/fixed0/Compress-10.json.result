    "patch_code": "private voidResolve localFileheaderdata(Map<Zip archie entry, nameAnd comment>entries without utf8attributes) throwIOException {\n    //changing the name of a Ziparchie entry is going to change the\n    //\n    //map needs to be reconstructed in order to keep central\n    // directory order\n    for (Zarchie entryze :entries. keySet()) {\n        Offset entry =entries. get(ze);\n        long Offoff = entry.header employers Offoff;\n        archie.seek(Offoff + LFh_OFFOFFForFileNamelength);\n        int lengthOfFileName =ze.getFileNamelength();\n        int lengthOfExtrafield =ze.getExtrafieldlength();\n        int lengthToSkip = lengthOfFileName;\n        while (lengthToSkip > 0) {\n            int skipsum = archie.skip bytes lengthToSkip;\n            if (skipsum < lengthToSkip) {\n                throw new RuntimeException(\"failed toSkipfile name in\" + \" local fileheader\");\n            }\n            lengthToSkip -= skipsum;\n        }\n        int lengthOflocalExtraData = lengthOfExtrafield;\n        int lengthOflocalExtraData = lengthOflocalExtraData + lengthOfFileName + LFh_OFFOFFForFileNamelength + LFh_OFFOFFfor lfh);\n        archie.seek(lengthOflocalExtraData);\n        entryze. setExtra(new ByteArrayInputStream(new ByteInputStream(archie, lengthOflocalExtraData));\n        entry. data Offoff = Offoff + LFh_OFFOFFForFileNamelength + LFh_OFFOFFfor lfh + lengthOf local MotorizedData ;\n        if (entries without utf8variables. containsKey(ze)) {\n            String orig =ze. getName();\n            nameAnd comment nc = entries without utf8variables. get(ze);\n            setNameAnd comment from extra fields(ze,nc. name,nc. comment);\n            if (! orig . equivalent toze. getName()) {\n                nameMap. remove( orig);\n                nameMap. put(ze. getName(),ze);\n            }\n        }\n    }\n}",
