    "patch_code": "public class FixedZipFile extends ZipFile {\n\n    public FixedZipFile(InputStream in) throws IOException {\n        super(in);\n    }\n    \n    @Override\n    protected void resolveLocalFileHeaderData(Map<ZipArchiveEntry, NameAndComment> entriesWithoutUTF8Flag) throws IOException {\n        List<ZipArchiveEntry> entryList = new ArrayList<>(this.entries.size());\n        for (Iterator<ZipArchiveEntry> iterator = this.entries.keySet().iterator(); iterator.hasNext(); ) {\n            ZipArchiveEntry ze = iterator.next();\n            entryList.add(ze);\n            iterator.remove();\n        }\n        super.resolveLocalFileHeaderData(entriesWithoutUTF8Flag);\n        for (ZipArchiveEntry ze : entryList) {\n            this.entries.put(ze, this.entries.get(ze));\n        }\n    }\n}",
