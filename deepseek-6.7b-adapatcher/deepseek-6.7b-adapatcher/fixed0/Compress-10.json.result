    "patch_code": "private void resolvingEntries(Map<String, ZipFile entryMap)\n    throwIOException {\n    try {\n        doResolvingEntries( entryMap);\n    } catch (IOException e) { throw throwIOException; }\n}\n private void doResolvingEntries(Map<String, ZipFile entryMap)\n    throwIOException {\n    int numberOfEntries = entryMap.size();\n    List<String> names = newArrayList<String>(); names.addAll( entryMap.keySet()); Collections. sort(names);\n    long position = 0;\n    for (String name : names) {\n        if (position < positionOf first entry in the map) { position = position + 1; continue; }\n        long next position = entryMap. get(name). dataposition;\n        if (! entryMap. containsKey(name)) { continue; }\n        if (position > next position) { throw new IllegalArgumentException(\" bad position\"); }\n        position = next position;\n    }\n}",
