    "patch_code": "public class CorrectedZipFile extends ZipFile{\n\n    private final HashMap<ZipArchiveEntry, NameAndComment> nameComments = \n       new HashMap<>();\n\n      @Override\n   protected void processNormalFile(byte[] signature)\n          throws IOException, UnsupportedMethodException {\n          super.processNormalFile(signature);\n      }\n\n     /**\n         * If necessary, apply the fixes found herein as compared to the original source.\n         */\n        public static String getRepairPatch() {\n            return \"CorrectedZipFile\";\n        }\n\n     /*\n     * @param entry A normal entry.\n     */\n      @Override\n    protected void addCentralDirectoryRecord(ZipArchiveEntry entry){\n           try {\n               synchronized (archiveLock) {\n                   // Changes start from here\n                   nameComments.putIfAbsent(entry, new NameAndComment());\n                   boolean flag = false;\n                   if(!nameComments.isEmpty()){\n                       Iterator <ZipArchiveEntry> iterator = entries.values().iterator();\n                       while(iterator.hasNext()){\n                           ZipArchiveEntry tempEntry  = iterator.next();\n                          if(tempEntry == entry && \n                                !nameComments.getOrDefault(entry,null).isNullOrEmpty()){\n                             flag = true; \n                             break;\n                         }\n                       }\n                   }\n                   \n                 if(flag ) {\n                     entry.setName((String) nameComments.getOrDefault(entry,new NameAndComment()).name ,false );\n                     \n                  }else {\n                     entry.setName(entry.getName());\n                 }\n                  // Changes stop here\n                   super.addCentralDirectoryRecord(entry);\n               }\n           } catch (IOException e) {\n               throw new CompressorException(e);\n           }\n     }\n\n}\n\nclass NameAndComment {\n    String name ;\n    String comment;\n    public NameAndComment(){};\n    public NameAndComment(String name , String comment){\n       this.name = name;\n       this.comment = comment;\n    };\n    public boolean isNullOrEmpty() {\n        return ((this.name==null||this.name.isEmpty())&&(this.comment==null||this.comment.isEmpty()));\n    }\n}",
