    "patch_code": "private List<ZipArchiveEntry> readCentralDirectory() throws IOException {\n    boolean utf8ModeActive = false;\n    final List<ZipArchiveEntry> result = new ArrayList<>();\n    try {\n      readAndProcessCentralDirectory(utf8ModeActive, result);\n      return result;\n    } finally {\n      if (utf8ModeActive && !entriesByHashCode.isEmpty()) {\n        entries = new HashMap<>(entriesByHashCode);\n      }\n    }\n  }\n\n  private void processZip64ExtendedInformation(final DataInput in) throws IOException {\n    final long sizeOfCD = in.readLong();\n    final long startingDiskNumber = in.readLong();\n    final long numberOfDisks = in.readLong();\n    final long directoryStartIndex = in.readLong();\n    final long numberOfEntriesInFirstDisk = in.readLong();\n    archive.discard((int) (sizeOfCD - OFFSET_SIZEOFCD));\n    if (startingDiskNumber > nextDiskNumber || startingDiskNumber < 0L) {\n        throw new ZipEncodingException(\"Illegal starting disk number\");\n    }\n    nextDiskNumber = startingDiskNumber;\n    if (numberOfDisks < nextDiskNumber || numberOfDisks > 0x7fffffffL) {\n       throw new ZipEncodingException(\"Invalid value for number of disks.\");\n    }\n    final DiskBuilder diskBldr = new DiskBuilder((int) numberOfDisks,\n        (int) numberOfEntriesInFirstDisk, (int) startingDiskNumber);\n    for (;;) {\n      final int idx = diskBldr.incrementIndexes();\n      if (idx >= OFFSET_CENTRALDIRECTORY) {\n          break;\n      }\n      discardIfOutside(archive.skipBytes(OFFSET_DISKNUMBER), true);\n      discardIfOutside(archive.skipBytes(OFFSET_DISKSTART), true);\n      discardIfOutside(archive.skipBytes(OFFSET_DISKENTRYCOUNT), true);\n      discardIfOutside(archive.skipBytes(OFFSET_TOTALENTRYCOUNT), true);\n      discardIfOutside(archive.skipBytes(OFFSET_COMMENTLEN), true);\n      discardIfOutside(archive.skipBytes(OFFSET_COMMENT), true);\n    }\n    final long commentLength = archive.readUnsignedInt();\n    if (commentLength > Integer.MAX_VALUE) {\n        throw new IllegalArgumentException(\"Comment length too big\");\n    }\n    discardIfOutside(archive.skipBytes((int) commentLength), true);\n}",
