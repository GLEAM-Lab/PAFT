    "patch_code": "import java.lang.reflect.ParameterizedType;\nimport java.lang.reflect.Type;\n\npublic class RepairedReadTypeVariablesMethod {\n\n    private Type[] typesArrayCache;\n    \n    private void readTypeVariables(){\n        \n          //if there's no bounds on type variables, break directly \n           if(typeVariable.getBounds().length == 0){\n               return ;\n           }\n      \n         typesArrayCache = new Type[typeVariable.getBounds().length];  \n            \n         int i = 0;\n         \n         //loop through all bound types\n         for (Type t : typeVariable.getBounds()){\n             \n             if(t instanceof ParameterizedType){\n                 ParameterizedType pt = (ParameterizedType) t;                 \n                 //recursive call here to solve nested generic problem\n                 readTypeVariables((TypeVariable<?>) pt.getActualTypeArguments()[i]);                    \n             } else{                     \n                 typesArrayCache[i] = t; \n                i++;                 \n             }\n        }     \n    }\n\n    /**\n     * Recursive function to handle nested generic problems\n     */\n    private void readTypeVariables(TypeVariable<?> tv){ \n        \n        typeVariable = tv;        \n        \n        if(tv == null || !typesByName.containsKey(tv.getName())){\n            return;\n        }        \n        \n        List<Type> listTypes = typesByName.remove(tv.getName());        \n        \n        Set<Type> setTypes = new LinkedHashSet<>();\n        for(Type eachType: listTypes){            \n            addSupertypeToListIfNotPresentAlready(eachType,setTypes);\n        }        \n        listTypes = new ArrayList<>(setTypes);\n        \n        Class<?> rawType = getUpperBoundedWildcardTypeOr(tv);         \n        if(!listTypes.isEmpty() && !rawType.equals(Object.class)){\n            throw new UnsupportedOperationException(tv + \" is both upper bounded wild card (\"+rawType +\") but have more than one direct or transitive super-types \" + listTypes);\n        } else if(!listTypes.isEmpty()){\n            setTypesFromSupertypesWithMoreThanOneDirectOrTransitives(tv , listTypes);\n        } else if(rawType!= Object.class){\n            setSuperInterfaceTypesFromClassesLowerBoundTo(tv, rawType );\n        }else{\n            rawExtraInterfaces.addAll(listTypes);\n        }\n        rawType = tv.getBounds()[0].getClass();  \n        if(rawType.isAssignableFrom(getUpperBoundedWildcardTypeOr(tv))){\n            throw new RuntimeException(\"bounding too tight:\" + tv  +\" -- lower bounded to:\"+rawType);\n        }else if (!tv.getBounds()[0].equals(listTypes.get(0).getClass())){\n            throw new UnsupportedOperationException(\"Conflicting bounds on type parameter: \" + tv + \n                                                   \" bounds: [\" + Arrays.toString(tv.getBounds()) + \"]\"+\n                                                    \" raw argument: \" + tv.getGenericDeclaration());\n        }\n        \n    }  \n}",
