    "patch_code": "private List<ResolvedType> bounds; \npublic GenericMetadataSupport(Type owner, Type rawOwner, Map<String, TypeVariable<?>> typeParametersByNameToMatchJre8) {\n    this.owner = owner;\n    this.typeVariable = (TypeVariable<T>) findTypeVariableFromOwnerOrItsSuperClasses(owner, rawOwner, typeParametersByNameToMatchJre8);\n    bounds = new ArrayList<>();\n    readTypeVariables();\n}\nprivate void registerTypeVariablesOn(Type type) {\n    Class<?> cls = (Class<?>) type;\n    for (Type t : cls.getGenericInterfaces()) {\n        bounds.addAll(((GenericMetadataSupport)t).bounds);\n    }\n}\nprivate void readTypeVariables() {\n    for (Type type : typeVariable.getBounds()) {\n        registerTypeVariablesOn(type);\n    }\n    registerTypeVariablesOn(getActualTypeArgumentFor(typeVariable));\n}",
