    "patch_code": "private void inferProperty typesTo match constraint(\n    JSType type, JSType constraint) {\n  if (type == null || constraint == null) {\n    return;\n  }\n\n  ObjectType constraint obj = ObjectType. cast( constraint . restrictByNot null or empty);\n  if ( constraint obj !=  null && constraint obj. is record type) {\n    ObjectType obj type = ObjectType. cast( type . restrictByNot null or empty);\n    if ( obj type !=  null) {\n      for ( String prop : constraint obj. get own property names) {\n        JSType prop type = constraint obj. get property type(prop);\n        if (! obj type. is property type defined(prop)) {\n          JSType type to infer = prop type;\n          if (! obj type. has property(prop)) {\n            type to infer = get Native type(vo id type). least supertype(prop type);\n          }\n          obj type. define infered property(prop, type to infer, null);\n        }\n      }\n    }\n  }\n}",
