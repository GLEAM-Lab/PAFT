    "patch_code": "package com.google.javascript.jscomp;\n\nimport com.google.common.collect.Sets;\nimport com.google.javascript.rhino.Node;\n\nimport java.util.Set;\n\nfinal class TypeInference implements AdvancedAstVisitor<Void> {\n  private final TypeInferencingContext context;\n\n  public TypeInference(TypeInferencingContext context) {\n    this.context = context;\n  }\n\n  // Snip... existing methods from original Java file ...\n\n  /**\n   * Infers property types that match certain constraints.\n   *\n   * <p>The input {@link Node} must either be a variable or property access, or a call expression with target\n   * being a variable or property access.\n   */\n  private Void inferPropertyTypes(Node node) {\n    Set<Variable> variables = Sets.newHashSet();\n    collectVariables(node, variables);\n\n    VariableInfo info = VariableInfo.fromVariableSet(variables);\n    Set<Variable> inferredProperties = info.inferredProperties();\n\n    for (Variable v : inferredProperties) {\n      JSType type = v.initialization() != null ? v.initialization().type() : null;\n      JSType constraint = resolveValueExpression(v.name(), context);\n      ConstraintsUtils.inferPropertyTypesToMatchConstraint(type, constraint, v.declaration(), false);\n    }\n\n    return null;\n  }\n\n  static boolean isValidPropertyAccessTargetForTypeInference(Node n) {\n    if (n instanceof Literal) {\n      return false;\n    }\n\n    while (true) {\n      if ((n instanceof PropertyGet) || (n instanceof Variable) ||\n          (n instanceof This)) {\n        return true;\n      } else if (!(n instanceof MemberExpr)) {\n        return false;\n      }\n      n = ((MemberExpr) n).object();\n    }\n  }\n}",
