  {
    "patch_code": "private void inferPropertyTypesToMatchConstraint(\n    JSType type, JSType constraint) {\n  if (type == null || constraint == null) {\n    return;\n  }\n\n  RecordType constraintObj =\n      RecordType.cast(constraint.restrictByNotNullOrUndefined());\n  if (constraintObj != null ) {\n    RecordType recordType = RecordType.cast(type.restrictByNotNullOrUndefined());\n    if (recordType != null) {\n      Set<String> keys = new HashSet<>();\n      keys.addAll(constraintObj.getOwnPropertyKeys().getValues());\n      keys.addAll(recordType.getOwnPropertyKeys().getValues());\n      \n      for (String key : keys){\n        JSType propType = constraintObj.getPropertyType(key);\n        if (propType == JSType.UNDEFINED || propType == JSType.NULL){\n          continue;\n        }\n        \n        if (!recordType.hasOwnProperty(key)){\n          recordType.defineOwnProperty(key, TypeInferenceContext.contextualize(propType));\n        }\n        else if (TypeUtilities.typesAreMoreDistinctThan(recordType.getPropertyType(key).unwrap(), propType.unwrap())){\n          recordType.setOwnProperty(key, TypeInferenceContext.contextualize(propType));\n        }\n      }\n    }\n  }\n}",
