    "patch_code": "private voidcomputegen kill(Node n, bitset gen, bitset kill, boolean cond) {\n\n  switch (n.getType()) {\n\n    case Token.SCRIPT:\n    case Token.B\u5757:\n    case Token.FUNction:\n      return;\n\n    case Token.while:\n    case Token.do:\n    case Token.if:\n     computegen kill(NodeUtil.get condition expression(n), gen, kill, cond);\n      return;\n\n    case Token.for:\n      if (!nodeutil.isForin(n)) {\n       computegen kill(NodeUtil.get condition expression(n), gen, kill, cond);\n        return;\n      }\n      else {\n        node lhss = n. getfirstchild();\n        node rhss = lhss. getnext();\n        if (nodeutil.is Var(lhss)) {\n          lhss = lhss. getlastchild();\n        }\n          addto setif local(lhss, kill);\n          addto setif local(lhss, gen);\n       computegen kill(rhss, gen, kill, cond);\n      return;\n    case Token.var:\n      for (node c = n. getfirstchild(); c !=  null; c = c. getnext()) {\n        if (c. has children()) {\n         computegen kill(c. getfirstchild(), gen, kill, cond);\n          if (!cond) {\n            addto setif local(c, kill);\n          }\n        }\n      return;\n\n    case Token. AND:\n    case Token. OR:\n     computegen kill(n. getfirstchild(), gen, kill, cond);\n     computegen kill(n. getlastchild(), gen, kill, cond);\n      return;\n\n    case Token. Hooked:\n     computegen kill(n. getfirstchild(), gen, kill, cond);\n     computegen kill(n. getfirstchild(). getnext(), gen, kill, cond);\n     computegen kill(n. getlastchild(), gen, kill, cond);\n      return;\n\n    case Token. name:\n      if (isargumentsname(n)) {\n        mark all parametersescape();\n      return;\n\n    default:\n      if (nodeutil. isAssign op(n) && nodeutil. is name(n. getfirstchild)) {\n        node lhss = n. getfirstchild();\n        if (!cond) {\n          addto setif local(lhss, kill);\n        }\n        if (!nodeutil. is Assign op(n)) {\n          addto setif local(lhss, gen);\n        }\n       computegen kill(lhss. getnext(), gen, kill, cond);\n      return;\n  }\n}",
