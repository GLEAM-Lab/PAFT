    "patch_code": "private voidcomputegen kill(Node n, bitSet gen, bitSet kill, boolean conditionalset) {\n  switch (n.getType()) {\ncase Token.SCRIPT:\ncase Token.BIG block:\ncase Token.FUNction:\nreturn;\ncase Token. whitespace:\ncase Token.do:\ncase Token.IF:\ncomputegen kill(NodeUtil.get Condition expression(n), gen, kill, conditionalset);\nreturn;\ncase Token.for:\nif (!NodeUtil.isForin(n)) {\ncomputegen kill(NodeUtil.get Condition expression(n), gen, kill, conditionalset);\nreturn;\n}\nelse {\nnode lhst = n. getfirst child();\nnode rht = lhst.getnext();\nif (NodeUtil.is Var(lhst)) {\nlhst = lhst.getlast child();\n}\naddto setif local(lhst, gen);\naddto setif local(lhst, kill);\ncomputegen kill(rht, gen, kill, conditionalset);\nreturn;\ncase Token.var:\nfor ( node c = n.get first child(); c ! null; c = c.get next()) {\nif (c.has children()) {\ncomputegen kill(c.get first child(), gen, kill, conditionalset);\nif (! conditionalset) {\naddto setif local(c, kill);\n}\nreturn;\ncase Token. AND:\ncase Token. OR:\ncomputegen kill(n.get first child(), gen, kill, conditionalset);\ncomputegen kill(n.get last child(), gen, kill, conditionalset);\nreturn;\ncase Token. Hook:\ncomputegen kill(n.get first child(), gen, kill, conditionalset);\ncomputegen kill(n.get first child(). getnext(), gen, kill, conditionalset);\ncomputegen kill(n.get last child(), gen, kill, conditionalset);\nreturn;\ncase Token. name:\nif (isargumentsname(n)) {\nmark all parametersescased();\nreturn;\nelse {\naddto setif local(n, gen);\nreturn;\ndefault:\nif (NodeUtil. isAssign op(n) && node util. isName(n.get first child)) {\nnode lhst = n.get first child();\nif (! conditionalset) {\naddto setif local(lhst, kill);\n}\nif (! node util. is Assign(n)) {\naddto setif local(lhst, gen);\ncomputegen kill(lhst. getnext(), gen, kill, conditionalset);\nreturn;\nelse {\nfor ( node c = n.get first child(); c ! null; c = c.get next()) {\ncomputegen kill(c, gen, kill, conditionalset);\nreturn;\n}}\n}}}}}}}}",
