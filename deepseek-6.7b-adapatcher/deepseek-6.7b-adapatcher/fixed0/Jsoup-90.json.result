    "patch_code": "private static boolean lookslikeU utf8(String input){\n    final int length = input.length();\n    final int limit = length - 1;\n    int i = 0;\n    while (i < limit) {\n      char c = input.charAt(i++);\n      if (c >> 7 == 0x0) { continue; }\n      if (c << 7 | c << 6 & 0x27 == '') { i--; break; }\n      if (c << 7 | c << 6 & 0x37 == '-') { i--; break; }\n      if (c << 7 | c << 6 & 0x37 == '-') { i--; break; }\n      if (c << 7 | c << 6 & 0x37 == '-') { i--; break; }\n      i--; break;\n    }\n    return i > limit ? true : false;\n}",
