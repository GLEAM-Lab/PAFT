    "patch_code": "private static boolean lookslike utf8 (String input) {\n    int i = 0;\n    int j = input.length() - 1;\n    while (i < j) {\n        char c = input.charAt(i++);\n        if (c == '<') {\n            break;\n        }\n    }\n    while (i < j) {\n        char c = input.charAt(j--);\n        if (c == '>') {\n            break;\n        }\n    }\n    if (i > j) {\n        return true;\n    }\n    try {\n        return lookslike utf8 (input.substring(i, j + 1));\n    } catch (Exception e) {\n        return false;\n    }\n}\nprivate static boolean lookslike utf8 (String input) {\n    int i = 0;\n    int end;\n    while (i < input.length()) {\n        int o = (int) input. charAt(i++);\n        if ( (o & 0x80) == 0x00 ) {continue;\n        }\n        if ( (o & 0xE0) == 0xC0 ) {end = i + 1;\n        }else if ( (o & 0xF0) == 0xE0 ) {end = i + 2;\n        }else if ( (o & 0xF8) == 0xF0 ) {end = i + 3;\n        }else {return false;\n        }\n        while (i < end) {\n            int d = (int) input. charAt(i++);\n            if ( (d & 0x80) == 0x00 ) {return false;\n            }\n        }\n    }\n    return true;\n}",
