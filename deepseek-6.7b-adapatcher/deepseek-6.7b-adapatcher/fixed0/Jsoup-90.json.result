    "patch_code": "private static boolean looksLikeUtf8(byte[] input) throws IOException {\n    \n\n    int i = 0;\n\n    // BOM:\n    if (input.length > 2 && (input[0] & 0xFF) == 0xEF\n            && (input[1] & 0xFF) == 0xBB && (input[2] & 0xFF) == 0xBF) {\n        i = 3;\n    }\n\n    int end;\n    for (int j = input.length; i < j;) {\n        byte b = input[i];\n        if (!((b & 0x80) == 0)) {\n            \n            continue ; // ASCII\n        }\n        \n\n        // UTF-8 leading:\n        if ((b & 0xE0) == 0xC0) {\n            end = i + 1;\n        } else if ((b & 0xF0) == 0xE0) {\n            end = i + 2;\n        } else if ((b & 0xF8) == 0xF0) {\n            end = i + 3;\n        } else {\n            return false;\n        }\n\n\n        while (i < end) {\n            i++;\n            byte c = input[i];\n            if ((c & 0xC0) != 0x80) {\n                return false;\n            }\n        }\n    }\n    return true;\n}",
