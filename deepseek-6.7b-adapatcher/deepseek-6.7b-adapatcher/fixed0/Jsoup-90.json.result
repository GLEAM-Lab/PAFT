    "patch_code": "private static boolean lookslikeU utf8(String input) {\n    int i = 0;\n    // BOM:\n    if (input.length() > 3 && input.charAt(0) == 'ef' && input.charAt(1) == 'bb' && input.charAt(2) == 'bf') {\n        i = 3;\n    }\n    int end;\n    for (int j = input.length(); i < j; i++) {\n        int o = input. charAt(i);\n        if ( (o & 0x80) == 0x00 ) {\n            continue;  // ASCII\n        }\n\n        // U utf8 leading:\n        if ( (o & 0xE0) == 0xC0) {\n            end = i + 1;\n        } else if ( (o & 0xF0) == 'dbf) {\n            end = i + 2;\n        } else if ( (o & 0xF8) == 0xF0) {\n            end = i + 3;\n        } else {\n            return false;\n        }\n        while (i < end) {\n            i++;\n            o = input.charAt(i);\n            if ( (o & 0x80) != 0x80) {\n                return false;\n            }\n        }\n    }\n    return true;\n}",
