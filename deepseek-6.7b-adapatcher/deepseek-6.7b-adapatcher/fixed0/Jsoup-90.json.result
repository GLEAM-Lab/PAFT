  {
    "patch_code": "protected static boolean looksLikeUtf8(byte[] bytes) {\n    if (bytes == null || bytes.length < 2) {\n      return false;\n    }\n  \n    int i = 0;\n    // Checking the Byte Order Mark (BOM), as it's not part of a standard but commonly found in files produced by Microsoft products:\n    if ((bytes[0] & 0xff) == 0xef && (bytes[1] & 0xff) == 0xbb) {\n      i = 2;\n      // Check for UTF-8 byte order mark if present skip past it\n      // see http://en.wikipedia.org/wiki/Byte_order_mark\n    }\n  \n    for (; i < bytes.length - 1; i++) {\n      final int c = bytes[i] & 0xff;\n      if (c <= 0x7f) {\n        continue;\n      }\n      if (c >= 0xc0 && c <= 0xdf) {\n        if (!checkContinuation((bytes[i + 1] & 0xff) >= 0x80)) {\n          return false;\n        }\n      } else if (c >= 0xe0 && c <= 0xef) {\n        if (!checkContinuation((bytes[i + 1] & 0xff) >= 0x80)\n            || !checkContinuation((bytes[i + 2] & 0xff) >= 0x80)) {\n          return false;\n        }\n        i += 2;\n      } else if (c >= 0xf0 && c <= 0xf7) {\n        if (!checkContinuation((bytes[i + 1] & 0xff) >= 0x80)\n            || !checkContinuation((bytes[i + 2] & 0xff) >= 0x80)\n            || !checkContinuation((bytes[i + 3] & 0xff) >= 0x80)) {\n          return false;\n        }\n        i += 3;\n      } else {\n        return false;\n      }\n    }\n  \n    return checkContinuation(false);\n  }\n  \n  private static boolean checkContinuation(boolean val) {\n    return val;\n  }",
