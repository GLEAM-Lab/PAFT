    "patch_code": "private boolean checkValid(Object v){\n    if (!(v instanceof Comparable)){\n        throw new IllegalArgumentException(\"Value is not a comparable\");\n        return false;\n    }else{\n        return true;\n    }\n}\n@Override\npublic void addValue(Object v) {\n    if(!checkValid(v))return;\n    Number numberVal;\n    if (v instanceof BigDecimal) {\n         numberVal= (BigDecimal) v;\n      }\n    else if (v instanceof Boolean) {\n        return;\n    } else if (v instanceof Byte || v instanceof Short\n            || v instanceof Integer || v instanceof Long) {\n         numberVal = (Number) v;\n     } else if (v instanceof Float || v instanceof Double) {\n          numberVal = (Number) v;\n   } else {\n           throw new UnsupportedOperationException(\"Unhandled type \" + v.getClass().getName());\n    }\n    synchronized (freqTable) {\n        freqTable.incrementAndGet((Long) numberVal);\n    }\n}",
