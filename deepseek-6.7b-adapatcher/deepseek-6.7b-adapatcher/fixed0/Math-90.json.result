    "patch_code": "public void addValue(Comparable<?> v) throws IllegalArgumentException {\n    Preconditions.checkNotNull(v);\n    synchronized (this) {\n        totalCount++;\n        \n        Comparable<?> comparable = v;\n        if (!comparablesOnly) {\n            \n            if (v instanceof Number) {\n                Number number = ((Number) v).doubleValue();\n                \n                comparable = new Double(number.doubleValue());\n            } else if (v instanceof Boolean) {\n                comparable = Boolean.TRUE.equals(v) ? TRUE_BOOLEAN : FALSE_BOOLEAN;\n            } else if (v instanceof Character) {\n                \n                comparable = Character.valueOf(((Character) v).charValue());\n            } else if (v instanceof Enum<?>) {\n                \n                comparable = (Comparable<?>) v;\n            }\n        }\n        freqTable.addElement(comparable);\n        freqTableToIndex.put(comparable, freqTable.size()-1);\n    }\n}",
