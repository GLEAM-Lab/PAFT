    "patch_code": "import java.util.*;\nclass Frequency{\n\n\nHashMap<String, Double > freqTable=new HashMap<>();  \nint totalNumberOfEntries = 0;\npublic  double calculatePercentage(double partial , double full){\nreturn (partial /full )* 100 ;\n}\npublic static void main(String[] args){\n Frequency frq = new Frequency();\n  Scanner scan = new Scanner(System.in);\n      int n = scan.nextInt();\n      String input[] = new String[n];\nfor (int i = 0; i < n; i++) {\ninput[i] =scan.next();\n}\nfrq.addValue(input[0]);\n    \n\ntry{\n System.out.printf(\"%2f\" , frq.getCount( \"aaa\"));\n}catch (IllegalArgumentException e){\nSystem.out.print(e.getMessage());\n}\ntry{\nSystem.out.printf(\"%2f\" , frq.getPct( \"ccc\"));\n}catch (IllegalArgumentException e){\nSystem.out.print(e.getMessage());\n}\n\n  frq.addMultipleValues(input);\ntry{\n System.out.printf(\"%2f\" , frq.getCount( \"ccc\"));\n}catch (IllegalArgumentException e){\nSystem.out.print(e.getMessage());\n}\ntry{\nSystem.out.printf(\"%2f\" , frq.getPct( \"ccc\"));\n}catch (IllegalArgumentException e){\nSystem.out.print(e.getMessage());\n}\n\n}\n public void addValue(String v) {\nif(!(freqTable.containsKey(v)))\n{ freqTable.put(v, 1.0 );\ntotalNumberOfEntries ++;}else{\nDouble oldVAlue= freqTable.get(v);\n freqTable.replace(v,oldVAlue+1 );\n}\n}\npublic void addMultipleValues(String [] v){\nfor(String st : v)\n{addValue(st);}\n}\n  /**\n   * Returns the cumulative frequency of a value.\n   * \n   * @param v the value\n   * @return the cumulative frequency\n   * @throws IllegalArgumentException if the value does not exist in the dataset.\n   */\n  public  double getCumFreq(String v) {\nif( freqTable.containsKey(v))\n{return freqTable.get(v);}\nthrow new IllegalArgumentException(\"Value does not exist in the dataset\");\n  }\n  /**\n   * Returns the cumulative percentage of a value.\n   * \n   * @param v the value\n   * @return the cumulative percentage\n   * @throws IllegalArgumentException if the value does not exist in the dataset.\n   */\n  public double getCumPct(String v) {\nif( freqTable.containsKey(v)){\nreturn calculatePercentage(getCumFreq(v) , totalNumberOfEntries );\n}\nthrow new IllegalArgumentException(\"Value does not exist in the dataset\");\n  }\n  /**\n   * Returns the number of occurrences of a value.\n   * \n   * @param v the value\n   * @return the occurrence count\n   * @throws IllegalArgumentException if the value does not exist in the dataset.\n   */\n  public double getCount(String v) {\nif( freqTable.containsKey(v))\n{return freqTable.get(v);}\nthrow new IllegalArgumentException(\"Value does not exist in the dataset\");\n  }\n  /**\n   * Returns the percentage of occurrences of a value.\n   * \n   * @param v the value\n   * @return the occurrence percentage\n   * @throws IllegalArgumentException if the value does not exist in the dataset.\n   */\n  public double getPct(String v) {\nif( freqTable.containsKey(v)){\nreturn calculatePercentage(getCount(v), totalNumberOfEntries);\n}\nthrow new IllegalArgumentException(\"Value does not exist in the dataset\");\n  }\n}",
