    "patch_code": "public class MyComparable implements Comparable{\n     private Object o;\n      public int compareTo(Object o){\n          //implement comparable interface's abstract method here\n      }\n }  \n\n  public void addValue(MyComparable mc) {\n\n        if (mc == null) {\n            return;\n        }\n        \n        Object countKey = mc;\n        \n        Number countNum = countsByNumber.get(countKey);\n        if (countNum == null) {\n            countsByNumber.put(countKey, ONE_INSTANCE);\n            ++nonNullCount;\n        } else {\n            long countLong = countNum.longValue();\n            if ((countLong >= Long.MAX_VALUE)) {\n                incrementExceeded(countKey);\n            } else {\n                countsByNumber.put(countKey, Long.valueOf(countLong + 1));\n                ++nonNullCount;\n            }\n        }\n        \n        String countStr = countsByString.get(countKey.toString());\n        if (countStr == null) {\n            countsByString.put(countKey.toString(), ONE_INSTANCE);\n            ++nonNullCount;\n        } else {\n            long countLong2 = Long.parseLong(countStr);\n            if ((countLong2 >= Long.MAX_VALUE)) {\n                incrementExceeded(countKey);\n            } else {\n                countsByString.put(countKey.toString(), Long.toUnsignedString(countLong2 + 1L));\n                ++nonNullCount;\n            }\n        }\n    }",
