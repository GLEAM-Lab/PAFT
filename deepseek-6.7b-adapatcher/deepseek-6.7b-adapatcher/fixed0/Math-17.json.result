    "patch_code": "@Override\n    public Dfp multiply(final int multiplier) {\n        BigInteger b = getValue();\n        BigInteger bigMultiplier = BigInteger.valueOf(Math.abs((long) multiplier));\n        if (!isValidIntForMultiplication(bigMultiplier)) {\n            throw new ArithmeticException(\"Dfp value out of range\");\n        }\n        boolean negativeResult = ((getSign() == LESS && multiplier >= 0) || (getSign() == MORE && multiplier <= 0));\n        setValue(b.multiply(BigInteger.valueOf(multiplier)));\n        setSign(negativeResult ? LESS : MORE);        \n        return this;\n    }",
