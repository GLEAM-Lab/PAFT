    "patch_code": "public Dfp multiply(final int x) {\n    if (x == 0) {\n        return ZERO;\n    } else if (x < 0 && -x > Integer.MIN_VALUE && DoubleUtils.isNegative(Integer.MIN_VALUE)) {\n        throw new ArithmeticException(\"integer overflow\");\n    } else if (x > 0 && x > Integer.MAX_VALUE) {\n        throw new ArithmeticException(\"integer overflow\");\n    }\n    final double v = getValue() * x;\n    setDoubleValue(v);\n    return this;\n}",
