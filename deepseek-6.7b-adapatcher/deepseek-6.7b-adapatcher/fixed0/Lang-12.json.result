    "patch_code": "public static String random(int count, int start, int end, boolean letter, boolean number, char[] chars, Random random) {\n    if (count == 0) {\n        return \"\";\n    }\n    else if (count<0) {\n        throw new IllegalArgumentException(\"Requested random string length \" + count + \" is less than 0.\");\n    }\n\n    if (chars == null || chars.length == 0) {\n        chars = letter ? Constants. letter : Constants. digits;\n    }\n\n    char[] result = new char[count];\n    int length = chars.length;\n    for (int i = 0; i < count; i++){\n        result[i] = chars[ random.nextInt(length)];\n    }\n    return new String(result);\n}",
