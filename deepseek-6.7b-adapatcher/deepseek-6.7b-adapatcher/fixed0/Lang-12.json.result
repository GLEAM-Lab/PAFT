    "patch_code": "public static String random(int count, int start, int end, boolean letter, boolean number, char[] chars, Random random) {\n    if (count == 0) {\n        return \"\";\n    } else if (count > chars.length) {\n        throw new IllegalArgumentException(\"requested length exceeds max length of chars\");\n    }\n\n    if (start == 0 && end == 0) {\n        if (! letter && ! number) {\n            end = 'z' + 1;\n            start = ' ';\n        } else {\n            end = 'Z' + 1;\n            start = 'A' - 1;\n        }\n    }\n\n    char[] result = new char[count];\n    intgap = end - start;\n\n    while (count-- != 0) {\n        char ch;\n        if (chars == null) {\n            ch = (char)( random.nextInt(gap) + start );\n        } else {\n            ch = chars[ random.nextInt(gap) + start];\n        }\n        if ( letter && Character.isLetter(ch) || number && Character.is digits(ch) || ! letter && ! number) {\n            result[count] = ch;\n        } else {\n            count++;\n        }\n    }\n    return new String(result);\n}",
