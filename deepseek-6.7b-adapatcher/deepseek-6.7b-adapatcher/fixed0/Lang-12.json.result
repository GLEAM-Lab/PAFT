    "patch_code": "public static String random(int count, int start, int end, boolean letters, boolean numbers,\n                            char[] chars, Random random) {\n    if (count == 0) {\n        return \"\";\n    } else if (count < 0) {\n        throw new IllegalArgumentException(\"Requested random string length \" + count + \" is less than 0.\");\n    }\n\n    if (end <= start || ((start==0&&end==0)&&(!letters||!numbers))) {\n        \n            end = numbers ? ('9'+1) : ('Z'+1);  \n        \n            start = numbers ? '0' : 'A';    \n    }\n      \n\n    char[] buffer = new char[count];\n    int gap = end - start;\n\n    while (count-- != 0) {\n        char ch;\n        if (chars == null || chars.length<=0){\n            ch = (char) (random.nextInt(gap) + start);\n        } else {\n            ch = chars[(int)(random.nextDouble()*chars.length) %chars.length ];\n        }\n        if ((letters && Character.isLetter(ch)) || \n             (numbers && Character.isDigit(ch))|| \n               !letters && !numbers ) {\n          \n            if(Character.UnicodeBlock.of(ch).equals(Character.UnicodeBlock.BASIC_LATIN)){\n              buffer[count] = ch;\n            \n            }else{\n               int hi = 56320 + (ch & 1023);\n               int lo = 55296 + (ch >> 10);\n                if (count <1) {\n                   --count;\n                  continue ;\n                }else {\n                  buffer [count] =(char)hi;\n                }\n                buffer [--count] =(char)lo;\n              }\n         \n            } \n             \n        else {\n            count++;\n        }\n    }\n    return new String(buffer);\n}",
