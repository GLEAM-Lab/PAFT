  {
    "patch_code": "private static StringBuilder escapeRegex(StringBuilder regex, String value, boolean unquote) {\n    int length = value.length(); \n    boolean wasWhiteSpace = false;\n    for(int i = 0; i < length; i++){\n        char character = value.charAt(i);\n        \n        // check for whitespace\n        if(Character.isWhitespace(character)){\n            if(!wasWhiteSpace){\n                regex.append(\"\\\\s*\");\n                wasWhiteSpace = true;\n                \n                while(++i < length && Character.isWhitespace(value.charAt(i))) {}\n                i--;\n                continue;    \n            }\n            \n            continue;\n        } else {\n            wasWhiteSpace = false;\n        }\n         \n        // normal characters\n        if (unquote && character == '\\'') {\n            if (++i >= length) {\n                break;\n            }\n            character = value.charAt(i);\n        }\n        \n        // escape special characters\n        switch (character) {\n            case '?':\n            case '[':\n            case ']':\n            case '(':\n            case ')':\n            case '{':\n            case '}':\n            case '|':\n            case '*':\n            case '+':\n            case '^':\n            case '$':\n            case '.':\n                regex.append('\\\\').append(character);\n                continue;\n        }\n          \n        regex.append(character);  \n    }\n     \n    return regex;\n}",
