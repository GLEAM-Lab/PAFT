  {
    "patch_code": "public class FastDateParser extends DateFormat {\n    private static final long serialVersionUID = 1L;\n\n    public FastDateParser() {\n    }\n\n    @Override\n    public Calendar getCalendar() {\n        throw new UnsupportedOperationException(\"Not supported yet.\");\n    }\n\n    @Override\n    public void setCalendar(Calendar calendar) {\n        throw new UnsupportedOperationException(\"Not supported yet.\");\n    }\n\n    private static StringBuilder escapeRegex(StringBuilder regex, String value) {\n        boolean wasWhite = false;\n        for (int i = 0; i < value.length(); ++i) {\n            char c = value.charAt(i);\n            if (!Character.isWhitespace(c)) {\n                if(wasWhite){\n                    regex.append(\"\\\\s*+\");\n                    wasWhite = false; \n                }\n                \n                regex.append(c);\n                continue;\n            }\n            \n            wasWhite = true;\n          \n        }\n        \n        if(wasWhite) {\n            regex.append(\"\\\\s*+\");\n        }\n        \n        return regex;\n    }\n    \n    public static int[] parse(String format, CharSequence input) {\n        return parse(format, input, 0);\n    }\n\n    public static int[] parse(String format, CharSequence input, int start) {\n        return parse(format, input, start, start + format.length());\n    }\n\n    public static int[] parse(String format, CharSequence input, int start, int end) {\n        try {\n            format = format.replaceAll(\"%[dDxXcCeEaAhHsS]\", \"%S\");\n            Pattern pattern = Pattern.compile(escapeRegex(new StringBuilder(), format).toString().intern());\n            Matcher matcher = pattern.matcher(input);\n            if (!matcher.find(start)) {\n                return null;\n            }\n            int groups = matcher.groupCount();\n            int[] fields = new int[groups];\n            Arrays.fill(fields, -1);\n            Field[] fs = Field.values();\n            for (int g = 1; g <= groups; ++g) {\n                String groupName = matcher.groupNames()[g - 1];\n                for (Field f : fs) {\n                    if (groupName.endsWith(f.name())) {\n                        fields[f.ordinal()] = Integer.parseInt(matcher.group(g));\n                        break;\n                    }\n                }\n            }\n            return fields;\n        } catch (IndexOutOfBoundsException e) {\n            throw new IllegalArgumentException(e);\n        }\n    }\n\n    protected static enum Field {\n        YEAR, MONTH, DAY_OF_MONTH, HOUR_OF_DAY, MINUTE, SECOND, WEEK_OF_YEAR, WEEK_OF_MONTH, DATE;\n    }\n\n  \n\n}",
