    "patch_code": "private static String escapeChars(String s) {\n    String replaced = s.replaceAll(\"'\", \"''\").replaceFirst(\"\\\\s\",\" \");\n    return Arrays.stream(replaced.split(\"\")).map(x -> x.matches(\"[\\\\p{P}\\\\p{S}]\") ? \"\\\\\" + x : x ).collect(Collectors.joining());\n}",
