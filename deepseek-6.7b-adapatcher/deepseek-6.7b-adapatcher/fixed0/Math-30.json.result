  {
    "patch_code": "private double createAsymmptoticalPValue( final double Umin, final int n1, final int n2)\n    {\n        final int n1n2 = n1*n2;\n        final double p = 1d - ( n1n2 / ( n1 + n2 ) );\n        final double pmin = n1 < n2 ? p : 1 - p;\n        final double q = 1d - pmin;\n        final double d1 = n1*p;\n        final double d2 = n1*q;\n        final double[] a = new double[] { n1*pmin, n1*q, n2*pmin };\n        final double[] b = new double[] { n1*p, n1*qmin, n2*p };\n        final double[] c = new double[] { n1*pmin, n1*qmin, n2*pmin };\n        final double[] d = new double[] { n1*p, n1*qmin, n2*qmin };\n\n        final double[] x = new double[] { d1, d1+d2, n1+1, n1+n2+1 };\n        final double[] y = new double[] { n1*pmin, n1*qmin, n2*p, n2*q };\n        final double[] pv = new double[] { 0, 0, 0, 0 };\n        for (int i = 0; i < x.length; i++){\n            final double xi = fastmath.round(x[i]-1);\n            final double yi = fastmath.round(y[i]-1);\n            final double factorialX = fastmath. factorial((int)xi);\n            final double factorialY = fastmath. factorial((int)yi);\n            final double factorialXY = factorialX * factoralY;\n            final double factorialXYz = factorialXY * fastmath. factorial((int)(xi + yi));\n            pv[i] = factorialXYz / factorialXY * fastmath. pow( q / factoralXY, x[i]-1 ) * fastmath. pow( p / factoralXY, y[i]-1 );\n        }\n        final double sum = fastmath. sum(pv);\n        return sum;\n    }",
