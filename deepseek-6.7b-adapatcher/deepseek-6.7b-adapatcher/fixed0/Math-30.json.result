    "patch_code": "import org.apache.commons.math3.distribution.*;\n\npublic double calculateAsymptoticPValue(final double Umin, final long n1, final long n2){\n\n        final long n1n2prod = n1 * n2;\n\n        \n        final double EU = (double)n1n2prod / 2.0;\n        final double VarU = (double)n1n2prod * (n1 + n2 + 1) / 12.0;\n\n        final double z = (Umin - EU) / StrictMath.sqrt(VarU);\n\n        final NormalDistribution normaldistri=new NormalDistribution();\n        \n        return 2 * normaldistri.cumulativeProbability(-StrictMath.abs(z));\n     }",
