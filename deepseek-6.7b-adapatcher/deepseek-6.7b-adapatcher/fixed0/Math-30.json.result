    "patch_code": "private double calculateAsymptoticPValue(double Umin, int n1, int n2) {\n    if ((Double.isNaN(Umin)) || Double.isInfinite(Umin) || n1 <= 0 || n2 <=0){\n        throw new IllegalArgumentException();\n    }\n\n    final long n1l = n1;\n    final long n2l = n2;\n\n    final double EuSumTimes = n1l*n2l/(2.0*(n1+n2));\n    double varUSumTime=(n1l*n2l*(n1+n2+1)/(12.0)-(int)(((double) n1)*((double) n2)));\n    \n    /* check for zero variance case */\n    if (varUSumTime < 0 && varUSumTime > -EPSILON ){\n        varUSumTime = 0;\n    }else if (Double.isNaN(varUSumTime)){\n        throw new ArithmeticException(\"Overflow in variances calculation\");\n    }\n   final double Zscore =(Umin - EuSumTimes)/ Math.sqrt(varUSumTime);\n\n    final org.apache.commons.math3.distribution.NormalDistribution NormalDistribution = new org.apache.commons.math3.distribution.NormalDistribution(0, 1);\n    return 2 * NormalDistribution.probability(-Zscore);\n}",
