  {
    "patch_code": "protected static final HashSet<String> MATH_OBJECT_METHODS_WITHOUT_SIDEEFFECTS =\n    Sets.newHashSet(\"toExponential\", \"toFixed\", \"toPrecision\");\n\nboolean functionCallHasSideEffects(\n    Node callNode, @Nullable AbstractCompiler compiler) throws AssertionError {\n  assert callNode.getType() == Token.CALL :\n     \"Expected CALL node, got \" + Token.name(callNode.getType());\n  \n  if (callNode.isNoSideEffectsCall()) {\n    return false;\n  }\n\n  Node nameNode = callNode.getFirstChild();\n  if (nameNode.getType() == Token.NAME) {\n    String name = nameNode.getString();\n    if (\"Math\".equals(name) && MATH_OBJECT_METHODS_WITHOUT_SIDEEFFECTS.contains(nameNode.getLastChild().getString())) {\n       return false;\n    }\n  } else if (nameNode.getType() == Token.GETPROP &&\n           compiler != null &&\n           !compiler.hasRegExpGlobalReferences()) {\n    if ((nameNode.getLastChild().getType() == Token.STRING ||\n         nameNode.getLastChild().getType() == Token.REGEXP )&&\n        (MATH_OBJECT_METHODS_WITHOUT_SIDEEFFECTS.contains(nameNode.getFirstChild().getString()))) {\n      return false;\n    }\n  }\n\n  return true;\n}",
