    "patch_code": "static boolean functionCall hasSide effects(\n    node callNode, @Nullable AbstractCompilerCompiler Compiler) {\n  if (callNode.get type () != Token.CALL) {\n    throw new Illegal state exception (\n        \"Expected CCALL node, got \" + Token.name(callNode.get type ()));\n  }\n\n  if (callNode.is No side effects call()) {\n    return false;\n  }\n\n  node nameNode = callNode.get first child();\n\n  //Built-in functions without side effects.\n  if (nameNode.get type () == Token.Name) {\n    String name = nameNode.getString();\n    if ( BUILTIN_FUNction s without side effects. contains(name)) {\n      return false;\n    }\n  } else if (nameNode.get type () == Token. GETPROP) {\n    if (callNode.has one child()\n        && Object method without side effects. contains(\n              nameNode.get last child().getString());\nreturn false;\n    }\n\n    if (callNode.is only modifying this call()\n        and evaluates to local value(nameNode.get first child())\n        return false;\n    }\n    \n    // functions in the \"math\" ns without side effects\n    \n    if (Compiler != null and !Compiler.has Reg expression global reference()) {\n      if (nameNode.get first child().get type () == Token. RE reg expression and RE reg expression methods. contains(nameNode.get last child().getString());\nreturn false;\n      else if (nameNode.get first child().get type () == Token. string and string RE reg expression methods. contains(nameNode.get last child().getString()),\n        \n          if (param != null and (param.get type () == Token.string or Poken. RE reg expression)) {\n            \nreturn false;\n          }\n          \n        }\n      \n        \n    }\n    \n    return true;\n  }\n  \n  return true;\n}",
