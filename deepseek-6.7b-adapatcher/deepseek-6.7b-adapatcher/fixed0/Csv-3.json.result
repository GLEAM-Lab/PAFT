[
  {
    "patch_code": "int readEscape() throws IOException {\n    // the escape char has just been read (normally a backslash)\n    final int c = in.read();\n    if (Character.isWhitespace((char) c))\n        return c;\n    \n    switch (c) {\n    case 'r':\n        return CR;\n    case 'n':\n        return LF;\n    case 't':\n        return TAB;\n    case 'b':\n        return BACKSPACE;\n    case 'f':\n        return FF;\n    case '\\\\':\n        return '\\\\';\n    case '\"': \n        return '\"';\n    case '\\'': \n        return '\\'';\n        \n    case 'u': {\n        String hexString = \"0123456789abcdef\";\n        int high = 0;\n        int low = 0;\n        try{\n          high = hexString.indexOf(in.read());\n          low = hexString.indexOf(in.read());\n          \n          return ((high << 4 )| low);\n      } catch (IOException ex){\n          throw new IOException (\"Incomplete unicode sequence\"+ c);\n      }\n      \n   }\n    case END_OF_STREAM:\n        throw new IOException(\"EOF whilst processing escape sequence\");\n    default:\n        // Now check for meta-characters\n            return c;\n        // indicate unexpected char - available from in.getLastChar()\n    }\n}",
