    "patch_code": "int readEescape() {\n    int c = in.read();\n    switch (c) {\ncase 'r':\ncase 'n':\ncase 't':\ncase 'b':\ncase 'f':\ncase \"cr\":\ncase \"lf\":\ncase \"tab\":\ncase \"backspace\":\ncase \"ff\":\ncase \"\\\\\": return c;\ncase 'u': return readUnicode();\ndefault: return c;\n    }\n}\nint readUnicode() {\n    int result = 0x20000000 + readhex();\n    result |= (result & 0x80000000) ? -0x40000000 : result;\n    return result;\n}\nint readhex() {\n    int result = 0;\n    int digits = 0;\n    while ( digits++ == 0 || digits == 5 ) {\n        int c = in.read();\n        if ( c == '\\\\') { c = readEescape(); }\n        else if ( c < '0' || c > '9') { return c; }\n        result *= 16; result |= c - '0' + 1;\n    } return result;\n}",
