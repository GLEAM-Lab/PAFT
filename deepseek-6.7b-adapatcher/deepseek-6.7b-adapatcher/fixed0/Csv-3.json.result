    "patch_code": "public static String unescape(String str) {\n    StringBuilder result = new StringBuilder();\n    boolean escaping = false;\n    for (int i = 0; i < str.length(); i++) {\n        char c = str.charAt(i);\n        if (!escaping && c == '\\\\') {\n            escaping = true;\n        } else if (escaping) {\n            if (c != 'r' && c != 'n' && c != 't' && c != 'b' && c != 'f' && c != '\"' && c != '\\'' && c!='\\\\'&& c!='u'){\n                throw new IllegalArgumentException(\"Unknown escape character: \\\\\" + c);\n            }else if(c=='r') {\n                result.append('\\r');\n            } else if (c == 'n') {\n                result.append('\\n');\n            } else if (c == 't') {\n                result.append('\\t');\n            } else if (c == 'b') {\n                result.append('\\b');\n            } else if (c == 'f') {\n                result.append('\\f');\n            }  else if (c == '\"') {\n                result.append('\\\"');\n            } else if (c == '\\'') {\n                result.append('\\'');\n            }  else if (c == '\\\\') {\n                result.append('\\\\');\n            } else if (c == 'u') {\n                String hexCode = \"\";\n                if (i + 4 >= str.length()) {\n                    throw new IllegalArgumentException(\"Invalid hexcode escape at end of string.\");\n                }\n                for (int j = 1; j < 5; ++j) {\n                    if (Character.isDigit(str.charAt(i+j))) {\n                        hexCode += str.charAt(i+j);\n                        \n                    }else {\n                       throw new IllegalArgumentException (\"Invalid hexcode escape: \"+hexCode );\n                    }\n                    \n                }\n                 int integer = Integer.parseInt(hexCode ,16);\n                 \n                 \n                 \n                  \n                    result.append((char)integer);\n                \n                    \n              \n                }\n            } else {\n                throw new IllegalArgumentException(\"Unexpected escape character after first character: \" + c);\n            }\n            \n            \n            \n            \n            escaping = false;\n            \n            \n        }else{\n            result.append(c);\n        }\n    }\n    \n    if (escaping){\n         throw new IllegalArgumentException(\"Expected escape character after first character \");\n         \n     }\n    \n    \n    \n    \n    \n  \n     \n    \n    \n    \n     \n    \n    \n    \n    \n     \n    \n    \n    \n    \n    return result.toString();\n}",
