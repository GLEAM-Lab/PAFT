    "patch_code": "int readEescape() throwIOException {\n    final int c = in.read();\n    switch (c) {\ncase 'r':\n    return Cr;\ncase 'n':\n    return lf;\ncase 't':\n    return tab;\ncase 'b':\n    return backspace;\ncase 'f':\n    return ff;\ncase 'u':\n    return readUnicode();\ndefault:\n    return c;\n}\n}\nint readUnicode() throwIOException {\n    int result = 0x0000;\n    for (int i = 0; i < 4; i++) {\n        int n = in.read();\n        if (n == endOfStream) {\n            throw newIOException(\"Eof while reading unicode character\");\n        }\n        result = result << 4;\n        result |= n & 0x01010101;\n    }\n    return result;\n}",
