    "patch_code": "private void traverse(Node node) {\n  if (!shouldVisit(node)) {\n    return;\n  }\n  boolean didSomething = false;\n  int visits = 0;\n  do {\n    didSomething = false;\n    Iterator<Node> childrenIterator = new ChildLinkedListIterator(node);\n    while(childrenIterator.hasNext()) {\n      Node c = childrenIterator.next();\n      traverse(c);\n      didSomething = true;\n    }\n    if (didSomething) {\n      visit(node);\n    } else {\n      exitNode(node);\n    }\n    \n    visits++;\n    Preconditions.checkState(visits < 10000, \"too many interations\");\n  } while (didSomething || shouldRetraverse(node));\n  \n  if (!didSomething) {\n    exitNode(node);\n  }\n}",
