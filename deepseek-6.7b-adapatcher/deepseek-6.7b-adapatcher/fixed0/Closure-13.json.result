    "patch_code": "public class PeepholeOptimizationsTest {\n  public static String visit(String src) {\n    class Walker extends JsAstWalker<Object> {\n\n        private final CompileTimeConstants constants = new CompileTimeConstants();\n\n        @Override Object getReceiver() { return null; }\n\n        @Override boolean shouldSkip(int types) {\n            return ((types & NUMBER_LITERAL) != 0 || (types & STRING_LITERAL) != 0 ||\n                    (types & TRUE) != 0 || (types & FALSE) != 0 ||\n                    (types & KEYWORDS) != 0 || (types & LABEL) != 0 ||\n                    (types & TYPEOF) != 0);\n        }\n      \n        @Override void noteConstantValue(ConstantExpression e) {\n          constants.addConstantExpression(e);\n        }\n        \n        @Override void onBooleanLiteral(BooleanLiteral l) {\n            if (l.getValue()) {\n                replaceCurrentNode(\"/*!\" + Expr.encode(constants.forTrue(), true)+ \"/\");\n            } else {\n                replaceCurrentNode(\"/*!\" + Expr.encode(constants.forFalse(), true)+\"/ \");\n            }\n        }\n        \n        @Override void onNumberLiteral(NumberLiteral l) {\n            replaceCurrentNode(\"/*!\"+Expr.encode(constants.forNumber(l.getValue()),true)+\"*/ \");\n        }\n        \n        @Override void onKeywordExpression(KeywordExpression n) {\n            checkArgument(n.isIn() || n.isInstanceof());\n            replaceCurrentNode(\"new \" +\n                        (n.isInstanceof() ? \"Reflect\" : \"RegExp\") + \"('\" + n.getVal().toLowerCase() + \"')\");\n        }\n        \n        @Override void onNullLiteral(JsAstWalker.NullLiteral n) {\n            checkPrecedence(OR);\n            replaceCurrentNode(\"(!(null))\");\n        }\n        \n        @Override void onStringLiteral(StringLiteral l) {\n            replaceCurrentNode(\"\\\"\" + escapeJavaScriptString(l.getStringContent()) + \"\\\"\");\n        }\n\n        @Override void onConditionalExpr(ConditionalExpr e) {\n            checkPrecedence(CONDITIONAL);\n            prependAndReplace(\"(\"+this.current().toString()+\")\",\"?\",\"\":\" );\n        }\n    \n        @Override void afterTraversal() {\n           // Do nothing - this does not remove all dead code from files.\n        }\n    }\n  \n    Walker w = new Walker();\n    WarningCollector wc = new WarningCollector();\n    JsParser p = new JsParser(wc);\n    try {\n        List<JsStatement> roots = p.parseStatements(src);\n        for (JsStatement root : roots) {\n            w.walk(root);\n        }\n    } catch (Throwable t) {\n        throw new Error(\"Unhandled exception.\", t);\n    }\n\n    // Walk again as a second pass to resolve things like function declarations inside statements\n    for (JsStatement root : roots) {\n      w.walk(root);\n    }\n\n    return w.getCodeWithoutComments();\n  }\n\n  private static String escapeJavaScriptString(String s) {\n      StringBuilder out = new StringBuilder(s.length());\n\n      char[] chars = s.toCharArray();\n      for (char c : chars) {\n          switch (c) {\n              case '\\n':\n                  out.append(\"\\\\n\");\n                  break;\n              case '\"' :\n                  out.append(\"\\\\\\\"\");\n                  break;\n              default:\n                  out.append(c);\n          }\n      }\n\n      return out.toString();\n  }\n}",
