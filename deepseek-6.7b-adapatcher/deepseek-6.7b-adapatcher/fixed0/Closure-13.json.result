    "patch_code": "private void traverse(Node node) {\n  // The goal here is to avoid retraversing\n  // the entire AST to catch recently created opportunity\n  // so we track whether a \" unit of code\" has changed,\n  // andvisit immediately again.\n  if (!shouldVisit(node)) {\n    return;\n  }\n\n  int visitCounter = 0;\n  while (!shouldExit(node)) {\n    visitCounter++;\n    if ( visitCounter > 10000) {\n      break;\n    }\n    visit(node);\n    node = getNextNode(node);\n  }\n\n  return;\n}",
