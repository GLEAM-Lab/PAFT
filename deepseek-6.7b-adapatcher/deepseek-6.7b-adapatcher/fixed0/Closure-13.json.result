  {
    "patch_code": "private void traverse(Node node) {\n  // The goal here is to avoid retraversing\n  // the entire AST to catch newly created opportunities.\n  // So we track whether a \"unit of code\" has changed,\n  // and revisit immediately.\n  if (!shouldVisit(node)) {\n    return;\n  }\n\n  List<Node> stack = new ArrayList<>();\n  stack.add(node);\n  while(!stack.isEmpty()) {\n    Node n = stack.remove(stack.size()-1);\n    visit(n);\n    \n    Iterator<Node> iter = n.getChildren().iterator();\n    while(iter.hasNext()) {\n      Node c = iter.next();\n      if(c != null) {\n        iter.remove();\n        \n        if (shouldVisit(c)){\n          stack.add(c);\n        }else{\n          continue;\n        }\n      }\n      \n      Node next = n.getNextSibling();\n      if (next == null){\n        break;\n      }\n      iter.set(next);\n    }\n  }\n  \n  exitNode(node);\n}",
