    "patch_code": "protected JavaType _narrow(Class<?> subclass)\n{\n    if (_class != null && Objects.equals(_class, subclass)) {\n        return this;\n    } else if (_interfaces.containsKey(subclass.getCanonicalName())) {\n    \tObject obj = _interfaces.get(subclass.getCanonicalName());\n        TypeBindings bindings = new TypeBindings();\n        Map<String,TypeBindings.Entry<JavaType>> mapperMap = \n        \t\t(Map<String,TypeBindings.Entry<JavaType>>)_mapperConfig().getProperties();\n        Set<String> keyset = mapperMap.keySet();\n        Iterator itr = keyset.iterator();\n        while (itr.hasNext()) {\n            String key = (String) itr.next();\n            if (!(obj instanceof Class) || \n            \t\t\tObjects.equals(((Class<?>)obj).getCanonicalName(), key)) {\n            \tbindings.setNormalValue(key, mapperMap.get(key));\n            }\n        }\n        List<JavaType> interfaces = new ArrayList<>();\n        Collections.addAll(interfaces, ((InterfaceWithSubTypes)subclass).getSuperInterfaceClasses());\n        return new SimpleType(subclass, bindings, this, interfaces,\n                _valueHandler, _typeHandler, _asStatic);\n    } else if (_superClass != null) {\n        return _superClass._narrow(subclass);\n    }\n        /*\n        throw new IllegalArgumentException(\"Class \" + subclass.getName() + \n        \" not sub-type of \" + _class.getName());\n                */\n    return new SimpleType(subclass, _bindings, this, _superInterfaces,\n            _valueHandler, _typeHandler, _asStatic);\n    // Otherwise, stitch together the hierarchy. First, super-class\n    // if not found, try a super-interface\n    // should not get here but...\n}",
