    "patch_code": "protected JavaType _narrow(Class<?> subclass)\n{\n    if (_class != null && _class != Object.class) {  \n        \n        Class<?>[] classes = ((Class<?>[])Array.newInstance(_class.getClass(),1));\n        classes[0] = _class;\n        List<Class<?>> classList = Arrays.asList(classes);\n    \n        if(classList.contains(subclass)){\n            return new SimpleType(subclass, _bindings, this, _superInterfaces,\n                    _valueHandler, _typeHandler, _asStatic);\n        }\n          \n        if (!subclass.isAssignableFrom(((JavaTypeImpl)this).getRawClass())){\n            \n            // If it's not assignable from current class nor its super classes, throw exception\n            throw new RuntimeException (\"Not implemented\");\n        }else{\n            \n            // If it is assignable from the current class or its super class, just narrow down the type\n            return new SimpleType(subclass, _bindings, this, _superInterfaces,\n                    _valueHandler, _typeHandler, _asStatic);\n        }      \n    } else if(!Object.class.equals(_class)) {\n        // Should we check that there is a sub-class relationship?\n        // 15-Jan-2016, tatu: Almost yes, but there are some complications with\n        //    placeholder values (`Void`, `NoClass`), so can not quite do yet.\n        // TODO: fix in 2.8\n        throw new IllegalArgumentException(\"Class \"+subclass.getName()+\" not sub-type of \"\n                +_class.getName());\n        \n    }\n    \n     return null;\n     \n    } \n}",
