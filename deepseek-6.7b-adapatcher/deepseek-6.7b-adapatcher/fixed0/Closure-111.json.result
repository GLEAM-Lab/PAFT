  {
    "patch_code": "protected JSType caseTopType(JSType topType) {\n      switch (topType.getKind()) {\n        case JSType.FUNCTION:\n          // We can't infer types from functions yet. So, just use Object.\n          return JS.global().Object();\n        default:\n          break;\n      }\n    return topType;\n}",
