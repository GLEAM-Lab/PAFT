    "patch_code": "public class ClosureTest extends JSTestCase {\n    public void testIsArray() throws Exception {\n        setCompilerOptions(\"--compilation_level\", \"ADVANCED_OPTIMIZATIONS\");\n        \n        String jsInput = \n                \"/**\\n\" +\n                \" * @param {*} object\\n\" +\n                \" * @return {*} \\n\" +\n                \" */\\n\"+\n                \"function test(object) {\\n\" +\n                    \"if (goog.isArray(object)) {\\n\" +\n                        \"var x = object;\\n\"+\n                        \"return x;\\n\" +\n                    \"}\\n\" +\n                \"}\\n\";\n    \n       TestResult result=compileAndRun(jsInput);\n    \n       Assert.assertTrue(\"Expected 'undefined' but found something else\",result.hasNoOutput());\n      }\n  }",
