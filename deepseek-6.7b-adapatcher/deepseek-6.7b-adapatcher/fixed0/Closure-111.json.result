    "patch_code": "import com.google.javascript.rhino.*;\n\npublic class ClosureReverseAbstractInterpreter extends AbstractJavaScriptInterpreter implements ReverseAbstractInterpreter{\n\n    \n    public NodeFactory getNodeFactory() {\n        return nodeFactory;\n    }\n    \n    protected JSType caseTopType(JSType topType){\n      // if array then it should be replaced with jsarray object otherwise just return the original obj\n         if (topType instanceof JSArray){\n             topType= new JSArray();\n         } \n      \n         return topType ;\n           \n      }\n  private final NodeFactory nodeFactory;\n\n\n    public ClosureReverseAbstractInterpreter(CodeGenerationRequest request, ErrorManager errorManager, int optimizationLevel, boolean verboseMode, WarningHandler warningHandler, SourceMap sourcemap) {\n        super(request, errorManager, optimizationLevel, verboseMode, warningHandler, sourcemap);\n        this.nodeFactory = new CodeGeneratingNodeFactory(this);\n    }\n    \n\n\n\n\n}",
