    "patch_code": "protected JSType caseTopType(JSType topType) {\n  if (!(topType instanceof JSObjectLiteralExpressionType)) {\n    // Not all ObjectLiteralExpressions are Arrays (for example \"new A()\"). Only treat those that have a literal form (\"[]\") as such.\n    return super.caseTopType(topType);\n  }\n\n  return getGlobal().makeArray();\n}",
