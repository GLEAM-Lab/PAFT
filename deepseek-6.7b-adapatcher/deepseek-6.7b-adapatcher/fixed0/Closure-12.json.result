    "patch_code": "/**\n * Copyright 2008 Google Inc.\n *\n * Licensed under the Apache License, Version 2.0 (the \"License\");\n * you may not use this file except in compliance with the License.\n * You may obtain a copy of the License at\n *\n *      http://www.apache.org/licenses/LICENSE-2.0\n *\n * Unless required by applicable law or agreed to in writing, software\n * distributed under the License is distributed on an \"AS IS\" BASIS,\n * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n * See the License for the specific language governing permissions and\n * limitations under the License.\n */\npackage com.google.javascript.jscomp;\nimport com.google.javascript.rhino.Node;\npublic class MaybeReachingVariableUse extends AbstractInterpreterPass {\n\n @Override\n public boolean canProcess(Node node) {\n   // We should only process uses of variables\n   return NodeUtil.isName(node) &&\n       !CodePrinter.isKeywordOrPunctuation(node.getString());\n }\n\n private static final int NEVER = 0;\n private static final int MAYBE = 1;\n private static final int REACHABLE = 2;\n\n private int[] flagsForNames = new int[1];\n private String namesToIndexesMap = \"\";\n\n public boolean hasExceptionHandler(Node node) {\n   while (!node.getParent().isTryCatch()) {\n     node = node.getParent();\n   }\n   return true;\n }\n\n @Override\n public void visitLHS(Node node) {\n   checkRHS(false);\n   super.visitLHS(node);\n }\n\n @Override\n public void visitRHS(Node node) {\n   checkRHS(true);\n   super.visitRHS(node);\n }\n\n @Override\n protected void reportUnusedVariable(int index) {\n   // Don't complain about variables used in exception handlers\n   if ((flagsForNames[index] & REACHABLE) == REACHABLE ||\n       (hasExceptionHandler(context.currentNode))) {\n     return;\n   }\n   super.reportUnusedVariable(index);\n }\n\n @Override\n public Node runAtOptimizationPass() {\n   return null;\n }\n\n private void addFlagsForDeclaredNames() {\n   for (String name : context.getNameManager().getNamesInScope()) {\n     if (name.equals(\"\")) {\n       continue;\n     }\n     int index = namesToIndexesMap.indexOf(name);\n     assert index != -1;\n     if (index >= flagsForNames.length) {\n       expandFlagsForNamesArray(index);\n     }\n     flagsForNames[index] |= REACHABLE;\n   }\n }\n\n private void expandFlagsForNamesArray(int size) {\n   int oldSize = flagsForNames.length;\n   flagsForNames = Arrays.copyOf(flagsForNames, Math.max(size + 1, oldSize * 2));\n   for (int i = oldSize; i < size; i++) {\n     flagsForNames[i] = NEVER;\n   }\n }\n}",
