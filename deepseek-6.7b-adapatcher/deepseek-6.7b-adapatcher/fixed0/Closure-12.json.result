    "patch_code": "private boolean hasExceptionHandler(Node cfgNode) {\n  while (!cfgNode.isTerminal()) {\n    for (AbstractBinaryTreeVisitor.ControlFlowEdge<Node> edge : cfgNode.succEdges()) {\n      Node target = edge.getTarget();\n      if (target != null && target.getKind().isExceptionHandler()) {\n        return true;\n      }\n    }\n    cfgNode = cfgNode.next();\n  }\n  return false;\n}",
