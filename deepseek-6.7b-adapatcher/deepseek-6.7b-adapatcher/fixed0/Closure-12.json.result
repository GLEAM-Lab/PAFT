    "patch_code": "private boolean hasExceptionHandler(Node cfgNode) {\n  while (cfgNode != null && !(cfgNode instanceof Statement)) {\n    cfgNode = cfgNode.getParent();\n  }\n  if (cfgNode == null || !(cfgNode instanceof Block)) {\n    return false;\n  }\n  List<Statement> statements = ((Block)cfgNode).statements;\n  for (int i = 0; i < statements.size(); ++i) {\n    ExpressionStatement expressionStatement = (ExpressionStatement)statements.get(i);\n    if (!(expressionStatement.expression instanceof AssignmentTarget)) {\n      continue;\n    }\n    String targetName = ((AssignmentTarget)expressionStatement.expression).name;\n    for (int j = i + 1; j < statements.size(); ++j) {\n      IfaceCall call;\n      if (!((call = getFunctionOrMethodCall(statements.get(j))) != null && call.target().getName() == \"$exceptionHandler\")){\n        continue;\n      } else if (((IfaceCall)call).args[0].name.equals(targetName)){\n         return true;\n      }\n    }\n  }\n  return false;\n}",
