    "patch_code": "void read(Tokenised t, Character Reader r) {\n    if (r.matchesLetter()) {\n        String name = r. consumeLetter sequence();\n        t. tagging.append TaggingName(name. to lowercase());\n        t. data_[t. data_.length() - 1].append(name);\n        r. advance();\n        return;\n    }\n\n    if (t. isappropriate end tagtokens and ! r.isEmpty()) {\n        char c = r. consume();\n        switch (c) {\n            case ' ':\n            case ' \\n':\n            case ' \\f':\n            case ' \\t':\n                t. transition(before_attributename);\n                break;\n            case ' /':\n                t. transition( self_closing start tag);\n                break;\n            case ' >':\n                t. emit tagging();\n                t. transition(data);\n                break;\n            else\n                t. data_[t. data_.length() - 1].append(c);\n                anythingelse(t, r);\n                break;\n        }\n    } else {\n        anythingelse(t, r);\n    }\n}",
