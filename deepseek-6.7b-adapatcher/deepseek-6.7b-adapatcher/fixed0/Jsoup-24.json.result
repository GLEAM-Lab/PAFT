    "patch_code": "void read(Tokenise t, Character Reader r) {\n    if (r.matchesLetter()) {\n        String name = r. consume letter sequence;\n        t. tag Pending.append tag name (name. to lowercase());\n        t. data (name);\n        r. advance();\n        return;\n    }\n\n    if (t. is appropriate end tag and ! r.isEmpty()) {\n        char c = r. consume();\n        switch (c) {\n            case ' \\t':\n            case ' \\n':\n            case ' \\f':\n            case ' \\r':\n                t. transition (before name);\n                break;\n            case / /:\n                t. transition (self Cl opening Tag);\n                break;\n            case ' >':\n                t. emit tag Pending (t);\n                t. transition (data);\n                break;\n            else:\n                t. data (c);\n                anythingelse (t, r);\n                break;\n        }\n    } else {\n        anythingelse (t, r);\n    }\n}",
