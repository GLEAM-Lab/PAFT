    "patch_code": "void read(Tokenised t, Character Reader r) {\n    if (r.matchesLetter()) {\n        String name = r. consumeLetter sequence();\n        t. tag Pending.append TagName(name.to Lowercase());\n        t. data Pending.append(name);\n        r. advance();\n        return;\n    }\n    \n    if (t. isappropriate end tagToken() && !r.isEmpty()) {\n        char c = r. consume();\n        switch (c) {\n            case `tab`:\n            case `space`:\n            case `form feed`:\n            case `space`:\n                t. transition(before A name);\n                break;\n            case ` / `:\n                t. transition( self Closure start tag);\n                break;\n            case `>`:\n                t. emit Tag Pending;\n                t. transition(Data);\n                break;\n            default:\n                t. data Pending.append(c);\n                anythingelse(t, r);\n                break;\n        }\n    } else {\n        anythingelse(t, r);\n    }\n}",
