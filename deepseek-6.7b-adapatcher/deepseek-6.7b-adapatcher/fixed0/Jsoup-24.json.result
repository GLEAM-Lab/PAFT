    "patch_code": "boolean matchesLetter(CharacterReader r){\n    return r.matchesLetter() ;\n}\nString consumeLetterSequence(CharacterReader r){\n    return r.consumeLetterSequence();\n}\nchar consume(CharacterReader r){\n    return r.consume();\n}\nvoid advance(CharacterReader r){\n    r.advance();\n}\n\nvoid read(Tokeniser t, CharacterReader r) {\n    if (matchesLetter(r)) {\n        String name = consumeLetterSequence(r);\n        t.tagPending.appendTagName(name.toLowerCase());\n        t.dataBuffer.append(name);\n        advance(r);\n        return;\n    }\n\n    if (t.isAppropriateEndTagToken() && !r.isEmpty()) {\n        char c = consume(r);\n        switch (c) {\n            case '\\t':\n            case '\\n':\n            case '\\f':\n            case ' ':\n                t.transition(BeforeAttributeName);\n                break;\n            case '/':\n                t.transition(SelfClosingStartTag);\n                break;\n            case '>':\n                t.emitTagPending();\n                t.transition(Data);\n                break;\n            default:\n                t.dataBuffer.append(c);\n                read(t, r);\n                break;\n        }\n    } else {\n        read(t, r);\n    }\n}",
