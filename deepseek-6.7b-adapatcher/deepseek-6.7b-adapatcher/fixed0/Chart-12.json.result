    "patch_code": "import org.jfree.chart.JFreeChart;\nimport org.jfree.chart.plot.MultiplePiePlot;\nimport org.jfree.chart.plot.PiePlot;\nimport org.jfree.chart.title.TextTitle;\nimport java.awt.*;\n\npublic class MultiPiePlot extends MultiplePiePlot{\n\n    public MultiPiePlot(CategoryDataset dataset){\n        super();\n        super.initialize();\n        super.setIgnoreNullValues(true);\n        super.setBaseSectionOutlinePaint(Color.WHITE);\n        \n        ((MultiPiePlot)this).addDomainTitle(\"Sub Category\");\n        \n        //Removing legend from all plots except the first one.\n        for(int i = 0 ; i < getPlotCount() ;i++){\n            \n            //Adding title on top of plot.\n          \n            String temp =\"Title \"+String.valueOf((char)(65+i));\n            \n            System.out.println(temp );\n            super.getPlot(i).setForegroundPaint(Color.white);\n            super.getPlot(i).addTextNote(1 , 1, \"hi how r u \",new Rectangle(1,1,2,2),null );\n            ((MultiPiePlot)this).getPlot(i).removeLegend();\n            \n        }\n        \n     // Setting dataset for all the plots.\n      super.setDataset(dataset);\n    }\n}",
