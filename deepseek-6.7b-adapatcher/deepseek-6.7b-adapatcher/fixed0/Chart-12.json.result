    "patch_code": "import org.jfree.chart.labels.StandardPieSectionLabelGenerator;\nimport java.awt.*;\nimport org.jfree.chart.entity.StandardEntityCollection;\nimport org.jfree.data.category.CategoryDataset;\n\npublic class MultiplePiePlot extends PiePlot{\n\n    private CategoryDataset dataSet;\n    public MultiplePiePlot(CategoryDataset d) {\n        super(new PieDataset());\n        this.setDataset(d);        \n        this.additionalConfigurations();        \n        this.getLegend().setFrame(BlockBorderType.HIDDEN);  \n    }\n    \n    private void additionalConfigurations() {\n        // Removes legend from plot\n        this.getLegend().setVisible(false);      \n        // Sets position of title \n        this.getPlot().getTitle().setPosition(RectangleEdge.UNDER); \n        // sets color & font style of section labels\n        this.getPlot().setLabelFont(new Font(\"Arial\", Font.ITALIC + Font.BOLD, 40));\n        this.getPlot().setLabelGenerator(new StandardPieSectionLabelGenerator(\"{0} : {1}\"));            \n    }\n\n    @Override\n    public void setDataset(CategoryDataset d) {\n        this.dataSet = d;         \n        this.fireChangeEvent();     \n    }\n}",
