    "patch_code": "import org.jfree.chart.JFreeChart;\nimport org.jfree.chart.entity.*;\nimport org.jfree.chart.plot.*;\nimport org.jfree.data.category.CategoryDataset;\nimport java.awt.Color;\nimport java.util.HashMap;\nimport java.util.Iterator;\nimport javax.swing.event.ChangeEvent;\nimport javax.swing.event.ChangeListener;\nimport org.jfree.chart.title.TextTitle;\nimport org.jfree.ui.RectangleInsets;\nimport org.jfree.chart.labels.*;\n\npublic class MultiplePiePlot extends AbstractCategoryPlot implements CategoryPlot, Cloneable {\n    \n    public MultiplePiePlot() {\n        super(new CategoryItemEntityCollection());\n        this.dataArea = new RectangleInsets(5, 0, 0, 18);        \n    }\n      \n    @Override\n    public void setDataset(int index, CategoryDataset dataset){\n        super.setDataset(index, dataset);\n        if (!getDataset().equals(dataset)) {\n             return;\n        }\n        PiePlot pi = new PiePlot(dataset);\n        pi.setLabelLinkEnabled(true);\n        pi.setLabelGenerator(new StandardPieSectionLabelGenerator(\"{0}: {@1}\"));\n        LegendState legendstate = new DefaultLegendState();\n        pi.setLegendState(legendstate);\n        Iterator iter = getDataset().getGroupKeys().iterator();\n        int i=0;\n        while (iter.hasNext()) {\n           pi.setSectionPaint(i, Color.decode(\"#\"+Integer.toHexString(((Integer)getDataset().getValue(iter.next(),1)).intValue()).substring(2)));\n           i++;\n        }\n        ChartPanel chartpanel = new ChartPanel(new JFreeChart(pi), true);\n        changeListeners = new ArrayList<>();\n        chartpanel.addChangeListener(new ChangeListener() {\n            @Override\n            public void stateChanged(ChangeEvent e) {\n                notifyListeners();\n            }\n        });\n        super.setDataset(index, null);\n        add(chartpanel);\n    }\n}",
