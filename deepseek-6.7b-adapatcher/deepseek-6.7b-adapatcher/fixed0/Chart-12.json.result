    "patch_code": "public class MultiplePiePlot extends CategoryPlot implements PlotListener{\nprivate PiePlot[] slices;\nprotected static final int MAX_SLICES = 60;\n\npublic MultiplePiePlot(CategoryDataset dataset) {\n    super(dataset);\n    slices = new PiePlot[MAX_SLICES];\n    createSlice(slices, dataset, false);\n    this.fireChangeEvent();\n}\n\nvoid createSlice(PiePlot[] sliceArray, CategoryDataset data, boolean stacked){\n    int categoryCount = data.getColumnCount(), seriesCount = data.getRowCount();\n    \n    if (stacked && !(data instanceof DefaultCategoryDataset)){\n        throw new IllegalArgumentException(\"Data must be instance of DefaultCategoryDataset.\");\n    }\n    int i=0;\n    while ((sliceArray!=null)&&(i<categoryCount)&&(i<sliceArray.length)){\n        PiePlot temp = new PiePlot((DefaultCategoryDataset) data, i, seriesCount - 1, stacked);\n        \n        temp.addPlotListener(this);\n        sliceArray[i]=temp;\n        i++;\n    }\n    while(i<sliceArray.length){\n        sliceArray[i]=null;\n        i++;\n    }\n}\n   private void removeAllPlots() {\n    synchronized (this) {\n        int size = plots.size();\n        for (int i = 0 ; i < size; i++) {\n             removePlot(plots.get(i).getDomainAxis().getID());\n        }\n    }\n}\n@Override\npublic void plotChanged(PlotChangeEvent event) {\n    fireChangeEvent();\n}\n\n@Override\npublic Rectangle getPlotAreaBounds(){\n    Enumeration e = slices;\n    int i = 0;\n    double x[] = new double[slices.length], y[] = new double[slices.length];\n    while (e.hasMoreElements()){\n        PiePlot temp = (PiePlot)e.nextElement();\n        Rectangle r = temp.getPlotAreaBounds();\n        x[i] = r.getX();\n        y[i] = r.getY();\n        i++;\n    }\n    return ChartUtilities.calculateBarPlotAreaBound(x,y);\n}\n}",
