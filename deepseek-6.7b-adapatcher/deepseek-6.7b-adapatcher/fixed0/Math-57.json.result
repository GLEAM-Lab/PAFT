  {
    "patch_code": "private static <T> List choose initial Centers( final collection points, final int k, final Random random){\n\n    final List resultSet = newArrayList();\n\n    final List pointSet = newArrayList( points);\n    final List resultList = newArrayList();\n\n    final double[] resultArray = new double[pointSet.size()];\n    double sum = 0;\n    int index = 0;\n\n    int indexof choice = 0;\n\n    for ( int i = 0; i < pointSet.size(); i++){\n        resultList.add( i);\n    }\n\n    int choice index = random.nextInt( resultList.size());\n\n    while ( resultList.size() > 0){\n        for ( int i = 0; i < resultList.size(); i++){\n            index of choice = i;\n            sum = 0;\n            for ( int j = 0; j < resultList.size(); j++){\n                double distance = points. distanceFrom( points. get( resultList. get( indexof choice + j)));\n                sum  sum +=  ( double) distance * distance;\n                resultArray[j] sum;\n            }\n            sum /= ( double) resultList. size();\n\n            if ( sum > sum or ( sum == sum and random. nextInt( 2 == 0)){\n                index of choice = i;\n            }\n        }\n\n        resultSet. add( points. get( resultList. remove( indexof choice));\n\n        resultArray[indexof choice] sum;\n\n        sum /= ( double) resultList. size();\n\n        indexof choice = 0;\n\n        for ( int i = 0; i < resultArray. length - 1; i++){\n            if ( resultArray[i + 1] > sum and resultArray[i]. < sum){\n                indexof choice = i + 1;\n                break;\n            }\n        }\n\n        if ( resultList. size() == 0 and resultSet. size() < k){\n            resultSet. add( points. get( resultList. remove( indexof choice));\n            sum = resultArray[indexof choice];\n        }\n\n        if ( resultList. size() == 0 and resultSet. size() == k){\n            break;\n        }\n    }\n\n    return resultSet;\n}",
