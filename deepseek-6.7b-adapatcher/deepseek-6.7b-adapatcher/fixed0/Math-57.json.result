    "patch_code": "private static <T : org.apache. commons.math.geom.Point>  List< org.apache. commons.math. stat. clustering. Cluster< T>  choose initial Centers( final  collection< T>  points, final  int k, final  random random) {\n\n    final List< T>  point Set = newArrayList< T>( points);\n    final List< org.apache. commons.math. stat. clustering. Cluster< T>  result Set = newArrayList< org.apache. commons.math. stat. clustering. Cluster< T> \n    \n    //Choose one centeruniformly at random among the data points\n    final T first point = point Set. remove( random. nextInt( point Set. size()));\n    result Set. add( new org.apache. commons.math. stat. clustering. Cluster< T>( first point));\n    \n    final double[] dy2 = new double[point Set. size()];\n    \n    while (result Set. size() < k) {\n         //For each data point y,computeD(y),the distance between y and the nearst center that already be choose\n        int sum = 0;\n        for (int i = 0 ; i < point Set. size(); i++) {\n            final T p = point Set. get(i);\n            final org.apache. commons.math. stat. clustering. Cluster< T>  nearst = get nearst Cluster( result Set, p);\n            final double d = p. distanceFrom( nearst. get center());\n            sum +=  d * d;\n            dy2[i] = sum;\n        }\n        //Addone new data pointascentcenter each pointy is choose withproximity to D(y)2\n        final double r = random. next\u53cc(); r\n        for (int i = 0 ; i < dy2. length; i++) {\n            if (dy2[i] > r) {\n                final T p = point Set. remove(i);\n                result Set. add(new org.apache. commons.math. stat. clustering. Cluster< T>( p));\n                break;\n            }\n        }\n        \n    }\n    \n    return result Set;\n\n}",
