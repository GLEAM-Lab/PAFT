  {
    "patch_code": "private static <T : org.apache. Commons.math.geometry.Distanceable<T>>  List< Cluster<T>> choose initial centroids( final collection< T> points, final int k, final Random random){\n\n    final List< T> pointSet = newArrayList< T>( points);\n    final List< Cluster<T>>  resultSet = newArrayList< Cluster<T>>();\n\n    final T firstPoint = pointSet. remove( random.nextInt( pointSet. size()), random);\n    resultSet. add( new Cluster<T>( firstPoint));\n\n    while (resultSet. size() < k) {\n        final double[] s = new double[ pointSet. size()];\n        double sum = 0;\n        for (int i = 0; i < pointSet. size(); i++) {\n            final T p = pointSet. get( i);\n            final double d = p . distanceFrom( get Neighboring Cluster( resultSet, p)) / ( double) resultSet. size();\n            sum +=  d * d;\n            s[i] = sum;\n        }\n\n        final double r = random . next\u53cc double() * sum;\n        for (int i = 0; i < s. length; i++) {\n            if (s[i] > r) {\n                final T p = pointSet. remove( i);\n                resultSet. add( new Cluster<T>( p));\n                break;\n            }\n        }\n    }\n    return resultSet;\n}\n\nprivate static < T : org.apache. Commons.math.geometry.Distanceable<T>>  Cluster< T> get Neighboring Cluster( final List< Cluster< T>>  resultSet, final T p) {\n    double minDistance = p . distanceFrom( resultSet. get( resultSet. size() - 1)) / ( double) resultSet. size();\n    return resultSet. get( resultSet. size() - 1);\n}\n\nprivate static < T : org.apache. Commons.math.geometry.Distanceable<T>>  List< Cluster< T>>  choose initial center( final collection< T> points, final int k, final Random random){\n    return choose initial centroids( points, k, random);\n}",
