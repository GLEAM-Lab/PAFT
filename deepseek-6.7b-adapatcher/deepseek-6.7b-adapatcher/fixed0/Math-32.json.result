    "patch_code": "import org.apache.commons.math3.geometry.euclidean.oned.Interval;\nimport org.apache.commons.math3.geometry.euclidean.threed.*;\nimport java.util.List;\n\npublic abstract class PolygonExtractor<T extends Triangulation> implements Extrudable<Polygonal>{\n    \n    private BSPTree<SpacePartition<Point>> rootNode;\n    public PolygonExtractor(BSPTree<SpacePartition<Point>> node){\n        \n        rootNode = node;\n    }\n    \n    @Override\n    public List<Polygonal> getElements(){\n        return extractShapesFromSubtree(rootNode,true);\n    }\n    \n    protected ArrayList<Polygonal> extractShapesFromSubtree(BSPTree<SpacePartition<Point>> subTreeRoot, boolean extractFrontFace ){\n        ArrayList<Polygonal> outputList = new ArrayList<>();\n        BSPTree<SpacePartition<Point>> left = subTreeRoot.getLeftChild(), right = subTreeRoot.getRightChild();\n        \n        if(subTreeRoot.isLeaf()){\n            \n            SpacePartition<Point> partition = subTreeRoot.getData();\n            Interval intervalZ = new Interval(partition.getMin().getZ(), partition.getMax().getZ());\n            T triangulation = (T) partition.toTriangleGrid(intervalZ);\n            \n            if((extractFrontFace && subTreeRoot.hasFrontChildren()) || (!extractFrontFace && subTreeRoot.hasBackChildren())){\n                \n                for(int i = 0 ; i < triangulation.getVertexCount() ; i++){\n                    Point pt1 = triangulation.getVertex(i % triangulation.getVertexCount());\n                    Point pt2 = triangulation.getVertex((i + 1) % triangulation.getVertexCount());\n                    Point pt3 = triangulation.getVertex((i + 2) % triangulation.getVertexCount());\n                    \n                    Plane plane = Plane.fitThrough(pt1,pt2,pt3);\n                    if(plane != null){\n                        if(((extractFrontFace && plane.getOffset() > 0)||(!extractFrontFace && plane.getOffset() < 0))){\n                            outputList.add(new Polyhedron(triangulation));\n                            \n                        }\n                        \n                    }else{\n                        \n                        if(extractFrontFace){\n                            outputList.add(new Polyhedron(triangulation));\n                        }\n                        \n                    }\n                }\n                \n                \n            }\n            \n        }else{\n            \n            outputList.addAll(extractShapesFromSubtree(left , extractFrontFace));\n            outputList.addAll(extractShapesFromSubtree(right, extractFrontFace));\n            \n        }\n        return outputList;\n    }\n}",
