    "patch_code": "public static <P extends Polygon> Collection<P> getFacesFromBspTree(final BSPTree<P> bspTree) {\n    assert bspTree != null;\n    \n    List<P> list = new ArrayList<>();\n    \n    Stack<Pair<BSPNode<P>, Integer>> stack = new Stack<>();\n    stack.add(Pair.of(bspTree.getRoot(), 0));\n    \n    while (!stack.isEmpty()) {\n      Pair<BSPNode<P>, Integer> top = stack.pop();\n      BSPNode<P> node = top.getFirst();\n      \n      if (top.getValue().equals(1)) {\n        list.addAll(node.getRegion());\n      } else {\n        List<BSPNode<P>> children = Lists.reverse(Lists.newArrayList(node.getChildren()));\n        \n        for (BSPNode<P> child : children) {\n          stack.push(Pair.of(child, 1));\n        }\n        \n        stack.push(Pair.of(node, 0));\n      }\n    }\n    \n    return list;\n  }",
