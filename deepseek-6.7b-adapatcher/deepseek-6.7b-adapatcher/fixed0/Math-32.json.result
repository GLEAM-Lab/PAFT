    "patch_code": "public abstract class GeometricObject implements Comparable<GeometricObject> {\n\n    public int compareTo(GeometricObject other){\n        \n        /* TODO: Implement comparison logic based on size */\n\n        return Double.compare(this.getSize(),other.getSize());\n    }\n    \n    public static class Vertex extends GeometricObject{\n       private final Vector3D pt;\n       private List<Vertex> neighbours = new ArrayList<>();\n       \n        public double distanceFromPoint(Vector3D target){\n            \n          /* TODO: Implement 3D Euclidean distance calculation between vertex and point*/\n            \n           return pt.subtract(target).getNorm();\n            \n        }\n\n        public boolean equals(Object other){\n            \n            if (!(other instanceof Vertex))\n                return false;\n            \n            Vertex o = (Vertex)other;\n            \n            return this.pt.equals(o.pt);\n                \n        }\n       \n        \n      // getters and setters\n    }\n    \n    public static class Edge extends GeometricObject {\n        \n        private final Vertex a;\n        private final Vertex b;\n        \n       \n        \n      // getters and setters\n        \n    }\n    \n    public static class Plane extends GeometricObject {\n        \n        private final Vector3D origin;\n        private final Vector3D normal;\n        \n        \n        public Vector3D projectPointOntoPlane(Vector3D source){\n            \n            /*TODO: implement projection algorithm */\n             \n            return null;\n        }\n\n      // getters and setters\n        \n    }\n\n\n    public static class Solid {\n        \n        Set<Vertex> vertices = new HashSet<>();\n        Set<Edge> edges = new HashSet<>();\n        Set<Plane> planes = new HashSet<>();\n        \n        \n        \n        // method for adding objects to sets\n        \n      \n    }\n\n    public static class BSPTree<E> {\n        \n        Node root;\n        BoundingBox bound;\n        \n        \n       \n\n        \n\n    }\n\n\n\n\n\n}",
