    "patch_code": "package org.apache.commons.math3.geometry.euclidean.threed;\n\nimport java.util.ArrayList;\nimport java.util.List;\n\n/**\n * Set of polygonal representations in Euclidean 3D.\n */\npublic abstract class PolygonalSet extends Euclidean3DSpace {\n\n    private static final long serialVersionUID = 20140506L;\n    \n    public enum Orientation{COUNTERCLOCKWISE,CLOCKWISE};\n\n    /** Vertices. */\n    private List<Vector3D> vertices;\n\n    /** Edges. */\n    private List<Edge> edges;\n\n    /** Faces. */\n    private List<Face> faces;\n\n    /**\n     * Empty constructor.\n     */\n    protected PolygonalSet(){\n        super();\n        vertices = new ArrayList<Vector3D>();\n        edges  = new ArrayList<Edge>();\n        faces   = new ArrayList<Face>();        \n    }\n\n    /**\n     * Add a vertex to the set.\n     * @param pt the vector representing the vertex.\n     */\n    protected void addVertex(Vector3D pt){\n        vertices.add(pt);        \n    }\n\n    /**\n     * Obtain the number of vertices in the set.\n     * @return the count of vertices.\n     */\n    public int getVertexCount(){\n        return vertices.size();\n    }\n\n    /**\n     * Obtain a vertex specified by its index.\n     * @param idx the zero-based index of the vertex.\n     * @throws IndexOutOfBoundsException if the index is negative or not less than the size of the set.\n     */\n    public Vector3D getVertex(int idx) throws IndexOutOfBoundsException{\n        return vertices.get(idx);\n    }\n    \n    /**\n     * Add a edge to the set.\n     * @param ege the edge to be added.\n     */\n    protected void addEdge(Edge ege){\n        edges.add(ege);        \n    }\n\n    /**\n     * Obtain the number of edges in the set.\n     * @return the count of edges.\n     */\n    public int getEdgesCount(){\n        return edges.size();\n    }\n\n    /**\n     * Obtain a Edge specified by its index.\n     * @param idx the zero-based index of the Edge.\n     * @throws IndexOutOfBoundsException if the index is negative or not less than the size of the set.\n     */\n    public Edge getEdge(int idx) throws IndexOutOfBoundsException{\n        return edges.get(idx);\n    }    \n\n    /**\n     * Add a face to the set.\n     * @param fac the face to be added.\n     */\n    protected void addFace(Face fac){\n        faces.add(fac);        \n    }\n\n    /**\n     * Obtain the number of faces in the set.\n     * @return the count of faces.\n     */\n    public int getFacesCount(){\n        return faces.size();\n    }\n\n    /**\n     * Obtain a Face specified by its index.\n     * @param idx the zero-based index of the Face.\n     * @throws IndexOutOfBoundsException if the index is negative or not less than the size of the set.\n     */\n    public Face getFace(int idx) throws IndexOutOfBoundsException{\n        return faces.get(idx);\n    }      \n    \n    /*\n     * This function must be implemented according to specific requirements\n     */\n    public abstract boolean contains(Vector3D pt);\n    \n}",
