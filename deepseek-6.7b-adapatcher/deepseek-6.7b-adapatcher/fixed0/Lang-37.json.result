    "patch_code": "import java.util.Arrays;\n\npublic class Main {\n   public static void main(String[] args){\n       Number[] st = addAll(new Integer[]{1}, new Long[]{2L});\n       Arrays.stream(st).forEach(System.out::println);\n   }\n   \n   public static Number[] addAll(Number[] array1, Number... array2) {\n       if (array1 == null || array2 == null){\n           throw new NullPointerException(\"Null arrays\");\n       }\n       int len1 = array1.length;\n       int len2 = array2.length;\n       Number[] result = new Number[len1+len2];\n       System.arraycopy(array1, 0, result, 0, len1);\n       System.arraycopy(array2, 0, result, len1, len2);\n       return result;\n   }\n}",
