    "patch_code": "public static <T> T[] addAll(T[] array1, T... array2) {\n    if (array1 == null) {\n        return clone(array2);\n    } else if (array2 == null) {\n        return clone(array1);\n    }\n    boolean primitive = false;\n    Class<?> wrapper1 = array1.getClass().getComponentType(),\n             wrapper2 = array2.getClass().getComponentType();\n    if (wrapper1.isPrimitive()) {\n        primitive = true;\n        wrapper1 = Primitives.wrap(wrapper1);\n    }\n    if (wrapper2.isPrimitive()) {\n        primitive = true;\n        wrapper2 = Primitives.wrap(wrapper2);\n    }\n    \n   // If the two arrays have different classes or one is primtive and the other isn't\n    if (!primitive && !wrapper1.equals(wrapper2)) {\n        throw new IllegalArgumentException(\"Mixed element types are not allowed\");\n    }\n    \n    @SuppressWarnings(\"unchecked\")\n    T[] joinedArray = (T[]) Array.newInstance(wrapper1, array1.length + array2.length);\n    System.arraycopy(array1, 0, joinedArray, 0, array1.length);\n    System.arraycopy(array2, 0, joinedArray, array1.length, array2.length);\n    return joinedArray;\n}",
