    "patch_code": "import java.util.*;\nimport java.lang.reflect.*;\n\npublic class Main\n{\n    public static void main(String[] args) {\n        try {\n            Number[] st = addAll(new Integer[]{1}, new Long[]{2L});\n            \n            for (Number n : st) {\n                System.out.println(n);\n            }\n        } catch (Exception e){\n            e.printStackTrace();\n        }\n        \n    }\n    \n\tpublic static <T> T[] addAll(T[] array1, T... array2) throws Exception {  \n\t    if(!checkMixedTypes(array1, array2)) throw new IllegalArgumentException(\"Mixed type arrays are not allowed\");\n        if (array1 == null) {\n            return Arrays.copyOf(array2, array2.length);\n        } else if (array2 == null) {\n            return Arrays.copyOf(array1, array1.length);\n        }\n        T[] result = Arrays.copyOf(array1, array1.length + array2.length);\n        System.arraycopy(array2, 0, result, array1.length, array2.length);\n        return result;\n\t}\n    \n    private static boolean checkMixedTypes(Object[] firstArray, Object[] secondArray){\n        if(firstArray==null || secondArray==null) return true;\n        Class<?> firstType = firstArray[0].getClass();\n        for(Object object : secondArray){\n            if(!object.getClass().equals(firstType)){\n               return false; \n           }\n        }\n        return true;\n    }\n}",
