    "patch_code": "private static ZipLong unixTimeToZipLong(long l) {\n    if (l < 0 || l > 0x7fffffffL) {\n        throw new IllegalArgumentException(\"X5455 timestamps must fit in a signed 32 bit integer: \" + l);\n    }\n    return new ZipLong(l & 0x7fffffffL);\n}",
