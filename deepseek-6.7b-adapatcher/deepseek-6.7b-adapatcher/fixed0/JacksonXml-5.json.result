    "patch_code": "package com.fasterxml.jackson.dataformat.xml.ser;\n\nimport java.io.IOException;\nimport javax.annotation.Priority;\n\nimport com.fasterxml.jackson.databind.*;\nimport com.fasterxml.jackson.databind.cfg.ConfigFeature;\nimport com.fasterxml.jackson.databind.type.LogicalType;\nimport com.fasterxml.jackson.databind.util.ClassUtil;\nimport com.fasterxml.jackson.databind.util.ISO8601DateFormat;\nimport com.fasterxml.jackson.databind.util.Named;\nimport com.fasterxml.jackson.datatype.jsr310.JSR310DateTimeSerializerBase;\nimport com.fasterxml.jackson.module.blackbird.BeanPropertyWriter;\nimport org.eclipse.persistence.internal.oxm.record.json.*;\nimport org.joda.time.format.DateTimeFormatter;\nimport org.joda.time.format.ISODateTimeFormat;\n\nimport com.fasterxml.jackson.core.JsonGenerator;\nimport com.fasterxml.jackson.databind.JavaType;\nimport com.fasterxml.jackson.databind.JsonMappingException;\nimport com.fasterxml.jackson.databind.NodeBuilder;\nimport com.fasterxml.jackson.databind.SerializerProvider;\nimport com.fasterxml.jackson.databind.annotate.JacksonPlugin;\nimport com.fasterxml.jackson.databind.ser.*;\nimport com.fasterxml.jackson.databind.tree.*;\n\n/**\n * @since 2.5\n */\npublic abstract class XmlValueSerializer extends JsonValueSerializer {\n    \n     /*\n         Changed this line of code here\n      if (pw.getAnnotation(JacksonXmlRootElement.class) == null) {\n          String logicalName = cls.getName();\n    ...\n    To this:\n      Named pwn;\n       if ((pwn=pw.getAnnotation(JacksonXmlRootElement.class)) == null) {\n          String logicalName = ClassUtil.getShortNameForCanonicalName(cls.getName(), getModule().getName());\n    ...\n   \n     */\n   public LogicalTypes.Nominal<?> typeIdentity() {\n      return TYPE_IDENTITY;\n   }\n\n    private static final class ArraySerializer extends XmlValueSerializer {\n        protected final JavaType valueType;\n        \n        public ArraySerializer(JavaType t, SerializerProvider p) {\n            super(p);\n            valueType = t.containedType();\n        }\n\n        public Boolean canSerialize(Object value) {\n           return value instanceof List;\n        }\n\n        public void serialize(Object value, JsonGenerator jgen, SerializerProvider provider)\n            throws IOException, JsonProcessingException\n        {\n            int i = 0;\n            List lst = (List) value;\n            \n            jgen.writeStartArray();\n            for (Iterator iter = lst.iterator(); iter.hasNext(); ++i) {\n                Object item = iter.next();\n                writeItem(item, jgen, provider);\n            }\n            jgen.writeEndArray();\n        }\n    }",
