    "patch_code": "package com.fasterxml.jackson.dataformat.xml.ser;\n\nimport java.util.Map;\nimport javax.annotation.Priority;\n\nimport com.fasterxml.jackson.databind.JavaType;\nimport com.fasterxml.jackson.databind.JsonMappingException;\nimport com.fasterxml.jackson.databind.ObjectMapper;\nimport com.fasterxml.jackson.databind.cfg.MapperConfig;\nimport com.fasterxml.jackson.databind.introspect.*;\nimport com.fasterxml.jackson.databind.ser.BeanPropertyWriter;\nimport com.fasterxml.jackson.databind.type.TypeFactory;\nimport com.fasterxml.jackson.datatype.guava.GuavaModule;\nimport org.junit.jupiter.api.Assertions;\n\n/**\n * Custom serializer provider for Jackson XML test case involving both mapping from/to\n * annotated classes, plus usage of {@link GuavaModule}.\n */\npublic class TestXmlSerializerProvider extends XmlSerializerProvider {\n\n     private final boolean failOnEmptyBeans;\n\n     /**\n      * Create serializer provider with basic configuration settings.\n      *\n      * @param mc Mapper to use\n      * @param typeFactory Type factory instance to use\n      * @param annotationIntrospector Annotation introspector to use\n      * @param failOnEmptyBeans Whether we should throw exception on encountering empty beans (i.e., ones without any properties defined), or just skip them.\n      */\n     protected TestXmlSerializerProvider(final MapperConfig mc,\n            final TypeFactory typeFactory,\n            final BeanDescription beanDesc,\n            final Class<?> mostSeniorRawType,\n            final String defaultTypingPrefix,\n            final boolean failOnEmptyBeans,\n            final boolean lenient) {\n         super(mc, typeFactory, beanDesc, mostSeniorRawType, defaultTypingPrefix, lenient);\n         this.failOnEmptyBeans = failOnEmptyBeans;\n     }\n\n     @Override\n     public BeanSerializerBase createSerializer(final SerializationConfig config,\n           final BeanDescription beanDesc, final JavaType type,\n           final JsonGenerator jgen, final SerializerProvider provder) throws JsonMappingException {\n          return new NoAnnotationBeanSerializer(config, beanDesc, type, jgen, provder);\n     }\n\n     public class NoAnnotationBeanSerializer extends BeanSerializerBase {\n\n         public NoAnnotationBeanSerializer(final SerializationConfig config,\n             final BeanDescription beanDesc, final JavaType viewType,\n             final JsonGenerator jgen, final SerializerProvider provider) throws JsonMappingException {\n             super(config, beanDesc, viewType, jgen, provider);\n         }\n\n         @Override\n         protected JavaType _getDefaultTyping(JavaType baseType, MapperConfig<?> config, BeanDescription beanDesc) throws JsonMappingException {\n             if (!config.isEnabled(MapperFeature.USE_STD_BEAN_NAMING)) {\n                 return super._getDefaultTyping(baseType, config, beanDesc);\n             }\n              return baseType;\n         }\n     }\n}",
