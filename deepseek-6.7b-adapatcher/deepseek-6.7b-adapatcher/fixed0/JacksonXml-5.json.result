  {
    "patch_code": "import com.fasterxml.jackson.annotation.JsonAutoDetect;\nimport com.fasterxml.jackson.databind.*;\nimport com.fasterxml.jackson.databind.cfg.HandlerInstantiator;\nimport com.fasterxml.jackson.databind.type.TypeFactory;\nimport com.fasterxml.jackson.module.afterburner.AfterburnerModule;\nimport com.fasterxml.jackson.module.mrbean.MrBeanModule;\nimport org.junit.Assert;\n\nimport java.util.Collection;\nimport java.util.Map;\nimport java.util.concurrent.ConcurrentHashMap;\n\n/**\n * Simple helper class for building JSON mappers with various features enabled or disabled.\n */\npublic class MapperBuilder {\n    private boolean useAnnotation = true;\n\n    /**\n     * Should Jackson data binding feature include JDK standard collection properties ?\n     */\n    private boolean includeJdkStandardCollections = true;\n\n    public MapperBuilder withAnnotationUsage(boolean b) {\n        this.useAnnotation = b;\n        return this;\n    }\n\n    public MapperBuilder withoutIncludeJdkStdColl() {\n        this.includeJdkStandardCollections = false;\n        return this;\n    }\n\n    /*\n    /**********************************************************\n    /* Main methods\n    /**********************************************************\n     */\n\n    public ObjectMapper buildObjectMapper() {\n        final ObjectMapper result = new ObjectMapper();\n        setupWithDefaults(result);\n        return result;\n    }\n\n    protected void setupWithDefaults(ObjectMapper mapper) {\n        if (!useAnnotation) {\n            mapper.disable(MapperFeature.USE_ANNOTATIONS);\n        }\n        mapper.registerModule(new AfterburnerModule());\n        mapper.registerModule(new MrBeanModule());\n        \n        \n        CollectionType types =  TypeFactory.defaultInstance().constructCollectionType(Collection.class, String.class);\n        Collection<String> testSet= mapper.convertValue(\"test\", types );\n        Assert.assertEquals( 1, testSet.size() );\n\n        // Additional setup goes here...\n        mapper.setVisibility(PropertyAccessor.ALL, JsonAutoDetect.Visibility.NONE);\n        mapper.setVisibility(PropertyAccessor.FIELD, JsonAutoDetect.Visibility.ANY);\n        if (!includeJdkStandardCollections) {\n            mapper.addMixIn(Collection.class, IgnoreJdkCollectionsMixin.class);\n            mapper.addMixIn(Map.class, IgnoreJdkCollectionsMixin.class);\n        }\n    }\n\n    public enum SerializationInclusion {\n        INCLUDE, EXCLUDE\n    }\n}",
