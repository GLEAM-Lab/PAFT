    "patch_code": "import com.fasterxml.jackson.annotation.JsonAutoDetect;\nimport com.fasterxml.jackson.databind.*;\nimport com.fasterxml.jackson.databind.cfg.ConfigFeature;\nimport com.fasterxml.jackson.databind.introspect.VisibilityChecker;\nimport com.fasterxml.jackson.databind.jsonFormatVisitors.JsonFormatVisitorWrapper;\nimport com.fasterxml.jackson.databind.node.ObjectNode;\nimport com.fasterxml.jackson.dataformat.xml.*;\nimport java.io.IOException;\nimport java.util.Map;\n\n// Repaired function from here: https://github.com/FasterXML/jackson-core/blob/master/src/main/java/com/fasterxml/jackson/databind/ser/std/NonTypedScalarSerializerBase.java#L36\nprivate static String getElementNameFromAnnotated(@Nullable Class<?> cls) {\n    if (cls == null) {\n        return null;\n    }\n    for (Class<?> c : CLASS_ORDER) {\n        if (!c.isAssignableFrom(cls)) {\n            continue;\n        }\n        JacksonXmlRootElement ann = findAnnotation(c, JacksonXmlRootElement.class);\n        if (ann != null) {\n            return ann.localName();\n        }\n        cls = c.getSuperclass();\n    }\n    return null;\n}",
