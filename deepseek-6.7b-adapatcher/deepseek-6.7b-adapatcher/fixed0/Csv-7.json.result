    "patch_code": "private Map<String, Integer> initializeHeader() throws IOException {\n        Map<String, Integer> hdrMap = null;\n        final String[] formatHeader = this.format.getHeader();\n        List<String> allHeaders = new ArrayList<>();\n        if (formatHeader != null) {\n            \n            if (formatHeader.length > 0) {\n                allHeaders.addAll(Arrays.asList(formatHeader));                \n                if (this.format.getSkipHeaderRecord()) {\n                    this.nextRecord();\n                }\n            }\n\n            while (true){\n                final CSVRecord nextRecord = this.nextRecord();\n                if (nextRecord == null) break;\n                for (String s : nextRecord.getValues()){\n                  if (!allHeaders.contains(s)){\n                      allHeaders.add(s);\n                  }  \n                }              \n            }\n        \n            reset();\n\n            // build the name to index mappings\n            hdrMap = new LinkedHashMap<String, Integer>();\n            for (int i = 0; i < allHeaders.size(); i++) {\n                hdrMap.put(allHeaders.get(i), Integer.valueOf(i));\n            }          \n\n        }\n        return hdrMap;\n    }",
