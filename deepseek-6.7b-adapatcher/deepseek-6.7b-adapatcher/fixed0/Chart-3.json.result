    "patch_code": "import org.jfree.chart.util.PublicCloneable;\n\npublic class TimeSeries extends AbstractTimeSeries implements PublicCloneable, Serializable {\n    \n    public TimeSeries createCopy(int start, int end) throws CloneNotSupportedException {\n        if (start < 0) {\n            throw new IllegalArgumentException(\"Requires start >= 0.\");\n        }\n        if (end < start) {\n            throw new IllegalArgumentException(\"Requires start <= end.\");\n        }\n        \n        TimeSeries copy = (TimeSeries) super.clone();\n        \n        copy.data = new ArrayList();\n        if (!this.data.isEmpty()) {\n            \n            final List list = new ArrayList(this.data);\n            Collections.sort(list, comparator());\n            List tempList = new ArrayList<>();\n            \n            for (Object obj : list) {\n                \n                TimeSeriesDataItem item = (TimeSeriesDataItem)obj;\n                if ((item.getDate().compareTo((java.util.Date)((Comparable) list.get(start)).getDate()) == 0) && \n                    (item.getDate().compareTo((java.util.Date)((Comparable) list.get(end)).getDate()) <= 0)) {\n                    \n                    TimeSeriesDataItem clone = (TimeSeriesDataItem) item.clone();\n                    tempList.add(clone);\n                }\n            }\n            \n            for (int i = 0; i<tempList.size();i++){\n                try {\n                    copy.add((TimeSeriesDataItem)tempList.get(i));\n                }\n                catch (SeriesException e) {\n                    e.printStackTrace();\n                }\n            }\n        }\n        \n        return copy;\n    }\n}",
