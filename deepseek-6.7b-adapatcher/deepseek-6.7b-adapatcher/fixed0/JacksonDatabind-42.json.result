  {
    "patch_code": "@JsonComponent\npublic class CustomLocaleSerializer extends JsonSerializer<Locale> {\n    \n    @Override\n    public Class<Locale> handledType() {\n        return Locale.class;\n    }\n    \n    @Override\n    public JsonNode serialize(Locale value, JsonGenerator jgen, SerializerProvider provider) throws IOException {\n        if (value != null && value.equals(Locale.ROOT)) {\n            jgen.writeString(\"\");\n            return jgen.getCodec().readTree(jgen);\n        }\n        \n        jgen.writeObject(value);\n        return jgen.getCodec().readTree(jgen);\n    }\n}",
