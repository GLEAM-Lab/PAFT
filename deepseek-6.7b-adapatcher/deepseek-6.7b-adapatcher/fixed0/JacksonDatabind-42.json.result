    "patch_code": "public class MyCustomResolver extends StdDelegatingContextResolver {\n\n    @Override\n    protected Object resolveByIdFromString(DeserializationContext ctxt, Class<?> idClass) throws JsonMappingException {\n        \n        if (idClass != null && Locale.class.equals(idClass)) {\n            return Locale.ROOT;\n        }\n        \n        return super.resolveByIdFromString(ctxt, idClass);\n    }\n    \n}",
