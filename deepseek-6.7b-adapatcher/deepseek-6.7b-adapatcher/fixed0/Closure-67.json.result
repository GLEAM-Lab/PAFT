    "patch_code": "private boolean isPrototypePropertyAssign(Node assign) {\n  Node n = assign.getFirstChild();\n  if (n != null && NodeUtil.isVarOrSimpleAssignLhs(n, assign)\n      && n.getType() == Token.GETPROP) {\n      \n      boolean isChainedProperty = n.getNumChildren() >= 3;\n      \n    if (isChainedProperty) {\n      Node child = n.getLastChild();\n\n      if (child.getType() == Token.STRING &&\n          child.getString().equals(\"prototype\")) {\n        return true;\n      }\n    } else {\n      String propName = ((GetPropExpr) n).getName();\n      FunctionDeclaration parentFuncDeclare = (FunctionDeclaration) n.getParent();\n        \n      for (int i = 0; i < parentFuncDeclare.getNumParams(); i++) {\n        if (parentFuncDeclare.getParam(i).getName().equals(propName)) {\n            return true;\n        }\n      }  \n          \n    \n  }\n\n  return false;\n}",
