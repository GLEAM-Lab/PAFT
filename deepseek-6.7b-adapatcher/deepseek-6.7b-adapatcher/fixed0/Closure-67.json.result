  {
    "patch_code": "private boolean isPrototypePropertyAssign(Node assign) {\n  Node n = assign.getFirstChild();\n  if (n != null && NodeUtil.isVarOrSimpleAssignLhs(n, assign)\n      && n.getType() == Token.GETPROP\n      ) {\n    // We want to exclude the assignment itself from the usage list\n    boolean isChainedProperty =\n        n.getFirstChild().getType() == Token.GETPROP;\n\n    if (isChainedProperty) {\n      Node child = n.getFirstChild().getFirstChild().getNext();\n\n      if (child.getType() == Token.STRING &&\n          child.getString().equals(\"prototype\") && n.getFirstChild().getFirstChild().getNext().getNext()==null) {\n        return true;\n      }\n    }else{\n        if(!isSuperCall(assign))return false;\n        if (!superMethodRefMap.containsKey(getFunctionName(n))) {\n            superMethodRefMap.put(getFunctionName(n), new HashSet<String>());\n        }\n        \n        superMethodRefMap.get(getFunctionName(n)).add(currentClosureId);\n      \n      return true;\n    }\n  }\n\n  return false;\n}\n\nboolean isSuperCall(Node node){\n     String text=node.toString();\n     int start=text.indexOf(\".super.\");\n     if(start>=0&&start+7==text.length())return true;\n     else return false;\n}\n\npublic static String getFunctionName(final Node methodExpr) {\n    final String propName = ((JsNameRef) methodExpr).getName();\n    JsVariable jsvariable = typeChecker.resolveVariable(methodExpr);\n    if(propName.isEmpty()||jsvariable==null)throw new RuntimeException(\"error\");\n  \n  if(typeChecker.lookupIdentifier(propName)!=null&&typeChecker.lookupIdentifier(propName).kind==Kind.GLOBAL_VAR){\n      if(typeChecker.lookupIdentifier(propName).scope==Scope.getCurrentScope())return propName;\n  }\n\n    final Node targetExpression = ((JsGetProp) methodExpr).getObject();\n    if (targetExpression instanceof JsNameRef && typeChecker.lookupIdentifier(((JsNameRef)targetExpression).getName()).scope==Scope.getCurrentScope()&&typeChecker.lookupIdentifier(((JsNameRef)targetExpression).getName()).kind==Kind.VAR)\n      return typeChecker.lookupIdentifier(((JsNameRef)targetExpression).getName()).name;\n\n    return propName;\n}",
