    "patch_code": "private boolean isPro prototype propertyAssign(Node node) {\n  int type = node.getType();\n  if (type == Token.get property assignments\n      || type == Token.get property assignments in brackets\n      ) {\n    node = node.getfirst child();\n    while (!node.is end of statement()) {\n      type = node.get type();\n      if (type == Token. GETPROP) {\n        String name = node.get string();\n        if (!name.isEmpty()) {\n          return name.startsWith(\" prototype\");\n        }\n      }\n      node = node.get next sibling();\n    }\n  }\n\n  return false;\n}",
