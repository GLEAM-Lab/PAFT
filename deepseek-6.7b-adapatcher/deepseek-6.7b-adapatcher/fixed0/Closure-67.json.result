  {
    "patch_code": "private boolean isPrototypePropertyAssign(Node assign) {\n  Node n = assign.getFirstChild();\n  if (n != null && NodeUtil.isVarOrSimpleAssignLhs(n, assign)\n      && n.getType() == Token.GETPROP\n      ) {\n    // We want to exclude the assignment itself from the usage list\n    boolean isChainedProperty =\n        n.getFirstChild().getType() == Token.GETPROP;\n\n    if (isChainedProperty) {\n      Node grandParentOfLeftGetPropNode = n.getFirstChild().getFirstChild().getFirstChild().getParent().getParent();\n      if (grandParentOfLeftGetPropNode.getType() == Token.VAR || grandParentOfLeftGetPropNode.getType() == Token.NAME){\n         return true;\n      }\n      \n      Node child = n.getFirstChild().getFirstChild().getNext();\n\n      if (child.getType() == Token.STRING &&\n          child.getString().equals(\"prototype\")&& grandParentOfLeftGetPropNode.getType()==Token.MEMBER && ((MemberExpr)grandParentOfLeftGetPropNode).object.type == Token.GETPROP) {\n        return true;\n      }\n    } else{\n        if((assign.getType() == Token.ASSIGN)){\n            Node child = n.getFirstChild().getNext();\n           if (child.getType() == Token.STRING &&\n             child.getString().equals(\"prototype\")) {\n               return true;\n           }  \n         }\n     }\n  }\n\n  return false;\n}",
