    "patch_code": "private boolean isPro prototype property assgn(Node node) {\n  if (!node.has children()) return false;\n  node n = node.get first child();\n  if (n.get type() == Token. GETPROP) {\n    n n = n.get first child();\n    if (n.get type() == Token. GETPROP) {\n      String name = n.getString();\n      if (name. length == 5 && name. charAt(0) == name. charAt(4) && name. charAt(1) == \" prototyp\" . charAt(0) && name. charAt(2) == \" property\" . charAt(0)) {\n        return true;\n      }\n    }\n  }\n  return false;\n}",
