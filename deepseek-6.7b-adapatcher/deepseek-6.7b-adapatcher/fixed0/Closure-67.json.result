    "patch_code": "public int compareTo(Node node) {\n  System.out.println (\"Comparing \" + this);\n  if (!check instanceof GetPropNode) {\n     return -1 * check;\n   } else if (!node instanceof GetPropNode) {\n     return (GetPropNode) check).compareTo((GetPropNode) node);\n  }\n\n  String name = ((GetPropNode) node).getName();\n  switch (name) {\n  case \"getter\":\n    name = ((GetPropNode) check).getName();\n    break;\n  default:\n    break;\n}\nreturn name.compareTo(((GetPropNode) check).getName());\n}",
