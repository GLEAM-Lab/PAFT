    "patch_code": "private boolean isOneExactlyFunctionOrDo(Node n) {\n     if (!((isBlockChild(n)) && !isEmptyStatement(n))) {\n         return false;\n    }\n       if (n.children[0] instanceof Label) {\n           return ((Label) n.children[0]).labeledStatements.size() > 0;\n     } else if (n.children.length == 1) {\n          Node child = n.children[0];\n          if (child instanceof Block) {\n               for (int i = 0; i < child.children.length; i++) {\n                   if (isBlockWithMoreThanOneNonEmptyStatement(child.children[i])) {\n                        return false;\n                  }\n             }\n         } else if (child instanceof FunctionLiteral) {\n              return true;\n        } else if (child instanceof DoWhileStatement) {\n              return true;\n        }\n   }\n    return false;\n }",
