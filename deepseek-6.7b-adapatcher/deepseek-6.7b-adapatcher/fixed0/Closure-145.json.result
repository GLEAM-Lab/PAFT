    "patch_code": "private static int isOneExactlyFunctionOrDo(Node n) {\n      // For labels with block children, we need to ensure that a\n      // labeled FUNCTION or DO isn't generated when extraneous BLOCKs \n      // are skipped. \n      //\n      // This is achieved by counting the number of statements in the block, which\n      // effectively disables generation for blocks that contain only a single\n      // statement.\n      return (n.getType() != Token.BLOCK && (n.getNumChildren() == 0 || \n              (!isLoopOrSwitchLabel(n) && isOneExactlyFunctionOrDo(n.getChild(0)))));\n}",
