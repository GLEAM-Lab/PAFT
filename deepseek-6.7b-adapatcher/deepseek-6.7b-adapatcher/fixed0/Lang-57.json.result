    "patch_code": "import java.util.*; \n\npublic class LocaleUtils { \n    private static Set<Locale> cAvailableLocaleSet = new HashSet<Locale>();\n    \n    public static void main(String[] args){\n        Locale l1 = new Locale(\"en\",\"US\");\n        cAvailableLocaleSet.add(l1);\n        \n        System.out.println(isAvailableLocale(new Locale(\"en\",\"US\"))); //true \n        System.out.println(isAvailableLocale(new Locale(\"it\",\"IT\"))); //false\n    }\n\n    public synchronized static void availableLocaleSet(){ \n        List languages = Arrays.asList(\"sq\", \"sr\", \"_BA\", \"af\", \"ak\", \"_BE\", \"bg\", \"_BR\", \"cs\", \"_CZ\", \"da\", \"_DE\", \"_DK\", \"_EE\", \"el\", \"eo\", \"_ES\", \"_FI\", \"fr\", \"_FR\", \"hr\", \"_HU\", \"hu\", \"_IE\", \"it\", \"_IT\", \"ja\", \"_JP\", \"ko\", \"_KR\", \"lt\", \"_LT\", \"mk\", \"_MK\", \"nb\", \"_NO\", \"nn\", \"_NL\", \"pl\", \"_PL\", \"pt\", \"_PT\", \"ro\", \"_RO\", \"ru\", \"_RU\", \"_SE\", \"sk\", \"_SI\", \"sl\", \"_SL\", \"sv\", \"_SV\", \"tr\", \"_TR\", \"_UA\", \"zh\", \"_CN\", \"in\", \"_ID\", \"ms\", \"_MY\", \"fa\", \"_IR\", \"uk\", \"_UK\", \"hy\", \"_AM\", \"az\", \"_AZ\", \"eu\", \"_ES\", \"bn\", \"_BD\", \"gl\", \"_ES\", \"mr\", \"_IN\", \"ta\", \"_LK\", \"te\", \"_IN\", \"kn\", \"_IN\", \"lo\", \"_LA\", \"ml\", \"_IN\", \"th\", \"_TH\", \"bo\", \"_CN\", \"my\", \"_MM\", \"km\", \"_KH\", \"iw\", \"_IL\", \"hi\", \"_IN\", \"as\", \"_IN\", \"ne\", \"_NP\", \"or\", \"_IN\", \"pa\", \"_AFG\", \"si\", \"_LK\", \"so\", \"_SO\", \"es\", \"_ES\", \"sw\", \"_TZ\", \"tk\", \"_TM\", \"ur\", \"_PK\", \"fil\", \"_PH\", \"yi\", \"_IL\", \"ca\", \"_ES\"); \n        for (Iterator it=languages.iterator(); it.hasNext();){ \n            String languageCode =  it.next().toString(); \n            cAvailableLocaleSet.add(new Locale(languageCode)); \n        } \n    } \n\n    public static boolean isAvailableLocale(Locale locale){ \n        if (cAvailableLocaleSet == null){\n            availableLocaleSet();\n        }\n        return cAvailableLocaleSet.contains(locale);\n    } \n}",
