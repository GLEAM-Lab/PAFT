    "patch_code": "private static Set<Locale> cAvailableLocaleSet;\nstatic {\n        try {\n            final ArrayList<Object> tmp = new ArrayList<>();\n            \n            URL urlImports = LocaleUtils.class.getResource(\"/org/apache/commons/lang3/LocaleUtils.xml\");\n            File importsFile = null != urlImports ? new File(urlImports.toURI()) : null;\n            SAXSaxParserFactory saxParserFactory = new SAXSaxParserFactory(); \n            XMLReader xmlreader = saxParserFactory.newSAXParser().getXMLReader();\n            XmlImportHandler handler = new XmlImportHandler((List<String>) tmp);\n            xmlreader.setContentHandler(handler);\n            xmlreader.parse(new InputSource(new FileInputStream(importsFile)));\n            \n            String[] availableLocalesArray  = (String[]) tmp.toArray(new String[tmp.size()]);\n          \n            cAvailableLocaleSet = new HashSet<Locale>(availableLocalesArray.length);\n            for (int i = 0; i < availableLocalesArray.length; ++i){\n                cAvailableLocaleSet.add(Locale.forLanguageTag(availableLocalesArray[i]));\n            }\n            \n        } catch (Throwable e) {\n          Logger.getLogger(\"org.apache.commons.lang\").log(Level.SEVERE,\"Unexpected exception reading internal data file\",e);\n      }\n    \n  }\n  \n public static boolean isAvailableLocale(Locale locale) throws Exception{\n    if(cAvailableLocaleSet == null || cAvailableLocaleSet.isEmpty() ){\n       availableLocaleSet();\n    }\n        return cAvailableLocaleSet.contains(locale);\n    }\n private static void availableLocaleSet() throws Exception {\n         try {\n            ClassLoader classLoader = Thread.currentThread().getContextClassLoader();\n            Properties properties = new Properties();\n            properties.load(classLoader.getResourceAsStream(\"org/apache/commons/lang3/LocaleCountryCodeData.properties\"));\n            Iterator<Map.Entry<Object, Object>> iterator = properties.entrySet().iterator();\n            while (iterator.hasNext()) {\n                Map.Entry<Object, Object> entry = iterator.next();\n                if ((Boolean) entry.getValue()) {\n                    cAvailableLocaleSet.add(new Locale((String) entry.getKey()));\n                }\n            }\n        } finally {}\n    }",
