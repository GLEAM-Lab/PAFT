    "patch_code": "private static final Set<Locale> cAvailableLocaleSet = new HashSet<Locale>(); \n\nstatic {\n    cAvailableLocaleSet.add(new Locale(\"\"));\n    cAvailableLocaleSet.add(new Locale(\"en\"));\n    cAvailableLocaleSet.add(new Locale(\"zh\"));\n}\n\npublic static synchronized void availableLocaleSet(){\n    cAvailableLocaleSet.clear();\n    String[] langs = Locale.getAvailableLocales().toString().split(\",\");       \n      for (int i = 0; i < langs.length; i++){               \n          cAvailableLocaleSet.add(new Locale(langs[i]));          \n      } \n}\n\npublic static boolean isAvailableLocale(Locale locale) {\n       if(cAvailableLocaleSet == null || cAvailableLocaleSet.size() == 0){           \n            availableLocaleSet();\n       }\n        \n    return cAvailableLocaleSet.contains(locale);\n}",
