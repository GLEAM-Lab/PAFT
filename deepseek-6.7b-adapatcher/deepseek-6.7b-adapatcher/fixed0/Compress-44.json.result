    "patch_code": "import java.io.*;\nimport org.apache.commons.compress.utils.ChecksumCalculatingInputStream;\n\npublic class Main{\n    \n    static int calculateChecksum (String filename){\n        \n        try{\n            \n            File file = new File(filename);\n            InputStream inputFile = new FileInputStream(file);\n            \n            byte [] b = new byte[(int) file.length()];\n            \n            while (inputFile.read() != -1 ){\n                for (int i = 0 ; i < b.length ; i++){\n                    \n                    inputFile.read();\n                    \n                }\n                \n            }\n            \n            inputFile.close();\n            \n            return Math.abs((b[7]<<24 | (b[6] & 0xFF) << 16 | (b[5] & 0xFF) << 8 | (b[4] & 0xFF)));\n             \n            \n        }catch(IOException e){\n            e.printStackTrace();\n        }return 0;\n        \n         \n     }\n     \n   public static void main(String[] args) throws Exception {\n       System.out.println(\"The calculated checksum is : \"+calculateChecksum(\"C:\\\\Users\\\\dell\\\\Desktop\\\\test.txt\"));\n   }\n    \n}",
    "patch_status": "UNCOMPILABLE",
