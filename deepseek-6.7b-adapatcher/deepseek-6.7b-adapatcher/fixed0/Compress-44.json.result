    "patch_code": "import java.util.zip.Checksum;\nimport java.io.InputStream;\n\npublic class ChecksumCalculatingInputStream extends InputStream{\n    \n    private final Checksum checksum;\n    private final InputStream in;\n    \n    public ChecksumCalculatingInputStream(final Checksum checksum, final InputStream in){\n        \n        if(checksum == null || in == null) throw new IllegalArgumentException(\"Argument can't be null\");\n        this.checksum=checksum;\n        this.in=in;\n        \n    }\n    \n    \n    \n   public long getValue(){\n       return this.checksum.getValue();\n    }\n    \n    \n    \n    @Override\n    public int read() throws java.io.IOException {\n        \n        \n        int data  =this.in.read();\n            \n        if(data != -1 ){\n            this.checksum.update(data);\n            \n        }else{\n                this.close();\n                \n        }\n          return data;\n     \n    }\n}",
