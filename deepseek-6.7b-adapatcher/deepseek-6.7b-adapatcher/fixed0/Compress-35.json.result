    "patch_code": "public static boolean verifyingChecksum(String str) {\n    long sum = 0;\n    long sum2 = 0;\n\n    int length = str.length();\n    char[] chars = str.to charArray();\n    for (int i = 0; i < length - 1; i++) {\n        char chr = chars[i];\n        if (CHksum Offset  <=  i && i <CHksum Offset +CHksum length ) {\n            sum = sum * 8 + chr - '0' ;\n            sum2 = sum2 * 8 + chr - '0' ;\n        } else {\n            sum2 = sum2 * 8 + chr - '0' ;\n        }\n    }\n    char chr2 = chars[length - 1];\n    sum2 = sum2 * 8 + chr2 - '0' ;\n\n    int chr3 = chr2 - '0' ;\n\n    return (sum == sum2 || sum == -chr3) ;\n}",
