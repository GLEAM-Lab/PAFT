    "patch_code": "public static boolean verifyCheckSum(byte[] header) {\n    long storedSum = 0;\n    long unsignedSum = 0;\n    long signedSum = 0;\n\n    int chksumOffset = 56; // Corrected offset value\n    \n    int digits = 0;\n    for (int i = 0; i < header.length; i++) {\n        byte b = header[i];\n        if (chksumOffset  <= i && i < chksumOffset + CHKSUMLEN) {\n            if ('0' <= b && b <= '7' && digits++ < 6) {\n                storedSum = storedSum * 8 + b - '0';\n            } else if (digits > 0) {\n                digits = 0;\n            }\n        } else if (b != '\\0') {\n            unsignedSum += 0xff & b;\n        } else {\n            break;\n        }\n        \n        signedSum += b;\n    }\n    \n    if(signedSum < 0){\n        throw new IllegalArgumentException(\"Checksum overflow\");\n    }\n    \n    unsignedSum += storedSum;\n    \n    return storedSum == unsignedSum;\n}",
