    "patch_code": "public static boolean verifyCheckSum(byte[] header) {\n    long storedSum = 0;\n    long unsignedSum = 0;\n    long signedSum = 0;\n\n    int digits = 0;\n    for (int i = 0; i < header.length; i++) {\n        byte b = header[i];\n        if (b == ' ') continue;\n        if (CHKSUM_OFFSET  + CHKSUMLEN > i && i >= CHKSUM_OFFSET && digits < 6 && '0' <= b && b <= '7') {\n            storedSum = storedSum * 8 + b - '0';\n            digits++;\n        } else break;\n        \n        unsignedSum += 0xff & b;\n        signedSum += b;\n    }\n    \n    return storedSum == unsignedSum || storedSum == signedSum;\n}",
