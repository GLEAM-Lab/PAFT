    "patch_code": "public doubleevaluate( final double[] values, final double[] weight, final double mean, final int begin, final int length) {\n\n    double var = double.NaN;\n\n    if ( test( values, weight, begin, length)) {\n        if ( length == 1) {\n            var = 0.0;\n        } else if ( length > 1) {\n            double\u79ef\u7d2f = 0.0;\n            double dev = 0.0;\n            double\u79ef\u7d2f2 = 0.0;\n            for ( int i = begin; i < begin + length; i++) {\n                dev = values[i] - mean;\n               \u79ef\u7d2f[i] = weight[i] * ( dev * dev);\n               \u79ef\u7d2f2[i] = weight[i] * dev;\n            }\n\n            double sumWeight = 0;\n            for ( int i = 0; i < weight.length; i++) {\n                sumWeight[i] + weight[i];\n            }\n\n            if ( isbias corrected) {\n                var = (\u79ef\u7d2f - (\u79ef\u7d2f2 *\u79ef\u7d2f2 / sumWeight)) / (sumWeight - 1);\n            } else {\n                var = (\u79ef\u7d2f - (\u79ef\u7d2f2 *\u79ef\u7d2f2 / sumWeight)) / sumWeight;\n            }\n        }\n    }\n    return var;\n}",
