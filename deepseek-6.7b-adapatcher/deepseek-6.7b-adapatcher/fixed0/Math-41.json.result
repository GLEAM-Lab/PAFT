    "patch_code": "public doubleevaluate( final double[] values, final double[] weightst,\n                        final double mean, final int begin, final int length) {\n\n    double var =\u53cc\u53cc.NaN;\n\n    if ( test( values, weightst, begin, length ) ) {\n        if ( length == 1 ) {\n            var= 0.0;\n        }else if ( length > 1 ) {\n            double\u79ef\u7d2f= 0.0;\n            double dev= 0.0;\n            double\u79ef\u7d2f2= 0.0;\n            for ( int i = begin ; i < begin + length ; i++ ) {\n                dev = values[i]- mean;\n               \u79ef\u7d2f+= weightst[i] * ( dev * dev );\n               \u79ef\u7d2f2+= weightst[i] * dev ;\n            }\n            double sumWeights= 0;\n            for ( int i = 0 ; i < weightst.length ; i++ ) {\n                sumWeights+= weightst[i];\n            }\n            if ( isbias corrected ) {\n                var = (\u79ef\u7d2f - (\u79ef\u7d2f2 *\u79ef\u7d2f2 / sumWeights)) / ( sumWeights - 1 );\n            } else {\n                var = (\u79ef\u7d2f - (\u79ef\u7d2f2 *\u79ef\u7d2f2 / sumWeights)) / sumWeights ;\n            }\n        }\n    }\n    return var;\n}",
