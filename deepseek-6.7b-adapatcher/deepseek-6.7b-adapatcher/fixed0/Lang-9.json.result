    "patch_code": "public class Main {\n    public static void main(String args[]){\n        int year = Calendar.getInstance().get(Calendar.YEAR);\n        \n        // 1st test with day in month quoted\n        try {\n            System.out.println(dateFromPatternAndStr(\"yyyy/dd/MM\", year + \"/20/12\"));            \n        } catch (ParseException e) {\n            e.printStackTrace();\n        }\n        \n        // 2nd test with hour in 24h format quoted\n        try {\n            System.out.println(dateFromPatternAndStr(\"dd MM yyyy HH\", \"20 12 \" + year + \" 16\"));            \n        } catch (ParseException e) {\n            e.printStackTrace();\n        }\n        \n        // 3rd test with year and two digit months quotation\n        try {\n            System.out.println(dateFromPatternAndStr(\"yy ''yy''\", \"\"+year+\" \"+year));            \n        } catch (ParseException e) {\n            e.printStackTrace();\n        }\n        \n        // 4th test without quotations\n        try {\n            System.out.println(dateFromPatternAndStr(\"DDD\", Integer.toString((int)Math.floor((System.currentTimeMillis()-new GregorianCalendar(year, 0, 1).getTimeInMillis())/(86400*1000))) ));            \n        } catch (ParseException e) {\n            e.printStackTrace();\n        }\n    }\n    \n    private static Date dateFromPatternAndStr(String pttrn, String str) throws ParseException{\n        return org.apache.commons.lang3.time.FastDateParser.parse(pttrn,str);\n    }\n}",
