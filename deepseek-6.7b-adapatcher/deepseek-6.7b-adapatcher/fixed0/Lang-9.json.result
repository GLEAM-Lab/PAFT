    "patch_code": "private boolean matchUnterminatedQuote() {\n    if (!hasMoreCharacters() || quoteCharacter == '\\0') {\n      return false;\n    }\n    \n    int ix = index;\n    do {\n      ++index;\n    } while (!isFinished && buffer[ix] != quoteCharacter);\n    \n    if (quoteCharacter != 0) {\n      quoteCharacter = 0;\n    }\n    \n    --index; // because we need to check last character also\n    \n    return true;\n  }\n\n  private static final class RegexStrategy extends Strategy {\n    public static final RegexStrategy INSTANCE = new RegexStrategy();\n\n    @Override\n    protected ParseHandler handlerFor(FastDateParser parser, char c) throws ParseException {\n      if (c == quoteCharacter) {\n        if (!parser.matchUnterminatedQuote()) {\n          throw new ParseException(\"Unterminated string literal\", -1);\n        } else {\n          // don't consume character, so add it back in postprocessing phase\n          return super.handlerFor(parser, c);\n        }\n      }\n      return super.handlerFor(parser, c);\n    }\n\n    @Override\n    public boolean addRegex(FastDateParser parser, StringBuilder buf) {\n      assert !\"\\\\\".equals(formatField);\n      buf.append('(');\n      buf.append(Pattern.quote(formatField));\n      buf.append(')');\n      return true;\n    }\n  }",
