    "patch_code": "public class Test {\n    public static void main(String[] args) throws ParseException {\n        FastDateParser parser1= new FastDateParser('d', \"20\", \"dd\");\n        System.out.println(parser1.parse().getDayOfMonth());\n        \n        FastDateParser parser2= new FastDateParser('d', \"2\", \"dd\");\n        System.out.println(parser2.parse().getDayOfMonth());\n        \n        FastDateParser parser3= new FastDateParser('d', \"20abc\", \"dd\");\n        System.out.println(parser3.parse().getDayOfMonth());\n        \n        FastDateParser parser4= new FastDateParser('d', \"abcd\", \"dd\");\n        System.out.println(parser4.parse().getDayOfMonth());\n        \n        FastDateParser parser5= new FastDateParser('d', \"\", \"dd\");\n        System.out.println(parser5.parse().getDayOfMonth());\n        \n        FastDateParser parser6= new FastDateParser('d', \"0\", \"dd\");\n        System.out.println(parser6.parse().getDayOfMonth());\n        \n        FastDateParser parser7= new FastDateParser('M', \"8\", \"MM\");\n        System.out.println(parser7.parse().getMonthOfYear());\n        \n        FastDateParser parser8= new FastDateParser('M', \"09\", \"MM\");\n        System.out.println(parser8.parse().getMonthOfYear());\n        \n        FastDateParser parser9= new FastDateParser('y', \"2010\", \"yyyy\");\n        System.out.println(parser9.parse().getYear());\n        \n        FastDateParser parser10= new FastDateParser('y', \"9\", \"yyyy\");\n        System.out.println(parser10.parse().getYear());\n    }\n    \n    private static class FastDateParser extends org.apache.commons.lang3.time.FastDateParser {\n        public FastDateParser(char fieldId, String value, String... formats) throws ParseException {\n            super((fieldId == 'y') ? Integer.valueOf(value).intValue() : Long.valueOf(value), TimeZone.getDefault(), Locale.US, formats);\n        }\n\n        @Override\n        protected Object parseSpecial(FieldAwareDateTimeFormatter formatter) throws ParseException {\n            int beginIndex= formatter.index();\n            FormatUtil.ParseResult result= formatter.parseFrom(formatter.buffer(), beginIndex, 1);\n            try {\n                return getFieldBasedOnID(result.id()).parse(result.text());\n            } catch (IllegalArgumentException ex) {\n                throw new ParseException(formatter.buffer(), beginIndex);\n            }\n        }\n    }\n}",
