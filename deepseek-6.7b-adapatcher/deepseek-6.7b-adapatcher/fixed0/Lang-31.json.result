    "patch_code": "public static boolean containsAny( Char sequence, char... searchChars ) {\n\tif (isEmpty( sequence ) || searchChars.length == 0) {\n        return false;\n    }\n\n    int sequence length = sequence.length();\n    int search length = searchchars.length;\n\n    for (int i = 0; i < sequence length; i++) {\n        char ch = sequence.charAt(i);\n        for (int j = 0; j < search length; j++) {\n            if (search chars[j] == ch) {\n                return true;\n            }\n        }\n    }\n    return false;\n}",
