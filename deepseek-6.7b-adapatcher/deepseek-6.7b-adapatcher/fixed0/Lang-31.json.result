    "patch_code": "public static boolean containsAny(CharSequence cs, CharSequence searchSeq) {\n        if (isEmpty(cs) || isEmpty(searchSeq)){\n            return false;\n        }\n        int csLen = cs.length(), ssLen = searchSeq.length(), idxInSearchSeq;\n        for (int i=0 ; i < csLen ; ){\n            int cp = Character.codePointAt(cs, i);\n            // High surrogate, could be followed by low surrogate\n            if ((cp & 0xFFFF) - 0xD800 < 564){\n                int hi = cp - 0xD800;\n                int lo = Character.codePointAt(cs, ++i) - 0xDC00;\n                if (hi < 0 || hi > 1023){\n                    break;\n                }\n                if (lo < 0 || lo > 1023){\n                    continue;\n                }\n                int suppCharIndex = hi * 1024 + lo + 0x10000;\n                idxInSearchSeq = 0;\n                while (idxInSearchSeq < ssLen){\n                    int codePointInSearchSeq = searchSeq.charAt(idxInSearchSeq++);\n                    if (suppCharIndex == codePointInSearchSeq){\n                        return true;\n                    }else if(suppCharIndex > codePointInSearchSeq && idxInSearchSeq != ssLen){\n                        codePointInSearchSeq += searchSeq.charAt(idxInSearchSeq++);\n                        continue;\n                    }\n                    break;\n                }\n            }else{\n               idxInSearchSeq= 0;\n               while (idxInSearchSeq<ssLen){\n                  if(cp==searchSeq.charAt(idxInSearchSeq++)){\n                      return true;\n                   }\n              }\n           }\n            \n            i += Character.charCount(cp);\n       }  \n    \n      return false;\n  }",
