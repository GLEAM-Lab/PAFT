    "patch_code": "import java.util.*;\n\npublic class Main\n{\n    public static void main(String args[])\n    {\n        System.out.println(\"The corrected program output:\");\n        \n        private static final String CharU20000 = \"\\uD840\\uDC00\";\n\t    private static final String CharU20001 = \"\\uD840\\uDC01\";\n    \n        assertEquals(false, containsAnyIgnoreOrder(Arrays.asList(CharU20000), Arrays.asList(CharU20001)));\n        assertEquals(false, containsAnyIgnoreOrder(Arrays.asList(CharU20001), Arrays.asList(CharU20000)));\n      \n        assertEquals(true, containsAnyIgnoreOrder(Arrays.asList(CharU20000, CharU20001), Arrays.asList(CharU20000)));\n        assertEquals(true, containsAnyIgnoreOrder(Arrays.asList(CharU20000, CharU20001), Arrays.asList(CharU20001)));\n        assertEquals(true, containsAnyIgnoreOrder(Arrays.asList(CharU20000, CharU20000), Arrays.asList(CharU20000)));\n        assertEquals(false, containsAnyIgnoreOrder(Arrays.asList(CharU20000), Arrays.asList(CharU20000)));\n    }\n    \n  \tpublic static boolean containsAnyIgnoreOrder(Collection<String> collection, Collection<String> subCollection){\n        Set<String> set = new HashSet<>(collection);\n        for(String str : subCollection){\n            if(set.contains(str)){\n                return true;\n            }\n        }\n        return false;\n    }\n}",
