    "patch_code": "import java.util.*;\nimport org.apache.commons.lang3.ArrayUtils;\nimport org.apache.commons.lang3.StringUtils;\nimport com.google.common.base.Preconditions;\n\n@SuppressWarnings(\"deprecation\")\nclass Main {\n    public static void main(String args[]) {\n        // Define Unicode characters\n        char[] searchChars={'\\uD840', '\\uDC00'};\n        char[] searchChars2={'\\uD840', '\\uDC01'};\n        \n        System.out.println(fixedContainsAny(\"\\uD840\\uDC00\", searchChars));\n        System.out.println(fixedContainsAny(\"\\uD840\\uDC01\", searchChars));\n        System.out.println(fixedContainsAny(\"\\uD840\\uDC01\", searchChars2));\n        System.out.println(fixedContainsAny(\"\\uD840\\uDC00\", searchChars2));\n   }\n    \n   private static boolean fixedContainsAny(CharSequence cs, char[] searchChars) {\n       if(Preconditions.checkNotNull(cs).toString().equals(\"\")) return false;\n       \n      for (int i = 0; i < cs.length(); i++){\n          if (Arrays.asList(searchChars).contains(cs.charAt(i))) return true;\n      }\n      return false;\n   }\n}",
