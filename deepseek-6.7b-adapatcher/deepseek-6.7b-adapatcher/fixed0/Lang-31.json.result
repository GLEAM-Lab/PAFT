    "patch_code": "import java.text.CharacterIterator;\nimport java.text.StringCharacterIterator;\n\npublic class Main {\n    public static void main(String[] args) {\n        System.out.println(contains(\"\\uD840\\uDC00\", \"\\uD840\")); // Expected output: True\n        System.out.println(contains(\"\\uD840\\uDC01\", \"\\uD840\")); // Expected output: False\n    }\n    \n    public static boolean contains(CharSequence cs, CharSequence searchChars){\n            if (isEmpty(cs) || isEmpty(searchChars)){\n                return false;\n            }\n            \n            int csLength= cs.length();\n            int searchLength=searchChars.length();\n            \n            for (int i= 0 ; i< csLength; i ++){\n                char cCs = cs.charAt(i);\n                \n                if (cCs >= 0xD800 && cCs <= 0xDBFF){\n                    if (i + 1 >= csLength){\n                        break;\n                    }\n                    \n                    char cNextCs = cs.charAt(i+1);\n                    \n                    if (cNextCs>= 0xDC00 && cNextCs <=0xDFFF){\n                        String combined= new StringBuilder().append((char)cCs).append((char)cNextCs).toString();\n                        \n                        if (combined.equals(searchChars.toString())){\n                            return true;\n                        }\n                    }\n                }else {\n                    if (searchChars.toString().contains(String.valueOf(cCs))) {\n                        return true;\n                    }\n                }\n            }\n        \n          return false;\n    }\n      private static boolean isEmpty(final CharSequence s) {\n        return s == null || s.length() == 0;\n    }\n}",
