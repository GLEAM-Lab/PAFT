    "patch_code": "import org.apache.commons.lang3.text.StrTokenizer;\nimport java.util.*;\n\npublic class Main{\n    public static void main(String[] args){\n        System.out.println(\"Repaired Function Output\");\n        \n        String str = \"a\\uD840\\uDC00b\\uD840\\uDC01c\";\n        String [] tokens = {\"\\uD840\\uDC00\",\"\\uD840\\uDC01\"};\n        StrTokenizer tok = new StrTokenizer(str);\n        ArrayList<String> list = new ArrayList<String>();\n        while(tok.hasNext()){\n            list.add(tok.nextToken());\n        }\n        Iterator itr = list.iterator();\n        while(itr.hasNext()) {\n           String s=(String)itr.next(); \n             if(Arrays.asList(tokens).contains(s)){\n                System.out.println(\"Found :\"+s);\n            }else{\n                 System.out.println(\"Not Found:\"+s);\n            }\n    \n        }\n     \n        \n      \n    }\n}",
