    "patch_code": "int nextIndexOf(CharSequence seq) {\n    // handles scanning for surrogates\n    char startChar = seq.charAt(0);\n    boolean trailingSurrogateFound = false;\n    for (int offset = pos; offset < length; offset++) {\n        if (!trailingSurrogateFound){\n             if(input[offset] > Character.MAX_VALUE){\n                 offset++;\n                 trailingSurrogateFound = true;\n             }\n        } else {\n            trailingSurrogateFound = false;\n        }\n        \n        // scan to first instance of startchar:\n        if (input[offset]!= startChar ){\n            do {\n                    offset++;\n            }while ((pos <= offset)&& (startChar != input[offset]));\n            \n        }\n        \n        \n        \n        int i = offset + 1;\n        int last = i + seq.length() - 1;\n        if (offset < length) {\n            \n            for (int j = 1; i < last && seq.charAt(j) == input[i]; i++, j++);\n            if (i == last) // found full sequence\n                return offset - pos;\n        }\n    }\n    return -1;\n}",
