    "patch_code": "public int nextIndexOf(CharSequence seq){\n    char startChar = seq.charAt(0);\n    int lastIdx = length - seq.length() + 1;\n    outerloop : for(int offset = pos; offset < lastIdx ; offset ++ ){\n        int currentOffset = offset;\n        innerloop : while(true){\n            if((startChar == input [currentOffset])){\n                \n                boolean match = true;\n                int indexInSeq = 1;\n                while (indexInSeq<seq.length()){\n                    if ((input [currentOffset+1]!= seq.charAt(indexInSeq))){\n                        match = false;\n                        break innerloop;\n                    }else {\n                        indexInSeq++;\n                        currentOffset++;\n                    }\n                }\n                if (match){\n                    continue outerloop;\n                }\n            }\n            currentOffset ++;\n            \n        }\n        \n        return offset -pos;\n    }\n    return -1;\n    \n}",
