    "patch_code": "int nextIndexOf( Char sequence ) {\n    char start char = sequence.charAt(0);\n    char end char = sequence.charAt(1);\n    for (int pos = this.pos; pos < length; pos++) {\n        char c = input[pos];\n        if (c == start char) {\n            int endpos = pos + 2;\n            while (endpos < length && input[endpos - 2] != end char || input[endpos - 1] != end char) {\n                endpos++;\n            }\n            if(endpos < length && endpos > pos + 2) {\n                return pos;\n            }\n        }\n    }\n    return -1;\n}",
