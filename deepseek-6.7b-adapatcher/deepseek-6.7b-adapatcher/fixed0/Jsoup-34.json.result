    "patch_code": "public int nextIndexOf(CharSequence seq){\n        char startChar = seq.charAt(0);\n        boolean flag = false;\n        int index=pos;\n         while (index<input.length&&(!flag)){\n             if (startChar==input[index]){\n                 if (seq.toString().equals((new String(Arrays.copyOfRange(input,index,Math.min(index+seq.length(),input.length)))).trim())){\n                     flag = true;\n                     \n                 }\n             }\n             index++;\n             \n         }\n         if (!flag){\n             return -1;\n         } else{\n             return index-pos;\n         }\n     }",
