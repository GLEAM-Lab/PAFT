    "patch_code": "import cern.jet.random.normal.BoxMullerGaussian;\n\npublic double cumulativeProbability(double x) throws MathException{\n    if (Double.isNaN(x)){\n        throw new IllegalArgumentException(\"Argument must be finite.\");\n    }\n\n    if (!isFinite(x)){\n        // If x deviates too much from the mean.\n        if (Math.abs(x - mean) > 24){  \n            return Double.POSITIVE_INFINITY;\n        }else if(mean == 0 && standardDeviation ==1 ) {\n        \tBoxMullerGaussian g = new BoxMullerGaussian();\n             return 0.5*g.cdf(x);\n        }else if (mean != 0 || standardDeviation != 1){\n            double v = (x - mean) / standardDeviation;\n            return 0.5 * (1.0 + Erf.erf(v / Math.sqrt(2.0)));\n        } else {\n            throw new ConvergenceException();\n        }\n    }\n    \n    \n    // Normal CDF calculations for finite values...\n    \n    double d = (x - mean) / standardDeviation;\n    return 0.5 + 0.5 * Erf.erf(d / Math.sqrt(2.0));\n}",
