    "patch_code": "import cern.jet.random.Normal;\nimport cern.jet.random.engine.*;\nimport org.apache.commons.math3.exception.*;\n\npublic class NormalDistributionImpl implements RealDistribution {\n    private final double mean;\n    private final double standardDeviation;\n    \n    public NormalDistributionImpl(double mean, double standardDeviation){\n        this.mean = mean;\n        if(Double.isNaN(standardDeviation) || Double.isInfinite(standardDeviation)){\n            throw new IllegalArgumentException(\"Standard deviation must be finite.\");\n        }else if(standardDeviation <= 0.0){\n            throw new IllegalArgumentException(\"Standard deviation must be positive.\");\n        }\n        this.standardDeviation = standardDeviation;\n    }\n\n    @Override\n    public double cumulativeProbability(double x) {\n        \n        try{\n            if ((x < (this.mean - 100 * this.standardDeviation)) || \n                    (x > (this.mean + 100 * this.standardDeviation)))\n                return 0;          // for large values of x deviating far from the mean\n            else if ((x >= (this.mean - 100 * this.standardDeviation)) && \n                    (x <= (this.mean + 100 * this.standardDeviation)))      \n                return 1;           //for small values of x close to the mean\n            \n            // Generating random numbers using CERN's Jet Random Engine library.\n            RandomEngine engine = new RandomEngineFunction();\n            Normal distribution = new Normal(mean, standardDeviation, engine);\n            double result = distribution.probability(x);\n                    \n            return result;\n        }catch(Exception e){\n            throw new MathIllegalNumberException(e);\n        }  \n    }\n    \n    @Override\n    public double density(double x) {\n        // TODO Auto-generated method stub\n        return 0;\n    }\n}",
