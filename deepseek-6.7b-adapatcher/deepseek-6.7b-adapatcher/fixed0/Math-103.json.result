    "patch_code": "import org.apache.commons.math.special.Erf;\npublic class NormalDistributionImpl{\n    private final double mean;\n    private final double standardDeviation;\n    public static final double TOLERANCE = 0.0000001;\n    public NormalDistributionImpl(double mean, double standardDeviation){\n        this.mean = mean;\n        this.standardDeviation = standardDeviation;\n    }\n    /**\n     * @param x\n     *            point at which CDF is evaluated\n     * @return the cumulative probability that X less than or equal to x\n     * @throws IllegalArgumentException\n     */\n    public double cumulativeProbability(double x) throws IllegalArgumentException {\n        if(Math.abs(x-mean)>10*standardDeviation){\n            return 0;\n        }\n        return 0.5 * (1.0 + Erf.erf((x - mean) /\n                (standardDeviation * Math.sqrt(2.0))));\n    }\n}",
