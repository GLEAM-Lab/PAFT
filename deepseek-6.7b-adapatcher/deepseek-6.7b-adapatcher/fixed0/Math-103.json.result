    "patch_code": "import org.apache.commons.math3.special.*;\npublic double cumulativeProbability(double x) {\n    if ((mean == Double.POSITIVE_INFINITY && x < 0) ||\n        (mean ==  Double.NEGATIVE_INFINITY && x > 0)){\n        return 0;\n    }\n    \n    else if ((mean ==  Double.POSITIVE_INFINITY && x >= 0) ||\n             (mean == Double.NEGATIVE_INFINITY && x <= 0)){\n        return 1;\n    }\n        \n  \n        return 0.5 * (1.0 + SpecialFunctions.erf((x - mean) /\n                (Math.sqrt(2) * standardDeviation)));\n}",
