    "patch_code": "import org.apache.commons.math3.special.Erf;\n\npublic double cumulativeProbability(double x) {\n    if (Double.isNaN(x) || Double.isInfinite(x)){\n        throw new IllegalArgumentException(\"x must not be NaN or Infinity\");\n    }    \n    if ((mean > 0 && x < (mean - maxDeviationsFromMean * standardDeviation)) || \n         (mean < 0 || x > (mean + maxDeviationsFromMean * standardDeviation))) {  \n        // The point is less than \"mean - maxDeviations\" from the mean, so definitely a 0 probability event\n        return 0.0;\n    }else if ((mean > 0 && x > (mean + maxDeviationsFromMean * standardDeviation)) || \n              (mean < 0 || x < (mean - maxDeviationsFromMean * standardDeviation))){\n       // The point is more than \"mean + maxDeviations\" from the mean, so definitely a 1 probability event\n        return 1.0;\n    }else{\n        return 0.5 * (1.0 + Erf.erf((x - mean) / (standardDeviation * Math.sqrt(2.0))));\n    }\n}",
