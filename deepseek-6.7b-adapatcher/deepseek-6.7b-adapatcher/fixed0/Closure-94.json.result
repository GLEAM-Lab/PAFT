    "patch_code": "static boolean isValidDefineValue(Node val, Set<String> defines) {\n   String value;\n    while (val != null) {\n        if (val.getType() == Token.STRING && ((StringLiteralAst) val).endsWith(\"\\\\\")){\n          value = ((StringLiteralAst) val).toString().replaceAll(\"(\\\\\\\\r|\\\\\\\\n|\\\\\\\\t)\", \"\");\n        }else {value = val.toString();}\n      \n        switch (val.getToken()) {\n            case Token.STRING:\n            case Token.NUMBER:\n            case Token.TRUE:\n            case Token.FALSE:\n                return true;\n            \n          \n        \n            case Token.BITAND:\n            case Token.BITNOT:\n            case Token.BITOR:\n            case Token.BITXOR:\n            \n             \n            case Token.NOT:\n            case Token.NEG:\n                if (!isValidDefineValue(val.jjtGetChild(0), defines)) {\n                    return false;\n                }\n                break;\n                \n            case Token.NAME:\n            case Token.GETPROP:\n                if (val.isQualifiedName()) {\n                    if (!defines.contains(val.getQualifiedName())) {\n                        return false;\n                    }\n                }\n        }\n        val = val.jjtGetNextSibling();\n    }\n    return true;\n}",
