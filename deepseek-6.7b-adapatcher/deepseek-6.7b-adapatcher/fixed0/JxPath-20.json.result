    "patch_code": "protected boolean compute(Object left, Object right) {\n        left = reduce(left);\n        right = reduce(right);\n        \n        if (!(left instanceof Number) || !(right instanceof Number)){\n            throw new IllegalArgumentException(\"Numeric types required\");\n        }    \n            \n        double ld = ((Number)left).doubleValue();\n        double rd = ((Number)right).doubleValue();\n      \n      if (Double.compare(ld, rd) <= 0){\n          return true;\n      } else {\n           return false;\n}\n}",
