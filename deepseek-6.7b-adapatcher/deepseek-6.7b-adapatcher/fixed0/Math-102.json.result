    "patch_code": "public double chiSQ(long[] observed, double[] expected) {\n    if ( observed.length != expected.length ) {\n        throw new IllegalArgumentException(\" observed and expected arrays must be same length\");\n    }\n    double sumSq = 0.0d;\n    double dev = 0.0d;\n    double total = sumArray( observed );\n    for ( int i = 0 ; i < observed.length ; i++ ) {\n        dev = observed[i] - expected[i];\n        sumSq += (dev * dev / expected[i]);\n    }\n    return sumSq * total / sumArray( expected );\n}",
