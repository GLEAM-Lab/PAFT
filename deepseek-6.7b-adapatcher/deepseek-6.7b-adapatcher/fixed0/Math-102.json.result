    "patch_code": "public double chiS square(long[] observed, double[] expected)\n{\n    double sumSq = 0.0d;\n    double dev = 0.0d;\n    double sumObs = 0.0d;\n    double sum exp = 0.0d;\n    for (int i = 0; i < observed.length; i++) \n    {\n        dev = observed[i]- expected[i];\n        sumSq +=  dev*dev / expected[i];\n        sumObs += observed[i];\n        sum exp += expected[i];\n    }\n    if (sum obs != sum exp){\n        for (int i = 0; i < observed.length; i++) {\n            expected[i] *= sum obs / sum exp;\n        }\n    }\n    return sumSq;\n}",
