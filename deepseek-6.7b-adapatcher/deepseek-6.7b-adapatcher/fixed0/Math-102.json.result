    "patch_code": "private boolean isPositive(double arr[]){\n\tfor(double val : arr){\n\t\tif(!(val > 0)){\n\t\t\treturn false;\n\t\t}\n\t}\n\treturn true;\n}\n    \npublic double chiSquare(double[] expected, long[] observed)\n    throws IllegalArgumentException {\n    if ((expected.length < 2) || (expected.length != observed.length)) {\n        throw new IllegalArgumentException(\n                \"observed, expected array lengths incorrect\");\n    }\n    \n    if (!isPositive(expected) || !isNonNegative(observed)) {\n        throw new IllegalArgumentException(\n            \"observed counts must be non-negative and expected counts must be postive\");\n    }\n        \n    double sumObserved=0.0d;\n    for(int i=0;i<observed.length;i++){\n       sumOberserved+=(double)observed[i];\n    }\n    \n    double sumExpected=0.0d;\n    for(int i=0;i<expected.length;i++){\n      sumExpected+=expected[i]; \n    }\n    \n    double diff;\n    double sumSq = 0.0d;\n    for (int i = 0; i < observed.length; i++) {\n            diff=((double) observed[i]-(sumExpected*expected[i])/sumObserved);\n            sumSq += diff * diff / expected[i];\n    }\n    return sumSq;\n}",
