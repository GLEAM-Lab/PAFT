    "patch_code": "public double chiSquare(double[] expected, long[] observed)\n    throws IllegalArgumentException {\n    if ((expected.length < 2) || (expected.length != observed.length)) {\n        throw new IllegalArgumentException(\n                \"observed, expected array lengths incorrect\");\n    }\n    if (!isPositive(expected) || !isNonNegative(observed)) {\n        throw new IllegalArgumentException(\n            \"observed counts must be non-negative and expected counts must be positive\");\n    }\n    double sumExp = 0.0d;\n    for(double exp : expected){\n        sumExp+=exp;\n    }\n    double sumObs = 0.0d;\n    for(long obs : observed){\n        sumObs+=obs;\n    }\n    \n    double sumSq = 0.0d;\n    double dev = 0.0d;\n    for (int i = 0; i < observed.length; i++) {\n            dev = ((double) observed[i] - expected[i]) ;\n             expected[i]=dev + sumObs/sumExp*expected[i];\n            sumSq += dev * dev / expected[i];\n    }\n    return sumSq;\n}",
