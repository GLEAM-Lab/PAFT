    "patch_code": "String cleanseElementName(String element){\n    List<Character> controlCharacters  = Arrays.asList('\\u0000','\\n','\\r','\u0001','\\t','\\f');\n    return element.chars().mapToObj(c -> (char) c).filter(c -> {if (!controlCharacters.contains((char) c)) return true; return false;} ).collect(Collector.of(() -> new StringBuilder(), (sb, c) -> sb.append((char) c), (sb1, sb2) -> sb1.append(sb2)));\n}",
