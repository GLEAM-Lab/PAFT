    "patch_code": "private static boolean IsControlChar(char c){\n\treturn ((c >= 0 && c <= 8)||(c == 11) || (c >= 14 && c <= 31));\t\n}\n\nfinal void newAttribute(){\n\tif(attributes==null)attributes=new Attributes();\n\tif(pendingAttributeName!=null){\n\t\tString tmp=pendingAttributeName.trim();\n\t\tif(!tmp.isEmpty()&&tmp.indexOf(' ')!=tmp.lastIndexOf(' ')){\n\t\t\tfor(int i=tmp.indexOf(\" \");i!=-1;i=tmp.indexOf(\" \",i+1)){\n\t\t\t\ttmp=tmp.substring(0,i) +\"&nbsp;\"+tmp.substring(i+1,tmp.length());\n\t\t\t}\n\t\t}\n\t\tpendingAttributeName=tmp;\n\t\tAttribute attribute;\n\t\tif(hasPendingAttributeValue){\n\t\t\ttry{\n\t\t\t\tif(pendingAttributeValue.length()>0){\n\t\t\t\t\tString value=pendingAttributeValue.toString().replace(\"\\n\",\"\").replace(\"\\r\",\"\");\n\t\t\t\t\tif(!value.isEmpty()&&value.indexOf(' ')!=value.lastIndexOf(' ')){\n\t\t\t\t\t\tfor(int i=value.indexOf(\" \");i!=-1;i=value.indexOf(\" \",i+1)){\n\t\t\t\t\t\t\tvalue=value.substring(0,i) +\"&nbsp;\"+value.substring(i+1,value.length());\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t\tattribute=new Attribute(pendingAttributeName,value);\n\t\t\t\t\t\t\t\n\t\t\t\t}else attribute=new Attribute(pendingAttributeName,pendingAttributeValueS);\n\t\t\t}catch(Exception e){\n\t\t\t\tattribute=new Attribute(pendingAttributeName,\"\");\n\t\t\t}\n\t\t}else if(hasEmptyAttributeValue) attribute=new Attribute(pendingAttributeName,\"\");\n\t\telse attribute=new BooleanAttribute(pendingAttributeName);\n\t\tattributes.put(attribute.getKey(),attribute);\n\t}\n\tpendingAttributeName=null;\n\thasEmptyAttributeValue=false;\n\thasPendingAttributeValue=false;\n\treset(pendingAttributeValue);\n\tpendingAttributeValueS=null;\n}",
