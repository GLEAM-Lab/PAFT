    "patch_code": "static final Pattern r_tagName = Pattern.compile(\"^[A-Za-z][A-Za-z0-9]*$\");\n...\nprivate static boolean validTagName(String tag) {\n   return r_tagName.matcher(tag).find();\n}\n...\nfinal void newAttribute() {\n    if (attributes == null)\n        attributes = new Attributes();\n\n    if (pendingAttributeName != null && !validTagName(pendingAttributeName)) {\n        throw new RuntimeException(\"Not a valid name:\"+pendingAttributeName);\n    }\n    \n    if (pendingAttributeName != null && pendingAttributeName.indexOf('<')>=0 || \n       (hasPendingAttributeValue&& pendingAttributeValueS.length()>0 && \n         pendingAttributeValueS.indexOf('<')>=0)){\n      int ix=pendingAttributeName.length()-1;\n      while ((ix!=0) && (pendingAttributeName.charAt(ix)!='>')){\n        if (!Character.isWhitespace((char)pendingAttributeName.charAt(ix))) break;\n          ix--;\n      }\n      pendingAttributeName = pendingAttributeName.substring(0,ix+1);\n          \n      if (hasPendingAttributeValue){\n        ix = pendingAttributeValueS.length()-1;\n        while ((ix!=0) && (pendingAttributeValueS.charAt(ix)!='>')){\n          if (!Character.isWhitespace((char)pendingAttributeValueS.charAt(ix))) break;\n            ix--;\n        }\n        pendingAttributeValueS  = pendingAttributeValueS .substring(0,ix+1);\n          \n      }\n      \n      \n      return ;\n    }\n\n\n    if (pendingAttributeName != null) {\n        pendingAttributeName = pendingAttributeName.trim();\n        if (pendingAttributeName.equals(\"\")) {\n           throw new RuntimeException(\"Invalid Token: empty name\");\n        }\n            \n            Attribute attribute;\n            if (hasPendingAttributeValue)\n                attribute = new Attribute(pendingAttributeName,\n                    pendingAttributeValue.length() > 0 ? pendingAttributeValue.toString() : pendingAttributeValueS);\n            else if (hasEmptyAttributeValue)\n                attribute = new Attribute(pendingAttributeName, \"\");\n            else\n                attribute = new BooleanAttribute(pendingAttributeName);\n            attributes.put(attribute);\n    }\n    pendingAttributeName = null;\n    hasEmptyAttributeValue = false;\n    hasPendingAttributeValue = false;\n    reset(pendingAttributeValue);\n    pendingAttributeValueS = null;\n}",
