    "patch_code": "private static final boolean CONTROL_CODES[] = {\n      true ,true ,true ,true ,true ,true ,true ,true ,true ,false,\n      false,true ,true ,true ,true ,true ,true ,false,true ,true ,\n};\n\nboolean c(char c){\n     return  c < 32 || CONTROL_CODES[c - 32];\n}\n\nfinal void newAttribute(){\n     if(attributes==null)\n         attributes=new Attributes();\n     if(pendingAttributeName!=null&&((hasPendingAttributeValue && pendingAttributeValue.length()!= 0||hasEmptyAttributeValue))){\n         pendingAttributeName=pendingAttributeName.trim();\n          Attribute attribute;\n          if(!hasPendingAttributeValue||(hasPendingAttributeValue && pendingAttributeValue.length()== 0)){\n              attribute=new Attribute(pendingAttributeName,pendingAttributeValueS );\n          }else{\n              attribute=new Attribute(pendingAttributeName,pendingAttributeValue.toString());\n           }\n           if (!attribute.isBooleanAttribute())\n               reset(pendingAttributeValue);\n           if (pendingAttributeValue instanceof StringBuilder) {\n             ((StringBuilder) pendingAttributeValue).setLength(0);\n           }\n           attributes.add(attribute);\n     }\n       reset(pendingAttributeValue);\n     pendingAttributeName=null;\n     hasPendingAttributeValue=false;\n     hasEmptyAttributeValue=false;\n   }",
