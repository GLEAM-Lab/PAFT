    "patch_code": "private static int skipSpaces(int c, final InputStream in)\n        throws IOException {\n    do {\n        if (!Character.isWhitespace((char)c)) {\n            return c;\n        }\n        c = in.read();\n    } while (c != -1);\n    return c;\n}\n\npublic static Map<String, String> parsePaxHeaders(final InputStream i)\n        throws IOException {\n    final Map<String, String> headers = new HashMap<String, String>();\n    while(true) {\n        int ch;\n        int len = 0;\n        while ((ch = i.read()) != '\\n') {\n            if (ch == -1) {\n                return headers;\n            }\n            len = (len << 3) + (len << 1) + (ch & 0xFF);\n        }\n        final int l = len;\n        final ByteArrayOutputStream baos = new ByteArrayOutputStream();\n        for (;;) {\n            char keyChr = (char)skipSpaces(i.read(),i);\n            if (keyChr < 0 || keyChr > '~'){\n                break;\n            }\n            baos.write(keyChr);\n        }\n        final String keyword = baos.toString(StandardCharsets.US_ASCII);\n        final boolean containsEqualsSignInValue = i.read()=='=';\n        if(!containsEqualsSignInValue){\n            System.out.println(\"Missing equals sign after pax header\");\n            continue;\n        }\n        final ByteArrayOutputStream val = new ByteArrayOutputStream();\n        int nextCharIntRepr = i.read();\n        while(nextCharIntRepr!='\\n'&&nextCharIntRepr!=-1){\n            val.write(nextCharIntRepr);\n            nextCharIntRepr = i.read();\n        }\n        final String value = val.toString(StandardCharsets.US_ASCII);\n        headers.put(keyword,value);\n    }\n}",
