  {
    "patch_code": "import java.io.*;\nimport java.util.*;\npublic class Main{\n    public static void main(String []args)throws Exception{\n       Scanner in=new Scanner(System.in);\n        String s=in.nextLine();\n        Map<String,String> map=parsePaxHeaders(new ByteArrayInputStream(s.getBytes()));\n         for(Iterator<String> it=map.keySet().iterator();it.hasNext();){\n             String key=it.next();\n             System.out.println(key +\"--->\"+ map.get(key));\n         }  \n    }\n    \n    static Map<String,String> parsePaxHeaders(InputStream i)throws IOException{\n        Map<String,String> headers=new HashMap<>();\n          while(true){\n              int c;\n               StringBuilder sb=new StringBuilder();\n               while((c=i.read())!='\\r');\n                 if(c==-1)break;\n                  while((c=i.read())!='\\n'){\n                     if(c==-1)throw new IllegalArgumentException(\"Unexpected EOS\");\n                      if(c==':')break;\n                     sb.append((char)c);\n                 }\n                   if(sb.length()==0&&headers.size()>0){\n                        break;\n                   }\n                    String keyword=sb.toString().trim();\n                    if(!headers.containsKey(keyword)){\n                         List<String> value=new ArrayList<>();\n                        headers.put(keyword,value);\n                    }else{\n                          value.add(keyword);\n                    }\n                 sb.delete(0,sb.length());\n           }\n      return headers;\n    }\n}",
