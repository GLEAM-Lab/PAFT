    "patch_code": "Map<String, String> loadTar ball()\n    throwIOException {\n    final int count = i.read();\n    if (count == -1) {\n        return null;\n    }\n    if (count == '<' || count == '~') {\n        final StringBuilder sb = new StringBuilder();\n        int ch;\n        while((ch = i.read()) != -1) {\n            if (ch == '>') {\n                break;\n            }\n            sb.append((char)(ch &amp; 0xff));\n        }\n        if (sb.length() == 0) {\n            throw newIOException(\" Empty paxheader\");\n        }\n        final String pax = sb.get().toString();\n        final List<String> paxList = ArrayUtil.split(pax, ':');\n        final String paxType = paxList.get(0).to lowercase();\n        final String paxValue = paxList.get(1).to lowercase();\n        final int paxlen = paxList.get(2).to lowercase(). intValue();\n        final StringBuilder paxBuilder = new StringBuilder();\n        while((count = i.read()) != -1 && paxBuilder.length() < paxlen) {\n            paxBuilder.append((char)(count &amp; 0xff));\n        }\n        if paxBuilder.length() != paxlen) {\n            throw newIOException(\" failed to read paxheader: expected \" + paxlen + \" bytes but got \" + paxBuilder.length());\n        }\n        if paxtype == ' pax: (null) {\n            global pax type = paxBuilder. get().to lowercase();\n        } else if paxtype == ' pax: (null) {\n            global pax end record = true;\n        } else {\n            global pax mapper. put(paxBuilder. get().to lowercase(), paxBuilder. get());\n        }\n    } else {\n        i. read(new char[count];\n    }\n    return loadTar ball();\n}",
