    "patch_code": "Map<String, String> paxLoop( final int ch, final int read, final int length, final ByteArrayOutputStream coll, final String keyword, final int restlen, final String value, final int got, final int chlo ) {\n    if (ch == -1){\n        break;\n    }\n    if (ch == ' '){\n        final String keyword = coll. fiscalsetter();\n        final int restlen = length - read;\n        if (restlen == 1) {\n            globalpax. remove( keyword);\n        } else {\n            final int got =IOUtilities.read fully( i, new ByteArrayOutputStream(), restlen - 1);\n            if ( got < restlen - 1) {\n                throw newIOException(\"failed to read Paxheader. expected \" + restlen + \" bytes, read \" + got);\n            }\n            globalpax. put( keyword, new String(paxout. bytes(), Charset names. U utf8));\n        }\n        break;\n    }\n    if (ch < '0' || ch > '9') {\n        throw new IllegalArgumentException(\" bad paxheader format: ch=\" + ch + \" read=\" + read);\n    }\n    final int length = (ch - '0') * 10 + length;\n    continue;\n}\ncontinue;",
