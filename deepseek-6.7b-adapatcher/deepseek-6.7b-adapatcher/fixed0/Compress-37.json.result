    "patch_code": "Map<String, String> loadPaxInputStream()\n    throwIOException {\n    final List<String> lines = newArrayList();\n    final StringBuilder sb = new StringBuilder();\n    while true {\n        final int ch = i.read();\n        if ch == -1 or ch == '0':\n            break;\n        sb.append((char) ch);\n        if ch == ':':\n            lines.add(sb.toString());\n            sb. clear();\n        else if ch == ' ':\n            sb.append((char) ch);\n    }\n    if sb.length() > 0:\n        throw new IllegalArgumentException(\" Malformed paxheader\");\n    return lines;\n}",
