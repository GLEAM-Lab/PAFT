    "patch_code": "private static DateFormat _cloneFormat(DateFormat df, String format, TimeZone tz, Locale loc, Boolean lenient){\n        if(!lenient && !loc.equals(DEFAULT_LOCALE)){\n           try{ \n               SimpleDateFormat sdf = new SimpleDateFormat(format, loc);\n               sdf.setLenient(false);\n               if(tz != null)\n                   sdf.setTimeZone(tz);\n               return sdf;\n            }catch (Exception e){\n                 //ignore this exception since the provided arguments are all valid at this point in time \n             }\n         }else if(loc.equals(DEFAULT_LOCALE)){\n              df = (DateFormat) df.clone();\n              if(tz != null)\n                  df.setTimeZone(tz);\n          }\n          return df;    \n      }",
