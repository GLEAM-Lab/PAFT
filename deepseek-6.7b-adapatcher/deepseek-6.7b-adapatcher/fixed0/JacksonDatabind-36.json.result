    "patch_code": "protected static class CustomDateFormat extends StdDateFormat{\n    \n    private boolean lenient = true;\n    \n    public void setLenient(boolean lenient){\n        this.lenient = lenient;\n    }\n    \n    @Override\n    protected DateFormat _cloneFormat(DateFormat df, String format,\n         TimeZone tz, Locale loc)\n    {\n        if (!(df instanceof SimpleDateFormat)){\n            throw new IllegalArgumentException(\"Only SimpleDateFormat instances supported\");\n        }\n        \n        SimpleDateFormat sdf = (SimpleDateFormat) df;\n        \n        sdf.setLenient(this.lenient);\n      \n        if (!loc.equals(DEFAULT_LOCALE)) {\n            df = new SimpleDateFormat(format, loc);\n            df.setTimeZone((tz == null) ? DEFAULT_TIMEZONE : tz);\n        } else {\n            df = (DateFormat) df.clone();\n            if (tz != null) {\n                df.setTimeZone(tz);\n            }\n        }\n        return df;\n    }\n}",
