    "patch_code": "protected final static DateFormat _cloneFormat(DateFormat df, String format,\n            TimeZone tz, Locale loc, Boolean lenient) throws ParseException\n    {\n        \n    \n       try{if(!lenient){\n           throw new IllegalArgumentException(\"Sorry, StdDateFormat does not support seting leniency to FALSE\");\n       }}finally{\n      if (!loc.equals(DEFAULT_LOCALE)) {\n            df = new SimpleDateFormat(format, loc);\n            df.setTimeZone((tz == null) ? DEFAULT_TIMEZONE : tz);\n        } else {\n            df = (DateFormat) df.clone();\n            if (tz != null) {\n                df.setTimeZone(tz);\n            }\n        }\n        return df;}\n}",
