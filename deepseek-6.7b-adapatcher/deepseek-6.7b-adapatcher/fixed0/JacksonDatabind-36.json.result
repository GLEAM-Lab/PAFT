    "patch_code": "public class NonStrictDateFormat extends DateFormat {\n\n    private volatile DateFormat delegate;\n    \n    public void setDelegate(DateFormat delegate){\n         this.delegate = delegate;\n    }\n    @Override\n    public StringBuffer format(Date date, StringBuffer toAppendTo, FieldPosition fieldPosition) {\n        return delegate.format(date, toAppendTo, fieldPosition);\n    }\n    @Override\n    public Date parse(String source, ParsePosition pos) {\n        try{\n             return delegate.parse(source,pos);\n        } catch (ParseException e){\n              // ignore exception and try next\n        }\n       return null;\n    }\n}",
