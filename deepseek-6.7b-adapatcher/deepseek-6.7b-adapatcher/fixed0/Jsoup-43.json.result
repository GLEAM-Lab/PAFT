    "patch_code": "private static int indexInList(Element search, ArrayList<Element> elements) {\n    Validate.notNull(search);\n    Validate.notNull(elements);\n\n    for (int i = 0; i < elements.size(); i++) {\n        Element element = elements.get(i);\n        if (element == search)\n            return i;\n    }\n    throw new IllegalArgumentException(\"search not found in list\");\n}",
