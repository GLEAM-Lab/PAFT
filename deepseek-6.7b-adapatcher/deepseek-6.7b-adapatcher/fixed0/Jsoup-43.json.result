    "patch_code": "private int getMyIndex() {\n    Node nodeParent = parent();\n    int retVal = 0;\n    for (Node tmp : nodeParent.childNodes()) {\n      if (tmp instanceof Element && ((Element) tmp).tagName().equalsIgnoreCase(this.tagName())){\n        if (tmp == this){\n          break;\n        } else {\n          retVal ++;\n        }\n     }\n   }\n   return retVal;\n}",
