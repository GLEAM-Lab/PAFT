    "patch_code": "public static int getChildNodeNumber(Element childElement) {\n    int count = 0;\n    Node parent = childElement.parent();\n    while (parent != null) {\n        Node firstChild = parent.childNodes().get(0);\n        if (firstChild instanceof Element && ((Element) firstChild).hasAttr(\"rowspan\")){\n            int rowSpanValue = Integer.parseInt(((Element) firstChild).attr(\"rowspan\"));\n            if (rowSpanValue > 1){\n                break;\n            }\n        } else {\n            count++;\n        }\n        parent = parent.previousSibling();\n    }\n    return count;\n}",
