    "patch_code": "import java.util.*;\nimport org.jsoup.nodes.*;\nimport org.jsoup.*;\n\npublic class Main{\n\tpublic static void main(String[] args){\n\t\tString html=\"<table id='id_a' border='1' cellspacing='0' cellpadding='0'>\\n\"+\n\t\t\t\t\"      <thead>\\n\"+\n\t\t\t\t\"        <tr align='center' style='height:30px'>\\n\"+\n\t\t\t\t\"          <th width='4%'/>\\n\"+\n\t\t\t\t\"            <th colspan='6' width='96%' >Data</th>\\n\"+\n\t\t\t\t\"         <!--th>Date/Time(ms)</th-->\\n\"+ \n\t\t\t\t\"\t\t</tr>\\n\"+\n\t\t\t\t\"\t  <tbody>\\n\" +\n\t\t         \"    <tr class=\\\"bdrB bgr00\\\" height=\\\"28\\\"> <td colspan=\\\"7\\\"> 2014-01-10 00:00:00 (Thu)</td></tr>\\n\" + \n                \"\\t   <!--tr align='center'  id='row2'\\n\"  +\n                \"\\t          style='height:30px;border-bottom:#AACCBB solid;background-color:#EEFBE7;font-weight:bold;'>-->\\n\"  +\n\t\t\t\t\"       <td > 0</td>\\n\" +\n\t\t\t\t\"        <td > 2965</td>\\n\" +\n\t\t\t\t\"        <td > 4291</td>\\n\" +\n\t\t\t\t\"        <td > 255</td>\\n\" +\n\t\t\t\t\"        <td > 13</td>\\n\" +\n\t\t\t\t\"        <td > 0</td>\\n\" +\n\t\t\t\t\"    </tr> \\n\" +\n\t\t\t\t\"\\n\" +\n\t\t\t\t\"     <tr class=\\\"bdrLRT bgr00\\\" height=\\\"28\\\"> <td> 2014-01-11 00:00:00 (Fri)</td></tr>\\n\" + \n                 \"\\t   <!--tr align='center'  id='row5'\\n\"  +\n                 \"\\t          style='height:30px;border-top:#CCDDEE solid;background-color:#FFBBDD;font-weight:bold;'>-->\\n\"  +\n\t\t\t\t\"       <td > 0</td>\\n\" +\n\t\t\t\t\"        <td > 3032</td>\\n\" +\n\t\t\t\t\"        <td > 3032</td>\\n\" +\n\t\t\t\t\"        <td > 255</td>\\n\" +\n\t\t\t\t\"        <td > 13</td>\\n\" +\n\t\t\t\t\"        <td > 0</td>\\n\" +\n\t\t\t\t\"    </tr> \\n\" +\n\t\t\t\t\"\t</tbody>\\n\" +\n\t\t\t\t\"      </thead>\\n\"+\n\t\t\t\t\"\\t<tfoot />\\n\" +\n\t\t\t\t\"</table>\";\n     Jsoup parser=Jsoup.parse(html);\n      \n      System.out.println(getIndex(\"2014-01-11 00:00:00 (Fri)\",parser));//expected output is 3 since it has index 3 as well \n\t}\n    public static int getIndex(String text,Document doc) {\n    \tfor(int i=0;i<doc.select(\"tr\").size()-1;i++) {\n    \t\tif(Objects.equals(((Element)(doc.select(\"tr\").get(i)).childNode(0).attributes().get(\"title\")) ,text)){\n    \t\t\treturn i;\n    \t\t}\n    \t}\n\t\treturn -1;\n    }\n}",
