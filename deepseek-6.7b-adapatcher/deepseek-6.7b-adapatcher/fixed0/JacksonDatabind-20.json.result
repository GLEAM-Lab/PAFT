    "patch_code": "public JsonNode setAll(Map<String,? extends JsonNode> properties)\n    {\n      // Changed from properties.entrySet() to properties.entrySet().iterator() because iterating over the entry set removes entries from the original Map\n        for (Iterator<Map.Entry<String,? extends JsonNode>> i = properties.entrySet().iterator();i.hasNext();){\n            \n          \n      \n            Map.Entry<String,? extends JsonNode> en = i.next();\n        \n    \n         \n        JsonNode n = en.getValue();\n        \n           if (n == null) {\n               n = nullNode();\n            }\n         \n            _children.put(en.getKey(), n);\n        }\n        return this;\n    }",
