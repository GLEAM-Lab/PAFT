    "patch_code": "public JsonNode setAll(Map<String,? extends JsonNode> properties)\n    {\n        Iterator var2 = properties.entrySet().iterator();\n\n        while(var2.hasNext()) {\n            Map.Entry<String,? extends JsonNode> entry = (Map.Entry)var2.next();\n            String key = (String)entry.getKey();\n            JsonNode value = (JsonNode)entry.getValue();\n            if (value == null) {\n                value = nullNode();\n            }\n\n            if (!this._children.containsKey(key)) {\n                this._children.put(key, value);\n            } else {\n                ((ObjectNode)this).replaceNode(this._children.get(key), value);\n            }\n        }\n\n        return this;\n    }",
