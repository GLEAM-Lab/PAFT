    "patch_code": "import java.awt.Rectangle;\nimport java.awt.geom.*;\nimport java.util.Iterator;\nimport org.jfree.util.ObjectUtilities;\n\npublic class ShapeList implements Cloneable, Iterable<GeneralPath> {\n    \nprivate ArrayList<GeneralPath> paths = new ArrayList<>();\n    \npublic Object clone() throws CloneNotSupportedException {\n    ShapeList clone = (ShapeList)super.clone();\n    for (int i = 0; i < paths.size(); i++){\n            clone.paths.set(i,(GeneralPath)paths.get(i).clone());\n         }\n    return clone;\n   }\n   \npublic Iterator<GeneralPath> iterator(){\nreturn this.paths.iterator();\n}\n\n public Rectangle getBounds(){\ndouble minX = Double.POSITIVE_INFINITY;\n    double maxX = Double.NEGATIVE_INFINITY;\n    double minY = Double.POSITIVE_INFINITY;\n    double maxY = Double.NEGATIVE_INFINITY;\n    for (GeneralPath path : paths) {\n        Rectangle r = path.getBounds();\n        if (r != null) {\n            if (r.x < minX){minX = r.x;}else{maxX = r.x + r.width;}\n            if (r.y < minY){minY = r.y;}else{maxY = r.y + r.height;}\n        }\n}\nreturn new Rectangle((int)minX,(int)minY,(int)(maxX - minX),(int)(maxY - minY));\n    }\n    \n@Override\npublic boolean equals(Object o) {\n    if (this == o) return true;\n    if (o == null || getClass() != o.getClass()) return false;\n    ShapeList shapeList = (ShapeList) o;\n    return Objects.equals(paths, shapeList.paths);\n}\n    \n @Override\npublic int hashCode() {\n    return Objects.hash(paths);\n}\n}",
