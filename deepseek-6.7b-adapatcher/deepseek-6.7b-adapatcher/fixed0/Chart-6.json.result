    "patch_code": "import java.awt.*;\n\npublic class ShapeList extends AbstractList<Shape> {\n    \n    private List<Shape> list;\n\n    public ShapeList() {\n        \n        this.list = new ArrayList<>();\n    }\n\n    @Override\n    public boolean add(Shape e) {\n        \n        for (int i = 0; i < size(); i++) {\n            \n            if (get(i).equals(e)) {\n                \n                return false;\n            }\n        }\n        return list.add(e);\n    }\n\n    @Override\n    public void add(int index, Shape element) {\n        \n        if (!contains(element)) {\n            \n            list.add(index, element);\n        }\n    }\n\n    @Override\n    public Shape get(int index) {\n        \n        return list.get(index);\n    }\n\n    @Override\n    public int size() {\n        \n        return list.size();\n    }\n\n    @Override\n    public boolean contains(Object o) {\n        \n        for (int i = 0; i < size(); i++) {\n            \n            if (get(i).equals(o)) {\n                \n                return true;\n            }\n        }\n        return false;\n    }\n\n    @Override\n    public boolean remove(Object o) {\n        \n        if (contains(o)) {\n            \n            for (int i = 0; i < size(); i++) {\n                \n                if (get(i).equals(o)) {\n                    \n                    list.remove(i);\n                }\n            }\n            return true;\n        }\n        return false;\n    }\n\n    @Override\n    public Iterator<Shape> iterator() {\n        \n        return list.iterator();\n    }\n}",
