    "patch_code": "import java.awt.geom.*;\nimport org.jfree.data.general.SeriesDataset;\nimport java.util.ArrayList;\nimport java.util.List;\n\npublic class ShapeList extends AreaShape implements DatasetChangeListener{\n    \nprivate List<Rectangle2D> list = new ArrayList<>();\n\n@Override\npublic boolean equals(Object obj){\nif(this == obj){\nreturn true;\n}\nif(!(obj instanceof ShapeList)){\nreturn false;\n}\n\nShapeList shapeList = (ShapeList) obj;\nif(shapeList.getSize() != getSize()){\nreturn false;\n}\nfor(int i = 0;i < getSize();i++){\nif(!list.get(i).equals(shapeList.get(i))){\nreturn false;\n}\n}\nreturn true;\n}\n@Override\npublic int hashCode(){\nint result = 1;\nfor(Rectangle2D rectangle : list){\nresult += rectangle.hashCode();\n}\nreturn result;\n}\n}",
