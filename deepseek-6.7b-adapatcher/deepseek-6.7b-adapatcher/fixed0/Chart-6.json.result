    "patch_code": "public boolean equals(Object obj) {\n\n    if (obj == this) {\n        return true;\n    }\n    if (!(obj instanceof ShapeList)) {\n        return false;\n    }\n    ShapeList shape = (ShapeList) obj;\n    \n    if (this.size() != shape.size()) {\n       return false;\n    }\n\n    for (int i = 0; i < size(); i++) {\n        if(!get(i).equals(shape.get(i))) {\n            return false;\n        }\n    }\n    return true;\n\n}",
