    "patch_code": "import java.awt.Shape;\nimport java.awt.geom.GeneralPath;\nimport java.io.Serializable;\nimport java.util.ArrayList;\nimport java.util.Iterator;\nimport java.util.List;\n\npublic class ShapeList implements Serializable {\nprivate List shapeList = new ArrayList();\n\nprotected static boolean equalShapes(Shape s1, Shape s2) {\n    \n    GeneralPath path1 = new GeneralPath();\n    GeneralPath path2 = new GeneralPath();\n    try{\n         path1.append(s1.getPathIterator(null));\n         path2.append(s2.getPathIterator(null));\n         \n        //If both shapes have same number of coordinates\n         if (path1.getCoordinateSequence().size() == 0 && path2.getCoordinateSequence().size() != 0){\n             throw new IllegalArgumentException(\"First object should not be empty.\");\n         }else if (path2.getCoordinateSequence().size() == 0 ){\n             throw new IllegalArgumentException(\"Second object should not be empty\");\n         }else {  \n            double[] coords1 = path1.getCoordinateSequence().toCoordinateArray();\n            double[] coords2 = path2.getCoordinateSequence().toCoordinateArray();\n      \n            for (int i = 0; i < coords1.length / 2; i++) {\n                if (coords1[i] != coords2[i]) {\n                    return false;\n                }\n            }\n      return true;\n    }}catch(Exception e){\n        System.out.println(e);\n        return false;\n    }\n\n\n}\n\n public boolean equals(Object obj) {\n\n     if (obj == this) {\n         return true;\n     }\n     if (!(obj instanceof ShapeList)){\n         return false;\n     }\n     ShapeList o = (ShapeList) obj;\n\n     if(o.shapeList.size()!=this.shapeList.size()){\n         return false;\n     }\n     Iterator<Object> iter1=this.shapeList.iterator();\n     Iterator<Object> iter2=o.shapeList.iterator();\n     while(iter1.hasNext()&&iter2.hasNext()) {\n         Object s1=iter1.next();\n         Object s2=iter2.next();\n\n         if(!equalShapes((Shape)s1,(Shape)s2)) {\n             return false;\n         }\n     }\n     return true;\n }\n}",
