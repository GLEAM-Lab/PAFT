    "patch_code": "import java.awt.geom.Rectangle2D;\nimport java.util.ArrayList;\nimport org.jfree.data.general.AbstractDataset;\nimport org.jfree.data.xy.XYDataset;\n\nclass MyClass extends AbstractDataset implements XYDataset {\n    private ArrayList<Number> data = new ArrayList<>();\n    \n    public synchronized void addItem(Number number){\n        int index = 0;\n        for(int i=0;i < data.size()-1;i++){\n            if(number.doubleValue()>=data.get(i).doubleValue() && number.doubleValue() <= data.get(i+1).doubleValue())\n                break;\n            else{\n                index = i+1;\n            }     \n        }\n        data.add(index,number);            \n    }\n    @Override\n    public Number getX(int series, int item) {\n        return null;\n    }\n\n    @Override\n    public Number getY(int series, int item) {\n        // TODO Auto-generated method stub\n        return null;\n    }\n\n    @Override\n    public int getSeriesCount() {\n        // TODO Auto-generated method stub\n        return 0;\n    }\n\n    @Override\n    public int getItemCount(int series) {\n        // TODO Auto-generated method stub\n        return 0;\n    }\n\n    @Override\n    public Rectangle2D createDataBounds(int series) {\n        // TODO Auto-generated method stub\n        return null;\n    }\n}",
