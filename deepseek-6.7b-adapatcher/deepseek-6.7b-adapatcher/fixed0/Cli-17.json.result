    "patch_code": "protected void burstToken(String token, boolean stopAtNonOption)\n{\n    int j = 0;\n    \n    while (j < token.length()) {\n        String str = String.valueOf(token.charAt(j));\n        \n        // Check whether it is an option or not\n        if (!str.equals(\"-\") && currentOption == null){\n            \n            if (stopAtNonOption) {\n                \n                tokens.add(token);\n                return; \n            }\n            continue;\n        } \n        if ((str.equals(\"-\")) || (str.equals(\"/\"))) {  \n         \n            if (currentOption != null) {\n                if (currentOption.hasArgs()) {\n                    throw new ParseException(\"Option \" + lastParsedOption.getValue() + \" requires an argument\");\n                }\n                 \n                Option newOpt = options.getOption(lastParsedOption.getKey());\n                 \n                if (newOpt != null && newOpt!=currentOption ) { \n                    \n                     \n                    checkBeforeSetValue(lastParsedOption);\n                  \n                    setUserSpecifiedValue(lastParsedOption,\"\"); \n                      \n                   \n                    lastParsedOption  = null;\n                    currentOption = null;\n                }\n            }\n             \n               continue ;\n        }else if (currentOption == null){\n          \n           ProcessArgument(token);\n         \n            continue ;\n        } else if ( currentOption != null) {\n            if (!currentOption.hasArgs() && !currentOption.isImplicit()){\n                 \n                 \n                tokens.add(\"-\"+str);\n               \n                lastParsedOption  = options.getOption(str);\n                \n                checkBeforeSetValue(lastParsedOption );\n      \n                setUserSpecifiedValue(lastParsedOption ,null);\n                \n                 \n                lastParsedOption   = null;\n                currentOption = null;\n               \n            }else if (currentOption.hasArgs()&&(!currentOption.isImplicit())) {\n                \n                if (j==token.length()-1) {\n                \n                    throw new ParseException (\"Option \" + currentOption.getKey ()+\" requires an argument\");\n                   \n                        \n                           \n                        }  else {\n                            \n                                 lastParsedOption   = options.getOption(token.substring(1, j + 2).trim()); \n                         \n                                 \n                                    \n                                    checkBeforeSetValue(lastParsedOption);\n                                    \n                                         \n                                     \n                                    setUserSpecifiedValue(lastParsedOption,token.substring(j+1).trim());\n                                            \n                                           \n                                lastParsedOption    = null;\n                                      \n                                        currentOption=null;\n                             \n                                \n                               break;\n                                 \n                                  \n                           } \n                 } else if (currentOption.isImplicit()) {\n                       tokens.add(\"-\"+str); \n                       \n                        lastParsedOption  = options.getOption(str); \n                \n                   \n                 \n                    checkBeforeSetValue(lastParsedOption);\n                    \n                    \n                   \n                 setUserSpecifiedValue(lastParsedOption, null); \n                   \n                \n                   lastParsedOption  = null;\n                \n                 \n                    currentOption = null;\n                     \n                \n                continue;\n                                        \n               \n               \n               \n               \n               \n            \n               \n            }\n            \n            \n            \n        } \n        j ++;\n    }\n}",
