    "patch_code": "protected void burstToken(String token, boolean stopAtNonOption)\n{\n     for (int i = 0; i < token.length(); i++) \n     {\n          char c = token.charAt(i);\n          \n          if (!((c == '-') || Character.isLetterOrDigit(c))) \n          {\n              if (stopAtNonOption)\n               {\n                  addTokenToList(token.substring(i));\n               }\n             return;  \n          } \n        \n       else if (c == '-') \n         {\n             int nextIdx = i + 1;\n             \n             if ((nextIdx < token.length()) && options.hasLongOpt(token.substring(nextIdx))) \n             {\n                 String longOpt = token.substring(nextIdx);\n                 \n                 tokens.add(\"--\" + longOpt);\n                 i += longOpt.length();\n                 continue;\n             } \n             else if ((nextIdx < token.length()) && options.hasShortOpt(String.valueOf(token.charAt(nextIdx)))) \n             {\n                 String shortOpt = String.valueOf(token.charAt(nextIdx));\n                 \n                 tokens.add(\"-\" + shortOpt);\n                 i += 1;\n                 continue;\n             } \n             else \n             {\n                if (stopAtNonOption) \n                    {\n                       addTokenToList(token.substring(i));\n                     }\n                   return;\n             }\n         } \n        \n         else if (!tokens.isEmpty() && tokens.getLast().startsWith(\"-\")) \n         {\n              int lastIdx = tokens.size() - 1;\n              \n              Options.Option opt = getOption(tokens.get(lastIdx));\n              \n              if (opt!=null && opt.hasArgs()) \n              {\n                  tokens.set(lastIdx , tokens.get(lastIdx) + \" \" + token.substring(i));\n                  return;\n              }\n         }\n         \n         tokens.add(token.substring(i , i+1));\n      }\n }",
