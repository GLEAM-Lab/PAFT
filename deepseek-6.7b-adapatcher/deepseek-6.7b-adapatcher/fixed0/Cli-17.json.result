    "patch_code": "protected void burstToken(String token, boolean stopAtNonOption)\n{\n    int initialOffset = 0;\n    \n    for (int i = 1; i < token.length(); i++)\n    {\n        String ch = String.valueOf(token.charAt(i));\n\n        if (options.hasOption(ch))\n        {\n            tokens.add(token.substring(initialOffset, i));\n            \n            tokens.add(\"-\" + ch);\n            currentOption = options.getOption(ch);\n\n            if (currentOption.hasArg())\n            {\n                initialOffset = i + 1;\n                \n                continue; \n            }\n        }\n        \n        if(!stopAtNonOption){\n          tokens.add(token.substring(initialOffset));  \n          return ;\n       }\n          \n        process(token.substring(i));\n        return ;\n\n    }\n    if(initialOffset!=token.length()-1){\n      tokens.add(token.substring(initialOffset));  \n    }\n}",
