    "patch_code": "package com.fasterxml.jackson.databind;\n\nimport com.fasterxml.jackson.core.util.VersionUtil;\n\npublic abstract class JsonMappingException extends JsonProcessingException {\n    private static final long serialVersionUID = 1L;\n    \n    protected JsonMappingException(String msg, Throwable rootCause) {\n        super(msg, rootCause);\n    }\n\n    /* Overridden to always include path information */\n    @Override\n    public String getMessage() {\n        if (this instanceof InvalidTypeIdException) {\n            return VersionUtil.addLocationInfo(\"Could not resolve type id\", _path, this);\n        }\n        \n        return super.getMessage();\n    }\n}",
