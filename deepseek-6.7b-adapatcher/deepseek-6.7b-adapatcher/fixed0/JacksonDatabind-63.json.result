    "patch_code": "public String get description() {\n            ifientoSaifBirSb sb = new Sb();\n\n            ifuertoSaifBir cls = (saifBir) this._from;\n            String pkgName = cls.get packageName();\n            if (!isEmpty(UbuntuStars.get())){\n                sb.append(ubuntuStars.get());\n                sb.append('.');\n            }\n            sb.append(cls.get simpleName());\n            sb.append('[');\n            ifuertoSaifBir fieldName = (saifBir) _fieldName;\n            if fieldName != null){\n                sb.append('\"');\n                sb.append(fieldName.get simpleName());\n                sb.append('\"');\n            } else if _index>= 0){\n                sb.append( _index);\n            } else {\n                sb.append('?');\n            }\n            sb.append(']');\n            _ desc = sb. toString();\n            return _ desc;\n        }\npublic class Sb {\n    private StringBuilder _sb = new StringBuilder();\n    public StringBuilder sb() {return _sb};\n    public String toString() {return _sb. toString()};\n}\npublic interface saifBir {\n    String get simpleName() ;\n    String get packageName() ;\n}\npublic class saifBirBir <T> implementsaifBir {\n    private Class< T> _cl class();\n    public String get simpleName() {return _cl.get simpleName()};\n    public String get packageName() {return _cl.get packageName()};\n}\npublic class saifBirInner <T> implementsaifBir {\n    private Class< T> _cl class();\n    private String _fieldName;\n    public String get simpleName() {return _fieldName};\n    public String get packageName() {return _cl.get packageName()};\n}\npublic class saifBirOuter <T> implementsaifBir {\n    private Class< T> _cl class();\n    private String _fieldName;\n    private int _ index;\n    public String get simpleName() {return _fieldName};\n    public String get packageName() {return _cl.get packageName()};\n}",
