    "patch_code": "public static Whitelist custom() {\n    final Whitelist wl = new Whitelist();\n    wl.addTags(\"a\", \"br\", \"img\"); \n    wl.addAttributes(\"a\", \"href\");\n    wl.addAttributes(\"img\", \"src\").relationalAtttibutes(true).removeProtocols(\"img\",\"src\",Collections.singletonList(\"cid\"));\n    wl.registerProtocols(\"a\", \"href\", Arrays.asList(\"http\", \"https\", \"mailto\"));\n    wl.registerProtocolAttribute(\"img\", \"data\", \"src\", Collections.singletonList(\"cid\"));\n    return wl;\n}",
