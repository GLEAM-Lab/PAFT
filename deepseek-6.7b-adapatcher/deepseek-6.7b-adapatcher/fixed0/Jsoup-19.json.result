    "patch_code": "public class ProtocolAttributeRemover extends Safelist {\n\n  @Override\n  public Set<String> safeTags() {\n    return new HashSet<String>();  \n  }\n\n  @Override\n  public Set<String> safeAttributes() {\n      return new HashSet<String>();\n  }\n\n  @Override\n  public List<String> protocols() {\n    ArrayList<String> protocolList =  new ArrayList<>();\n      \n    for (Protocol protocol : Protocol.values()) {\n        protocolList.add(protocol.name());\n    }\n\n    return Collections.unmodifiableList(protocolList);\n  }\n\n  private static final Whitelist.Builder BLOCKALL = new Whitelist.Builder() {{\n    blocks(Collections.EMPTY_SET);\n    attributes(Collections.EMPTY_SET);\n    elements(Collections.EMPTY_SET);\n    protocols(Collections.EMPTY_SET);\n}};\n\n@Deprecated\npublic static ProtocolAttributeRemover none(){\n    return (ProtocolAttributeRemover)BLOCKALL.build();\n  }\n  \n}",
