    "patch_code": "public static void main(String[] args) throws IOException {\n    String url_list1 = \"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAUAAAAFCAYAAACNbyblAAAAHElEQVQI12P4//8/w39obOws+CvYM9JeX4W7DnZR5fEb2lkcABtbzv5yD8uTAAAAAElFTkSuQmCC\";\n\n    List<String> urls1=new ArrayList<>(); \n    urls1.add(\"https://www.wikicid.com/images/a/aa/Turkey_map.svg\");\n    urls1.add(\"/tutorial-page-header-background\");\n    \n    Document doc = new Document(\"http://www.google.com\");\n    Element link  = new Element(\"link\").attr(\"rel\", \"stylesheet\")\n                            .attr(\"href\", \"/path/style.css\");\n\n    Elements elementsLink = new Elements();\n    elementsLink.add(link);\n    elementsLink.add(url_list1);\n        \n    System.out.println(elementsLink);\n  \n        Whitelist whitelist = new Whitelist();\n\nwhitelist.addAttributes(\"a\",\"href\");\nwhitelist.addAttributes(\"img\",\"src\");\n\n    cleanImagesInAnchorTags(doc,\"a\",\"href\",urls1);\ncleanImagesInAnchorTags(doc,\"img\",\"src\",urls1);\n    \nSystem.out.println(Jsoup.parse(doc.html(),\"http://www.google.com\"));\n\n    }\n\n\n\n\n private static void cleanImagesInAnchorTags(Document document, final String elementName,final String attr,List<String> allowed){\n\nElements links = document.select(elementName);\nlinks.stream().forEach((link)->{\n\nString value = link.attr(attr).trim();\n\nif(!allowed.contains(value)){\nlink.remove();\n}\n});\n}",
