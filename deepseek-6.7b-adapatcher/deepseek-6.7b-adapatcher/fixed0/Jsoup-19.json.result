    "patch_code": "protected static boolean testValidProtocol(Element el, Attribute attr, Set<Protocol> protocols) {\n    final AtomicBoolean found = new AtomicBoolean();\n    String value = attr.getValue();\n    Iterator<String> iterator = protocols.iterator();\n    while (iterator.hasNext()) {\n        String prot = iterator.next().name();\n        Pattern pattern = Pattern.compile(\"^\"+Pattern.quote(prot), Pattern.CASE_INSENSITIVE);\n        Matcher matcher1 = pattern.matcher(value);\n        if(matcher1.find()){\n            found.set(true);\n            break;\n        }\n    }\n    return found.get();\n}",
