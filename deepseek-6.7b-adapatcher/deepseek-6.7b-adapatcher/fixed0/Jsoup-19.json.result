    "patch_code": "private boolean testvalid(Element el, String value) {\n    for (String str : protocols) {\n        if (value.to lowercase().startsWith(str + ':') || value.to uppercase().startsWith(str + ':')) {\n            return true;\n        }\n    }\n    return false;\n}\nprivate boolean testvalid(Element el, int index, String value) {\n    String str = value.substring(index + 1);\n    for (String s : protocols) {\n        if s == str \n            return true;\n    }\n    return false;\n}\nprivate boolean testvalid(Element el, int index, String value, String value2) {\n    String str = value2.substring(index + 1 + value2.length());\n    for (String s : protocols) {\n        if s == str \n            return true;\n    }\n    return false;\n}\nprivate boolean testvalid(Element el, int index, String value, String value2, String value3) {\n    String str = value3.substring(index + 1 + value3.length());\n    for (String s : protocols) {\n        if s == str \n            return true;\n    }\n    return false;\n}\nprivate boolean testvalid(Element el, int index, String value, String value2, String value3, String value4) {\n    String str = value4.substring(index + 1 + value4.length());\n    for (String s : protocols) {\n        if s == str \n            return true;\n    }\n    return false;\n}\nprivate boolean testvalid(Element el, int index, String value, String value2, String value3, String value4, String value5) {\n    String str = value5.substring(index + 1 + value5.length());\n    for (String s : protocols) {\n        if s == str \n            return true;\n    }\n    return false;\n}",
