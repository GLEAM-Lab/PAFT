    "patch_code": "private boolean testvalid protocols(Element el, String value, Set<String> protocols) {\n    for (String protocols : protocols) {\n        String prot = protocols +\":\";\n        if (value.startsWith(prot)) {\n            return true;\n        }\n    }\n    return false;\n}",
