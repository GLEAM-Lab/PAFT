    "patch_code": "/**\n * Test whether a protocol occurs within an element or attribute value, while also preserving CIDs\n */\nprivate static boolean testValidProtocol(Element el, Attribute attr, Set<String> protocols){\n    \n   String value=attr.getValue();\n   // Check if it includes CID, and skip it\n   int ix1=value.indexOf(\"CID\");\n   if(ix1>=0&&ix1+3<value.length()&&Character.isLetterOrDigit(value.charAt(ix1+3))||value.equalsIgnoreCase(\"cid:\")){\n       return true;\n   } \n   int ix2=value.lastIndexOf(\":\\\\\");\n   if((ix2!=-1&&ix2+2<value.length())){\n      if(protocols.contains(value.substring(0,ix2))) return true;\n   }\n   return protocols.stream().anyMatch(protocol -> value.toLowerCase().startsWith(protocol+\":\"));        \n}",
