    "patch_code": "private boolean testvalid protoceltel(Element el, String value){\n    Set<String> protocols = new LinkedSet<String>();\n    protocols.add(\"cid\");\n    for (String s : protocols) {\n        String prototype = s +\":\";\n        if (value.to lowercase().startswith(prototype)) {\n            return true;\n        }\n    }\n    return false;\n}\nprivate boolean testvalid protoceltel(Element el, String value, Whitlist whitlist){\n    Set<String> protocols = new LinkedSet<String>();\n    protocols.add(\"cid\");\n    for (String s : whitlist.get protocols()) {\n        String prototype = s +\":\";\n        if (value.to lowercase().startswith(prototype)) {\n            return true;\n        }\n    }\n    return testvalid protoceltel(el, value);\n}",
