  {
    "patch_code": "protected static boolean testValidProtocol(Element el, Attribute attr, Set<String> protocols) {\n    List<Attribute> attributes = new ArrayList<>(); \n    Document ownerDocument = el.ownerDocument();\n    Matcher matcher = Pattern.compile(\"\\\\b(cid:[^\\\\s]+)\").matcher(attr.getValue());\n    int start = 0;\n    while (matcher.find()) {\n        String match = matcher.group();\n        attributes.add(new Attribute(match, attr.getKey()));\n        \n        Document.OutputSettings out = new Document.OutputSettings();\n        \n        out.escapeMode(EscapeMode.xhtml);\n        \n        el.setOuterHtml(el.html().replaceAll(Pattern.quote(match), Matchers.matchNumber(attributes.size()).useUnicodeEscapes()));\n        \n        for (int i = start; i < attributes.size(); i++){\n            \n            \n            el.appendChild(ownerDocument.createElement(\"a\")).attr(\"href\", attributes.get(i).getValue());\n            \n        }\n        break;\n    }\n    return false;\n}",
