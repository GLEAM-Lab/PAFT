    "patch_code": "void insert(Token.Comment commentToken) {\n    Comment comment = new Comment(commentToken.getData());\n    Node insert = comment;\n    if (!commentToken.isBogus()) {\n        if(commentToken.getData().startsWith(\"?\")) {\n            Document doc = Jsoup.parse(\"<processingInstruction>\"+commentToken.getData().substring(1), baseUri, Parser.xmlParser());\n            processingInstruction pi = (processingInstruction)doc.child(0);\n            insert = pi;\n        } else if(commentToken.getData().contains(\"!\")) {\n            int index = commentToken.getData().indexOf(\"!\");\n            String content =  commentToken.getData().substring(index+1).trim();\n            if(!content.isEmpty()){\n                \n                doc = Jsoup.parse(\"<markup>\"+content, baseUri, Parser.xmlParser());\n                markup mrk  = (markup)doc.child(0);\n                insert = new markup(\"markup\");\n                ((Element)insert).attributes().put(\"w\",\"a\");\n                insertNode(insert);\n            }\n            \n        } \n    }\n    \n    insertNode(insert);\n}",
