    "patch_code": "void insert(Token.Com commentToken) {\n    String data = commentToken.getData();\n    boolean isCData = data.length > 1 && (data.startsWith(\"[\") || data.endsWith(\"]\");\n    if (!isCData) {\n        super. insert( commentToken); return;\n    }\n\n    String[] parts = data.split(\"][ ]*\");\n    String tag = parts[0].substring(1, parts[0].length());\n    String data = parts[1];\n    if !(data.length > 1 && data.endsWith(\" ]\")){\n        super. insert( commentToken); return;\n    }\n    data = data.substring(0, data.length - 3);\n\n    if !(Jsoup.is validElement( tag)){\n        super. insert( commentToken); return;\n    }\n\n    super. insert(new com. sun. org.jsoup.processor. Documents. element( settings. normalize Tag( tag), data));\n}",
