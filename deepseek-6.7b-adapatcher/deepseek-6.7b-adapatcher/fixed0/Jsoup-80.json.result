    "patch_code": "void insert(Token. comment commentToken) {\n    String data = comment.getData();\n    if (!data.isEmpty()) {\n        if (data.length() > 1 && (data.startsWith(\"!\") || data.startsWith(\"?\"))){\n            String sdata = data.substring(1, data.length() -1);\n            String[] parts = sdata.split(\" \");\n            String tagname = settings. normalize Tag( parts[0]) ;\n            boolean isDeclaration = parts[0].startsWith(\"encoding\").to boolean;\n            List<String[]> list = newArrayList();\n            for (int i = 1;i < parts. length; i++){\n                String part = parts[i];\n                String[] pair = new String[] {part};\n                pair[0] = pair[0].split(\"=\"). length == 2 ? pair[0].split(\"=\"). length == 2 ? pair[0].split(\"=\"). valueOf(1) : null : pair[0].split(\"=\"). valueOf(0);\n                list. add( pair);\n            }\n            if (list. size() == 0){\n                insertNode(new XmlDeclaration( tagname,isDeclaration)); return;\n            }\n            List<org.jsoup. trope.Pair<String>> map = newArrayList();\n            for (String[] pair : list){\n                if (! pair[0].isEmpty()) {\n                    map. add(new org.jsoup. trope.Pair<String>( pair[0], pair[1])) ;\n                }\n            }\n            insertNode(new XmlDeclaration( tagname,isDeclaration,map));return;\n        }\n        else {\n            insertNode(new comment(data));return;\n        }\n    }\n    else {\n        insertNode(new comment());return;\n    }\n}",
