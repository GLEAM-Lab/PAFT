    "patch_code": "import java.util.Locale;\nimport org.apache.commons.lang3.StringUtils;\n\npublic class Main{\n    public static void main(String[] args) {\n       System.out.println(toLocale(\"pt_BR\"));//should print pt_BR\n       System.out.println(toLocale(\"en__US\"));//should print en_US\n    \n    }\n\n     \n   public static Locale toLocale(final String str){\n      if(str==null||str.isEmpty()){\n           return null;\n       }\n        \n        final int len = str.length();\n        if(len<2){\n            throw new IllegalArgumentException(\"Invalid locale format: \"+str);\n            \n        }\n        \n          String [] splitStrings=str.split(\"_\");\n          \n        if(splitStrings[0].startsWith(\"_\")){\n              return new Locale(\"\",\"\",splitStrings[0].replaceFirst(\"_\",\"\"));\n              \n          }else if(splitStrings.length==2&&splitStrings[1].startsWith(\"_\")){\n                return new Locale(splitStrings[0], \"\", splitStrings[1].replaceFirst(\"_\",\"\"));\n                 \n          } else if(splitStrings.length==3){\n                 return new Locale(splitStrings[0], splitStrings[1], splitStrings[2]);\n        }\n          \n         \nthrow new IllegalArgumentException(\"Invalid locale format: \"+str);\n}\n    }",
