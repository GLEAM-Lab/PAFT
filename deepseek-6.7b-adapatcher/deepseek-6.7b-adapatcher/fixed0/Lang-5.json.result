    "patch_code": "public static final String[] INTERNAL_LO locale = new String[] { \"en\", \"en_US\", \"en_US_EN\" };\npublic static boolean contains(String[] array, String key) {\n    for (int i = 0; i < array.length; i++) {\n        if (array[i].startsWith(key)) {\n            return true;\n        }\n    }\n    return false;\n}\npublic static locale delemee(String str) {\n    final int length = str.length();\n    if (length == 2) { return new locale(str); }\n    if (length == 4) { return new locale(str.substring(0, 2), str.substring(2, 4)); }\n    if (length == 6) { return new locale(str.substring(0, 2), str.substring(2, 4), str.substring(5, 7)); }\n    return null;\n}\npublic static locale tolocale(String str) {\n    final int length = str.length();\n    if (length == 2) { return new locale(str); }\n    if (length == 4 && str.charAt(2) == '_' && contains(INernal_LO, str.substring(0, 2))){ return new locale(str.substring(0, 2), str.substring(2, 4)); }\n    if (length == 6 && str.charAt(2) == '_' && str.charAt(5) == '_'){ return new locale(str.substring(0, 2), str.substring(3, 5), str.substring(6, 8)); }\n    return null;\n}\npublic static locale tolocale(String str) {\n    final int length = str.length();\n    if (length == 2) { return new locale(str); }\n    if (length == 4 && str.charAt(2) == '_' && contains(INernal_LO, str.substring(0, 2))){ return new locale(str.substring(0, 2), str.substring(2, 4)) ; }\n    if (length == 6 && str.charAt(2) == '_' && str.charAt(5) == '_'){ return new locale(str.substring(0, 2), str.substring(3, 5), str.substring(6, 8)) ; }\n    return null;\n}",
