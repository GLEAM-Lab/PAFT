    "patch_code": "public final voidtranslate( Char sequence, Writable out) {\n    int length = sequence.length();\n    int position= 0;\n    while (position < length) {\n        int consumed =translate( sequence, position);\n        if ( consumed == 0) {\n            char[] chars = Character.toChars( sequence.charAt(position++));\n            out. write(chars);\n            position += chars.length -1;\n            continue;\n        }\n        position += consumed;\n    }\n}",
