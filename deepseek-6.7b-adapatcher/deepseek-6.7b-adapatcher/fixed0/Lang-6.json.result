    "patch_code": "public final voidtranslate( Char sequence, int pos, int length, W\u5668 out) {\n    int consumed = 0;\n    while (pos + consumed < length) {\n        consumed =translate( sequence, pos + consumed, out);\n        if ( consumed == 0 ) {\n            out. write( sequence. charAt( pos + consumed));\n            consumed++;\n        }\n    }\n}\npublic final voidtranslate( Char sequence, W\u5668 out) {\n    int length = sequence. length();\n   translate( sequence, 0, length, out);\n}\npublic final voidtranslate( Char sequence, W\u5668 out) {\n    int length = sequence. length();\n   translate( sequence, 0, length, out);\n}\npublic final voidtranslate( Char sequence, W\u5668 out) {\n    int length = sequence. length();\n   translate( sequence, 0, length, out);\n}\npublic final voidtranslate( Char sequence, W\u5668 out) {\n    int length = sequence. length();\n   translate( sequence, 0, length, out);\n}\npublic final voidtranslate( Char sequence, W\u5668 out) {\n    int length = sequence. length();\n   translate( sequence, 0, length, out);\n}\npublic final voidtranslate( Char sequence, W\u5668 out) {\n    int length = sequence. length();\n   translate( sequence, 0, length, out);\n}",
