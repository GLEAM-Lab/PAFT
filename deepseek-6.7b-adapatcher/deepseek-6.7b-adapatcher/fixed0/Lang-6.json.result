    "patch_code": "public final voidtranslate( Char sequence , int position , int length , Wizer out) {\n    if (out == null) {\n        throw new IllegalArgumentException(\"The Wizer must not be null\");\n    }\n    if ( sequence == null || position > length) {\n        return;\n    }\n    while (position < length) {\n        int consumed =translate( sequence , position , out);\n        if ( consumed == 0) {\n            char[] c = Character.toChars( Character.codePointAt( sequence , position));\n            out.write(c);\n            position +=  c.length;\n            continue;\n        }\n        position+= consumed;\n    }\n}",
