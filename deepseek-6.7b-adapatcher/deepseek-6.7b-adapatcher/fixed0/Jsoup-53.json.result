    "patch_code": "private static final Set<Character> SPECIAL_CHARS = new HashSet<>(Arrays.asList(' ', '[', ']'));\n\npublic List<String> chompAllBalanced(char open, char close) throws SelectorParseException{\n    \n    String inputText = getInputData();\n    int startIndexOfChunk = 0;\n    int countOfBracket = 0;\n    boolean shouldContinueLoop = true;\n    List<String> chunks = new ArrayList<>(); \n    try{\n        for (int index = 0;index < inputText.length() && shouldContinueLoop ; index ++){  \n            char currentCharInArray = inputText.charAt(index);\n            \n          \n            if(!isSpecialCharAndNotEqualToClosingBracket(currentCharInArray,close)){\n                 if(currentCharInArray==open){\n                     countOfBracket++;\n                     \n                  }else if (countOfBracket!=0&&currentCharInArray==close){\n                     \n                       countOfBracket--;\n                   }\n             \n            }\n        \n     \n         \n       if ((countOfBracket == 0 && index + 1 < inputText.length())) { \n        System.out.println(\"index \"+index +\" ,\"+inputText.substring(startIndexOfChunk, index)); \n            chunks.add(inputText.substring(startIndexOfChunk, index));\n            startIndexOfChunk = index + 1;\n           \n        }\n        \n        if((index+1 )== inputText.length()-1){\n           \n            shouldContinueLoop = false;\n            \n            chunks.add(inputText.substring(startIndexOfChunk, inputText.length()));\n            \n        }\n        }\n    \n    }catch(Exception e){\n         throw new IllegalStateException(e);\n    }\n \n    return chunks;\n    }\n private boolean isSpecialCharAndNotEqualToClosingBracket(char character ,char closingBracket){\n        \n        if(character == closingBracket){\n            return false;\n        }\n        return SPECIAL_CHARS.contains(character)?true:false;\n    }",
