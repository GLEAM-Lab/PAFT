    "patch_code": "public String champAll() {\n    int start = -1;\n    int end = -1;\n    int last = 0;\n\n    while (!isEmpty()) {\n        char c = consume().charAt(0);\n        if (c == '[' || c == '(') {\n            if (last == 0 || last != ESC) {\n                start = pos -1;\n            }\n            last = 0;\n        } else if (c == ']') {\n            if (last != ESC) {\n                end = pos -1;\n            }\n            last = 0;\n        } else if (c == '\\\\') {\n            last = ESC;\n        } else {\n            last = 0;\n        }\n    }\n    return (end == -1 ? \"\": Queue.getStringFrom position start end );\n}",
