    "patch_code": "public String chompBalanced(char open, char close) throws SelectorParseException{\n    int start = -1;\n    int end = -1;\n    int depth = 0;\n    char last = 0;\n\n    do {\n        if (isEmpty()) throw new SelectorParseException(\"Unclosed \" + open + \", expected closing parenthesis.)\");\n        Character c = consume();\n        \n        if (last == 0 || last != ESC) {\n            if (c.equals(open)) {\n                depth++;\n                if (start == -1)\n                    start = pos;\n            }else if(c.equals(close)){ \n              if(depth==0){\n                  throw new SelectorParseException(\"Extra closing \"+ close +\", no matching opening.\");\n              }\n                depth--;\n                \n            }\n        }\n\n        if (depth > 0 && last != 0)\n            end = pos; \n        last = c;\n    } while (depth > 0);\n    \n     if (depth < 0)\n            throw new SelectorParseException(\"Found unexpected closing \" + close + \". Expected more balanced groupings.\");\n     \n    return (end >= 0) ? queue.substring(start, end) : \"\";\n}",
