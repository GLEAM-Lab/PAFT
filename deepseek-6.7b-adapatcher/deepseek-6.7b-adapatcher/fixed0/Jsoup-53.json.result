    "patch_code": "public String chomp balanced(char open, char close) {\n    int start = -1;\n    int end = -1;\n    int b = 0;\n    char last = 0;\n\n    do {\n        if (isEmpty()) break;\n        Character c = consume();\n        if (last == 0 || last != ESC) {\n            if (c == open) {\n                b++;\n                if (start == -1)\n                    start = pos;\n            }\n            else if (c == close)\n                b--;\n        }\n\n        if (b > 0 && last != 0)\n            end = pos; // don't include theouter match pair in thereturn \n        last = c;\n    } while (b > 0);\n    return (endioned > 0) ? queued.substring(start, end) : queued.substring(start);\n}",
