    "patch_code": "public String chompBalanced(char open, char close) throws SelectorParseException{\n    int start = -1;\n    int end = -1;\n    int depth = 0;\n    char last = 0;\n    boolean flag = false;\n    \n    do {\n        if (isEmpty()){ \n        \tbreak;\n        }  \n      \tflag = true;\n        Character c = consume();\n        if (last == 0 || last != ESC) {\n            if (c.equals(open)) {\n                depth++;\n                if (start == -1)\n                    start = pos;\n            }\n            else if (c.equals(close)) {\n            \t\tif(depth>0) {\n            \t\t\tthrow new SelectorParseException(\"unbalanced character\");\n            \t\t\t\n            \t\t}else {\n            \t\t\tdepth--;\n                    \tif(end==-1) end=pos;\t\n                \t}\n                \t \n            \t      }\n          \telse if(!c.equals(open)&&!c.equals(close)&&depth==0) throw new SelectorParseException(\"unbalanced bracket without meaning\"+queue.substring(pos));\n            }\n        \n         \n        last = c;\n    } while (depth != 0||c!=null&&c!=ESC);\n    return ((end >= 0) ? queue.substring(start, end) : \"\") + (!flag?\"\":\"^\");\n}",
