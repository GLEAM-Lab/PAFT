    "patch_code": "import org.mockito.exceptions.base.StackTraceFilter;\nimport org.mockito.exceptions.stacktrace.*;\n\nimport java.lang.reflect.Field;\nimport java.util.Arrays;\nimport java.util.List;\n\nimport static org.hamcrest.CoreMatchers.anyOf;\nimport static org.hamcrest.core.IsEqual.equalTo;\nimport static org.junit.Assert.assertEquals;\nimport static org.junit.Assert.assertThat;\n\npublic class StackTracesTest {\n\n    @Rule\n    public ExpectedException thrown = ExpectedException.none();\n\n    private final List<String> IN_JDK_METHODS = Arrays.asList(\"equals\", \"hashCode\", \"toString\");\n    private Class<? extends Throwable> actualType;\n\n    private Exception throwException(Runnable runnable) {\n        try {\n            runnable.run();\n            fail(\"Expected exception but none found!\");\n            return null; // Make compiler happy.\n        } catch (Exception e) {\n            actualType = e.getClass();\n            return e;\n        }\n    }\n\n    @After\n    public void filterTest() {\n        String className = actualType.getName();\n        assertThat(className, anyOf(endsWith(\".Subclass\"), endsWith(\".InnerClass\"), equalTo(\"SomeOtherName\")));\n    }\n\n    @SuppressWarnings({\"unchecked\", \"rawtypes\"})\n    @Test\n    public void shouldRemoveJdkMethodsInStackTraceWhenUseStackTraceFilters() throws Exception {\n        // given:\n        Exception exception = throwException(() -> testStackTrace());\n\n        // when:\n        MockitoSession session = openMocks();\n        Field field = session.getClass().getDeclaredField(\"filter\");\n        field.setAccessible(true);\n        StackTraceFilter stackTraceFilter = (StackTraceFilter) field.get(session);\n\n        // then:\n        String[] stackTraceLines = exception.getStackTrace();\n        assertTrue(stream(stackTraceLines).allMatch(line -> line.contains(\"at \") && !IN_JDK_METHODS.contains(extractMethodName(line))));\n\n        close(session);\n    }\n\n    /**\n     * Test methods. Modified to use {@link Mockito#testStackTrace()} instead of the actual call to JUnit\n     * tests in order to work around issue http://code.google.com/p/powermock/issues/detail?id=72\n     */\n    public static void testStackTrace() {\n        ...\n    }\n\n}",
