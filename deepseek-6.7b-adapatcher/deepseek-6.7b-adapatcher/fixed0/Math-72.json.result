    "patch_code": "public double Solve( final Univariate real function f, final double min, final double max, final double initial)\n    throw max iterationsexceeded exception,functionevaluation exception{\n\n    clearresult();\n    verify sequence(min, initial, max);\n\n    double y initial = f.value( initial);\n    if (abs(y initial)<=function valueaccuracy) {\n        setresult( initial, 0);return result;\n    }\n\n    double y min = f.value( min);\n    if (abs(y min)<=function valueaccuracy) {\n        setresult( y min, 0);return result;\n    }\n\n    double y max = f.value( max);\n    if (abs(y max)<=function valueaccuracy) {\n        setresult( y max, 0);return result;\n    }\n\n    if (y min * y max > 0) {\n        throw new IllegalArgumentException(non Bracketting message);\n    }\n\n    return Solve(f, min, y min, max, y max, initial, y initial);\n}\n\nprivate double Solve( final univariate real function f, final double min, final double minvalue, final double max, final double maxvalue, final double initial, final double initialvalue)\n    throw max iterationsexceeded exception,functionevaluation exception{\n\n    double midpoint = (min + max / 2);\n    double midvalue = f.value(midpoint);\n\n    if (abs(midvalue) < abs( initialvalue)) {\n        setresult( midpoint, midvalue);\n        return result;\n    }\n\n    if (minvalue * midvalue <0){\n        return Solve(f, min, minvalue, midpoint, midvalue, initial, initialvalue);\n    } else {\n        return Solve(f, midpoint, midvalue, max, maxvalue, initial, initialvalue);\n    }\n}",
