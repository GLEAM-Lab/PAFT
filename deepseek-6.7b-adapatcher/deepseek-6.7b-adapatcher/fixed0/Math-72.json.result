    "patch_code": "private double solve(UnivariateRealFunction f,\n                    double a, double fa, double b, double fb,\n                    double c, double fc) throws MaxIterationsExceededException, FunctionEvaluationException {\n    ++iterations;\n    boolean leftBracketing;\n    if ((fc != 0 && fb!= 0) || (fb == 0)) {\n      leftBracketing = false;\n    } else {\n      leftBracketing = true;\n    }\n    double s;\n    if (leftBracketing) {\n      s = b - (fb / (fa - fb)) * (a - b);\n    } else {\n      s = a + (fa / (fb - fa)) * (b - a);\n    }\n    final double fs = f.value(s);\n    double t;\n    if (fs != 0) {\n      if (leftBracketing == (fc * fs < 0)) {\n        a = s;\n        fa = fs;\n      } else {\n        b = s;\n        fb = fs;\n      }\n    } else {\n      a = s;\n      fa = fs;\n    }\n    if (!DoubleUtils.isNaN(a) && !DoubleUtils.isNaN(b)) {\n      if ((b - a) > intervalAccuracy) {\n        if (iterations < MAXIMUM_ITERATIONS) {\n          return solve(f, a, fa, b, fb);\n        }\n      }\n    }\n    setResult((a+b)/2., iterations);\n    return result;\n}",
