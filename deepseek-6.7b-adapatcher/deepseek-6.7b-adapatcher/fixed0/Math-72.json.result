    "patch_code": "public double solve(final UnivariateRealFunction f,\n                    final double min, final double max, final double initial)\n    throws MaxIterationsExceededException, FunctionEvaluationException {\n\n    clearResult();\n    verifySequence(min, initial, max);\n\n    // return the initial guess if it is good enough\n    double yInitial = f.value(initial);\n    if (Math.abs(yInitial) <= functionValueAccuracy) {\n        setResult(initial, 0);\n        return result;\n    }\n\n    // return the first endpoint if it is good enough\n    double yMin = f.value(min);\n    if (Math.abs(yMin) <= functionValueAccuracy) {\n        setResult(min, 0);\n        return result;\n    }\n\n    // return the second endpoint if it is good enough\n    double yMax = f.value(max);\n    if (Math.abs(yMax) <= functionValueAccuracy) {\n        setResult(max, 0);\n        return result;\n    }\n\n    // Brackets did not include the root, narrow down the range\n    if (yInitial * yMin < 0) {\n        return solve(f, min, initial, yMin, yInitial);\n    } else if (yInitial * yMax < 0){\n        return solve(f, initial, max, yInitial, yMax);\n    }\n\n    if (yMin * yMax > 0) {\n        throw new MaxIterationsExceededException(NON_BRACKETING_MESSAGE);\n    }\n\n    // Full Brent algorithm\n    return solve(f, min, max, initial, yMin, yMax, 0);\n}\n\nprivate double solve(UnivariateRealFunction f, double x1, double x2, double y1, double y2) {\n    clearIntervalInformation();\n    addIntervalInformation(x1, x2, 0);\n    double middle = 0;\n    int steps = 0;\n\n    do {\n        ++steps;\n        assertIntermediateResult(x1, x2, y1, y2);\n        double t = bisectionMethodStep(x1, x2, y1, y2);\n        double tau = brentRuleStep(t, x1, x2, y1, y2);\n\n        if (tau != 0) {\n            x2 -= tau;\n            y2 = f.value(x2);\n        }\n\n        if (t == 0) {\n            break;\n        }\n\n        middle = x1 + ((3 * x2 - x1) / 4);\n        double sigma = f.value(middle);\n\n        boolean switchBranch = false;\n\n        if (sigma != 0) {\n            if (y1 * sigma <= 0) {\n                x2 = middle;\n                y2 = sigma;\n            } else {\n                x1 = middle;\n                y1 = sigma;\n            }\n        }\n\n        // Choose between bisection method and secant method based on whether we switched branches\n        if (!switchBranch && (sigma == 0 || tau != 0)) {\n            x1 += t;\n            y1 = f.value(x1);\n            steps--;\n        }\n\n    } while (!finished(steps));\n\n    setResult((x1 + x2) / 2, 0);\n    return getResult();\n}",
