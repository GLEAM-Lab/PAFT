    "patch_code": "import org.apache.commons.math3.analysis.UnivariateRealFunction;\nimport org.apache.commons.math3.analysis.solvers.*;\n\npublic class RepairBrentSolver implements Solver {\n\n    @Override\n    public double solve(UnivariateRealFunction function, double lower, double upper) throws MaxCountExceededException, NoBracketingException {\n    \n        double yLower = function.value(lower);\n        if (yLower == 0){\n            return lower;\n        }\n        \n        double yUpper = function.value(upper);\n        if (yUpper == 0){\n            return upper;\n        }\n        \n        if (yLower*yUpper >= 0){\n            throw new NoBracketingException(NoBracketingException.POSITIVE_OR_NEGATIVE);\n        }\n            \n        if ((upper - lower) < this.getAbsoluteAccuracy() ){\n            return (upper + lower)/2;\n        }\n      \n        int i = 1;\n        do {\n          \n            double x = (lower + upper) / 2;\n            double y = function.value(x);\n         \n            if (y==0){\n                return x;\n            } else if (yLower*y<0) {\n               upper=x;\n            }else {\n                yUpper=y;\n                lower=x;\n                \n            }\n           \n           \n           \n            if (Math.abs((upper - lower)) < this.getAbsoluteAccuracy()) {\n                return (upper+lower)/2;\n            }\n            \n        } while (++i <= this.getMaxEvaluations());\n      \n        throw new MaxCountExceededException();\n     \n    }\n  \n\n     /* GETTER AND SETTER FOR ABSOLUTE PRECISION */\n    private double absoluteAccuracy = 1e-6;\n    \n    public double getAbsoluteAccuracy(){\n        return this.absoluteAccuracy;\n    }\n\n    public void setAbsoluteAccuracy(double pAbsoluteAccuracy) {\n        this.absoluteAccuracy = pAbsoluteAccuracy;\n    }\n    \n    /* GETTER AND SETTER FOR MAX EVALUATION */\n    private int maximumEvaluations = 1000;\n    \n    public int getMaxEvaluations() {\n        return this.maximumEvaluations;\n    }\n\n    public void setMaxEvaluations(int nEvals) {\n        if (nEvals <= 0)\n            throw new IllegalArgumentException(\"Number of evaluations must be positive\");\n        this.maximumEvaluations = nEvals;\n    }\n}",
