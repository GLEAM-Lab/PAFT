    "patch_code": "public double solve(final UnivariateRealFunction f,\n                    final double min, final double max, final double initial)\n    throws MaxIterationsExceededException, FunctionEvaluationException {\n\n    clearResult();\n    verifySequence(min, initial, max);\n\n    // return the initial guess if it is good enough\n    double yInitial = f.value(initial);\n    if (Math.abs(yInitial) <= functionValueAccuracy) {\n        setResult(initial, 0);\n        return result;\n    }\n\n    // return the first endpoint if it is good enough\n    double yMin = f.value(min);\n    if (Math.abs(yMin) <= functionValueAccuracy) {\n        setResult(yMin, 0);\n        return result;\n    }\n    \n      // change in the function value from one iteration to another remains less than a small threshold, terminate the iterations\n    for (int iter = 1; ; iter++) {\n        if (iter > ITERATION_LIMIT) {\n            throw new MaxIterationsExceededException(LOCAL_MAXIMUM_ITERATION_COUNT);\n        }\n        \n          // return the second endpoint if it is good enough\n        double yMax = f.value(max);\n        if (Math.abs(yMax) <= functionValueAccuracy) {\n            setResult(yMax, 0);\n            return result;\n        }\n\n        // Reduce the current bracket according to the bisection method\n        // Note that the two endpoints must not have the same sign\n        assert yMin * yMax <= 0 : \"There should be exactly one root within this bracket.\";\n\n        if (yInitial * yMax < 0) {\n            assert max - initial < initial - min;\n            min = initial;\n            yMin = yInitial;\n        } else {\n            assert initial - max < max - min;\n            max = initial;\n            yMax = yInitial;\n        }\n\n        initial = ((min + max) / 2);\n        yInitial = f.value(initial);\n    }\n\n}",
