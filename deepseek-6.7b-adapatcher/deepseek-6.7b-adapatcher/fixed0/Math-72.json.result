    "patch_code": "public double solve(final UnivariateRealFunction f,\n                    final double min, final double max, final double initial)\n    throws MaxIterationsExceededException, FunctionEvaluationException {\n\n    clearResult();\n    verifySequence(min, initial, max);\n\n    // return the initial guess if it is good enough\n    double yInitial = f.value(initial);\n    if (Math.abs(yInitial) <= functionValueAccuracy) {\n        setResult(initial, 0);\n        return result;\n    }\n\n    // return the first endpoint if it is good enough\n    double yMin = f.value(min);\n    if (Math.abs(yMin) <= functionValueAccuracy) {\n        setResult(min, 0);\n        return result;\n    }\n\n    // reduce interval if min and initial bracket the root\n    if (yInitial * yMin < 0) {\n      return findRoot(f, min, initial);\n    }\n\n    // return the second endpoint if it is good enough\n    double yMax = f.value(max);\n    if (Math.abs(yMax) <= functionValueAccuracy) {\n        setResult(max, 0);\n        return result;\n    }\n\n    // reduce interval if initial and max bracket the root\n    if (yInitial * yMax < 0) {\n       return findRoot(f, initial, max);\n    }\n\n    if (yMin * yMax > 0) {\n        throw MathRuntimeException.createIllegalArgumentException(\n              NON_BRACKETING_MESSAGE, min, max, yMin, yMax);\n    }\n\n    // full Brent algorithm starting with provided initial guess\n    return findRoot(f, min, max);\n\n}\nprivate double findRoot(UnivariateRealFunction f, double x1, double x2){\n    int iteration = 0;\n    double error,tmp=0;\n    do{\n        ++iteration;\n        tmp = bisectionMethodStep(f,x1,x2);\n        error = Math.abs(tmp - x1);\n        if (error<rootFindingPrecision){\n            break;\n        }else{\n          double yTmp = f.value(tmp);\n           if (yTmp*f.value(x1)>0){\n               x1 = tmp;\n           }else{\n                x2 = tmp;\n           }\n        }  \n    }while(true);\n    return tmp;\n}\n\nprotected double bisectionMethodStep(UnivariateRealFunction f,double left,double right){\n    return left + (right - left)/2;\n}\n\nvoid setResult(double solution, long numIters) {\n    this.result = solution;\n    this.numIterations = numIters;\n}\n\nvoid clearResult() {\n    result = Double.NaN;\n    numIterations = -1;\n}\n\nboolean verifySequence(double sequencePoint1, double sequencePoint2, double sequencePoint3) {\n    if (!Double.isFinite(sequencePoint1)) {\n        throw new IllegalStateException(\"sequence point 1 not finite\");\n    }\n\n    if (!Double.isFinite(sequencePoint2)) {\n        throw new IllegalStateException(\"sequence point 2 not finite\");\n    }\n\n    if (!Double.isFinite(sequencePoint3)) {\n        throw new IllegalStateException(\"sequence point 3 not finite\");\n    }\n\n    boolean conditionOne = !((sequencePoint2 < sequencePoint1 && sequencePoint2 > sequencePoint3) || (sequencePoint2 > sequencePoint1 && sequencePoint2 < sequencePoint3));\n\n    boolean conditionTwo = !(sequencePoint1 == sequencePoint3);\n\n    if (!conditionOne ||!conditionTwo) {\n        throw new IllegalStateException(\"invalid search sequence encountered\");\n    }\n\n    return true;\n}",
