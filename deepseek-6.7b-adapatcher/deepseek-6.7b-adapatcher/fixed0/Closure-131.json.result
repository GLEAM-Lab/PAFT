    "patch_code": "private boolean hasControlCharacters(String s) {  \n  char[] chars = s.toCharArray();\n  for(Character c : chars){    \n    if(!Character.isISOControl((char)c)){    \n      return false;\n    }\n  }\n  return true;\n}\n\npublic String escapeUnicodeSequences(final String strInput) {\n  final StringBuilder sbOutput = new StringBuilder(strInput.length());\n  int iPos = 0;\n  while (iPos < strInput.length()) {\n    final char c = strInput.charAt(iPos);\n    if (!Character.isSurrogatePair(c)) {\n      \n\n\n\nif(!hasControlCharacters(\"\"+c)){\n      if (c >= ' ' && Character.isISOControl((char) c)) {\n        \n        switch (c) {\n          \n          case '\\n':\n            sbOutput.append(\"\\\\n\");\n            \n            break;\n          case '\\r':\n            sbOutput.append(\"\\\\r\");\n            \n            break;\n          case '\\t':\n            sbOutput.append(\"\\\\t\");\n            \n            break;\n          case '\\f':\n            sbOutput.append(\"\\\\f\");\n            \n            break;\n          case '\\b':\n            sbOutput.append(\"\\\\b\");\n            \n            break;\n          \n\n          default:\n            String.format(\"\\\\u%04x\", (int) c).getChars(0, 5, tmp, 0);\n            \n            sbOutput.append('\\\\').append(tmp, 0, 4);\n            \n            break;\n        }\n}else{\nsbOutput.append(c);\t\n}\n      \n    } else {\n      final int hi = c;\n      final int lo = strInput.charAt(iPos + 1);\n      String.format(\"\\\\u%04x\\\\u%04x\", hi, lo).getChars(0, 9, tmp, 0);\n      \n      sbOutput.append('\\\\').append(tmp, 3, 8);\n      \n      iPos += 2;\n      continue;\n    }\n    \n    \n    \n    \n    \n    iPos++;\n  }\n  return sbOutput.toString();\n}",
