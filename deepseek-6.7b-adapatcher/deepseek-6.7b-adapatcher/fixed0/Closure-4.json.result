    "patch_code": "JSType resolveInternal(ErrorReporter t, StaticScope<JSType> enclosing) {\n  JSType referenced = null;\n  \n  // Resolve the type using the static registry of defined types, if needed, creating them as needed.\n  if (!resolveReferenceToRegisteredType(referenced)) {\n    \n    if (detectImplicitPrototypeCycle()) {\n      handleTypeCycle(t);\n    } else {\n      \n      // If we couldn't find it in the registry, attempt to resolve the reference directly.\n      resolveDirectly(t, enclosing, false);\n    }\n  }\n  \n  super.resolveInternal(t, enclosing);\n  finishPropertyContinuations();\n  \n  return !registry.hasNewVersionsInCurrentGeneration() &&\n         registry.isLastGeneration() ?\n      getReferencedType() : this;\n}",
