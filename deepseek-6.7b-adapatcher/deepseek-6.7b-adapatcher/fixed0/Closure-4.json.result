    "patch_code": "public JSType resolveInternal(ErrorReporter t, StaticScope<JSType> enclosing) {\n  boolean resolved = false;\n  try {\n    resolved = resolveViaRegistry(t, enclosing);\n    if (!registry.isLastGeneration() || resolved) {\n      super.resolveInternal(t, enclosing);\n      finishPropertyContinuations();\n      return registry.isLastGeneration() ? getReferencedType() : this;\n    }\n  } catch (ReturnControlFlow e) {\n    throw e;\n  } catch (Exception e) {\n    // Ignore exception. It is caused by unsupported features or invalid JavaScript.\n  }\n\n  try {\n    resolveViaProperties(t, enclosing);\n    if (!registry.isLastGeneration() && checkForCyclesDuringImplicitPrototypes()) {\n      handleTypeCycle(t);\n    } else {\n      super.resolveInternal(t, enclosing);\n    }\n    \n    if (isResolved()) {\n      finishPropertyContinuations();\n    }\n    \n    return registry.isLastGeneration() ? getReferencedType() : this;\n  } catch (ReturnControlFlow e2) {\n    throw e2;\n  } catch (Exception e2) {\n    // Ignore exceptions caused by unsupported features or invalid JavaScript.\n  }\n  \n  try {\n    assertFailure(\"Unable to resolve type \" + name);\n  } catch (Exception e3) {\n    throw new RuntimeException(e3);\n  }\n  return null;\n}",
