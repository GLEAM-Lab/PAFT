    "patch_code": "protected JSType resolveInternal(ErrorReporter t, StaticScope<JSType> enclosing) {\n  boolean resolveChecker = false;\n  \n  if (!resolveChecker && resolveViaRegistry(t, enclosing)) {\n    resolveChecker = true;\n  } else if (detectImplicitPrototypeCycle()) {\n    handleTypeCycle(t);\n  }\n\n  if (resolveChecker){\n    super.resolveInternal(t, enclosing);\n    finishPropertyContinuations();\n    \n    return registry.isLastGeneration() ?\n        getReferencedType() : this;\n  }\n\n  if (!resolveChecker && resolveViaProperties(t, enclosing)){\n    resolveChecker = true;\n  } else if (detectImplicitPrototypeCycle()){\n    handleTypeCycle(t);\n  }\n\n  if (resolveChecker){\n    super.resolveInternal(t, enclosing);\n    if (isResolved()) {\n      finishPropertyContinuations();\n    }\n  }\n  return registry.isLastGeneration() ?\n      getReferencedType() : this;\n}",
