    "patch_code": "public JSType resolveInternal(ErrorReporter t, StaticScope<JSType> enclosing) {\n  boolean newGenStart = !registry.isLastGeneration();\n  JSType result = null;\n  try {\n    if (!newGenStart && !hasBeenHandledByResolver) {\n      hasBeenHandledByResolver = true;\n      if (getHasWarnings()) {\n        t.printWarning(\"Ignored type warnings\");\n      } else if (t.useStrictMode()) {\n        String name = getQualifiedName().replace(\"/\", \".\");\n        throw new EcmaError(t, ErrorManager.ECMA262_3_14, name + \" is not a constructor\");\n      }\n      return getReferencedType();\n    }\n\n    if ((result = resolveViaRegistry(t, enclosing)) != null || detectImplicitPrototypeCycle()) {\n      if (newGenStart) {\n        handleUnresolvedInterfaceSuperCallsAndPrototypes(enclosing, t);\n        handleUnboundConstructorsOrInterfacesInRegistries(t);\n        maybeHandleMissingConstructorErrorsForNewGeneration(t);\n      }\n      if (!suppressNotInitializedFlagSetting) {\n        setIsNotYetInitialized(true);\n      }\n      setNeedsLazyInitPhaseIfAllPropertiesAreBoundNow();\n      handleTypeCycle();\n    } else {\n      resolveViaProperties(t, enclosing);\n    }\n\n    result = super.resolveInternal(t, enclosing);\n    finishPropertyContinuations();\n    checkPropertyOverrides();\n\n    if (!hasNonStaticMethodPropagated && result instanceof JSScriptableObjectType &&\n        ((JSScriptableObjectType) result).propagatesMethodsFromBase) {\n      applyBaseClassMethodsToInstances();\n    }\n    suppressNotInitializedFlagSetting = false;\n\n    assert !(isTemplate() && needsLazyInitPhase);\n  } finally {\n    if (newGenStart) {\n      finishProcessingNewGeneration();\n    }\n  }\n\n  return registry.isLastGeneration() ? getReferencedType() : result == null ? this : result;\n}",
