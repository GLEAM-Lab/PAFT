    "patch_code": "import java.io.IOException;\nimport java.io.Writer;\nimport java.util.HashMap;\nimport java.util.Map;\n\n/**\n * Unicode-specific implementation of {@link org.apache.commons.lang3.text.translate.NumericEntityUnescaper}.\n */\npublic final class NumericUnicodeEscaper extends NumericEntityUnescaper {\n    /** The sole instance. */\n    private static final NumericUnicodeEscaper INSTANCE = new NumericUnicodeEscaper();\n\n    /** Cache of frequent codes. */\n    private static final Map<Integer, Character> FREQUENT_CHARS = new HashMap<>();\n    \n    /** Maximum size of frequent chars cache. */\n    private static final int MAX_CACHE_SIZE = 512;\n    \n    static {\n        for (int code = 0; code <= 0xFFFF; code++) {\n            FREQUENT_CHARS.put(code, (char) code);\n        }\n    }\n\n    /** Private constructor, use {@link #INSTANCE} instead. */\n    private NumericUnicodeEscaper() {}\n\n    @Override\n    public Object clone() throws CloneNotSupportedException {\n        throw new CloneNotSupportedException(\"Instance has singleton properties\");\n    }\n\n    @Override\n    public int translate(final CharSequence input, final int index, final Appendable output) throws IOException {\n        int codePoint = Character.codePointAt(input, index);\n        Character cachedCharacter = FREQUENT_CHARS.get(codePoint);\n        if (cachedCharacter != null) {\n            output.append(cachedCharacter);\n            return index + 1;\n        } else if (codePoint >= 0x800 && codePoint < 0x10000) {\n            appendAsTwoDigitHex(output, codePoint >> 12 & 0xf);\n            appendAsTwoDigitHex(output, codePoint >>  8 & 0xf);\n            appendAsTwoDigitHex(output, codePoint >>  4 & 0xf);\n            appendAsTwoDigitHex(output, codePoint       & 0xf);\n            return index + 2;\n        } else {\n            throw new UnsupportedOperationException(\"Code point \" + codePoint + \" does not map to a supported unicode escape sequence.\");\n        }\n    }\n    \n    private static void appendAsTwoDigitHex(Appendable output, int value) throws IOException {\n        char highChar  = Character.toChars(value)[0];\n        output.append(\"\\\\u\"+ Integer.toHexString(highChar));\n    }\n}",
