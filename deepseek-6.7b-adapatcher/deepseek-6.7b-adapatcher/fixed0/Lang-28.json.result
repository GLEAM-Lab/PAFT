  {
    "patch_code": "import java.io.*;\nimport org.apache.commons.lang3.StringEscapeUtils;\n\nclass Main {\n  static String custom_escape(String s) {\n    if (s.isEmpty()) {\n      return s;\n    }\n\n    final StringBuilder accumulator = new StringBuilder();\n\n    final int length = s.length();\n    for (int i = 0; i < length;) {\n      int codePoint = Character.codePointAt(s, i);\n\n      switch (Character.charCount(codePoint)) {\n        case 1:\n          accumulator.appendCodePoint(codePoint);\n          break;\n        default:\n          accumulator.append(\"&#\").append(codePoint).append(\";\");\n      }\n      i += Character.charCount(codePoint);\n    }\n\n    return accumulator.toString();\n  }\n  \n  public static void main(String[] args){\n      \n        System.out.println(custom_escape(\"Hello World\"));\n    \n        \n        /*Expected output\n         * Hello World\n           */\n            \n        System.out.println(custom_escape(\"\\uD834\\uDD1E\"));\n        \n        /* Expected output\n         * &#12354;\n           */\n  }\n}",
