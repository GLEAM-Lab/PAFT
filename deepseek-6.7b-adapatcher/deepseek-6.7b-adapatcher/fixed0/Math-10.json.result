    "patch_code": "public void atan2(double[] y, int yOffset, double[] x, int xOffset, double[] result, int resultOffset) {\n    if(Double.isNaN(y[yOffset]) && Double.isInfinite(y[yOffset])){\n         result[resultOffset]= y[yOffset] < 0 ? -Math.PI/2 : Math.PI/2;\n        return ;\n    }else if((Double.isNaN(x[xOffset]) || Double.isInfinite(x[xOffset]))){\n           if(y[yOffset] > 0) result[resultOffset] = Math.PI / 2;\n        else if(y[yOffset] < 0 ) result[resultOffset] = -Math.PI / 2;\n        else if(y[yOffset] == 0 && Double.isNaN(x[xOffset])) result[resultOffset]  = Double.POSITIVE_INFINITY;\n        else if(y[yOffset] == 0 && !Double.isNaN(x[xOffset])) result[resultOffset]  = 0;\n        \n        return;\n    }\n\n    if(x[xOffset]>0&&y[yOffset]>=0||x[xOffset]<0&&y[yOffset]>0){\n        double val=Math.atan(y[yOffset]/(Math.sqrt(x[xOffset]*x[xOffset]+y[yOffset]*y[yOffset])));\n        result[resultOffset]=val;\n        return;\n    }if(x[xOffset]==0&&y[yOffset]>=0){\n        result[resultOffset]=Math.PI/2;\n        return;\n    }if(x[xOffset]==0&&y[yOffset]<0){\n        result[resultOffset]=-Math.PI/2;\n        return;\n    }if(y[yOffset]==0&&x[xOffset]<0){\n        result[resultOffset]=Math.PI;\n        return;\n    }if(y[yOffset]==0&&x[xOffset]>0){\n        result[resultOffset]=0;\n        return;\n    }if(x[xOffset]<0&&y[yOffset]<0){\n        double val=Math.atan(y[yOffset]/x[xOffset]);\n        result[resultOffset]=-val;\n        return;\n    }if(x[xOffset]>0&&y[yOffset]<0){\n        double val=Math.atan(-y[yOffset]/x[xOffset]);\n        result[resultOffset]=-val;\n        return;\n    }\n\n}",
