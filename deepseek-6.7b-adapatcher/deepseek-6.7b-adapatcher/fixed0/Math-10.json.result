    "patch_code": "public static double atan2(double y, double x) {\n    if (x > 0) {\n        return StrictMath.atan(y / x);\n    } else if (x < 0 && y >= 0) {\n        return StrictMath.PI + StrictMath.atan(y / x);\n    } else if (x < 0 && y < 0) {\n        return -StrictMath.PI + StrictMath.atan(y / x);\n    } else if (Double.isInfinite(x) || Double.isNaN(x) || \n        \tDouble.isInfinite(y) || Double.isNaN(y)) {\n        throw new IllegalArgumentException(\"Arguments must be finite\");\n    } else { // x == 0\n        return y > 0 ? StrictMath.PI / 2 : -StrictMath.PI / 2;\n    }\n}",
