    "patch_code": "public void atan2(double[] y, int yOffset,\n               double[] x, int xOffset,\n               double[] result, int resultOffset) {\n\n    int n = getSize();\n    boolean positiveX = true, positiveY = true;\n    if (Double.isInfinite(x[xOffset]) || Double.isNaN(x[xOffset])) {\n        xOffset--;\n    }\n    if (Double.isInfinite(y[yOffset]) || Double.isNaN(y[yOffset])) {\n        yOffset--;\n    }\n    if (x[xOffset] < 0) {\n        positiveX = false;\n    }\n    if (y[yOffset] < 0) {\n        positiveY = false;\n    }\n\n    if (!positiveX && !positiveY) {\n        for (int i = 0; i < n; i++) {\n            if (!Double.isNaN(y[i]) && !Double.isInfinite(y[i]) && !Double.isNaN(x[i]) && !Double.isInfinite(x[i])) {\n                result[i] = FastMath.PI;\n            }\n        }\n    } else if (!positiveX) {\n        for (int i = 0; i < n; i++) {\n            if (!Double.isNaN(y[i]) && !Double.isInfinite(y[i]) && !Double.isNaN(x[i]) && !Double.isInfinite(x[i])) {\n                result[i] = FastMath.PI - FastMath.atan(y[i] / (-x[i]));\n            }\n        }\n    } else if (!positiveY) {\n        for (int i = 0; i < n; i++) {\n            if (!Double.isNaN(y[i]) && !Double.isInfinite(y[i]) && !Double.isNaN(x[i]) && !Double.isInfinite(x[i])) {\n                result[i] = -FastMath.atan(y[i] / x[i]);\n            }\n        }\n    } else {\n        for (int i = 0; i < n; i++) {\n            if (!Double.isNaN(y[i]) && !Double.isInfinite(y[i]) && !Double.isNaN(x[i]) && !Double.isInfinite(x[i])) {\n                result[i] = FastMath.atan(y[i] / x[i]);\n            }\n        }\n    }\n}",
