    "patch_code": "static void processDocDecl(Document doc, Map cache) throws Exception {\n    NamespaceCache nsc = null;\n    \n    try {\n        \n        nsc = new SimpleNamespaceCache();\n        String[] recList = getRecursiveNamespaces(doc);\n        int len = recList.length - 1;\n        while (len >= 0) {\n            nsc.registerNamespace(recList[len]);\n            len--;\n        }\n        for (int i = 0; i < len; ++i) {\n            Element elm = (Element) doc.getElementsByTagName(recList[i]).item(0);\n            Attr attr = elm.getAttributeNode(\"xmlns\");\n            if (!attr.hasValue()) {\n                \n                continue;\n            } else {\n                nsc.registerNamespace(recList[i], attr.getValue());\n                attr = elm.getAttributeNode(\"xmlns:xsi\");\n                if (!\"\".equals(attr.getValue())) {\n                    nsc.registerNamespace(\"xsi\", attr.getValue());\n                }\n                attr = elm.getAttributeNode(\"xmlns:xi\");\n                if (!\"\".equals(attr.getValue())) {\n                    nsc.registerNamespace(\"xi\", attr.getValue());\n                }\n            }\n        }\n        \n    } finally {\n        if (cache != null && nsc != null) {\n            cache.put(NAMESPACE_MAP_KEY, nsc);\n        }\n    }\n}",
