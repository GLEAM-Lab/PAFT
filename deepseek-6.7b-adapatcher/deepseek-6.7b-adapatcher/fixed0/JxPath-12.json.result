    "patch_code": "import org.w3c.dom.*;\nimport javax.xml.XMLConstants;\n\npublic class JXPathDomPointerExample {\n   public static void main(String[] args) throws Exception {\n       DocumentBuilderFactory factory = DocumentBuilderFactory.newInstance();\n       DocumentBuilder builder = factory.newDocumentBuilder();\n       Document document = builder.parse(\"input.xml\");\n       XPathExpression expression = XPathFactory.newInstance().newXPath().compile(\"/root[1]/element\");\n       NodeList nodes = (NodeList)expression.evaluate(document, XPathConstants.NODESET);\n       System.out.println(\"\\nNode Name:\\t\" + nodes.item(0).getNodeName());\n       System.out.println(\"Node Value:\\t\" + nodes.item(0).getTextContent());\n       System.out.println(\"Attributes: \");\n       NamedNodeMap attrs = nodes.item(0).getAttributes();\n       for (int i = 0; i < attrs.getLength(); i++){\n           Attr attribute = (Attr)attrs.item(i);\n           System.out.println(attribute.getName() + \" : \" + attribute.getValue());\n       }\n       System.out.print(\"\\nUnregistered Namespace Prefixes: \");\n       NamespaceContext context = new DefaultNamespaceContext();\n       System.out.println(context.getNamespaceURI(\"default\")); // returns null because it has not been registered\n\n       // Registering namespace\n       Map<String, String> prefix2uri = new HashMap<>();\n       prefix2uri.put(\"prefix\", \"http://example.com/mynamespace\");\n       context = new SimpleNamespaceContext(prefix2uri);\n       System.out.println(context.getNamespaceURI(\"prefix\")); // returns http://example.com/mynamespace\n\n       System.exit(0);\n   }\n\nstatic class SimpleNamespaceContext implements NamespaceContext {\n      private final Map<String, String> prefix2uri;\n\n     public SimpleNamespaceContext(final Map<String, String> prefix2uri) {\n          if (prefix2uri == null) {\n              throw new IllegalArgumentException(\"Null map\");\n         }\n         this.prefix2uri = Collections.unmodifiableMap(prefix2uri);\n      }\n\n   @Override\n   public String getNamespaceURI(final String prefix) {\n        if (prefix == null) {\n            throw new IllegalArgumentException(\"Null prefix\");\n        } else if (\"default\".equals(prefix)) {\n            return XMLConstants.NULL_NS_URI;\n        }\n       return prefix2uri.get(prefix);\n    }\n\n     @Override\n     public String getPrefix(final String namespaceURI) {\n        throw new UnsupportedOperationException();\n     }\n\n     @Override\n     public Iterator getPrefixes(final String namespaceURI) {\n        throw new UnsupportedOperationException();\n     }\n}\n}",
