    "patch_code": "import java.util.*;\n\nclass Solution {\n    \n    private Map<String, String> namespaceMap = new HashMap<>();\n    \n    public void registerNamespace(String prefix, String uri) {\n        namespaceMap.put(uri, prefix);\n    }\n    \n    public String getQualifiedName(String localname, String namespaceUri) {\n        \n        if (!namespaceMap.containsKey(namespaceUri)) {\n            throw new IllegalArgumentException(\"Unknown namespace \" + namespaceUri);\n        } else {\n            String prefix = namespaceMap.get(namespaceUri);\n            return prefix + \":\" + localname;\n        }\n    }\n\n}\n\npublic class Main {\n  \n    public static void main(String[] args){\n      org.apache.commons.jxpath.ri.model.dom.DOMNodePointer dom; //initialize your DOM here.\n      \n        try{\n          System.out.println(dom.getAttributes().item(0));//print first attribute value\n        } catch (Exception e){\n          \n            Solution s = new Solution();\n            \n            String qName = dom.getAttributes().item(0).getNodeName();\n            \n            String uri = dom.getAttributes().item(0).getNamespaceURI();\n            \n            s.registerNamespace(\"xsi\", \"http://www.w3.org/2001/XMLSchema-instance\");\n            \n            String qualifiedName = s.getQualifiedName(qName, uri);\n            \n            System.out.println(qualifiedName);\n            \n        } finally{\n          dom.freeRecursive();\n        }\n    }\n  \n}",
