    "patch_code": "public static boolean testNode(Node node,Node testnode) {\n    if (testnode == null) {\n        return true;\n    }\n    if (testnode.getNodeType() == node.getNodeType()) {\n        if (testnode.getNodeType() == node.getNodeType()) {\n            return true;\n        }\n        if (testnode.getNodeType() ==Node.NODE_NODE ) {\n            return testNode( node, testnode);\n        }\n        return false;\n    }\n    if (testnode.getNodeType() ==Node.NODE_NODE ) {\n        return testNode( node, testnode);\n    }\n    if (testnode.getNodeType() ==Node.NODE_NODE ) {\n        return testNode( node, testnode);\n    }\n    if (testnode.getNodeType() ==Node.NODE_NODE ) {\n        return testNode( node, testnode);\n    }\n    return false;\n}",
