    "patch_code": "import javax.xml.XMLConstants;\nimport java.util.HashMap;\nimport org.w3c.dom.*;\n\npublic class NamespaceRegistrar implements XmlConstants{\n   private HashMap nsDecls= new HashMap();\n    \n   public void addNamespaceDeclaration(String s, String uri){\n       if(!this.nsDecls.containsKey(uri)){\n           this.nsDecls.put(uri, s);\n       } else{\n          throw new IllegalArgumentException(\"Attempted redeclaration of existing URI \" + uri);\n       }\n   }\n  \n   public String getPrefix(String uri){\n      if(uri==null || uri.length()==0){\n          uri= XMLConstants.NULL_NS_URI;\n      } \n      return (String)this.nsDecls.get(uri);\n   }\n   \n   public String getURI(String prefix){\n       if(prefix==null || prefix.length()==0){\n           prefix=XMLConstants.DEFAULT_NS_PREFIX;\n       } \n       return (String)this.nsDecls.get(prefix);\n   }\n   \n   public void registerAllNamespacesOnDocument(Document doc){\n      NamedNodeMap atts =doc.getDocumentElement().getAttributes();\n      for (int i = 0; i < ats.getLength(); i++) {\n         Attr attr=(Attr)ats.item(i);\n         registerNamespaceOfAttr(attr);\n      } \n   }\n\n   public void registerNamespaceOfAttr(Attr attr){\n      String qname=attr.getNodeName();\n      int colonIndex=qname.indexOf(':');\n      if(colonIndex!=-1&& colonIndex!=qname.length()-1){\n          String prefix=qname.substring(0, colonIndex);\n          String uri=getURI(prefix);\n          if(uri==null){\n              throw new IllegalArgumentException (\"Unknown namespace prefix: \"+ prefix);\n          }\n          attr.setPrefix(prefix);\n          attr.setNamespaceURI(uri);\n      } \n   }\n}",
