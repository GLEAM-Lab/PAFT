    "patch_code": "public static boolean testNode(Node node,Node test) {\n    if (test == null) {\n        return true;\n    }\n    if (test.getNodeType() == node.getNodeType()) {\n        return test == node;\n    }\n    if (test.getNodeType() == node.getNodeType()) {\n        return test == node;\n    }\n    if (test.getNodeType() == node.getNodeType()) {\n        return test == node;\n    }\n    if (test.getNodeType() == node.getNodeType()) {\n        return test == node;\n    }\n    if (test.getNodeType() == node.getNodeType()) {\n        return test == node;\n    }\n    if (test.getNodeType() == node.getNodeType()) {\n        return test == node;\n    }\n    return false;\n}",
