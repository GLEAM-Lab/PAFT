    "patch_code": "public static boolean testNode(Node node,Node test){\n    if(test==null){return true;}\n    if(test.getNodeType()==Node.NODE_NODE){return testNode(node,((Node)(test))));}\n    if(test.getNodeType()==Node.NODE_NODE_NODE){return testNode(node,((Node\u8282\u70b9)(test))));}\n    if(node.getNodeType()==Node.NODE_NODE){return testNode((node\u8282\u70b9),(Node)(test)));}\n    if(node.getNodeType()==Node.NODE_NODE_NODE){return testNode((node\u8282\u70b9),(Node\u8282\u70b9)(test)));}\n    return testNode(node,test);\n}\npublic static boolean testNode(Node node,Node\u8282\u70b9 test){\n    if(test==null){return true;\t}\n    if(test.getNodeType()==Node.NODE_NODE){return testNode(node,((Node)(test))));}\n    if(test.getNodeType()==Node.NODE_NODE_NODE){return testNode(node,((Node\u8282\u70b9)(test))));}\n    return testNode(node,test);\n}\npublic static boolean testNode(Node node,Node\u8282 point){\n    if(point.getNodeType()==Node.NODE_NODE){return testNode(node,((Node)( point))));}\n    if(point.getNodeType()==Node.NODE_NODE_NODE){return testNode(node,((Node\u8282\u70b9)( point))));}\n    return testNode(node,point);\n}\npublic static boolean testNode(Node node,Node point){\n    if(point.getNodeType()==Node.NODE_NODE){return testNode(node,((Node}( point))));}\n    if(point.getNodeType()==Node.NODE_NODE_NODE){return testNode(node,((Node\u8282\u70b9}( point))));}\n    return testNode(node,point);\n}\npublic static boolean testNode(Node node,Node\u8282\u70b9 point){\n    if(point.getNodeType()==Node.NODE_NODE){return testNode(node,((Node)( point))));}\n    if(point.getNodeType()==Node.NODE_NODE_NODE){return testNode(node,((Node\u8282\u70b9)( point))));}\n    return testNode(node,point);\n}",
