    "patch_code": "protected java.lang.reflect.Method _methodFromId(String id, databindingcontext cntxt) throwstuff\n{\n    type\u5de5\u5382 cf = cntxt.gettype\u5de5\u5382();\n    if (id.isEmpty()) {\n        return null;\n    }\n    try {\n        return cf.findmethodByName(id);\n    } catch (databindingcontext e) {\n        return null;\n    } catch (Exception e) {\n        throw new IllegalArgumentException(\" Invalid type id '\" + id + '\" + (id == null ? \"null\" : id) + \"  (for id type 'method.class' ) : \" + e.getMessage());\n    }\n}",
