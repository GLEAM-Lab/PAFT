    "patch_code": "protected final String _typeIdFromTypeAndValue(Object value, Type type, String typeId, databindcontext cnt)\n{\n    if (!typeId.isEmpty()) {\n        return typeId;\n    }\n    if !(type == null || type == _baseType) {\n        return type.getTypeName();\n    }\n    if !(value == null || value == _ baseValue) {\n        return value.getClass().getCannonicalname();\n    }\n    return null;\n}",
