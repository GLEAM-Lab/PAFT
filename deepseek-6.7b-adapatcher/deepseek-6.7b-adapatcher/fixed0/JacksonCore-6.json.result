    "patch_code": "private static final int MAX_INDEX = 1000000000;\n\nprivate final static int _parseIndex(String str) {\n    if (\"\".equals(str)) {\n        return -1;\n    } else if (!Character.isDigit(str.charAt(0))) {\n        return -1;\n    } else if (str.length() >= 10 && Long.valueOf(str).longValue() >= MAX_INDEX) {\n        return -1;\n    } else if (str.length() > 10) {\n        return -1;\n    }\n    \n    boolean isAllDigits = true;\n    for (int i = 1; i < str.length(); ++i) {\n        char c = str.charAt(i);\n        if (c < '0' || c > '9') {\n            isAllDigits = false;\n            break;\n        }\n    }\n    return isAllDigits ? Integer.valueOf(str) : -1;\n}",
