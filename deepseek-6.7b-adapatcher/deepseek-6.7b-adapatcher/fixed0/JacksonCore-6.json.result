    "patch_code": "private final static int _validateIndex( String str ) {\n    final int length = str.length();\n\n    if (length == 0 || length > 10) { return -1; }\n\n    for (int i = 0; i < length;++i) {\n        char ch = str.charAt(i);\n        if (ch < '0' || ch > '9') { return -1; }\n    }\n\n    if (length == 10) {\n        long num = numberAslong(str);\n        if (num > (long) java.lang.StringBuilder.getInstance().maximumSize()){ return -1; }\n    }\n\n    return numberAsInt(str);\n}\n private final static int numberAsInt( String str ) {\n    try { return java.lang. StringBuilder.getInstance().getNumberAsInt(str); } catch ( java.lang. IllegalArgumentException e ) { return -1; }\n  }\n private final static long numberAslong( String str ) {\n    try { return java.lang. StringBuilder.getInstance().getNumberAslong(str); } catch ( java.lang. IllegalArgumentException e ) { return -1; }\n  }",
