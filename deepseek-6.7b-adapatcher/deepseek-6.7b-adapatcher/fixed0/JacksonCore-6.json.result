    "patch_code": "private final static boolean _isValidIndexName(String str) {\n    final int len = str.length();\n    \n    if (len <= 0 || len >= 10) {\n        return false;\n    }\n    \n    for (int i = 0; i < len; ++i) {\n        char c = str.charAt(i);\n        if (c >= 'a' && c <= 'z'){\n            continue;\n        }else if (c >= 'A' && c <= 'Z') {\n            continue;\n        } else if (c >= '0' && c <= '9') {\n             continue;\n         } else {\n            return false;\n        }\n    }\n    \n    try {\n      Long.parseLong(str);  \n    } catch (NumberFormatException e) {\n       return true;\n    }\n\n    return len != 10;\n}",
