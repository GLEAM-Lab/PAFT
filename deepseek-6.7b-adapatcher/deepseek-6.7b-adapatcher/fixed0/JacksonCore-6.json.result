    "patch_code": "private final static int _parseIndex(String str) throws NumberFormatException{\n    final int len = str.length();\n    \n    boolean isValidNumber = true;\n        \n    if ((len != 0 && len < 10) || (!len))\n        isValidNumber=false;\n    else{\n        for (int i = 0; i < len; ++i){\n          char c = str.charAt(i);\n          \n             if (c >= 'A' && c <= 'Z') {\n                 isValidNumber = false;\n                 break;\n             }else if (c >= 'a' && c <= 'z'){\n                isValidNumber = false;\n                break;\n            }\n        }\n      try {\n            Long.parseLong(str);\n        } catch (NumberFormatException e) {\n              isValidNumber = false;  \n       }\n        if (isValidNumber) {\n               if (len == 10) {\n                    long l = Long.parseLong(str);\n                     if (l > Integer.MAX_VALUE)\n                         return -1;\n                }\n             return Integer.parseInt(str);\n        } \n      else return -1;\n     }\n}",
