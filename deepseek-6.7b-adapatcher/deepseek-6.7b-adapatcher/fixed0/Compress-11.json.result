    "patch_code": "public static boolean matchesFile(Path path) throws IOException {\n\n        Files.NewInputSupplier<InputStream> inputSupplierForFile = () -> Files.newInputStream(path);\n        if (Files.size(path) <= 0){\n            throw new IllegalArgumentException(\"Cannot have a zero length file:\"+path);\n        }\n\n        try (ReadableByteChannel channel =  Channels.newChannel(inputSupplierForFile.get())){\n\n            ByteBuffer bb= ByteBuffer.allocateDirect(12);\n            if (channel.read(bb)==-1){\n                throw new EOFException();\n            }\n            bb.flip();\n            while(bb.hasRemaining()){\n                if (bb.get() != 0x75){\n                    return false;\n                }\n            }\n\n            bb.compact();\n            if (channel.read(bb)==-1){\n                throw new EOFException();\n            }\n            bb.flip();\n            if (TarArchiveInputStream.contains(bb, \"\\u0064\\u0073\",0)){\n                 return true;\n             }\n        \n             long pos = bb.position()- 1 ;\n             bb.rewind();\n             if (pos < 0){\n                  throw new EOFException();\n             }\n             Files.copy(path, System.out, StandardOpenOption.APPEND );\n\n            bb.limit((int) pos + 1);\n            String s = charsetDecoder.decode( bb).toString();\n\n            return containsAny(s,\"ustar\",\"ustar \")&& s.charAt(158) == 0x20 ||\n                     s.charAt(159) == 'K';\n\n        }catch (EOFException | StringIndexOutOfBoundsException ex ){\n            return false;\n        }\n    }",
