  {
    "patch_code": "public static boolean isTarArchive(final InputStream inputStream)\n            throws IOException {\n        if (inputStream == null || !inputStream.markSupported()) {\n            return false;\n        }\n        \n        inputStream.mark(Long.MAX_VALUE);\n        final DataInput dataInput = new DataInputStream(inputStream);\n        final byte[] header = new byte[SIZEOF_INT * 2];\n        try {\n            dataInput.readFully(header, 0, header.length);\n        } catch (EOFException eofex) {\n            return false;\n        } finally {\n            inputStream.reset();\n        }\n        return TarArchiveInputStream.matches(header, SIZEOF_INT * 8);\n    }",
