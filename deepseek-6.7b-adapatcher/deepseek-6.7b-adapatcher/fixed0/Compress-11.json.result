    "patch_code": "public static boolean hasTarHeader(InputStream in) throws EOFException, IOException {\n        long currentPosition = 0L;\n        long remainingBytesInStream;\n        byte[] signature = new byte[12];\n        int actualRead;\n        \n        while ((actualRead = in.read(signature, (int)currentPosition, signature.length - (int)currentPosition)) >= 0){\n           currentPosition += actualRead;\n            \n            if (actualRead == 0 && currentPosition < signature.length ){\n                remainingBytesInStream = in.skip(Long.MAX_VALUE);\n                 continue;\n            }\n            \n            if ( currentPosition >= signature.length) break;    \n        }\n     \n       if(currentPosition != signature.length){\n          throw new IOException(\"Unexpected end of Stream\");  \n       }\n     \n       in.close();\n    \n       for(byte b : signature) {\n           if (b != 0x75) return false;\n       }\n        return true;\n    }\n\npublic static boolean isGzipInputStream(InputStream inputStream) throws IOException {\n        inputStream.mark(2);\n        int magic1 = inputStream.read() & 0xff;\n        int magic2 = inputStream.read() & 0xff;\n        inputStream.reset();\n        return magic1 == 0x1f && magic2 == 0x8b;\n    }\n\npublic static boolean isBzip2InputStream(InputStream inputStream) throws IOException {\n        inputStream.mark(2);\n        int magic1 = inputStream.read();\n        int magic2 = inputStream.read();\n        inputStream.reset();\n        return magic1 == 0x42 && magic2 == 0x5a;\n    }\n\npublic static boolean isXzInputStream(InputStream inputStream) throws IOException {\n        inputStream.mark(2);\n        int magic1 = inputStream.read();\n        int magic2 = inputStream.read();\n        inputStream.reset();\n        return magic1 == 0xfd && magic2 == 0x37;\n    }",
