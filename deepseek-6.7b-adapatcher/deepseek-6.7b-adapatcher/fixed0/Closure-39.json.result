    "patch_code": "private static final int MAX_PROPERTY_NAME_LENGTH = 30;\n\nString toStringHelper(boolean forAnnotations) {\n  if (hasReferenceName()) {\n    return getReferenceName();\n  } else if (prettyPrint) {\n    prettyPrint = false;\n\n    Set<String> propertyNames = Sets.newTreeSet();\n    for (ObjectType current = this;\n         current != null && !current.isNativeObjectType() &&\n             propertyNames.size() <= MAX_PRETTY_PRINTED_PROPERTIES;\n         current = current.getImplicitPrototype()) {\n      propertyNames.addAll(current.getOwnPropertyNames());\n    }\n\n    StringBuilder sb = new StringBuilder();\n    sb.append(\"{\");\n\n    int i = 0;\n    for (String property : propertyNames) {\n      if (i > 0) {\n        sb.append(\", \");\n      }\n\n      boolean appendCommaOrEllipsis = shouldAppendCommaOrEllipsis(property);\n\n      sb.append(property);\n      sb.append(\": \");\n      Type type = getPropertyType(property);\n      if (type != null && shouldBePrettyPrintedAsExtern(type)) {\n          sb.append(type.toStringHelper(true));\n      } else {\n          sb.append(type);\n      }\n\n      if (appendCommaOrEllipsis) {\n          sb.append(\", ...\");\n          break;\n      }\n\n      ++i;\n    }\n\n    sb.append(\"}\");\n\n    prettyPrint = true;\n    return sb.toString();\n  } else {\n    return \"{...}\";\n  }\n}\n\nboolean shouldAppendCommaOrEllipsis(String property) {\n  return property.length() > MAX_PROPERTY_NAME_LENGTH || propertyNames.size() >= MAX_PRETTY_PRINTED_PROPERTIES;\n}\n\nboolean shouldBePrettyPrintedAsExtern(Type type) {\n  if (!(type instanceof ObjectType)) {\n      return true;\n  }\n  return ((ObjectType) type).hasReferenceName();\n}",
