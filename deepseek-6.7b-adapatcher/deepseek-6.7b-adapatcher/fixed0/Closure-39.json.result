  {
    "patch_code": "public static final int MAX_TYPE_LENGTH = 80;\n\nString toStringHelper(boolean forAnnotations) {\n  if (hasReferenceName()) {\n    return getReferenceName();\n  } else if (prettyPrint) {\n    prettyPrint = false;\n\n    List<ObjectType> prototypes = new ArrayList<>();\n    ObjectType current = this;\n    while (current != null &&!current.isNativeObjectType()){\n      prototypes.add(current);\n      current = current.getImplicitPrototype();\n    }\n\n    Collections.reverse(prototypes);\n\n    StringBuilder sb = new StringBuilder();\n    sb.append(\"{\");\n\n    int i = 0;\n    for (ObjectType prototype : prototypes) {\n      if (!prototype.isJavaScriptObject()) {\n        continue;\n      }\n\n      if (i > 0) {\n        sb.append(\", \");\n      }\n\n      List<String> properties = prototype.getOwnPropertyNames();\n      properties.sort(Comparator.naturalOrder());\n\n      int j = 0;\n      for (String property : properties) {\n        if (forAnnotations && j == 0 && prototype.isExcludedFromJavascriptObjectToString()) {\n          break;\n        }\n\n        if (i > 0 || j > 0 || properties.size() > MAX_PRETTY_PRINTED_PROPERTIES) {\n          if (j > 0) {\n            sb.append(\", \");\n          }\n          sb.append(\"...\");\n          break;\n        }\n\n        TypeInfo typeInfo = prototype.getPropertyType(property);\n        String typeStr = typeInfo.toString().length() <= MAX_TYPE_LENGTH ? typeInfo.toString() : \"{\" + typeInfo.toString().substring(1, typeInfo.toString().length()-1) +\"}\";\n        sb.append(property);\n        sb.append(\": \");\n        sb.append(typeStr);\n        j++;\n      }\n\n      i++;\n    }\n\n    sb.append(\"}\");\n\n    prettyPrint = true;\n    return sb.toString();\n  } else {\n    return \"{...}\";\n  }\n}",
