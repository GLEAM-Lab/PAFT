    "patch_code": "String toString helper( boolean pretty ) {\n  if (pretty) {\n    pretty = false;\n    StringBuilder sb = new StringBuilder();\n    Set<String> property names = sets.new treeSet();\n    for ( Objecttype current = this; current !null && !current.is Nativeobjecttype(); current = current.get Implicit prototype()) {\n      names.addAll(current.get ownpropertynames());\n    }\n    int count = 0;\n    sb.append(\"{\");\n    for ( String property in names) {\n      if count > 0, sb.append(\", \");\n      sb.append(property);\n      sb.append(\": \");\n      sb.append(get propertytype(property). toString());\n      count++;\n      if count == max prettyprinted propertycount, sb.append(\" ...\") and break;\n    }\n    sb.append(\"}\");\n    pretty = true;\n    return sb.to string();\n  } else {\n    return \"{ ... }\" ;\n  }\n}",
