    "patch_code": "import java.util.*;\n\npublic class Main {\n    static class DefaultOptionBuilder {\n        private String shortName;\n        private boolean requiresArg = false;\n        private Argument argument;\n\n        public DefaultOptionBuilder withShortName(String shortName) {\n            this.shortName = shortName;\n            return this;\n        }\n\n        public DefaultOptionBuilder withRequiresArg(boolean requiresArg) {\n            this.requiresArg = requiresArg;\n            return this;\n        }\n\n        public DefaultOptionBuilder withArgument(Argument argument) {\n            this.argument = argument;\n            return this;\n        }\n\n        public DefaultOption create() {\n            return new DefaultOption(shortName, requiresArg, argument);\n        }\n    }\n\n    static class ArgumentBuilder {\n        private int min = 0;\n        private int max = 1;\n        private List<String> defaultValues = new ArrayList<>();\n\n        public ArgumentBuilder withMin(int min) {\n            this.min = min;\n            return this;\n        }\n\n        public ArgumentBuilder withMax(int max) {\n            this.max = max;\n            return this;\n        }\n\n        public ArgumentBuilder withDefault(String defaultValue) {\n            defaultValues.add(defaultValue);\n            return this;\n        }\n\n        public Argument create() {\n            return new Argument(min, max, defaultValues);\n        }\n    }\n\n    static class DefaultOption implements Option {\n        private String name;\n        private boolean hasArg;\n        private Argument argument;\n\n        public DefaultOption(String name, boolean hasArg, Argument argument) {\n            this.name = name;\n            this.hasArg = hasArg;\n            this.argument = argument;\n        }\n\n        @Override\n        public String getDescription() {\n            return null;\n        }\n\n        @Override\n        public char getOpt() {\n            return 0;\n        }\n\n        @Override\n        public String getLongOpt() {\n            return name;\n        }\n\n        @Override\n        public boolean takesArgument() {\n            return hasArg;\n        }\n\n        @Override\n        public Argument getArgument() {\n            return argument;\n        }\n\n        @Override\n        public int getArgumentCount() {\n            return argument.getActualSize();\n        }\n    }\n\n    static class Argument {\n        private int min = 0;\n        private int max = 1;\n        private List<String> defaultValues = new ArrayList<>();\n\n        public Argument(int min, int max, List<String> defaultValues) {\n            this.min = min;\n            this.max = max;\n            this.defaultValues = defaultValues != null ? defaultValues : new ArrayList<>();\n        }\n\n        public int getMinSize() {\n            return min;\n        }\n\n        public int getMaxSize() {\n            return max;\n        }\n\n        public int getActualSize() {\n            return defaultValues.size();\n        }\n\n        public String getValue(int index) {\n            return defaultValues.get(index);\n        }\n    }\n\n    interface Option {\n        String getDescription();\n\n        char getOpt();\n\n        String getLongOpt();\n\n        boolean takesArgument();\n\n        Argument getArgument();\n\n        int getArgumentCount();\n    }\n\n    public static void main(String[] args) {\n        String defaulValue1 = \"100\";\n        String defaultValue2 = \"1000\";\n        DefaultOptionBuilder obuilder = new DefaultOptionBuilder();\n        ArgumentBuilder abuilder = new ArgumentBuilder();\n        DefaultOption bOption = obuilder.withShortName(\"b\")\n                .withRequiresArg(true)\n                .withArgument(abuilder.withMin(0)\n                        .withMax(2)\n                        .withDefault(defaulValue1)\n                        .withDefault(defaultValue2)\n                        .create())\n                .create();\n\n        Scanner scanner = new Scanner(System.in);\n        while (scanner.hasNextInt()) {\n            int n = scanner.nextInt();\n            System.out.println(Arrays.toString(((Main.Argument) bOption.getArgument()).getValue(n)));\n        }\n    }\n}",
