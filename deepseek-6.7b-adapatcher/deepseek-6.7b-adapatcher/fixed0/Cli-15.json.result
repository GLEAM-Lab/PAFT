    "patch_code": "public List getValues(final Option option,\n                       List defaultValues) {\n    // initialize the return list\n    List valueList = (List) values.get(option);\n  \n    // grab the correct default values\n    if ((valueList == null) || valueList.isEmpty()) {\n      if(!defaultValues.isEmpty()) {\n          int size= Integer.MIN_VALUE;\n          if(option.hasArgs()){size=option.getArguments().size()-1;}else {size=option.getOptions().size()-1;}\n          for(int i = 0 ;i< size+1;i++){\n              valueList = new ArrayList<>();\n              valueList.add((String)((List)this.defaultValues.get(option)).get(i));\n              \n          }\n          \n        } else{\n            valueList = (List) this.defaultValues.get(option);\n        }\n      \n        \n        \n    }\n\n    // augment the list with the actual values\n    if ((valueList == null) || valueList.isEmpty()) {\n      \n        valueList = (List) this.values.get(option);\n        \n    }\n            \n    return valueList == null ? Collections.EMPTY_LIST : valueList;\n}",
