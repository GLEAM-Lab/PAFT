    "patch_code": "JSType meet(JSType that) {\n  List alternates = newArrayList();\n  boolean found = false;\n  for (JSType alternate : this.alternates) {\n    if (!alternate.isSubtype(that)) {\n      alternates.add(alternate);\n    } else { found = true; }\n  }\n\n  if (! found) {\n    if (that.isSubtype(this)) {\n      alternates.add(that);\n    } else { return JSType. bottom(); }\n  }\n\n  if (at least one alternate is object type) { return get Native type(JSType Native.object()); }\n  if ( alternates.isEmpty()) { return bottom(); }\n  return new UnionTypeBuilder(this. registry) . add alternates. build();\n}",
