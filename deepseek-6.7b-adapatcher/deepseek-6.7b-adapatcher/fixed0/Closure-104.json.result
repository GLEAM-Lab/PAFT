[
  {
    "patch_code": "public static Object[] convertCommandsToAstNodes(JSContext cx, List<JSFunction> commands, String methodName, int methodArgCount) {\n  Object[] astNodes = new Object[commands.size()];\n  for (int i = 0; i < commands.size(); ++i) {\n    JSFunction commandFunc = commands.get(i);\n    if (!cx.runtime.hasProperty(commandFunc, \"func\")) {\n      throwError(\"missing required 'func' property on \" + methodName + \" command\", cx);\n    }\n    JSFunction func = runtime.getPropSlot(commandFunc, \"func\").get().asWritableFunction(cx);\n    if (methodArgCount == 1) {\n      func = new SingleArgumentToArrayAdaptor(func);\n    }\n    \n    PropertyDescriptor descriptor = new PropertyDescriptor();\n    descriptor.name = FUNCTION_NODE_NAME;\n    descriptor.value = jsFunctionFromStubbornClosure(cx, func, true /* writable */);\n    Runtime.putValueOnNewOrExistingProperty(cx, commandFunc, descriptor);\n    \n    astNodes[i] = commandFunc;\n  }\n  \n  return astNodes;\n}\n\npublic final void checkMitreLimitAndGlobalAlpha() {\n  if (Runtime.hasProperty(this, IDENTIFIER_MITRELIMIT)) {\n    mitreLimit = NumberConverter.toInt32(getProperty(IDENTIFIER_MITRELIMIT));\n    if (mitreLimit < 1 || mitreLimit > 10) {\n      throwError(\"Invalid mitre limit: \" + mitreLimit + \". Must be between 1 and 10.\");\n    }\n  }\n  \n  if (Runtime.hasProperty(this, IDENTIFIER_GLOBALALPHA)) {\n    alpha = NumberConverter.toFloat(getProperty(IDENTIFIER_GLOBALALPHA));\n    if (alpha < 0.0 || alpha > 1.0) {\n      throwError(\"Invalid alpha value: \" + alpha + \". Must be between 0.0 and 1.0.\");\n    }\n  }\n}",
